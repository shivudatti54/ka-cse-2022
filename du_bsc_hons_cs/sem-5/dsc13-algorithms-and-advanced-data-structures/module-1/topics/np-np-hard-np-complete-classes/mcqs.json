{
  "topicId": "np-np-hard-np-complete-classes",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "Which complexity class contains problems that can be verified in polynomial time?",
      "options": [
        {
          "key": "A",
          "text": "NP"
        },
        {
          "key": "B",
          "text": "P"
        },
        {
          "key": "C",
          "text": "NP-Hard"
        },
        {
          "key": "D",
          "text": "EXPTIME"
        }
      ],
      "correctAnswer": "A",
      "explanation": "NP is defined as the class of problems verifiable in polynomial time.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "The Traveling Salesman Problem (decision version) belongs to:",
      "options": [
        {
          "key": "A",
          "text": "P"
        },
        {
          "key": "B",
          "text": "NP-Complete"
        },
        {
          "key": "C",
          "text": "Both NP and NP-Hard"
        },
        {
          "key": "D",
          "text": "None of these"
        }
      ],
      "correctAnswer": "C",
      "explanation": "TSP is NP-Complete (both NP and NP-Hard).",
      "difficulty": "medium"
    },
    {
      "id": "mcq-3",
      "question": "Which problem was the first proven to be NP-Complete?",
      "options": [
        {
          "key": "A",
          "text": "3-SAT"
        },
        {
          "key": "B",
          "text": "Graph Coloring"
        },
        {
          "key": "C",
          "text": "Boolean Satisfiability (SAT)"
        },
        {
          "key": "D",
          "text": "Knapsack"
        }
      ],
      "correctAnswer": "C",
      "explanation": "Cook's Theorem (1971) proved SAT is NP-Complete.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-4",
      "question": "If a polynomial-time algorithm is found for an NP-Complete problem:",
      "options": [
        {
          "key": "A",
          "text": "P = NP"
        },
        {
          "key": "B",
          "text": "All NP problems become tractable"
        },
        {
          "key": "C",
          "text": "Only that specific problem is solved"
        },
        {
          "key": "D",
          "text": "Both A & B"
        }
      ],
      "correctAnswer": "D",
      "explanation": "NP-Complete problems are reducible to each other, so solving one solves all.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-5",
      "question": "Which statement about NP-Hard problems is FALSE?",
      "options": [
        {
          "key": "A",
          "text": "They are at least as hard as NP-Complete"
        },
        {
          "key": "B",
          "text": "All require exponential time"
        },
        {
          "key": "C",
          "text": "May not be in NP"
        },
        {
          "key": "D",
          "text": "Include optimization versions of NP-Complete"
        }
      ],
      "correctAnswer": "B",
      "explanation": "NP-Hard doesn't imply exponential time - just that no known poly-time solution exists.",
      "difficulty": "hard"
    }
  ]
}