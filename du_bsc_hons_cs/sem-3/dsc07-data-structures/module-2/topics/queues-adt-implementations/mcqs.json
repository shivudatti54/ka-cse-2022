      "id": "mcq-1",
      "question": "In a queue, which end is used for insertion?",
      "options": [
        {
          "key": "A",
          "text": "Front end"
        },
        {
          "key": "B",
          "text": "Rear end"
        },
        {
          "key": "C",
          "text": "Both ends"
        },
        {
          "key": "D",
          "text": "Middle"
        }
      ],
      "correctAnswer": "B",
      "explanation": "Insertion (enqueue) always happens at the rear end of the queue, following FIFO principle.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
