    {
      "id": "mcq-1",
      "question": "In a tree with 15 nodes, how many edges are there?",
      "options": [
        {
          "key": "A",
          "text": "14"
        },
        {
          "key": "B",
          "text": "15"
        },
        {
          "key": "C",
          "text": "16"
        },
        {
          "key": "D",
          "text": "13"
        }
      ],
      "correctAnswer": "A",
      "explanation": "A tree with n nodes always has exactly n-1 edges. Therefore, 15 nodes = 14 edges.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "Which node in a tree is called the ancestor of all other nodes?",
      "options": [
        {
          "key": "A",
          "text": "Leaf node"
        },
        {
          "key": "B",
          "text": "Root node"
        },
        {
          "key": "C",
          "text": "Internal node"
        },
        {
          "key": "D",
          "text": "Parent node"
        }
      ],
      "correctAnswer": "B",
      "explanation": "The root node is the topmost node and is the ancestor of all other nodes in the tree.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "A node with degree zero is called:",
