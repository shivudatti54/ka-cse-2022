{
  "topicId": "inverse-of-matrix",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "For a 2\u00d72 matrix A = [[2, 1], [1, 1]], what is A\u207b\u00b9?",
      "options": [
        {
          "key": "A",
          "text": "[[1, -1], [-1, 2]]"
        },
        {
          "key": "B",
          "text": "[[1, -1], [-1, 1]]"
        },
        {
          "key": "C",
          "text": "[[-1, 1], [1, -1]]"
        },
        {
          "key": "D",
          "text": "[[2, -1], [-1, 1]]"
        }
      ],
      "correctAnswer": "A",
      "explanation": "det(A) = 2\u00d71 - 1\u00d71 = 1. Inverse = (1/1) \u00d7 [[1, -1], [-1, 2]] = [[1, -1], [-1, 2]].",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "Which of the following matrices is NOT invertible?",
      "options": [
        {
          "key": "A",
          "text": "[[3, 1], [1, 2]]"
        },
        {
          "key": "B",
          "text": "[[1, 2], [2, 4]]"
        },
        {
          "key": "C",
          "text": "[[1, 0], [0, 1]]"
        },
        {
          "key": "D",
          "text": "[[2, 3], [1, 1]]"
        }
      ],
      "correctAnswer": "B",
      "explanation": "det([[1,2],[2,4]]) = 1\u00d74 - 2\u00d72 = 0. A zero determinant means singular/not invertible.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "If A is an invertible matrix, which property is INCORRECT?",
      "options": [
        {
          "key": "A",
          "text": "(A\u207b\u00b9)\u207b\u00b9 = A"
        },
        {
          "key": "B",
          "text": "(AB)\u207b\u00b9 = A\u207b\u00b9B\u207b\u00b9"
        },
        {
          "key": "C",
          "text": "(kA)\u207b\u00b9 = (1/k)A\u207b\u00b9 for k \u2260 0"
        },
        {
          "key": "D",
          "text": "A\u207b\u00b9A = I"
        }
      ],
      "correctAnswer": "B",
      "explanation": "(AB)\u207b\u00b9 = B\u207b\u00b9A\u207b\u00b9 (order reversed), not A\u207b\u00b9B\u207b\u00b9. This is a common mistake.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-4",
      "question": "The inverse of identity matrix I\u2099 is:",
      "options": [
        {
          "key": "A",
          "text": "Zero matrix"
        },
        {
          "key": "B",
          "text": "I\u2099 itself"
        },
        {
          "key": "C",
          "text": "Undefined"
        },
        {
          "key": "D",
          "text": "Transpose of I\u2099"
        }
      ],
      "correctAnswer": "B",
      "explanation": "I\u2099 \u00d7 I\u2099 = I\u2099, so I\u2099\u207b\u00b9 = I\u2099. The identity matrix is its own inverse.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-5",
      "question": "For matrix A = [[1, 2], [3, 6]], the determinant is:",
      "options": [
        {
          "key": "A",
          "text": "12"
        },
        {
          "key": "B",
          "text": "0"
        },
        {
          "key": "C",
          "text": "-12"
        },
        {
          "key": "D",
          "text": "1"
        }
      ],
      "correctAnswer": "B",
      "explanation": "det(A) = 1\u00d76 - 2\u00d73 = 6 - 6 = 0. Matrix is singular, no inverse exists.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-6",
      "question": "What is the adjugate of matrix [[1, 2], [3, 4]]?",
      "options": [
        {
          "key": "A",
          "text": "[[4, -2], [-3, 1]]"
        },
        {
          "key": "B",
          "text": "[[4, -3], [-2, 1]]"
        },
        {
          "key": "C",
          "text": "[[-4, 2], [3, -1]]"
        },
        {
          "key": "D",
          "text": "[[1, -2], [-3, 4]]"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Cofactor matrix = [[4, -3], [-2, 1]], transpose = [[4, -2], [-3, 1]].",
      "difficulty": "medium"
    },
    {
      "id": "mcq-7",
      "question": "A 3\u00d73 matrix has rank 3. It is:",
      "options": [
        {
          "key": "A",
          "text": "Singular"
        },
        {
          "key": "B",
          "text": "Non-singular (invertible)"
        },
        {
          "key": "C",
          "text": "Idempotent"
        },
        {
          "key": "D",
          "text": "Nilpotent"
        }
      ],
      "correctAnswer": "B",
      "explanation": "Full rank (rank = n for n\u00d7n matrix) means the matrix is invertible (non-singular).",
      "difficulty": "easy"
    },
    {
      "id": "mcq-8",
      "question": "The inverse of [[0, 1], [1, 0]] is:",
      "options": [
        {
          "key": "A",
          "text": "[[1, 0], [0, 1]]"
        },
        {
          "key": "B",
          "text": "[[0, 1], [1, 0]]"
        },
        {
          "key": "C",
          "text": "[[-1, 0], [0, -1]]"
        },
        {
          "key": "D",
          "text": "[[0, -1], [-1, 0]]"
        }
      ],
      "correctAnswer": "B",
      "explanation": "This is a permutation matrix (swap rows). It is its own inverse: P \u00d7 P = I.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-9",
      "question": "If A and B are invertible matrices such that AB = I, then B equals:",
      "options": [
        {
          "key": "A",
          "text": "A"
        },
        {
          "key": "B",
          "text": "A\u1d40"
        },
        {
          "key": "C",
          "text": "A\u207b\u00b9"
        },
        {
          "key": "D",
          "text": "I"
        }
      ],
      "correctAnswer": "C",
      "explanation": "If AB = I, multiplying by A\u207b\u00b9 on left: A\u207b\u00b9(AB) = A\u207b\u00b9I \u2192 B = A\u207b\u00b9.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-10",
      "question": "Which of the following is NOT a method to find matrix inverse?",
      "options": [
        {
          "key": "A",
          "text": "Cofactor method"
        },
        {
          "key": "B",
          "text": "Gauss-Jordan elimination"
        },
        {
          "key": "C",
          "text": "Eigenvalue decomposition"
        },
        {
          "key": "D",
          "text": "Prime factorization"
        }
      ],
      "correctAnswer": "D",
      "explanation": "Prime factorization is not a standard method. Cofactor method, Gauss-Jordan, and eigenvalue decomposition are valid methods.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-11",
      "question": "For diagonal matrix D = diag(2, 3, 4), what is D\u207b\u00b9?",
      "options": [
        {
          "key": "A",
          "text": "diag(1/2, 1/3, 1/4)"
        },
        {
          "key": "B",
          "text": "diag(2, 3, 4)"
        },
        {
          "key": "C",
          "text": "diag(-2, -3, -4)"
        },
        {
          "key": "D",
          "text": "I\u2083"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Inverse of diagonal matrix is diagonal of reciprocals, provided no diagonal element is zero.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-12",
      "question": "If A is a 4\u00d74 matrix with det(A) = 0.25, what is det(A\u207b\u00b9)?",
      "options": [
        {
          "key": "A",
          "text": "4"
        },
        {
          "key": "B",
          "text": "0.25"
        },
        {
          "key": "C",
          "text": "-4"
        },
        {
          "key": "D",
          "text": "0.5"
        }
      ],
      "correctAnswer": "A",
      "explanation": "det(A\u207b\u00b9) = 1/det(A) = 1/0.25 = 4. The determinant of inverse is reciprocal.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-13",
      "question": "What is the inverse of a scalar matrix kI\u2099 (k \u2260 0)?",
      "options": [
        {
          "key": "A",
          "text": "(1/k)I\u2099"
        },
        {
          "key": "B",
          "text": "kI\u2099"
        },
        {
          "key": "C",
          "text": "k\u00b2I\u2099"
        },
        {
          "key": "D",
          "text": "I\u2099"
        }
      ],
      "correctAnswer": "A",
      "explanation": "(kI\u2099)(1/k I\u2099) = (k \u00d7 1/k) I\u2099I\u2099 = 1 \u00d7 I\u2099 = I\u2099. So inverse is (1/k)I\u2099.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-14",
      "question": "An orthogonal matrix A satisfies:",
      "options": [
        {
          "key": "A",
          "text": "A = A\u207b\u00b9"
        },
        {
          "key": "B",
          "text": "A\u1d40 = A\u207b\u00b9"
        },
        {
          "key": "C",
          "text": "A = -A\u207b\u00b9"
        },
        {
          "key": "D",
          "text": "A\u1d40 = A"
        }
      ],
      "correctAnswer": "B",
      "explanation": "By definition, orthogonal matrix: A\u207b\u00b9 = A\u1d40. Also means A\u1d40A = AA\u1d40 = I.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-15",
      "question": "In Gauss-Jordan method, to find A\u207b\u00b9 we create:",
      "options": [
        {
          "key": "A",
          "text": "[A | I]"
        },
        {
          "key": "B",
          "text": "[I | A]"
        },
        {
          "key": "C",
          "text": "[A | A]"
        },
        {
          "key": "D",
          "text": "[A\u207b\u00b9 | I]"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Form augmented matrix [A | I] and apply row operations until left side becomes I; right side becomes A\u207b\u00b9.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-16",
      "question": "For matrix A = [[1, 0, 0], [0, 2, 0], [0, 0, 3]], what is the determinant?",
