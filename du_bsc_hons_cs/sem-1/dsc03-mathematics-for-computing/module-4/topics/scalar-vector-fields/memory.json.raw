{
  "topicId": "scalar-vector-fields",
  "mnemonics": [
    {
      "id": "m-1",
      "title": "DIV Curl Gradient",
      "content": "D-Direction, I-Increase, V-Value: Gradient points uphill. C-Continuous, U-Uniform, R-Rotation, L-Local: Curl measures spin. D-Diverging, I-Inward/Outward, V-Volume: Divergence measures flow out."
    },
    {
      "id": "m-2",
      "title": "SCALAR vs VECTOR",
      "content": "S-Calars Are Lazy: Just a single number. V-ectors Have Energy: Both magnitude and direction."
    },
    {
      "id": "m-3",
      "title": "Grad Div Curl Formula",
      "content": "GRADIENT = Rising Arrow (points up), DIVERGENCE = Dot product (· measures outflow), CURL = Cross product (× measures rotation)"
    },
    {
      "id": "m-4",
      "title": "Nabla Song",
      "content": "Nabla Nabla, what can you be? Sometimes grad, sometimes div, sometimes curl you see! ∇f = grad, ∇·F = div, ∇×F = curl"
    },
    {
      "id": "m-5",
      "title": "Green Stokes Divergence",
      "content": "Green's Theorem: Line to Area (2D). Stokes: Line to Surface (3D). Divergence: Surface to Volume (3D closed)."
    }
  ],
  "acronyms": [
    {
      "term": "GRAD",
      "expansion": "Gradient - Rate of change in direction of steepest ascent",
      "usage": "When you need to find which direction a scalar field increases most rapidly. ∇f gives a vector field from scalar field f."
    },
    {
      "term": "DIV",
      "expansion": "Divergence - Net outward flow per unit volume",
      "usage": "When analyzing sources and sinks in a vector field. ∇·F > 0 means source, ∇·F < 0 means sink. Used in fluid flow and electromagnetism."
    },
    {
      "term": "CURL",
      "expansion": "Curl - Rotation/curling measure at a point",
      "usage": "When detecting spinning motion in a vector field. ∇×F = 0 means conservative/irrotational field. Used in fluid dynamics and Maxwell's equations."
    },
    {
      "term": "NABLA",
      "expansion": "∇ - Del operator (partial derivatives vector)",
      "usage": "The magic operator! Used as ∇ (gradient), ∇· (divergence), and ∇× (curl). Remember: It does different things to different fields!"
    },
    {
      "term": "FTC",
      "expansion": "Fundamental Theorem for Line Integrals",
      "usage": "If ∇×F = 0 (conservative), then path integral depends only on endpoints. Used in physics for work done by conservative forces."
    }
  ],
  "visualTips": [
    {
      "concept": "Scalar Field",
      "visualization": "Imagine a colored topographic map or heat map. Each point has ONE value (temperature, height, pressure). Think of a weather app showing temperature across India - just one color/number per location."
    },
    {
      "concept": "Vector Field",
      "visualization": "Think of a weather app showing wind arrows at each location. Each point has an ARROW with direction and length (speed). The field is full of little arrows everywhere!"
    },
    {
      "concept": "Gradient (∇f)",
      "visualization": "You're at a point on a mountain (scalar field = height). Gradient arrow points STEEPEST UPHILL. The arrow length = how steep. It's like a compass always pointing up the steepest path."
    },
    {
      "concept": "Divergence (∇·F)",
      "visualization": "Picture a sprinkler (source) spraying water outward - positive divergence. Now picture a drain (sink) sucking water inward - negative divergence. It's the "expansion" or "contraction" at a point."
    },
    {
      "concept": "Curl (∇×F)",
      "visualization": "Imagine a whirlpool or tornado. Put a tiny paddle wheel in the vector field at a point. Curl = how fast and which direction the paddle spins. No spin = zero curl."
    },
    {
      "concept": "Conservative Field",
      "visualization": "Think of gravity on Earth. Work done moving an object depends ONLY on start and end points, not the path taken. Path independence = conservative field = zero curl."
    },
    {
      "concept": "Line Integral ∫F·dr",
      "visualization": "Walk along a curved path, at each point multiply the field vector by your tiny displacement vector, add them all up. Like measuring total work done walking through a force field."
    },
    {
      "concept": "Green's Theorem",
      "visualization": "2D version: The sum of all little rotations inside a region (curl) = the circulation around the boundary. Like counting all tiny eddies in a pond by watching the water flow around the edges."
    }
  ],
  "analogies": [
    {
      "concept": "Scalar Field",
      "analogy": "Temperature distribution in Delhi during summer. At every location, there's ONE temperature value - hot, hotter, hottest! No direction, just magnitude."
    },
    {
      "concept": "Vector Field",
      "analogy": "Traffic flow on Delhi roads. At every intersection, cars have both SPEED (magnitude) and DIRECTION - some going north, some south, some fast, some slow."
    },
    {
      "concept": "Gradient",
      "analogy": "A hiker climbing Lodhi Gardens. The gradient tells you which direction is steepest uphill at any point. It's your personal mountain guide pointing up!"
    },
    {
      "concept": "Divergence",
      "analogy": "Water fountain at India Gate. Water sprays OUTWARD from the center - that's positive divergence (source). A drain in a pool - water flows INWARD - negative divergence (sink)."
    },
    {
      "concept": "Curl",
      "analogy": "The Ganga river's meandering currents. Some parts have whirlpools and eddies - that's curl! If the water flows straight without spinning, curl = 0."
    },
    {
      "concept": "Conservative Field",
      "analogy": "Lifts in a multistorey building. Work done by gravity going from 1st floor to 5th floor is the same whether you take the stairs, escalator, or lift - only start and end matter!"
    },
    {
      "concept": "Line Integral as Work",
      "analogy": "Cycling through Delhi traffic. Your effort (work) depends on both how hard you pedal AND which direction you travel relative to the wind (force). Go with the wind = easy, against = hard work."
    },
    {
      "concept": "Surface Integral",
      "analogy": "Collecting rainwater on a rooftop. The total water collected depends on the roof's area AND the rain's angle (vertical rain = more collection). It's the field passing through a surface."
    }
  ]
}