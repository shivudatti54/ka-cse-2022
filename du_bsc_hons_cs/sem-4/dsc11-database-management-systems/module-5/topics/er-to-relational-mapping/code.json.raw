{
  "topicId": "er-to-relational-mapping",
  "examples": [
    {
      "id": "code-1",
      "language": "Python",
      "title": "Basic Entity Mapping - Strong Entity Set",
      "description": "Demonstrates mapping a strong entity with simple attributes to a relational schema",
      "code": "# ER-to-Relational Mapping: Strong Entity\n# Entity: STUDENT (student_id PK, name, age, email)\n\nclass EntityMapper:\n    \"\"\"Maps ER entities to relational schema\"\"\"\n    \n    def __init__(self, entity_name, attributes, primary_key):\n        self.entity_name = entity_name\n        self.attributes = attributes\n        self.primary_key = primary_key\n    \n    def to_relational_schema(self):\n        \"\"\"Generate CREATE TABLE statement\"\"\"\n        columns = []\n        for attr in self.attributes:\n            if attr == self.primary_key:\n                columns.append(f\"    {attr} VARCHAR(20) PRIMARY KEY\")\n            else:\n                columns.append(f\"    {attr} VARCHAR(100)\")\n        \n        schema = f\"CREATE TABLE {self.entity_name} (\\n\"\n        schema += \",\\\n\".join(columns) + \"\\n);\"\n        return schema\n\n# Example: STUDENT Entity\nstudent_entity = EntityMapper(\n    entity_name=\"STUDENT\",\n    attributes=[\"student_id\", \"name\", \"age\", \"email\", \"phone\"],\n    primary_key=\"student_id\"\n)\n\nprint(\"=== Basic Entity Mapping ===\")\nprint(\"ER Entity: STUDENT (student_id, name, age, email, phone)\")\nprint(\"\\nMapped Relational Schema:\")\nprint(student_entity.to_relational_schema())\n\n# Simulate sample data\nprint(\"\\n--- Sample Data ---\")\nsample_data = [\n    (\"S001\", \"Alice\", 20, \"alice@university.edu\", \"9876543210\"),\n    (\"S002\", \"Bob\", 21, \"bob@university.edu\", \"9876543211\")\n]\nprint(\"STUDENT Table:\")\nprint(\"| student_id | name | age | email | phone |\")\nprint(\"|------------|------|-----|-------|--------|\")\nfor row in sample_data:\n    print(f\"| {row[0]:^10} | {row[1]:^4} | {row[2]:^2} | {row[3]:^15} | {row[4]} |\")",
      "explanation": "Step 1: Identify the strong entity STUDENT with attributes. Step 2: Create a relation (table) with same name. Step 3: Include all simple attributes as columns. Step 4: Designate student_id as PRIMARY KEY. Step 5: Composite attribute 'phone' could be multi-valued - stored separately in practice. The mapping preserves all atomic attributes from the ER diagram.",
      "timeComplexity": "O(1)",
      "spaceComplexity": "O(1)"
    },
    {
      "id": "code-2",
      "language": "Python",
      "title": "Relationship Mapping - 1:N and M:N Relationships",
      "description": "Demonstrates mapping different types of relationships between entities",
      "code": "# ER-to-Relational Mapping: Relationships\n# Scenario: DEPARTMENT (1) -- manages -- (N) PROFESSOR\n#           PROFESSOR (M) -- teaches -- (N) COURSE\n\nclass RelationshipMapper:\n    \"\"\"Maps ER relationships to relational schema\"\"\"\n    \n    @staticmethod\n    def map_one_to_many(parent_entity, child_entity, relationship_name):\n        \"\"\"1:N - Add foreign key to the 'many' side\"\"\"\n        parent_pk = f\"{parent_entity.lower()}_id\"\n        \n        schema = f\"\"\"-- Mapping {relationship_name} (1:N)\n-- Add foreign key to child table\n\nCREATE TABLE {parent_entity} (\n    {parent_pk} VARCHAR(20) PRIMARY KEY,\n    dept_name VARCHAR(50) NOT NULL\n);\n\nCREATE TABLE {child_entity} (\n    professor_id VARCHAR(20) PRIMARY KEY,\n    professor_name VARCHAR(50),\n    {parent_pk} VARCHAR(20),\n    salary DECIMAL(10,2),\n    FOREIGN KEY ({parent_pk}) REFERENCES {parent_entity}({parent_pk})\n);\"\"\"\n        return schema\n    \n    @staticmethod\n    def map_many_to_many(entity1, entity2, relationship_name):\n        \"\"\"M:N - Create separate relationship table\"\"\"\n        e1_pk = f\"{entity1.lower()}_id\"\n        e2_pk = f\"{entity2.lower()}_id\"\n        \n        schema = f\"\"\"-- Mapping {relationship_name} (M:N)\n-- Create separate relationship table with composite PK\n\nCREATE TABLE {entity1} (\n    {e1_pk} VARCHAR(20) PRIMARY KEY,\n    course_name VARCHAR(50)\n);\n\nCREATE TABLE {entity2} (\n    {e2_pk} VARCHAR(20) PRIMARY KEY,\n    student_name VARCHAR(50)\n);\n\nCREATE TABLE {relationship_name} (\n    {e1_pk} VARCHAR(20),\n    {e2_pk} VARCHAR(20),\n    semester VARCHAR(10),\n    grade CHAR(2),\n    PRIMARY KEY ({e1_pk}, {e2_pk}),\n    FOREIGN KEY ({e1_pk}) REFERENCES {entity1}({e1_pk}),\n    FOREIGN KEY ({e2_pk}) REFERENCES {entity2}({e2_pk})\n);\"\"\"\n        return schema\n\nprint(\"=== Relationship Mapping Examples ===\\n\")\n\n# 1:N Example\nprint(\"--- 1:N Relationship: DEPARTMENT manages PROFESSOR ---\")\nprint(RelationshipMapper.map_one_to_many(\"DEPARTMENT\", \"PROFESSOR\", \"manages\"))\n\nprint(\"\\n--- M:N Relationship: PROFESSOR teaches COURSE ---\")\nprint(RelationshipMapper.map_many_to_many(\"COURSE\", \"STUDENT\", \"ENROLLMENT\"))\n\n# Demonstrate relationship data\nprint(\"\\n--- Sample Relationship Data ---\")\nprint(\"DEPARTMENT: [{'dept_id': 'CS', 'dept_name': 'Computer Science'},\n              {'dept_id': 'MA', 'dept_name': 'Mathematics'}]")\nprint(\"PROFESSOR: [{'prof_id': 'P001', 'name': 'Dr. Smith', 'dept_id': 'CS'},\n              {'prof_id': 'P002', 'name': 'Dr. Jones', 'dept_id': 'CS'}]")\nprint(\"ENROLLMENT: [{'course_id': 'C001', 'student_id': 'S001', 'grade': 'A'},\n               {'course_id': 'C001', 'student_id': 'S002', 'grade': 'B'}]")",
      "explanation": "Step 1: For 1:N relationship (DEPARTMENT-PROFESSOR), add foreign key to the 'many' side (PROFESSOR). Step 2: The professor table includes dept_id referencing DEPARTMENT's primary key. Step 3: For M:N relationship (COURSE-STUDENT via ENROLLMENT), create a new relation table. Step 4: The relationship table has composite primary key (course_id, student_id). Step 5: Include descriptive attributes like grade and semester as non-key attributes in relationship table.",
      "timeComplexity": "O(1)",
      "spaceComplexity": "O(1)"
    },
    {
      "id": "code-3",
      "language": "Python",
      "title": "Advanced Mapping - Weak Entities, Multi-valued, and Derived Attributes",
      "description": "Demonstrates complex ER to relational mappings with weak entities and special attribute types",
      "code": "# ER-to-Relational Mapping: Advanced Cases\n# Weak Entity: DEPENDENT (weak entity of EMPLOYEE)\n# Multi-valued: phone (from EMPLOYEE)\n# Derived: age (calculated from birth_date)\n# Composite: address (broken into street, city, zip)\n\nclass AdvancedEntityMapper:\n    \"\"\"Handles advanced ER to relational mappings\"\"\"\n    \n    @staticmethod\n    def map_weak_entity(parent_entity, weak_entity, parent_pk, weak_attributes):\n        \"\"\"Weak entity: Include parent PK as part of composite key\"\"\"\n        schema = f\"\"\"-- Weak Entity Mapping: {weak_entity}\n-- Primary key = ({parent_pk}, identifying attribute)\n\nCREATE TABLE {parent_entity} (\n    employee_id VARCHAR(20) PRIMARY KEY,\n    employee_name VARCHAR(50),\n    birth_date DATE\n);\n\nCREATE TABLE {weak_entity} (\n    dependent_name VARCHAR(50),\n    {parent_pk} VARCHAR(20),\n    relationship VARCHAR(20),\n    PRIMARY KEY (dependent_name, {parent_pk}),\n    FOREIGN KEY ({parent_pk}) REFERENCES {parent_entity}(employee_id)\n    ON DELETE CASCADE\n);\"\"\"\n        return schema\n    \n    @staticmethod\n    def map_multivalued_attribute(entity_name, pk_attribute, multivalued_attr):\n        \"\"\"Multi-valued attribute: Separate relation table\"\"\"\n        schema = f\"\"\"-- Multi-valued Attribute Mapping: {multivalued_attr}\n-- Create separate relation with entity PK\n\nCREATE TABLE {entity_name} (\n    {pk_attribute} VARCHAR(20) PRIMARY KEY,\n    employee_name VARCHAR(50),\n    birth_date DATE\n);\n\nCREATE TABLE {multivalued_attr}_TABLE (\n    {pk_attribute} VARCHAR(20),\n    {multivalued_attr} VARCHAR(20),\n    PRIMARY KEY ({pk_attribute}, {multivalued_attr}),\n    FOREIGN KEY ({pk_attribute}) REFERENCES {entity_name}({pk_attribute})\n    ON DELETE CASCADE\n);\"\"\"\n        return schema\n    \n    @staticmethod\n    def map_composite_attribute(entity_name, composite_attr, components):\n        \"\"\"Composite attribute: Break into simple attributes\"\"\"\n        component_cols = \", \".join([f\"{c} VARCHAR(50)\" for c in components])\n        \n        schema = f\"\"\"-- Composite Attribute Mapping: {composite_attr}\n-- Break into constituent simple attributes\n\nCREATE TABLE {entity_name} (\n    entity_id VARCHAR(20) PRIMARY KEY,\n    entity_name VARCHAR(50),\n    {component_cols}\n);\"\"\"\n        return schema\n\nprint(\"=== Advanced ER to Relational Mapping ===\\n\")\n\n# Weak Entity Example\nprint(\"--- Weak Entity: DEPENDENT (belongs to EMPLOYEE) ---\")\nprint(AdvancedEntityMapper.map_weak_entity(\"EMPLOYEE\", \"DEPENDENT\", \"employee_id\", [\"dependent_name\", \"relationship\"]))\n\nprint(\"\\n--- Multi-valued Attribute: phone numbers ---\")\nprint(AdvancedEntityMapper.map_multivalued_attribute(\"EMPLOYEE\", \"employee_id\", \"phone\"))\n\nprint(\"\\n--- Composite Attribute: address ---\")\nprint(AdvancedEntityMapper.map_composite_attribute(\"EMPLOYEE\", \"address\", [\"street\", \"city\", \"state\", \"zip_code\"]))\n\n# Complete Example Summary\nprint(\"\\n=== Complete Mapped Schema Summary ===\")\nschema_summary = \"\"\"\nEMPLOYEE(employee_id PK, employee_name, birth_date)\n    |-- Derived: age (computed from birth_date)\n    |-- Composite: address -> (street, city, state, zip_code)\n    |-- Multi-valued: phone -> PHONE_TABLE(employee_id PK, phone PK)\n    \nDEPENDENT(dependent_name, employee_id PK+FK, relationship)\n    |-- Weak entity - composite key with parent's FK\n    \nRelationship: EMPLOYEE has DEPENDENT (1:N)\n\"\"\"\nprint(schema_summary)",
      "explanation": "Step 1: For weak entity DEPENDENT, include owner entity's primary key (employee_id) as foreign key and part of composite primary key. Step 2: For multi-valued attribute phone, create separate PHONE_TABLE with entity's PK and phone as composite key. Step 3: For composite attribute address, break into simple attributes: street, city, state, zip_code. Step 4: Derived attribute 'age' is NOT stored - computed when needed using birth_date. Step 5: ON DELETE CASCADE ensures referential integrity when parent is deleted.",
      "timeComplexity": "O(1)",
      "spaceComplexity": "O(1)"
    }
  ]
}