{"topicId":"er-to-relational-mapping","examples":[{"id":"code-1","language":"Python","title":"Basic ER to Relational Mapping - Entities and Relationships","description":"Maps simple ER diagram with entities (Student, Course) and M:N relationship (Enroll) to relational schema","code":""\nimport sqlite3\n\n# ER Model:\n# Entity: Student(Student_ID (PK), Name, Age)\n# Entity: Course(Course_ID (PK), Title, Credits)\n# Relationship: Enroll (M:N) with attribute Grade\n\n# Step 1: Create database and tables\nconn = sqlite3.connect(':memory:')\ncursor = conn.cursor()\n\n# Mapping Entity 'Student' to relation\ncursor.execute('''\n    CREATE TABLE Student (\n        Student_ID INTEGER PRIMARY KEY,\n        Name VARCHAR(100) NOT NULL,\n        Age INTEGER\n    )\n''')\n\n# Mapping Entity 'Course' to relation\ncursor.execute('''\n    CREATE TABLE Course (\n        Course_ID INTEGER PRIMARY KEY,\n        Title VARCHAR(100) NOT NULL,\n        Credits INTEGER\n    )\n''')\n\n# Mapping M:N relationship 'Enroll' to relation\n# (creates separate table with foreign keys)\ncursor.execute('''\n    CREATE TABLE Enroll (\n        Student_ID INTEGER,\n        Course_ID INTEGER,\n        Grade VARCHAR(2),\n        PRIMARY KEY (Student_ID, Course_ID),\n        FOREIGN KEY (Student_ID) REFERENCES Student(Student_ID),\n        FOREIGN KEY (Course_ID) REFERENCES Course(Course_ID)\n    )\n''')\n\n# Insert sample data\ncursor.executemany('INSERT INTO Student VALUES (?, ?, ?)',\n    [(1, 'Alice', 20), (2, 'Bob', 22), (3, 'Charlie', 21)])\ncursor.executemany('INSERT INTO Course VALUES (?, ?, ?)',\n    [(101, 'Database Systems', 3), (102, 'Data Structures', 4)])\ncursor.executemany('INSERT INTO Enroll VALUES (?, ?, ?)',\n    [(1, 101, 'A'), (1, 102, 'B'), (2, 101, 'A'), (3, 102, 'C')])\n\nconn.commit()\n\n# Verify mapping - query enrolled students\ncursor.execute('''\n    SELECT s.Name, c.Title, e.Grade\n    FROM Student s\n    JOIN Enroll e ON s.Student_ID = e.Student_ID\n    JOIN Course c ON c.Course_ID = e.Course_ID\n''')\n\nprint(\"Relational Schema Created:\")\nprint(\"Student(Student_ID PK, Name, Age)\")\nprint(\"Course(Course_ID PK, Title, Credits)\")\nprint(\"Enroll(Student_ID PK, Course_ID PK, Grade)\")\nprint(\"\\nEnrolled Students:\")\nfor row in cursor.fetchall():\n    print(f\"  {row[0]} - {row[1]}: {row[2]}\")\n\nconn.close()\n"","explanation":"This example demonstrates basic ER to relational mapping: (1) Strong entities map to tables with primary keys, (2) M:N relationships create a separate junction table with composite primary key, (3) Relationship attributes become columns in the junction table, (4) Foreign keys maintain referential integrity.","timeComplexity":"O(n)","spaceComplexity":"O(1)"},{"id":"code-2","language":"Python","title":"Advanced ER to Relational Mapping - Weak Entities, Attributes, and Relationships","description":"Maps complex ER diagram with weak entity, composite/multivalued attributes, and various relationship types (1:1, 1:N)","code":""\nimport sqlite3\n\n# ER Model Complex Example:\n# Entity: Department(Dept_ID PK, Name)\n# Entity: Employee(Emp_ID PK, Name (Composite: First, Last), Age (Derived))\n# Weak Entity: Dependent(Dependent_ID, Name) under Employee\n# Relationship: Manages (1:1) between Department and Employee\n# Relationship: Works_In (1:N) between Employee and Department\n# Multivalued Attribute: Phone (for Employee)\n\nconn = sqlite3.connect(':memory:')\ncursor = conn.cursor()\n\n# Mapping Entity: Department\ncursor.execute('''\n    CREATE TABLE Department (\n        Dept_ID INTEGER PRIMARY KEY,\n        Name VARCHAR(100) NOT NULL\n    )\n''')\n\n# Mapping Entity: Employee\n# - Composite attribute 'Name' broken into First_Name, Last_Name\n# - Derived attribute 'Age' excluded (computed at runtime)\ncursor.execute('''\n    CREATE TABLE Employee (\n        Emp_ID INTEGER PRIMARY KEY,\n        First_Name VARCHAR(50) NOT NULL,\n        Last_Name VARCHAR(50) NOT NULL,\n        DOB DATE,\n        Dept_ID INTEGER,\n        FOREIGN KEY (Dept_ID) REFERENCES Department(Dept_ID)\n    )\n''')\n\n# Mapping Weak Entity: Dependent\n# - Weak entity gets partial key + foreign key to owner\n# - Owner is Employee (Emp_ID)\ncursor.execute('''\n    CREATE TABLE Dependent (\n        Dependent_ID INTEGER,\n        Emp_ID INTEGER,\n        Name VARCHAR(100) NOT NULL,\n        Relationship VARCHAR(50),\n        PRIMARY KEY (Dependent_ID, Emp_ID),\n        FOREIGN KEY (Emp_ID) REFERENCES Employee(Emp_ID)\n    )\n''')\n\n# Mapping Multivalued Attribute: Phone\n# - Creates separate table for multivalued attributes\ncursor.execute('''\n    CREATE TABLE Employee_Phone (\n        Emp_ID INTEGER,\n        Phone VARCHAR(20),\n        PRIMARY KEY (Emp_ID, Phone),\n        FOREIGN KEY (Emp_ID) REFERENCES Employee(Emp_ID)\n    )\n''')\n\n# Mapping 1:1 Relationship: Manages\n# - Add Manager_ID to Department (or Emp_ID to Department)\ncursor.execute('''\n    ALTER TABLE Department ADD COLUMN Manager_ID INTEGER\n''')\ncursor.execute('''\n    ALTER TABLE Department \n    ADD FOREIGN KEY (Manager_ID) REFERENCES Employee(Emp_ID)\n''')\n\n# Insert sample data\ncursor.executemany('INSERT INTO Department VALUES (?, ?, ?)',\n    [(1, 'IT', 101), (2, 'HR', 102)])\ncursor.executemany('INSERT INTO Employee VALUES (?, ?, ?, ?, ?)',\n    [(101, 'John', 'Smith', '1985-05-15', 1),\n     (102, 'Jane', 'Doe', '1990-08-20', 2)])\ncursor.executemany('INSERT INTO Dependent VALUES (?, ?, ?)',\n    [(1, 101, 'Emily', 'Daughter'), (2, 101, 'Michael', 'Son')])\ncursor.executemany('INSERT INTO Employee_Phone VALUES (?, ?)',\n    [(101, '555-1234'), (101, '555-5678'), (102, '555-9999')])\n\nconn.commit()\n\n# Query: Employee with dependents and phones\ncursor.execute('''\n    SELECT e.First_Name, e.Last_Name, d.Name as Dependent, d.Relationship, ph.Phone\n    FROM Employee e\n    LEFT JOIN Dependent d ON e.Emp_ID = d.Emp_ID\n    LEFT JOIN Employee_Phone ph ON e.Emp_ID = ph.Emp_ID\n    WHERE e.Emp_ID = 101\n''')\n\nprint(\"=== Advanced ER to Relational Mapping ===\")\nprint(\"\\nTables Created:\")\nprint(\"- Department(Dept_ID PK, Name, Manager_ID FK)\")\nprint(\"- Employee(Emp_ID PK, First_Name, Last_Name, DOB, Dept_ID FK)\")\nprint(\"- Dependent(Dependent_ID PK, Emp_ID PK/FK, Name, Relationship)\")\nprint(\"- Employee_Phone(Emp_ID PK/FK, Phone PK)\")\nprint(\"\\nEmployee 101 (John Smith) - Dependents & Phones:\")\nfor row in cursor.fetchall():\n    print(f\"  Dependent: {row[2]} ({row[3]}), Phone: {row[4]}\")\n\n# Calculate age (derived attribute demonstration)\ncursor.execute('''\n    SELECT First_Name, Last_Name,\n           CAST((julianday('now') - julianday(DOB)) / 365.25 AS INTEGER) as Age\n    FROM Employee WHERE Emp_ID = 101\n''')\nprint(\"\\nDerived Attribute (Age computed):\")\nfor row in cursor.fetchall():\n    print(f\"  {row[0]} {row[1]}: {row[2]} years old\")\n\nconn.close()\n"","explanation":"This advanced example demonstrates: (1) Weak entities map with composite key (owner's PK + weak entity's partial key), (2) Composite attributes are split into simple columns, (3) Multivalued attributes create separate tables, (4) Derived attributes are omitted from schema and computed at runtime, (5) 1:1 relationships can be implemented via foreign key in either entity.","timeComplexity":"O(n)","spaceComplexity":"O(1)"}]}