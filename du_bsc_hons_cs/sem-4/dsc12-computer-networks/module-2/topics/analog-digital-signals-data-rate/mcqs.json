    {
      "id": "mcq-14",
      "question": "A signal has peak amplitude of 10V and noise amplitude of 0.1V. What is the SNR ratio?",
      "options": [
        {
          "key": "A",
          "text": "10"
        },
        {
          "key": "B",
          "text": "20"
        },
        {
          "key": "C",
          "text": "100"
        },
        {
          "key": "D",
          "text": "1000"
        }
      ],
      "correctAnswer": "C",
      "explanation": "SNR = Signal Power / Noise Power = (10\u00b2)/(0.1\u00b2) = 100/0.01 = 10000. Wait, voltage ratio = 10/0.1 = 100. So SNR = 100 (power ratio), in dB = 20 log\u2081\u2080(100) = 40 dB.",
      "difficulty": "hard"
    },
