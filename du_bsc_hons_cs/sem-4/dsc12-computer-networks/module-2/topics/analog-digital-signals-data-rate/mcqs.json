{
  "topicId": "analog-digital-signals-data-rate",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "A signal has a frequency of 1 kHz. What is its period?",
      "options": [
        {
          "key": "A",
          "text": "1000 seconds"
        },
        {
          "key": "B",
          "text": "0.001 seconds (1 ms)"
        },
        {
          "key": "C",
          "text": "1 second"
        },
        {
          "key": "D",
          "text": "100 seconds"
        }
      ],
      "correctAnswer": "B",
      "explanation": "Period T = 1/f = 1/1000 Hz = 0.001 seconds = 1 ms.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "Which type of signal represents data using discrete values?",
      "options": [
        {
          "key": "A",
          "text": "Analog signal"
        },
        {
          "key": "B",
          "text": "Digital signal"
        },
        {
          "key": "C",
          "text": "Continuous signal"
        },
        {
          "key": "D",
          "text": "Sine wave"
        }
      ],
      "correctAnswer": "B",
      "explanation": "Digital signals use discrete values (typically binary 0s and 1s) to represent data.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "According to Nyquist theorem, if bandwidth is 3000 Hz and we use 4 signal levels, what is the maximum bit rate?",
      "options": [
        {
          "key": "A",
          "text": "6000 bps"
        },
        {
          "key": "B",
          "text": "12000 bps"
        },
        {
          "key": "C",
          "text": "24000 bps"
        },
        {
          "key": "D",
          "text": "3000 bps"
        }
      ],
      "correctAnswer": "B",
      "explanation": "Maximum bit rate = 2B \u00d7 log\u2082M = 2 \u00d7 3000 \u00d7 log\u2082(4) = 6000 \u00d7 2 = 12000 bps.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-4",
      "question": "Shannon's theorem gives the maximum data rate for:",
      "options": [
        {
          "key": "A",
          "text": "Noiseless channels only"
        },
        {
          "key": "B",
          "text": "Noisy channels only"
        },
        {
          "key": "C",
          "text": "Both noiseless and noisy channels"
        },
        {
          "key": "D",
          "text": "Neither"
        }
      ],
      "correctAnswer": "B",
      "explanation": "Shannon's theorem specifically addresses channel capacity in the presence of noise (S/N ratio).",
      "difficulty": "easy"
    },
    {
      "id": "mcq-5",
      "question": "If bandwidth is 4 kHz and SNR is 30 dB, what is the channel capacity using Shannon's theorem? (Use log\u2081\u2080 approximation)",
      "options": [
        {
          "key": "A",
          "text": "4 kbps"
        },
        {
          "key": "B",
          "text": "40 kbps"
        },
        {
          "key": "C",
          "text": "400 kbps"
        },
        {
          "key": "D",
          "text": "4 Mbps"
        }
      ],
      "correctAnswer": "B",
      "explanation": "SNR(dB)=30 means SNR=10^(30/10)=1000. C = B \u00d7 log\u2082(1+S/N) = 4000 \u00d7 log\u2082(1001) \u2248 4000 \u00d7 9.97 \u2248 39880 bps \u2248 40 kbps.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-6",
      "question": "What does baud rate measure?",
