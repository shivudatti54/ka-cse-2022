    },
    {
      "id": "mcq-8",
      "question": "A channel has bandwidth of 20 kHz. Using Nyquist theorem with 2 signal levels, maximum bit rate is:",
      "options": [
        {
          "key": "A",
          "text": "10 kbps"
        },
        {
          "key": "B",
