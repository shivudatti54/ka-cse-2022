{
  "topicId": "quantifiers-rules-of-inference",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "Which rule is used in: 'All humans are mortal. Socrates is human. Therefore, Socrates is mortal.'",
      "options": [
        {
          "key": "A",
          "text": "Universal Instantiation"
        },
        {
          "key": "B",
          "text": "Modus Tollens"
        },
        {
          "key": "C",
          "text": "Existential Generalization"
        },
        {
          "key": "D",
          "text": "Hypothetical Syllogism"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Universal Instantiation applies \u2200x P(x) to a specific instance.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "What is the contrapositive of \u2200x (P(x) \u2192 Q(x))?",
      "options": [
        {
          "key": "A",
          "text": "\u2200x (\u00acQ(x) \u2192 \u00acP(x))"
        },
        {
          "key": "B",
          "text": "\u2203x (\u00acP(x) \u2192 \u00acQ(x))"
        },
        {
          "key": "C",
          "text": "\u2200x (\u00acP(x) \u2192 \u00acQ(x))"
        },
        {
          "key": "D",
          "text": "\u2203x (Q(x) \u2192 P(x))"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Contrapositive of P\u2192Q is \u00acQ\u2192\u00acP, applied universally.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-3",
      "question": "Which inference rule is invalid?",
      "options": [
        {
          "key": "A",
          "text": "From P\u2192Q and Q\u2192R, infer P\u2192R"
        },
        {
          "key": "B",
          "text": "From P\u2228Q and \u00acP, infer Q"
        },
        {
          "key": "C",
          "text": "From P\u2192Q and \u00acP, infer \u00acQ"
        },
        {
          "key": "D",
          "text": "From \u2200x P(x), infer P(a)"
        }
      ],
      "correctAnswer": "C",
      "explanation": "Denying the antecedent (\u00acP) doesn't prove \u00acQ.",
      "difficulty": "hard"
    }
  ]
}