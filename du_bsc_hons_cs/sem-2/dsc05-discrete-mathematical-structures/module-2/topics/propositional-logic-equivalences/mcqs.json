{
  "topicId": "propositional-logic-equivalences",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "Which equivalence represents implication elimination?",
      "options": [
        {
          "key": "A",
          "text": "p \u2192 q \u2261 \u00acp \u2228 q"
        },
        {
          "key": "B",
          "text": "p \u2192 q \u2261 p \u2227 \u00acq"
        },
        {
          "key": "C",
          "text": "p \u2192 q \u2261 \u00acp \u2227 q"
        },
        {
          "key": "D",
          "text": "p \u2192 q \u2261 p \u2228 \u00acq"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Implication can always be rewritten as disjunction of negated antecedent and consequent",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "Which is NOT a valid logical equivalence?",
      "options": [
        {
          "key": "A",
          "text": "p \u2192 q \u2261 \u00acq \u2192 \u00acp"
        },
        {
          "key": "B",
          "text": "p \u2228 (q \u2227 r) \u2261 (p \u2228 q) \u2227 r"
        },
        {
          "key": "C",
          "text": "\u00ac(p \u2227 q) \u2261 \u00acp \u2228 \u00acq"
        },
        {
          "key": "D",
          "text": "p \u2228 p \u2261 p"
        }
      ],
      "correctAnswer": "B",
      "explanation": "Correct distributive law requires both disjunctions with q and r",
      "difficulty": "medium"
    },
    {
      "id": "mcq-3",
      "question": "Which law simplifies p \u2227 (\u00acp \u2228 q)?",
      "options": [
        {
          "key": "A",
          "text": "Distributive Law"
        },
        {
          "key": "B",
          "text": "De Morgan's Law"
        },
        {
          "key": "C",
          "text": "Resolution"
        },
        {
          "key": "D",
          "text": "Absorption Law"
        }
      ],
      "correctAnswer": "C",
      "explanation": "Resolution: p \u2227 (\u00acp \u2228 q) \u2261 p \u2227 q",
      "difficulty": "hard"
    }
  ]
}