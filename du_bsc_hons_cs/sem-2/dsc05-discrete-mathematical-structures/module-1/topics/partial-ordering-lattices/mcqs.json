      "question": "Which relation is NOT a partial order?",
      "options": [
        {
          "key": "A",
          "text": "Divisibility on \u2115"
        },
        {
          "key": "B",
          "text": "Subset inclusion"
        },
        {
          "key": "C",
          "text": "Congruence modulo n"
        },
        {
          "key": "D",
          "text": "\u2264 on \u211d"
        }
      ],
      "correctAnswer": "C",
      "explanation": "Congruence is equivalence relation (symmetric) but not antisymmetric",
      "difficulty": "easy"
