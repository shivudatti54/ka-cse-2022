  "topicId": "sequences-summations",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "Evaluate the sum Σ_{i=1}^{5} (2i + 1).",
      "options": [
        {
          "key": "A",
          "text": "30"
        },
        {
          "key": "B",
          "text": "35"
        },
        {
          "key": "C",
          "text": "40"
        },
        {
          "key": "D",
          "text": "45"
        }
      ],
      "correctAnswer": "B",
      "explanation": "The sum equals 2·(1+2+3+4+5) + 5 = 2·15 + 5 = 35.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "What is the value of the sum of the first 100 natural numbers, Σ_{i=1}^{100} i?",
      "options": [
        {
          "key": "A",
          "text": "5050"
        },
        {
          "key": "B",
          "text": "5000"
        },
        {
          "key": "C",
          "text": "4950"
        },
        {
          "key": "D",
          "text": "5100"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Using the formula n(n+1)/2 gives 100·101/2 = 5050.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "Consider the code fragment: for i = 1 to n do for j = i to n do constant work. What is its time complexity?",
      "options": [
        {
          "key": "A",
          "text": "O(n)"
        },
        {
          "key": "B",
          "text": "O(n log n)"
        },
        {
          "key": "C",
          "text": "O(n^2)"
        },
        {
          "key": "D",
          "text": "O(n^3)"
        }
      ],
      "correctAnswer": "C",
      "explanation": "The number of iterations is Σ_{i=1}^{n} (n-i+1) = n(n+1)/2 = Θ(n^2).",
      "difficulty": "medium"
    },
    {
      "id": "mcq-4",
      "question": "Evaluate Σ_{i=0}^{10} 3·2^i.",
      "options": [
        {
          "key": "A",
          "text": "6140"
        },
        {
          "key": "B",
          "text": "6141"
        },
        {
          "key": "C",
          "text": "6142"
        },
        {
          "key": "D",
          "text": "6143"
        }
      ],
      "correctAnswer": "B",
      "explanation": "Using the geometric series formula a(r^{k+1} - 1)/(r - 1) with a=3, r=2, k=10 gives 3(2^{11} - 1) = 6141.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-5",
      "question": "Compute Σ_{i=1}^{n} (1/i - 1/(i+1)).",
      "options": [
        {
          "key": "A",
          "text": "n/(n+1)"
        },
        {
          "key": "B",
          "text": "(n+1)/n"
        },
        {
          "key": "C",
          "text": "1/(n+1)"
        },
        {
          "key": "D",
          "text": "n+1"
        }
      ],
      "correctAnswer": "A",
      "explanation": "The series telescopes to 1 - 1/(n+1) = n/(n+1).",
      "difficulty": "medium"
    },
    {
      "id": "mcq-6",
      "question": "Rewrite the summation Σ_{i=4}^{n} (i^2 - i) using the change of variable j = i - 3.",
      "options": [
        {
          "key": "A",
          "text": "Σ_{j=1}^{n-3} ((j+3)^2 - (j+3))"
        },
        {
          "key": "B",
          "text": "Σ_{j=0}^{n-4} ((j+3)^2 - (j+3))"
        },
        {
          "key": "C",
          "text": "Σ_{j=1}^{n} ((j+3)^2 - j)"
        },
        {
          "key": "D",
          "text": "Σ_{j=4}^{n} (j^2 - j)"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Substituting j = i - 3 shifts the lower limit to j = 1 and the upper limit to j = n - 3.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-7",
      "question": "Find a closed‑form expression for Σ_{i=1}^{n} Σ_{j=1}^{i} (i + j).",
      "options": [
        {
          "key": "A",
          "text": "n(n+1)^2/2"
        },
        {
          "key": "B",
          "text": "n(n+1)(2n+1)/6"
        },
        {
          "key": "C",
          "text": "n(n+1)(n+2)/2"
        },
        {
          "key": "D",
          "text": "n^2(n+1)/2"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Summing yields (1/2)(3∑i^2 + ∑i) = n(n+1)^2/2.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-8",
      "question": "What is the asymptotic order of Σ_{i=1}^{n} ⌊n/i⌋?",
      "options": [
        {
          "key": "A",
          "text": "Θ(n)"
        },
        {
          "key": "B",
          "text": "Θ(n log n)"
        },
        {
          "key": "C",
          "text": "Θ(n√n)"
        },
        {
          "key": "D",
          "text": "Θ(n^2)"
        }
      ],
      "correctAnswer": "B",
      "explanation": "The sum equals n log n + O(n), which is Θ(n log n).",
      "difficulty": "hard"
    }
  ]
