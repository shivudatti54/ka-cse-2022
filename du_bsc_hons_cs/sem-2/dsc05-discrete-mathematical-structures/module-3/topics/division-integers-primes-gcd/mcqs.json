    {
      "id": "mcq-14",
      "question": "For the Division Algorithm to hold, the condition on remainder r is:",
      "options": [
        {
          "key": "A",
          "text": "0 \u2264 r < b"
        },
        {
          "key": "B",
          "text": "0 \u2264 r \u2264 b"
        },
        {
          "key": "C",
          "text": "0 < r < b"
        },
        {
          "key": "D",
          "text": "-b < r < b"
        }
      ],
      "correctAnswer": "A",
      "explanation": "The remainder must be non-negative and strictly less than the absolute value of the divisor: 0 \u2264 r < |b|.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-15",
      "question": "Using Euclidean Algorithm, find gcd(144, 89):",
      "options": [
        {
          "key": "A",
          "text": "1"
        },
        {
          "key": "B",
          "text": "17"
        },
        {
          "key": "C",
          "text": "89"
        },
        {
          "key": "D",
          "text": "13"
        }
      ],
      "correctAnswer": "A",
      "explanation": "144 = 89\u00d71 + 55; 89 = 55\u00d71 + 34; 55 = 34\u00d71 + 21; 34 = 21\u00d71 + 13; 21 = 13\u00d71 + 8; 13 = 8\u00d71 + 5; 8 = 5\u00d71 + 3; 5 = 3\u00d71 + 2; 3 = 2\u00d71 + 1; 2 = 1\u00d72 + 0. GCD = 1.",
      "difficulty": "hard"
    },
    {
