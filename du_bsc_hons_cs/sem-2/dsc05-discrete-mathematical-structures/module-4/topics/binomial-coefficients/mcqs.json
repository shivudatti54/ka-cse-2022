      "id": "mcq-1",
      "question": "The value of C(8,3) is:",
      "options": [
        {
          "key": "A",
          "text": "56"
        },
        {
          "key": "B",
          "text": "24"
        },
        {
          "key": "C",
          "text": "336"
        },
        {
          "key": "D",
          "text": "64"
        }
      ],
      "correctAnswer": "A",
      "explanation": "C(8,3) = 8!/(3!\u00d75!) = 40320/(6\u00d7120) = 40320/720 = 56.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "Which of the following is equal to C(10, 7)?",
      "options": [
        {
          "key": "A",
          "text": "C(10, 3)"
        },
        {
          "key": "B",
          "text": "C(10, 8)"
