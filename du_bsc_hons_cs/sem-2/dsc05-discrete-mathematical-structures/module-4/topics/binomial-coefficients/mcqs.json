      "question": "Which identity is known as Vandermonde's Identity?",
      "options": [
        {
          "key": "A",
          "text": "C(n,k) = C(n, n-k)"
        },
        {
          "key": "B",
          "text": "C(n,k) = C(n-1,k-1) + C(n-1,k)"
        },
        {
          "key": "C",
          "text": "\u03a3 C(r,k)C(s,n-k) = C(r+s,n)"
        },
        {
          "key": "D",
          "text": "\u03a3 C(n,k) = 2^n"
        }
      ],
      "correctAnswer": "C",
      "explanation": "Vandermonde's Identity: \u03a3 (k=0 to n) C(r,k)C(s,n-k) = C(r+s, n).",
      "difficulty": "medium"
    },
