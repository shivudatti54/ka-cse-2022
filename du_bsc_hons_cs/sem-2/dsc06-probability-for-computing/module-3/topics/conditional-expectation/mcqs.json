    {
      "id": "mcq-2",
      "question": "Which property is NOT true for conditional expectation?",
      "options": [
        {
          "key": "A",
          "text": "E[X|X] = X"
        },
        {
          "key": "B",
          "text": "E[E[X|Y]] = E[X]"
        },
        {
          "key": "C",
          "text": "E[X|Y] is always constant"
        },
        {
          "key": "D",
          "text": "E[a|Y] = a for constant a"
        }
      ],
      "correctAnswer": "C",
      "explanation": "E[X|Y] is a function of Y, hence a random variable",
      "difficulty": "medium"
    },
