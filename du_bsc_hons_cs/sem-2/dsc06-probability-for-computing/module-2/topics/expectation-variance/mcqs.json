{
  "topicId": "expectation-variance",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "If X is a fair die roll, what is E[X]?",
      "options": [
        {
          "key": "A",
          "text": "3"
        },
        {
          "key": "B",
          "text": "3.5"
        },
        {
          "key": "C",
          "text": "4"
        },
        {
          "key": "D",
          "text": "2.5"
        }
      ],
      "correctAnswer": "B",
      "explanation": "E[X] = \u03a3 x\u00b7P(X=x) = (1+2+3+4+5+6)/6 = 21/6 = 3.5",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "For a Poisson distribution with parameter \u03bb=5, what is the variance?",
      "options": [
        {
          "key": "A",
          "text": "5"
        },
        {
          "key": "B",
          "text": "25"
        },
        {
          "key": "C",
          "text": "\u221a5"
        },
        {
          "key": "D",
          "text": "10"
        }
      ],
      "correctAnswer": "A",
      "explanation": "For Poisson(\u03bb), both mean and variance equal \u03bb. So Var(X) = 5.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "If X ~ Bin(10, 0.3), what is E[X]?",
      "options": [
        {
          "key": "A",
          "text": "0.3"
        },
        {
          "key": "B",
          "text": "3"
        },
        {
          "key": "C",
          "text": "7"
        },
        {
          "key": "D",
          "text": "10"
        }
      ],
      "correctAnswer": "B",
      "explanation": "For Bin(n,p), E[X] = n\u00b7p = 10 \u00d7 0.3 = 3",
      "difficulty": "easy"
    },
    {
      "id": "mcq-4",
      "question": "Which property of variance is correct?",
      "options": [
        {
          "key": "A",
          "text": "Var(X + Y) = Var(X) + Var(Y)"
        },
        {
          "key": "B",
          "text": "Var(aX) = a\u00b7Var(X)"
        },
        {
          "key": "C",
          "text": "Var(X + c) = Var(X) + c\u00b2"
        },
        {
          "key": "D",
          "text": "Var(cX) = c\u00b2\u00b7Var(X)"
        }
      ],
      "correctAnswer": "D",
      "explanation": "Var(cX) = c\u00b2\u00b7Var(X) where c is a constant. Adding a constant doesn't change variance.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-5",
      "question": "Two independent random variables X and Y have Var(X)=4 and Var(Y)=9. What is Var(2X + 3Y)?",
      "options": [
        {
          "key": "A",
          "text": "13"
        },
        {
          "key": "B",
          "text": "52"
        },
        {
          "key": "C",
          "text": "85"
        },
        {
          "key": "D",
          "text": "25"
        }
      ],
      "correctAnswer": "C",
      "explanation": "Var(2X+3Y) = 4\u00b7Var(2X) + 9\u00b7Var(3Y) = 4\u00d74 + 9\u00d79 = 16 + 81 = 85 (using Var(aX)=a\u00b2Var(X) and independence)",
      "difficulty": "medium"
    },
    {
      "id": "mcq-6",
      "question": "The Law of Total Expectation states:",
      "options": [
        {
          "key": "A",
          "text": "E[X|Y] = E[X]"
        },
        {
          "key": "B",
          "text": "E[E[X|Y]] = E[X]"
        },
        {
          "key": "C",
          "text": "E[X\u00b7Y] = E[X]\u00b7E[Y]"
        },
        {
          "key": "D",
          "text": "E[X+Y] = E[X] + E[Y]"
        }
      ],
      "correctAnswer": "B",
      "explanation": "Law of Total Expectation: E[E[X|Y]] = E[X]. The expected value of conditional expectation equals unconditional expectation.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-7",
      "question": "If Cov(X,Y) = 0, X and Y are:",
      "options": [
        {
          "key": "A",
          "text": "Always independent"
        },
        {
          "key": "B",
          "text": "Always dependent"
        },
        {
          "key": "C",
          "text": "Always uncorrelated"
        },
        {
          "key": "D",
          "text": "Sometimes independent"
        }
      ],
      "correctAnswer": "C",
      "explanation": "Cov = 0 means uncorrelated. Independent variables are always uncorrelated, but uncorrelated variables may still be dependent.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-8",
      "question": "For a fair coin tossed 100 times, the expected number of heads is:",
      "options": [
        {
          "key": "A",
          "text": "50"
        },
        {
          "key": "B",
          "text": "25"
        },
        {
          "key": "C",
          "text": "100"
        },
        {
          "key": "D",
          "text": "10"
        }
      ],
      "correctAnswer": "A",
      "explanation": "X ~ Bin(100, 0.5), so E[X] = n\u00b7p = 100 \u00d7 0.5 = 50",
      "difficulty": "easy"
    },
    {
      "id": "mcq-9",
      "question": "What is E[X\u00b2] if X has variance 4 and E[X] = 3?",
      "options": [
        {
          "key": "A",
          "text": "9"
        },
        {
          "key": "B",
          "text": "4"
        },
        {
          "key": "C",
          "text": "13"
        },
        {
          "key": "D",
          "text": "7"
        }
      ],
      "correctAnswer": "C",
      "explanation": "Var(X) = E[X\u00b2] - (E[X])\u00b2, so E[X\u00b2] = Var(X) + (E[X])\u00b2 = 4 + 9 = 13",
      "difficulty": "medium"
    },
    {
      "id": "mcq-10",
      "question": "The standard deviation of a random variable X is 3. What is the variance?",
      "options": [
        {
          "key": "A",
          "text": "3"
        },
        {
          "key": "B",
          "text": "6"
        },
        {
          "key": "C",
          "text": "9"
        },
        {
          "key": "D",
          "text": "\u221a3"
        }
      ],
      "correctAnswer": "C",
      "explanation": "Standard deviation is \u221aVariance, so variance = (3)\u00b2 = 9",
      "difficulty": "easy"
    },
    {
      "id": "mcq-11",
      "question": "For a Geometric distribution with p=0.2, what is the variance?",
      "options": [
        {
          "key": "A",
          "text": "5"
        },
        {
          "key": "B",
          "text": "20"
        },
        {
          "key": "C",
          "text": "4"
        },
        {
          "key": "D",
          "text": "0.8"
        }
      ],
      "correctAnswer": "B",
      "explanation": "For Geometric(p), Var(X) = (1-p)/p\u00b2 = (0.8)/(0.04) = 20",
      "difficulty": "hard"
    },
    {
      "id": "mcq-12",
      "question": "The expected value of a constant c is:",
      "options": [
        {
          "key": "A",
          "text": "0"
        },
        {
          "key": "B",
          "text": "c"
        },
        {
          "key": "C",
