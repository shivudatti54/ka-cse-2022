    {
      "id": "mcq-15",
      "question": "The Law of Total Variance states: Var(X) = ?",
      "options": [
        {
          "key": "A",
          "text": "Var(E[X|Y]) + E[Var(X|Y)]"
        },
        {
          "key": "B",
          "text": "E[Var(X|Y)] + Var(E[X|Y])"
        },
        {
          "key": "C",
          "text": "E[Var(X|Y)] \u00d7 Var(E[X|Y])"
        },
        {
          "key": "D",
          "text": "Var(E[X|Y]) - E[Var(X|Y)]"
        }
      ],
      "correctAnswer": "B",
      "explanation": "Var(X) = E[Var(X|Y)] + Var(E[X|Y]). Total variance = average conditional variance + variance of conditional means.",
      "difficulty": "hard"
    },
    {
