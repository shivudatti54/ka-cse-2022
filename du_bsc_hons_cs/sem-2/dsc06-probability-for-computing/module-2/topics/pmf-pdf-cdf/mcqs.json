    {
      "id": "mcq-1",
      "question": "Which function describes probabilities for continuous variables?",
      "options": [
        {
          "key": "A",
          "text": "PDF"
        },
        {
          "key": "B",
          "text": "PMF"
        },
        {
          "key": "C",
          "text": "CDF"
        },
        {
          "key": "D",
          "text": "All above"
        }
      ],
      "correctAnswer": "A",
      "explanation": "PDF (Probability Density Function) is used for continuous variables",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "For a fair 6-sided die, what is PMF(3)?",
      "options": [
        {
          "key": "A",
          "text": "1/6"
        },
        {
          "key": "B",
          "text": "1/3"
        },
        {
          "key": "C",
          "text": "0.5"
        },
        {
          "key": "D",
          "text": "Undefined"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Discrete uniform distribution: P(X=k)=1/6 for k=1-6",
      "difficulty": "easy"
    },
    {
