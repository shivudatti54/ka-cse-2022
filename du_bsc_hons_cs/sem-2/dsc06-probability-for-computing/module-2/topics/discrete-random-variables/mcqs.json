{
  "topicId": "discrete-random-variables",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "Which of the following is NOT a discrete random variable?",
      "options": [
        {
          "key": "A",
          "text": "Number of customers arriving at a bank in one hour"
        },
        {
          "key": "B",
          "text": "Number of heads when tossing 3 coins"
        },
        {
          "key": "C",
          "text": "Time taken to complete a task"
        },
        {
          "key": "D",
          "text": "Number of defective items in a batch"
        }
      ],
      "correctAnswer": "C",
      "explanation": "Time is a continuous variable as it can take any value within an interval. The other options involve countable outcomes.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "For a discrete random variable X with PMF p(x), which condition must always hold?",
      "options": [
        {
          "key": "A",
          "text": "\u03a3 p(x) = 0"
        },
        {
          "key": "B",
          "text": "\u03a3 p(x) = 1"
        },
        {
          "key": "C",
          "text": "\u03a3 p(x) > 1"
        },
        {
          "key": "D",
          "text": "\u03a3 p(x) < 0"
        }
      ],
      "correctAnswer": "B",
      "explanation": "The sum of probabilities over all possible values must equal 1 (the total probability).",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "If X follows a Bernoulli distribution with success probability p, what is E[X]?",
      "options": [
        {
          "key": "A",
          "text": "p"
        },
        {
          "key": "B",
          "text": "1-p"
        },
        {
          "key": "C",
          "text": "p(1-p)"
        },
        {
          "key": "D",
          "text": "1"
        }
      ],
      "correctAnswer": "A",
      "explanation": "For Bernoulli(p): P(X=1)=p, P(X=0)=1-p. So E[X] = 1\u00b7p + 0\u00b7(1-p) = p.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-4",
      "question": "A fair die is rolled 5 times. What is the probability of getting exactly 2 sixes?",
      "options": [
        {
          "key": "A",
          "text": "C(5,2) \u00b7 (1/6)\u00b2 \u00b7 (5/6)\u00b3"
        },
        {
          "key": "B",
          "text": "C(5,2) \u00b7 (1/6)\u00b3 \u00b7 (5/6)\u00b2"
        },
        {
          "key": "C",
          "text": "(1/6)\u00b2 \u00b7 (5/6)\u00b3"
        },
        {
          "key": "D",
          "text": "C(5,2) \u00b7 (1/6)\u00b2"
        }
      ],
      "correctAnswer": "A",
      "explanation": "This is a binomial problem with n=5, p=1/6. P(X=2) = C(5,2) \u00b7 (1/6)\u00b2 \u00b7 (5/6)\u00b3.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-5",
      "question": "The variance of a Bernoulli random variable X with parameter p is:",
      "options": [
        {
          "key": "A",
          "text": "p"
        },
        {
          "key": "B",
          "text": "p\u00b2"
        },
        {
          "key": "C",
          "text": "p(1-p)"
        },
        {
          "key": "D",
          "text": "1-p"
        }
      ],
      "correctAnswer": "C",
      "explanation": "Var(X) = E[X\u00b2] - (E[X])\u00b2 = p - p\u00b2 = p(1-p), since X\u00b2 = X for Bernoulli variables.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-6",
      "question": "If X ~ Bin(10, 0.3), what is E[X]?",
      "options": [
        {
          "key": "A",
          "text": "0.3"
        },
        {
          "key": "B",
          "text": "3"
        },
        {
          "key": "C",
          "text": "7"
        },
        {
          "key": "D",
          "text": "10"
        }
      ],
      "correctAnswer": "B",
      "explanation": "For Bin(n, p), E[X] = n \u00d7 p = 10 \u00d7 0.3 = 3.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-7",
      "question": "A Poisson random variable with mean 4 has P(X=0) equal to:",
      "options": [
        {
          "key": "A",
          "text": "4"
        },
        {
          "key": "B",
          "text": "e^(-4)"
        },
        {
          "key": "C",
          "text": "e^4"
        },
        {
          "key": "D",
          "text": "1/4"
        }
      ],
      "correctAnswer": "B",
      "explanation": "P(X=0) = (e^(-\u03bb) \u00d7 \u03bb^0) / 0! = e^(-4) \u00d7 1 = e^(-4).",
      "difficulty": "medium"
    },
    {
      "id": "mcq-8",
      "question": "The expected value of the sum of two independent random variables equals:",
      "options": [
        {
          "key": "A",
          "text": "Product of their expectations"
        },
        {
          "key": "B",
          "text": "Sum of their expectations"
        },
        {
          "key": "C",
          "text": "Difference of their expectations"
        },
        {
          "key": "D",
          "text": "Minimum of their expectations"
        }
      ],
      "correctAnswer": "B",
      "explanation": "E[X + Y] = E[X] + E[Y] always holds due to linearity of expectation, regardless of independence.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-9",
      "question": "For X ~ Geometric(p) with p=0.2, what is P(X=3)?",
      "options": [
        {
          "key": "A",
          "text": "0.2\u00b3"
        },
        {
          "key": "B",
          "text": "0.8\u00b2 \u00d7 0.2"
        },
        {
          "key": "C",
          "text": "0.8 \u00d7 0.2"
        },
        {
          "key": "D",
          "text": "0.2 \u00d7 0.8"
        }
      ],
      "correctAnswer": "B",
      "explanation": "P(X=k) = (1-p)^(k-1) \u00d7 p = (0.8)^(2) \u00d7 0.2 = 0.64 \u00d7 0.2 = 0.128.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-10",
      "question": "The variance of X + Y for independent random variables X and Y is:",
      "options": [
        {
          "key": "A",
          "text": "Var(X) + Var(Y)"
        },
        {
          "key": "B",
          "text": "Var(X) \u00d7 Var(Y)"
        },
        {
          "key": "C",
          "text": "Var(X) - Var(Y)"
        },
        {
          "key": "D",
          "text": "Var(X) + Var(Y) + 2Cov(X,Y)"
        }
      ],
      "correctAnswer": "A",
      "explanation": "For independent variables, Var(X + Y) = Var(X) + Var(Y) since Cov(X,Y) = 0.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-11",
      "question": "Which distribution models the number of events occurring in a fixed time interval?",
      "options": [
        {
          "key": "A",
          "text": "Binomial"
        },
        {
          "key": "B",
          "text": "Geometric"
        },
        {
          "key": "C",
          "text": "Poisson"
        },
        {
          "key": "D",
          "text": "Bernoulli"
        }
