        {
          "key": "C",
          "text": "\u2264 0.75"
        },
        {
          "key": "D",
          "text": "\u2264 0.10"
        }
      ],
      "correctAnswer": "A",
      "explanation": "k = 10/\u03c3 = 10/5 = 2 \u2192 1/k\u00b2 = 1/4",
