      "id": "mcq-1",
      "question": "In a single throw of a fair die, what is the probability of getting an even number?",
      "options": [
        {
          "key": "A",
          "text": "1/6"
        },
        {
          "key": "B",
          "text": "1/2"
        },
        {
          "key": "C",
          "text": "1/3"
        },
        {
          "key": "D",
          "text": "2/3"
        }
      ],
      "correctAnswer": "B",
      "explanation": "Even numbers on a die are {2, 4, 6}. There are 3 favorable outcomes out of 6 total outcomes, so P = 3/6 = 1/2.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "Two events A and B are mutually exclusive if:",
      "options": [
        {
          "key": "A",
          "text": "P(A \u222a B) = P(A) + P(B)"
        },
        {
          "key": "B",
          "text": "P(A \u2229 B) = 0"
        },
        {
          "key": "C",
          "text": "P(A) = 1 - P(B)"
        },
        {
          "key": "D",
          "text": "P(A|B) = P(A)"
        }
      ],
      "correctAnswer": "B",
      "explanation": "Mutually exclusive events cannot occur together, so their intersection has probability zero: P(A \u2229 B) = 0.",
      "difficulty": "easy"
    },
