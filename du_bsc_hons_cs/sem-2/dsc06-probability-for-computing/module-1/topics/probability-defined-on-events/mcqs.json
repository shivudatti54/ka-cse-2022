          "key": "C",
          "text": "0"
        },
        {
          "key": "D",
          "text": "1.4"
        }
      ],
      "correctAnswer": "B",
      "explanation": "P(A') = 1 - P(A) = 1 - 0.4 = 0.6. Complementary events always sum to 1.",
      "difficulty": "easy"
    },
