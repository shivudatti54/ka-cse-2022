      "title": "Process Creation, Termination, and System Calls",
      "description": "Animated diagram showing fork/exec/wait process creation flow, termination types (normal, error, fatal, kill), zombie and orphan processes, and key system calls (fork, exec, exit, wait, kill)",
      "type": "animated-svg",
      "file": "assets/operations-on-processes.svg",
      "animated": true
    }
  ],
  "diagrams": [
    {
      "id": "d1",
      "title": "Process Creation Flow with fork() and exec()",
      "type": "flow",
      "content": {
        "nodes": [
          {
            "id": "n1",
            "label": "Parent Process (Program A)"
          },
          {
            "id": "n2",
            "label": "fork() called"
          },
          {
            "id": "n3",
            "label": "Child Process (Copy of A)"
          },
          {
            "id": "n4",
            "label": "Parent calls wait(NULL)"
          },
          {
            "id": "n5",
            "label": "Child calls exec()"
          },
          {
            "id": "n6",
            "label": "Child runs Program B (same PID)"
          },
          {
            "id": "n7",
            "label": "Child calls exit()"
          },
          {
            "id": "n8",
            "label": "Parent resumes after wait()"
          }
        ],
        "edges": [
          {
            "from": "n1",
            "to": "n2"
          },
          {
            "from": "n2",
            "to": "n3",
            "label": "returns 0 to child"
          },
          {
            "from": "n2",
            "to": "n4",
            "label": "returns child PID to parent"
          },
          {
            "from": "n3",
            "to": "n5"
          },
          {
            "from": "n5",
            "to": "n6"
          },
          {
            "from": "n6",
            "to": "n7"
          },
          {
            "from": "n7",
            "to": "n8",
            "label": "exit status passed"
          }
        ]
      }
    },
    {
      "id": "d2",
      "title": "Process Termination Types",
      "type": "category",
      "content": {
        "categories": [
          {
            "label": "Voluntary",
            "items": ["Normal exit() - task completed", "Error exit - handled error"]
          },
          {
            "label": "Involuntary",
            "items": [
              "Fatal error (e.g., division by zero)",
              "Killed by kill() signal from another process"
            ]
          }
        ]
      }
    },
    {
      "id": "d3",
      "title": "Zombie vs Orphan Processes",
      "type": "comparison",
      "content": {
        "items": [
          {
            "label": "Zombie Process",
            "description": "Child has exited but parent has not called wait(). PCB remains in process table until parent reaps it."
          },
          {
            "label": "Orphan Process",
            "description": "Parent has exited while child is still running. Child is reparented to init (PID 1) which eventually reaps it."
          }
        ]
      }
    }
  ]
}
