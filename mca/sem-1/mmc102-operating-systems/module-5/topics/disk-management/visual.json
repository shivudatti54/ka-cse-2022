      "id": "d3",
      "title": "Bad Block Handling: Sparing vs Slipping",
      "type": "comparison",
      "content": {
        "nodes": [
          {
            "id": "n1",
            "label": "Sector Sparing: Remap bad sector to spare from reserved pool"
          },
          {
            "id": "n2",
            "label": "Sector Slipping: Shift adjacent sectors to fill the gap"
          },
          {
            "id": "n3",
            "label": "Sparing breaks sequential order; Slipping preserves it"
          }
        ],
        "edges": []
      }
