      "title": "Swap Space: Raw Partition vs File System",
      "type": "comparison",
      "content": {
        "nodes": [
          {
            "id": "n1",
            "label": "Raw Partition: Faster, no FS overhead, fixed size"
          },
          {
            "id": "n2",
            "label": "File System Swap: Easier to manage, slower, resizable"
          },
          {
            "id": "n3",
            "label": "Modern OS: Swap at page granularity with swap map"
          }
