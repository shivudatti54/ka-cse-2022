{
  "topicId": "point-to-point-protocol",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "PPP is defined in which layer of OSI model?",
      "options": [
        {
          "key": "A",
          "text": "Physical Layer"
        },
        {
          "key": "B",
          "text": "Data Link Layer"
        },
        {
          "key": "C",
          "text": "Network Layer"
        },
        {
          "key": "D",
          "text": "Transport Layer"
        }
      ],
      "correctAnswer": "Data Link Layer",
      "explanation": "PPP operates at the Data Link Layer (Layer 2) and provides framing, error detection, and link establishment between two nodes.",
      "difficulty": "easy"
    },
    {
