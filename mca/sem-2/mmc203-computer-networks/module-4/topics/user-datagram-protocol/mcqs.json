    {
      "id": "mcq-1",
      "question": "What is the size of the UDP header in bytes?",
      "options": [
        {
          "key": "A",
          "text": "4 bytes"
        },
        {
          "key": "B",
          "text": "8 bytes"
        },
        {
          "key": "C",
          "text": "16 bytes"
        },
        {
          "key": "D",
          "text": "20 bytes"
        }
      ],
      "correctAnswer": "8 bytes",
      "explanation": "UDP has a fixed 8-byte header consisting of four 16-bit fields: Source Port, Destination Port, Length, and Checksum.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
