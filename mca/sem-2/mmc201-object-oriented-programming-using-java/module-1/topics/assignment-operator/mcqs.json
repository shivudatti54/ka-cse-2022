      "id": "mcq-1",
      "question": "What is the output?\nint a = 5;\na += a + a;\nSystem.out.println(a);",
      "options": [
        {
          "key": "A",
          "text": "10"
        },
        {
          "key": "B",
          "text": "15"
        },
        {
          "key": "C",
          "text": "25"
        },
        {
          "key": "D",
          "text": "5"
        }
      ],
      "correctAnswer": "15",
      "explanation": "a += (a + a) means a = a + (a + a) = 5 + 10 = 15",
      "difficulty": "easy"
