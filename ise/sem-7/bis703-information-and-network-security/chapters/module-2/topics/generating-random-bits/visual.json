      "id": "d3",
      "title": "Worked Example: Linear Recurrence",
      "type": "example",
      "content": {
        "recurrence": "a_n = 3*a_(n-1) + 2, a_0 = 1",
        "generatingFunction": "G(x) = (1+x)/((1-x)(1-3x))",
        "closedForm": "a_n = -1 + 2*3^n"
      }
    },
    {
      "id": "d4",
      "title": "Fibonacci Sequence via Generating Functions",
      "type": "example",
      "content": {
        "recurrence": "F_n = F_(n-1) + F_(n-2), F_0=0, F_1=1",
        "generatingFunction": "G(x) = x/(1-x-x^2)",
        "closedForm": "F_n = (phi^n - phi'^n)/sqrt(5)"
      }
    }
