      "id": "d3",
      "title": "Key CSP Directives for XSS Prevention",
      "type": "table",
      "content": {
        "headers": ["Directive", "Purpose", "XSS Impact"],
        "rows": [
          ["script-src", "Controls which scripts can execute", "Primary XSS defense"],
          ["default-src", "Fallback for all resource types", "Baseline restriction"],
          [
            "'nonce-<value>'",
            "Allows specific inline scripts with matching nonce",
            "Replaces unsafe-inline"
          ],
          ["'sha256-...'", "Allows inline scripts matching a hash", "Replaces unsafe-inline"],
          ["report-uri", "Sends violation reports to server", "Attack detection"]
        ]
