      "id": "d3",
      "title": "Traffic Light Protocol (TLP) Classification",
      "type": "reference",
      "description": "TLP:RED - No disclosure beyond immediate recipients. TLP:AMBER - Limited disclosure within recipient organization. TLP:GREEN - Disclosure within the wider community. TLP:CLEAR - No restrictions, public distribution."
