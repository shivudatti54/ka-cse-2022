    {
      "id": "d2",
      "title": "CSP Directives Overview",
      "type": "concept-map",
      "content": {
        "nodes": [
          {
            "id": "c1",
            "label": "default-src: Fallback for all resource types"
          },
          {
            "id": "c2",
            "label": "script-src: Controls JavaScript execution"
          },
          {
            "id": "c3",
            "label": "style-src: Controls CSS stylesheets"
          },
          {
            "id": "c4",
            "label": "img-src: Controls image loading"
          },
          {
            "id": "c5",
            "label": "connect-src: Controls XHR and WebSocket"
          },
          {
            "id": "c6",
            "label": "frame-src: Controls iframe embedding"
          },
          {
            "id": "c7",
            "label": "form-action: Controls form submission targets"
          }
        ]
      }
    },
    {
      "id": "d3",
      "title": "Phased Deployment Strategy",
      "type": "flow",
      "content": {
        "nodes": [
          {
            "id": "p1",
