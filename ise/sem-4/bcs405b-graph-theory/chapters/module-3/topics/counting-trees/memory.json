  "formulas": [
    {
      "id": "f1",
      "name": "Inclusion-Exclusion (2 sets)",
      "formula": "|A ∪ B| = |A| + |B| - |A ∩ B|",
      "example": "|{1,2,3} ∪ {2,3,4}| = 3 + 3 - 2 = 4"
    },
    {
      "id": "f2",
      "name": "Pigeonhole",
      "formula": "⌈n/m⌉ items in at least one container",
      "example": "13 people, 12 months: ⌈13/12⌉ = 2 share month"
    }
  ]
}
