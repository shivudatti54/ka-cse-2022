{
  "topicId": "bankers-algorithm",
  "diagrams": [
    {
      "id": "data-structures",
      "type": "table",
      "title": "Banker's Algorithm Data Structures",
      "description": "Matrices used in the algorithm",
      "content": {
        "structures": [
          { "name": "Available[m]", "description": "Free resources of each type" },
          { "name": "Max[n×m]", "description": "Maximum demand of each process" },
          { "name": "Allocation[n×m]", "description": "Currently allocated to each process" },
          { "name": "Need[n×m]", "description": "Max - Allocation (remaining need)" }
        ]
      }
    },
    {
      "id": "safety-algorithm",
      "type": "flowchart",
      "title": "Safety Algorithm",
      "description": "Steps to check if state is safe",
      "content": {
        "steps": [
          { "step": 1, "action": "Work = Available, Finish[] = false" },
          { "step": 2, "action": "Find i: Finish[i]=false AND Need[i]≤Work" },
          { "step": 3, "decision": "Found?", "yes": "Step 4", "no": "Step 5" },
          { "step": 4, "action": "Work += Allocation[i], Finish[i]=true, goto 2" },
          { "step": 5, "action": "All Finish=true? → SAFE, else UNSAFE" }
        ]
      }
    },
    {
      "id": "request-algorithm",
      "type": "flowchart",
      "title": "Resource Request Algorithm",
      "description": "Handling a resource request",
      "content": {
        "steps": [
          { "step": 1, "check": "Request ≤ Need?", "no": "Error!" },
          { "step": 2, "check": "Request ≤ Available?", "no": "Wait" },
          { "step": 3, "action": "Pretend allocate (update matrices)" },
          { "step": 4, "check": "Run Safety → Safe?", "yes": "Grant", "no": "Deny & restore" }
        ]
      }
    }
  ]
}
