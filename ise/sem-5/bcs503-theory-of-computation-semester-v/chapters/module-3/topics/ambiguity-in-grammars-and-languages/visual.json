      "svgContent": "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"420\" height=\"350\"><defs><linearGradient id=\"bg\" x1=\"0%\" y1=\"0%\" x2=\"0%\" y2=\"100%\"><stop offset=\"0%\" style=\"stop-color:#E3F2FD\"/><stop offset=\"100%\" style=\"stop-color:#BBDEFB\"/></linearGradient></defs><rect width=\"420\" height=\"350\" fill=\"url(#bg)\" rx=\"12\"/><text x=\"210\" y=\"25\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"13\" font-weight=\"bold\" fill=\"#1565C0\">Ambiguity in Grammars and Languages</text><!-- Grammar Box --><rect x=\"50\" y=\"60\" width=\"120\" height=\"40\" fill=\"#2196F3\" rx=\"5\"></rect><text x=\"110\" y=\"85\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"11\" fill=\"white\">\n    Grammar\n    \n  </text><!-- Ambiguous Parse Path 1 --><path d=\"M170 80 C 220 50, 270 50, 320 80\" stroke=\"#1565C0\" stroke-width=\"2\" fill=\"none\"></path><polygon points=\"320 80, 315 75, 315 85\" fill=\"#1565C0\"></polygon><!-- Parse Tree 1 --><rect x=\"300\" y=\"60\" width=\"100\" height=\"40\" fill=\"#64B5F6\" rx=\"5\"></rect><text x=\"350\" y=\"85\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"11\" fill=\"white\">\n    Parse Tree 1\n    \n  </text><!-- Ambiguous Parse Path 2 --><path d=\"M170 80 C 220 110, 270 110, 320 80\" stroke=\"#1565C0\" stroke-width=\"2\" fill=\"none\"></path><polygon points=\"320 80, 315 75, 315 85\" fill=\"#1565C0\"></polygon><!-- Parse Tree 2 --><rect x=\"300\" y=\"120\" width=\"100\" height=\"40\" fill=\"#64B5F6\" rx=\"5\"></rect><text x=\"350\" y=\"145\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"11\" fill=\"white\">\n    Parse Tree 2\n    \n  </text><!-- Input String --><rect x=\"50\" y=\"150\" width=\"120\" height=\"40\" fill=\"#1565C0\" rx=\"5\"></rect><text x=\"110\" y=\"175\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"11\" fill=\"white\">\n    Input String\n    \n  </text><!-- Arrow from Input to Grammar --><path d=\"M110 150 L110 130\" stroke=\"#1565C0\" stroke-width=\"2\" marker-end=\"url(#arrowhead)\"></path><!-- Question Mark --><text x=\"350\" y=\"100\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"20\" font-weight=\"bold\" fill=\"#1565C0\">\n    ?\n    \n  </text><!-- Definition Text --><text x=\"210\" y=\"220\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"10\" fill=\"#1565C0\">\n    A grammar is ambiguous if a string has multiple parse trees\n    \n  </text><defs><marker id=\"arrowhead\" markerWidth=\"10\" markerHeight=\"7\" refX=\"9\" refY=\"3.5\" orient=\"auto\"><polygon points=\"0 0, 10 3.5, 0 7\" fill=\"#1565C0\"/></marker></defs></svg>",
