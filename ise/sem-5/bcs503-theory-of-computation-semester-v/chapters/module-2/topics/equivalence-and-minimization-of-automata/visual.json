eight=\"50\" fill=\"#1976D2\" rx=\"5\"></rect><text x=\"210\" y=\"280\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"11\" fill=\"white\">\n    Equivalence Check\n    \n  </text><!-- Arrow from Minimal to Equivalence --><path d=\"M300 130 L270 250\" stroke=\"#1565C0\" stroke-width=\"2\" marker-end=\"url(#arrowhead)\"></path><!-- Arrow from Initial to Equivalence --><path d=\"M120 130 L150 250\" stroke=\"#1565C0\" stroke-width=\"2\" marker-end=\"url(#arrowhead)\"></path><!-- States Representation --><circle cx=\"90\" y=\"70\" r=\"5\" fill=\"#FF5722\"></circle><circle cx=\"330\" y=\"70\" r=\"5\" fill=\"#FF5722\"></circle><!-- Transition Arrows --><path d=\"M95 70 L105 70\" stroke=\"#FF5722\" stroke-width=\"2\" marker-end=\"url(#arrowhead)\"></path><path d=\"M335 70 L345 70\" stroke=\"#FF5722\" stroke-width=\"2\" marker-end=\"url(#arrowhead)\"></path></svg>",
