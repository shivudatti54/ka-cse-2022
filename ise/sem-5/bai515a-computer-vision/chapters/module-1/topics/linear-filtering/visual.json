    {
      "id": "d4",
      "title": "Padding Strategies Comparison",
      "type": "comparison",
      "content": {
        "strategies": [
          {
            "name": "Zero Padding",
            "description": "Exterior pixels filled with 0",
            "pros": "Simple, no artifacts from data",
            "cons": "Darkens edges, reduces border accuracy"
          },
          {
            "name": "Replicate Padding",
            "description": "Nearest border pixel value extended",
            "pros": "Preserves edge intensity",
            "cons": "Can create flat regions at borders"
          },
          {
            "name": "Reflect Padding",
            "description": "Mirror pixel values at boundary",
            "pros": "Smooth transition, no discontinuity",
            "cons": "May introduce symmetry artifacts"
          },
          {
            "name": "Wrap-around Padding",
            "description": "Pixels from opposite side of image",
            "pros": "Good for periodic/tiling images",
            "cons": "Creates artifacts for non-periodic images"
          }
        ]
      }
    }
  ]
