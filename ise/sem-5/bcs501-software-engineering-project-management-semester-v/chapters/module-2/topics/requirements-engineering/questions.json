{
  "topicId": "requirements-engineering-basics",
  "questions": [
    {
      "id": "q1",
      "question": "Explain the difference between functional and non-functional requirements with examples.",
      "type": "long",
      "expectedPoints": [
        "Functional: what system does - login, reports, calculations",
        "Non-functional: quality attributes - performance, security",
        "Functional are specific behaviors",
        "Non-functional constrain the solution"
      ]
    },
    {
      "id": "q2",
      "question": "List and briefly describe the steps in the requirements engineering process.",
      "type": "long",
      "expectedPoints": [
        "Feasibility study - assess viability",
        "Elicitation - gather requirements from stakeholders",
        "Analysis - classify, prioritize, resolve conflicts",
        "Specification - document in SRS",
        "Validation - verify completeness and correctness",
        "Management - handle changes, maintain traceability"
      ]
    }
  ]
}
