  "topicId": "basic-logic",
  "mcqs": [
    {
      "id": "mcq1",
      "question": "p → q is equivalent to:",
      "options": [
        { "key": "A", "text": "p ∧ q" },
        { "key": "B", "text": "¬p ∨ q" },
        { "key": "C", "text": "q → p" },
        { "key": "D", "text": "¬p ∧ q" }
      ],
      "correctAnswer": "B",
      "explanation": "p → q ≡ ¬p ∨ q (material implication). This is a fundamental equivalence.",
      "difficulty": "easy"
    },
    {
      "id": "mcq2",
      "question": "Which is a tautology?",
      "options": [
        { "key": "A", "text": "p ∧ q" },
        { "key": "B", "text": "p → q" },
        { "key": "C", "text": "p ∨ ¬p" },
        { "key": "D", "text": "p ∧ ¬p" }
      ],
      "correctAnswer": "C",
      "explanation": "p ∨ ¬p is always true (Law of Excluded Middle). p ∧ ¬p is a contradiction.",
      "difficulty": "easy"
    }
  ]
}
