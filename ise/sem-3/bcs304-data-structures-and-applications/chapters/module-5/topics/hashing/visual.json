{
  "topicId": "hashing-fundamentals",
  "visuals": [
    {
      "id": "hash-table-structure",
      "title": "Hash Table Structure",
      "type": "diagram",
      "description": "How hash table stores data",
      "content": {
        "diagram": [
          "KEY        HASH FUNCTION      INDEX    TABLE",
          "",
          "\"apple\"  → hash(\"apple\")=7  →  [7]  → [\"apple\", 100]",
          "\"banana\" → hash(\"banana\")=3 →  [3]  → [\"banana\", 200]",
          "\"cherry\" → hash(\"cherry\")=7 →  [7]  → Collision!",
          "",
          "TABLE (with chaining):",
          "Index | Content",
          "------|------------------",
          "  0   | NULL",
          "  1   | NULL",
          "  2   | NULL",
          "  3   | (\"banana\", 200)",
          "  4   | NULL",
          "  5   | NULL",
          "  6   | NULL",
          "  7   | (\"apple\",100) → (\"cherry\",300)",
          "  8   | NULL",
          "  9   | NULL"
        ]
      }
    },
    {
      "id": "load-factor",
      "title": "Load Factor Impact",
      "type": "diagram",
      "description": "How load factor affects performance",
      "content": {
        "diagram": [
          "LOAD FACTOR α = n/m (elements/table_size)",
          "",
          "α = 0.3 (low)     α = 0.7 (moderate)    α = 1.0+ (high)",
          "[_][X][_][_][_]   [X][X][_][X][X]       [X][X][X][X][X]→overflow",
          "",
          "Few collisions    Some collisions       Many collisions",
          "Fast lookups      Acceptable speed      Slow lookups",
          "Wasted space      Good balance          May need resize",
          "",
          "RECOMMENDATION: Keep α < 0.7",
          "When α exceeds threshold → resize table (usually 2x)"
        ]
      }
    },
    {
      "id": "operations-flow",
      "title": "Hash Table Operations",
      "type": "diagram",
      "description": "Insert, Search, Delete flow",
      "content": {
        "diagram": [
          "INSERT(key, value):",
          "  key → hash() → index → [check collision] → store",
          "",
          "SEARCH(key):",
          "  key → hash() → index → [search chain] → return value/null",
          "",
          "DELETE(key):",
          "  key → hash() → index → [find in chain] → remove",
          "",
          "Example: INSERT(\"dog\", 50)",
          "1. hash(\"dog\") = 42",
          "2. index = 42 % 10 = 2",
          "3. Check bucket[2] for collision",
          "4. Add (\"dog\", 50) to bucket[2]"
        ]
      }
    }
  ]
}
