      "title": "Symmetric vs Asymmetric Scalability",
      "type": "comparison",
      "content": {
        "left": {
          "label": "Symmetric",
          "formula": "n(n-1)/2 keys",
          "example": "10 users = 45 keys"
        },
        "right": {
          "label": "Asymmetric",
          "formula": "2n keys",
          "example": "10 users = 20 keys"
        }
      }
