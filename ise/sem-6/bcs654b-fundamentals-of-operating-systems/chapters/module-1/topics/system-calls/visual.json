      "id": "d1",
      "title": "System Call Execution Flow",
      "type": "flow",
      "content": {
        "nodes": [
          {
            "id": "n1",
            "label": "User Application\nCalls read() API"
          },
          {
            "id": "n2",
            "label": "C Library prepares args\nSets eax = SYS_READ"
          },
          {
            "id": "n3",
            "label": "Trap: syscall / int 0x80\nSave state, switch to Kernel Mode"
          },
          {
            "id": "n4",
            "label": "Kernel: Dispatch\nsyscall_table[eax] -> sys_read()"
          },
          {
            "id": "n5",
            "label": "Kernel: Execute sys_read()\nPerform I/O, set return value"
          },
          {
            "id": "n6",
            "label": "Return to User Mode\nRestore state, resume process"
          }
        ],
        "edges": [
          { "from": "n1", "to": "n2" },
          { "from": "n2", "to": "n3" },
          { "from": "n3", "to": "n4" },
          { "from": "n4", "to": "n5" },
          { "from": "n5", "to": "n6" }
        ]
      }
    },
    {
