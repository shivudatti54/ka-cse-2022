          ],
          [
            "File Management",
            "Create, read, write, manipulate files",
            "open(), read(), write(), close()"
          ],
          ["Device Management", "Request/release devices, read/write", "ioctl(), read(), write()"],
          ["Information Maintenance", "Get/set system data", "getpid(), gettimeofday()"],
          ["Communication", "Inter-process communication", "pipe(), shmget(), msgget()"],
          ["Protection", "Control access to resources", "chmod(), chown(), setuid()"]
        ]
      }
    }
