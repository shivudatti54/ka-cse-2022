{
  "topicId": "singly-linked-list",
  "visuals": [
    {
      "id": "insert-beginning",
      "title": "Insert at Beginning",
      "type": "step-diagram",
      "description": "Steps to insert node at the beginning",
      "steps": [
        {
          "step": 1,
          "label": "Initial state",
          "visual": "HEAD → [10|→] → [20|→] → [30|NULL]",
          "note": "Insert value 5 at beginning"
        },
        {
          "step": 2,
          "label": "Create new node",
          "visual": "newNode → [5|NULL]\nHEAD → [10|→] → [20|→] → [30|NULL]",
          "note": "Allocate and initialize new node"
        },
        {
          "step": 3,
          "label": "Point new node to head",
          "visual": "newNode → [5|→] → [10|→] → [20|→] → [30|NULL]\n           ↑\nHEAD ──────┘",
          "note": "newNode->next = head"
        },
        {
          "step": 4,
          "label": "Update head",
          "visual": "HEAD → [5|→] → [10|→] → [20|→] → [30|NULL]",
          "note": "head = newNode (done!)"
        }
      ]
    },
    {
      "id": "delete-beginning",
      "title": "Delete from Beginning",
      "type": "step-diagram",
      "description": "Steps to delete first node",
      "steps": [
        {
          "step": 1,
          "label": "Initial state",
          "visual": "HEAD → [10|→] → [20|→] → [30|NULL]",
          "note": "Delete first node (10)"
        },
        {
          "step": 2,
          "label": "Save reference to first node",
          "visual": "temp → [10|→] → [20|→] → [30|NULL]\n        ↑\nHEAD ───┘",
          "note": "temp = head"
        },
        {
          "step": 3,
          "label": "Move head forward",
          "visual": "temp → [10|→] → [20|→] → [30|NULL]\n                 ↑\nHEAD ────────────┘",
          "note": "head = head->next"
        },
        {
          "step": 4,
          "label": "Free old node",
          "visual": "HEAD → [20|→] → [30|NULL]",
          "note": "free(temp) - memory released"
        }
      ]
    },
    {
      "id": "reverse-visual",
      "title": "Reverse Linked List",
      "type": "step-diagram",
      "description": "Iterative reversal process",
      "steps": [
        {
          "step": 1,
          "label": "Initial",
          "visual": "prev=NULL, curr=[1], next=NULL\n[1|→] → [2|→] → [3|NULL]",
          "note": "Initialize pointers"
        },
        {
          "step": 2,
          "label": "Iteration 1",
          "visual": "prev=[1], curr=[2]\n[1|NULL]  [2|→] → [3|NULL]\n    ↑      ↑\n   prev  curr",
          "note": "1 now points to NULL"
        },
        {
          "step": 3,
          "label": "Iteration 2",
          "visual": "prev=[2], curr=[3]\n[1|NULL] ← [2|←]  [3|NULL]\n                   ↑\n                 curr",
          "note": "2 now points to 1"
        },
        {
          "step": 4,
          "label": "Final",
          "visual": "HEAD → [3|→] → [2|→] → [1|NULL]",
          "note": "head = prev (reversed!)"
        }
      ]
    },
    {
      "id": "two-pointer-technique",
      "title": "Two Pointer (Slow & Fast)",
      "type": "diagram",
      "description": "Finding middle element",
      "content": {
        "steps": [
          "List: [1] → [2] → [3] → [4] → [5]",
          "",
          "Start: slow=1, fast=1",
          "Step 1: slow=2, fast=3",
          "Step 2: slow=3, fast=5",
          "Step 3: fast.next = NULL, stop!",
          "",
          "Middle = slow = 3"
        ],
        "note": "Fast moves 2x speed, so when fast reaches end, slow is at middle"
      }
    },
    {
      "id": "cycle-detection",
      "title": "Floyd's Cycle Detection",
      "type": "diagram",
      "description": "How tortoise and hare detect cycles",
      "content": {
        "visual": [
          "[1] → [2] → [3] → [4]",
          "              ↑     ↓",
          "              └─[5]←┘",
          "",
          "slow: 1 → 2 → 3 → 4 → 5 → 3 → 4",
          "fast: 1 → 3 → 5 → 4 → 3 → 5 → 4",
          "",
          "They meet at node 4! Cycle exists."
        ],
        "note": "If fast reaches NULL, no cycle. If slow==fast, cycle detected."
      }
    }
  ]
}
