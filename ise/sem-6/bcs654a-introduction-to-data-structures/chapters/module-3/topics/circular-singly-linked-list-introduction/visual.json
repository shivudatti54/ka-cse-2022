    {
      "id": "d3",
      "title": "List Reversal Process",
      "type": "sequence",
      "content": {
        "steps": [
          {
            "step": 1,
            "description": "Initialize: prev = NULL, current = head, next = NULL"
          },
          {
            "step": 2,
            "description": "While current != NULL: store next = current->next"
          },
          {
            "step": 3,
            "description": "Reverse: current->next = prev"
          },
          {
            "step": 4,
            "description": "Move pointers: prev = current, current = next"
          },
          {
            "step": 5,
            "description": "Finally: head = prev"
          }
        ]
      }
    },
