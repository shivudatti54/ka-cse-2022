{
  "topicId": "water-borne-diseases-water-induced-diseases",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "Which of the following is NOT a water-borne disease?",
      "options": [
        {
          "key": "A",
          "text": "Cholera"
        },
        {
          "key": "B",
          "text": "Malaria"
        },
        {
          "key": "C",
          "text": "Typhoid"
        },
        {
          "key": "D",
          "text": "Hepatitis A"
        }
      ],
      "correctAnswer": "Malaria",
      "explanation": "Malaria is a water-induced disease transmitted by Anopheles mosquitoes that breed in water, not directly through contaminated water consumption.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "The causative organism of Cholera is:",
      "options": [
        {
          "key": "A",
          "text": "Salmonella typhi"
        },
        {
          "key": "B",
          "text": "Vibrio cholerae"
        },
        {
          "key": "C",
          "text": "Escherichia coli"
        },
        {
          "key": "D",
          "text": "Shigella dysenteriae"
        }
      ],
      "correctAnswer": "Vibrio cholerae",
      "explanation": "Cholera is caused by Vibrio cholerae bacteria, specifically serogroups O1 and O139, which produce cholera toxin.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "Which disease is transmitted through the fecal-oral route?",
      "options": [
        {
          "key": "A",
          "text": "Malaria"
        },
        {
          "key": "B",
          "text": "Dengue"
        },
        {
          "key": "C",
          "text": "Amoebiasis"
        },
        {
          "key": "D",
          "text": "Filariasis"
        }
      ],
      "correctAnswer": "Amoebiasis",
      "explanation": "Amoebiasis (caused by Entamoeba histolytica) is transmitted via fecal-oral route through contaminated water and food.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-4",
      "question": "The vector for Dengue fever breeds in:",
      "options": [
        {
          "key": "A",
          "text": "Running water"
        },
        {
          "key": "B",
          "text": "Stagnant water"
        },
        {
          "key": "C",
          "text": "Sea water"
        },
        {
          "key": "D",
          "text": "River water"
        }
      ],
      "correctAnswer": "Stagnant water",
      "explanation": "Aedes aegypti mosquitoes breed in stagnant water found in containers, tires, flower pots, and other artificial containers.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-5",
      "question": "Which parasite causes Giardiasis?",
