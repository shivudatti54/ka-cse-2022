        {
          "key": "A",
          "text": "Calcium"
        },
        {
          "key": "B",
          "text": "Magnesium"
        },
        {
          "key": "C",
          "text": "Carbon"
        },
        {
          "key": "D",
          "text": "Phosphorus"
        }
      ],
      "correctAnswer": "Calcium",
      "explanation": "Bone char contains calcium compounds that can exchange with fluoride ions, reducing fluoride concentration.",
      "difficulty": "hard"
    },
    {
