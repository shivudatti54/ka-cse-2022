{
  "topicId": "fluoride-problem-in-drinking-water",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "The optimal fluoride concentration in drinking water for preventing dental caries is:",
      "options": [
        {
          "key": "A",
          "text": "0.1-0.5 mg/L"
        },
        {
          "key": "B",
          "text": "0.5-1.5 mg/L"
        },
        {
          "key": "C",
          "text": "2.0-3.0 mg/L"
        },
        {
          "key": "D",
          "text": "5.0-6.0 mg/L"
        }
      ],
      "correctAnswer": "0.5-1.5 mg/L",
      "explanation": "WHO and BIS recommend 0.5-1.5 mg/L as the optimal range for dental health benefits without causing fluorosis.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "Fluorosis is caused by:",
      "options": [
        {
          "key": "A",
          "text": "Excessive calcium intake"
        },
        {
          "key": "B",
          "text": "Excessive fluoride intake"
        },
        {
          "key": "C",
          "text": "Deficiency of iron"
        },
        {
          "key": "D",
          "text": "Excessive chlorine"
        }
      ],
      "correctAnswer": "Excessive fluoride intake",
      "explanation": "Fluorosis occurs due to prolonged intake of water/food containing fluoride above recommended limits.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "Dental fluorosis primarily affects:",
      "options": [
        {
          "key": "A",
          "text": "Roots of teeth"
        },
        {
          "key": "B",
          "text": "Enamel of teeth"
        },
        {
          "key": "C",
          "text": "Gums"
        },
        {
          "key": "D",
          "text": "Jaw bone"
        }
      ],
      "correctAnswer": "Enamel of teeth",
      "explanation": "Dental fluorosis affects tooth enamel during development, causing white spots, staining, and pitting.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-4",
      "question": "Skeletal fluorosis affects:",
      "options": [
        {
          "key": "A",
          "text": "Teeth only"
        },
        {
          "key": "B",
          "text": "Bones and joints"
        },
        {
          "key": "C",
          "text": "Heart"
        },
        {
          "key": "D",
          "text": "Liver"
        }
      ],
      "correctAnswer": "Bones and joints",
      "explanation": "Skeletal fluorosis causes hardening of bones, joint pain, stiffness, and in severe cases, spine rigidity.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-5",
      "question": "According to BIS (IS 10500:2012), the permissible limit of fluoride in drinking water is:",
      "options": [
        {
          "key": "A",
          "text": "0.5 mg/L"
        },
        {
          "key": "B",
          "text": "1.0 mg/L"
        },
        {
          "key": "C",
          "text": "1.5 mg/L"
        },
        {
          "key": "D",
          "text": "3.0 mg/L"
        }
      ],
      "correctAnswer": "1.5 mg/L",
      "explanation": "Bureau of Indian Standards specifies 1.5 mg/L as the acceptable limit for fluoride in drinking water.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-6",
      "question": "The Nalgonda technique uses which chemicals for defluoridation?",
      "options": [
        {
          "key": "A",
          "text": "Sodium chloride and lime"
        },
        {
          "key": "B",
          "text": "Aluminum sulfate and lime"
        },
        {
          "key": "C",
          "text": "Calcium carbonate and soda"
        },
        {
          "key": "D",
          "text": "Iron sulfate and chlorine"
        }
      ],
      "correctAnswer": "Aluminum sulfate and lime",
      "explanation": "Nalgonda technique uses alum (aluminum sulfate) and lime to precipitate fluoride as insoluble aluminum fluoride.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-7",
      "question": "Which of the following is NOT a defluoridation method?",
      "options": [
        {
          "key": "A",
          "text": "Activated alumina adsorption"
        },
        {
          "key": "B",
          "text": "Reverse osmosis"
        },
        {
          "key": "C",
          "text": "Chlorination"
        },
        {
          "key": "D",
          "text": "Ion exchange"
        }
      ],
      "correctAnswer": "Chlorination",
      "explanation": "Chlorination is used for disinfection, not defluoridation. Other methods effectively remove fluoride.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-8",
      "question": "The main source of fluoride in groundwater is:",
      "options": [
        {
          "key": "A",
          "text": "Industrial waste"
        },
        {
          "key": "B",
          "text": "Agricultural runoff"
        },
        {
          "key": "C",
          "text": "Natural weathering of rocks"
        },
        {
          "key": "D",
          "text": "Atmospheric deposition"
        }
      ],
      "correctAnswer": "Natural weathering of rocks",
      "explanation": "Fluoride enters groundwater mainly through natural geological processes dissolving fluoride-containing minerals.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-9",
      "question": "Which Indian state is NOT typically associated with high fluoride groundwater?",
      "options": [
        {
          "key": "A",
          "text": "Rajasthan"
        },
        {
          "key": "B",
          "text": "Kerala"
        },
        {
          "key": "C",
          "text": "Gujarat"
        },
        {
          "key": "D",
          "text": "Andhra Pradesh"
        }
      ],
      "correctAnswer": "Kerala",
      "explanation": "Kerala generally has low to moderate fluoride levels, while Rajasthan, Gujarat, and AP have endemic fluorosis areas.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-10",
      "question": "Fluoride concentration in water increases with:",
      "options": [
        {
          "key": "A",
          "text": "Lower pH (acidic)"
        },
        {
          "key": "B",
          "text": "Higher pH (alkaline)"
        },
        {
          "key": "C",
          "text": "Neutral pH"
        },
        {
          "key": "D",
          "text": "Temperature decrease"
        }
      ],
      "correctAnswer": "Higher pH (alkaline)",
      "explanation": "In alkaline conditions, fluoride ions become more soluble and mobile, increasing concentration in water.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-11",
      "question": "Activated alumina defluoridation works by:",
      "options": [
        {
          "key": "A",
          "text": "Chemical precipitation"
        },
        {
          "key": "B",
          "text": "Adsorption"
        },
        {
          "key": "C",
          "text": "Ion exchange only"
        },
        {
          "key": "D",
          "text": "Filtration"
        }
      ],
      "correctAnswer": "Adsorption",
      "explanation": "Activated alumina (Al2O3) adsorbs fluoride ions on its surface. It can be regenerated using NaOH.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-12",
      "question": "The age group most vulnerable to dental fluorosis is:",
      "options": [
        {
          "key": "A",
          "text": "1-4 years"
        },
        {
          "key": "B",
          "text": "10-15 years"
        },
        {
          "key": "C",
          "text": "20-30 years"
        },
        {
          "key": "D",
          "text": "50-60 years"
        }
      ],
      "correctAnswer": "1-4 years",
      "explanation": "Children aged 1-4 are most vulnerable as permanent teeth develop during this period.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-13",
      "question": "A condition with fluoride level below 0.5 mg/L leads to:",
      "options": [
        {
          "key": "A",
          "text": "Fluorosis"
        },
        {
          "key": "B",
          "text": "Goiter"
        },
        {
          "key": "C",
          "text": "Dental caries"
        },
        {
          "key": "D",
          "text": "Osteoporosis"
        }
      ],
      "correctAnswer": "Dental caries",
      "explanation": "Low fluoride levels (<0.5 mg/L) reduce the protective effect on tooth enamel, increasing cavity risk.",
      "difficulty": "medium"
    },
    {
