        },
        {
          "key": "D",
          "text": "Cloneable"
        }
      ],
      "correctAnswer": "Remote",
      "explanation": "A remote interface must extend java.rmi.Remote to indicate its methods can be invoked remotely.",
      "difficulty": "easy"
    },
    {
