          "text": "Runtime Method Integration"
        },
        {
          "key": "D",
          "text": "Remote Messaging Interface"
        }
      ],
      "correctAnswer": "Remote Method Invocation",
      "explanation": "RMI stands for Remote Method Invocation, a Java API for distributed computing.",
      "difficulty": "easy"
    },
    {
