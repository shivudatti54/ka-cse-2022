{
  "topicId": "multicasting-routing-mospf",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "In multicast routing, what is the main advantage over unicast?",
      "options": [
        {
          "key": "A",
          "text": "Faster delivery"
        },
        {
          "key": "B",
          "text": "Reduced bandwidth usage"
        },
        {
          "key": "C",
          "text": "Simpler addressing"
        },
        {
          "key": "D",
          "text": "Lower latency"
        }
      ],
      "correctAnswer": "Reduced bandwidth usage",
      "explanation": "Multicast sends a single packet replicated at branches, avoiding separate streams to each receiver, thus saving bandwidth.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "MOSPF stands for:",
      "options": [
        {
          "key": "A",
          "text": "Multiple Open Shortest Path First"
        },
        {
          "key": "B",
          "text": "Multicast Open Shortest Path First"
        },
        {
          "key": "C",
          "text": "Mobile Open Shortest Path First"
        },
        {
          "key": "D",
          "text": "Main Open Shortest Path First"
        }
      ],
      "correctAnswer": "Multicast Open Shortest Path First",
      "explanation": "MOSPF is the multicast extension of the OSPF unicast routing protocol.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "Which protocol is used by hosts to inform routers about multicast group memberships?",
      "options": [
        {
          "key": "A",
          "text": "ARP"
        },
        {
          "key": "B",
          "text": "IGMP"
        },
        {
          "key": "C",
          "text": "ICMP"
        },
        {
          "key": "D",
          "text": "DHCP"
        }
      ],
      "correctAnswer": "IGMP",
      "explanation": "Internet Group Management Protocol (IGMP) manages host membership in multicast groups.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-4",
      "question": "What is MBONE?",
      "options": [
        {
          "key": "A",
          "text": "Multicast Base"
        },
        {
          "key": "B",
          "text": "Multicast Backbone"
        },
        {
          "key": "C",
          "text": "Mobile Backbone"
        },
        {
          "key": "D",
          "text": "Multiple Backbone"
        }
      ],
      "correctAnswer": "Multicast Backbone",
      "explanation": "MBONE is the virtual network supporting IP multicasting over the Internet.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-5",
      "question": "Reverse Path Broadcasting (RPB) ensures:",
      "options": [
        {
          "key": "A",
          "text": "Fastest delivery"
        },
        {
          "key": "B",
          "text": "Loop prevention"
        },
        {
          "key": "C",
          "text": "Maximum bandwidth"
        },
        {
          "key": "D",
          "text": "Minimum delay"
        }
      ],
      "correctAnswer": "Loop prevention",
      "explanation": "RPB forwards packets only on interfaces toward receivers, preventing loops and duplicates.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-6",
      "question": "Which multicast routing approach uses flood-and-prune?",
      "options": [
        {
          "key": "A",
          "text": "Sparse Mode"
        },
        {
          "key": "B",
          "text": "Dense Mode"
        },
        {
          "key": "C",
          "text": "Core-based"
        },
        {
          "key": "D",
          "text": "Source-specific"
        }
      ],
      "correctAnswer": "Dense Mode",
      "explanation": "Dense Mode protocols flood the network and prune branches without receivers.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-7",
      "question": "MOSPF uses what type of LSA for group membership?",
      "options": [
