        },
        {
          "key": "D",
          "text": "Summary LSA"
        }
      ],
      "correctAnswer": "Group Membership LSA",
      "explanation": "MOSPF introduces Group Membership LSAs to distribute multicast group information.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-8",
      "question": "A shared tree in multicast routing is rooted at:",
      "options": [
        {
          "key": "A",
          "text": "Source"
