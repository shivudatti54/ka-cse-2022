        {
          "key": "C",
          "text": "Rendezvous Point"
        },
        {
          "key": "D",
          "text": "Core Router"
        }
      ],
      "correctAnswer": "Rendezvous Point",
      "explanation": "Shared trees are rooted at a Rendezvous Point (RP) that connects sources and receivers.",
