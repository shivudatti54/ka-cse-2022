      "difficulty": "medium"
    },
    {
      "id": "mcq-10",
      "question": "The Steiner Tree problem in multicast routing is:",
      "options": [
        {
          "key": "A",
          "text": "NP-complete"
        },
        {
          "key": "B",
          "text": "Linear time"
        },
        {
          "key": "C",
          "text": "Polynomial time"
        },
        {
          "key": "D",
          "text": "Constant time"
        }
      ],
      "correctAnswer": "NP-complete",
      "explanation": "Finding minimum-cost tree connecting all receivers is computationally expensive (NP-complete).",
      "difficulty": "hard"
    },
    {
      "id": "mcq-11",
      "question": "Tunneling in MBONE is used to:",
      "options": [
