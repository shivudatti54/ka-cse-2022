          "key": "C",
          "text": "BCD arithmetic"
        },
        {
          "key": "D",
          "text": "Modular arithmetic"
        }
      ],
      "correctAnswer": "One's complement",
      "explanation": "RFC 1071 specifies the use of one's complement arithmetic for Internet checksum calculation.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-3",
      "question": "What is the result when receiver's checksum verification produces all 1s (FFFFH)?",
      "options": [
        {
          "key": "A",
          "text": "Error detected"
        },
        {
          "key": "B",
          "text": "Data corrupted"
        },
        {
          "key": "C",
          "text": "Data is error-free"
        },
        {
          "key": "D",
          "text": "Retransmission required"
        }
      ],
      "correctAnswer": "Data is error-free",
      "explanation": "In one's complement addition, if the final sum equals all 1s, no error is detected.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-4",
