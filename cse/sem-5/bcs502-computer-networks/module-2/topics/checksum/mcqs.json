          "text": "Added back to MSB (end-around carry)"
        },
        {
          "key": "D",
          "text": "Negated"
        }
      ],
      "correctAnswer": "Added back to MSB (end-around carry)",
      "explanation": "In one's complement addition, overflow is cycled back and added to the result.",
      "difficulty": "medium"
