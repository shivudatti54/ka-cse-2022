{
  "topicId": "the-phong-lighting-model",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "The Phong Lighting Model was introduced in which year?",
      "options": [
        {
          "key": "A",
          "text": "1973"
        },
        {
          "key": "B",
          "text": "1975"
        },
        {
          "key": "C",
          "text": "1977"
        },
        {
          "key": "D",
          "text": "1980"
        }
      ],
      "correctAnswer": "1975",
      "explanation": "Bui Tuong Phong introduced this illumination model in 1975.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "In the Phong model, which component simulates light scattered from all directions?",
      "options": [
        {
          "key": "A",
          "text": "Specular"
        },
        {
          "key": "B",
          "text": "Diffuse"
        },
        {
          "key": "C",
          "text": "Ambient"
        },
        {
          "key": "D",
          "text": "Reflective"
        }
      ],
      "correctAnswer": "Ambient",
      "explanation": "Ambient light simulates scattered light that comes from all directions uniformly.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "Which vector in Phong model represents the direction from surface to viewer?",
      "options": [
        {
          "key": "A",
          "text": "L"
        },
        {
          "key": "B",
          "text": "N"
        },
        {
          "key": "C",
          "text": "R"
        },
        {
          "key": "D",
          "text": "V"
        }
      ],
      "correctAnswer": "V",
      "explanation": "V is the view vector pointing from the surface toward the observer's eye.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-4",
      "question": "In the Phong reflection formula, what does R represent?",
      "options": [
        {
          "key": "A",
          "text": "Refraction vector"
        },
        {
          "key": "B",
          "text": "Reflection vector"
        },
        {
          "key": "C",
          "text": "Refracted light"
        },
        {
          "key": "D",
          "text": "Radiosity"
        }
      ],
      "correctAnswer": "Reflection vector",
      "explanation": "R is the reflection direction calculated using R = 2(N·L)N - L.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-5",
      "question": "The shininess exponent in the Phong model controls:",
      "options": [
        {
          "key": "A",
          "text": "Light intensity"
        },
        {
          "key": "B",
          "text": "Size of specular highlight"
        },
        {
          "key": "C",
          "text": "Color of light"
        },
        {
          "key": "D",
          "text": "Ambient light"
        }
      ],
      "correctAnswer": "Size of specular highlight",
      "explanation": "Higher shininess values produce smaller, sharper specular highlights.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-6",
      "question": "If L·N = -0.5, what value is used in Phong diffuse calculation?",
      "options": [
        {
          "key": "A",
          "text": "-0.5"
        },
        {
          "key": "B",
          "text": "0"
        },
        {
          "key": "C",
          "text": "0.5"
        },
        {
          "key": "D",
          "text": "-1"
        }
      ],
      "correctAnswer": "0",
      "explanation": "max(L·N, 0) = max(-0.5, 0) = 0, as light behind surface contributes no diffuse light.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-7",
      "question": "Which Phong component is responsible for shiny highlights on surfaces?",
      "options": [
        {
          "key": "A",
          "text": "Ambient"
        },
        {
          "key": "B",
          "text": "Diffuse"
        },
        {
          "key": "C",
          "text": "Specular"
        },
        {
          "key": "D",
          "text": "Transmissive"
        }
      ],
      "correctAnswer": "Specular",
      "explanation": "The specular component creates bright highlights when light reflects toward the viewer.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-8",
      "question": "The diffuse reflection follows which law?",
      "options": [
        {
          "key": "A",
          "text": "Snell's law"
        },
        {
          "key": "B",
          "text": "Lambert's cosine law"
        },
        {
          "key": "C",
          "text": "Beer-Lambert law"
        },
        {
          "key": "D",
          "text": "Cauchy's law"
        }
      ],
      "correctAnswer": "Lambert's cosine law",
      "explanation": "Diffuse intensity is proportional to cos(θ) = L·N, following Lambert's law.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-9",
      "question": "For a perfectly smooth mirror surface, the shininess exponent should be:",
      "options": [
        {
          "key": "A",
          "text": "0"
        },
        {
          "key": "B",
          "text": "1"
        },
        {
          "key": "C",
          "text": "10"
        },
        {
          "key": "D",
          "text": "Very large (e.g., 100+)"
        }
      ],
      "correctAnswer": "Very large (e.g., 100+)",
      "explanation": "High shininess creates concentrated specular highlights typical of mirrors.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-10",
      "question": "What is the range of reflection coefficients Ka, Kd, Ks?",
      "options": [
        {
          "key": "A",
          "text": "-1 to 1"
        },
        {
          "key": "B",
          "text": "0 to 1"
        },
        {
          "key": "C",
          "text": "0 to 100"
        },
        {
          "key": "D",
          "text": "-∞ to +∞"
        }
      ],
      "correctAnswer": "0 to 1",
      "explanation": "Reflection coefficients represent fraction of light reflected, ranging from 0 to 1.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-11",
      "question": "The Phong model is classified as a:",
      "options": [
        {
          "key": "A",
          "text": "Global illumination model"
        },
        {
          "key": "B",
          "text": "Local illumination model"
        },
        {
          "key": "C",
          "text": "Ray tracing model"
        },
        {
          "key": "D",
          "text": "Radiosity model"
        }
      ],
      "correctAnswer": "Local illumination model",
      "explanation": "Phong model only considers direct lighting, ignoring inter-reflections between surfaces.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-12",
      "question": "When the view vector V aligns with reflection vector R, what happens?",
      "options": [
        {
          "key": "A",
          "text": "Minimum illumination"
        },
        {
          "key": "B",
          "text": "Maximum specular highlight"
        },
        {
          "key": "C",
          "text": "No change"
        },
        {
          "key": "D",
          "text": "Diffuse only"
        }
      ],
      "correctAnswer": "Maximum specular highlight",
      "explanation": "When V = R, R·V = 1, giving maximum specular component KsIs.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-13",
      "question": "Which vector must be normalized in Phong calculations?",
      "options": [
        {
          "key": "A",
          "text": "L, N, R, and V"
        },
        {
          "key": "B",
          "text": "Only N"
        },
        {
          "key": "C",
          "text": "Only L and N"
        },
        {
          "key": "D",
          "text": "L and V only"
        }
      ],
      "correctAnswer": "L, N, R, and V",
      "explanation": "All direction vectors should be unit vectors for correct dot product calculations.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-14",
      "question": "What type of surface produces no specular reflection?",
      "options": [
        {
          "key": "A",
          "text": "Shiny surface"
        },
        {
          "key": "B",
          "text": "Matte surface"
        },
        {
          "key": "C",
          "text": "Metallic surface"
        },
        {
          "key": "D",
          "text": "Polished surface"
        }
      ],
      "correctAnswer": "Matte surface",
      "explanation": "Matte surfaces (like chalk) have Ks = 0, showing only ambient and diffuse reflection.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-15",
      "question": "The term (R·V)^n in Phong model represents:",
      "options": [
        {
          "key": "A",
          "text": "Diffuse factor"
        },
        {
          "key": "B",
          "text": "Specular highlight"
        },
        {
          "key": "C",
          "text": "Ambient term"
        },
        {
          "key": "D",
          "text": "Shadow factor"
        }
      ],
      "correctAnswer": "Specular highlight",
      "explanation": "(R·V)^n is the specular component, decaying based on angle and shininess n.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-16",
      "question": "In Phong model, if N·L = 0.707, what is diffuse contribution assuming Kd=1, Id=1?",
      "options": [
        {
          "key": "A",
          "text": "0.293"
        },
        {
          "key": "B",
          "text": "0.707"
        },
        {
          "key": "C",
          "text": "1.0"
        },
        {
          "key": "D",
          "text": "0"
        }
      ],
      "correctAnswer": "0.707",
      "explanation": "Diffuse = Kd × Id × max(L·N, 0) = 1 × 1 × 0.707 = 0.707.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-17",
      "question": "The reflection vector R is computed using:",
      "options": [
        {
          "key": "A",
          "text": "R = L - 2(N·L)N"
        },
        {
          "key": "B",
          "text": "R = 2(N·L)N - L"
        },
        {
          "key": "C",
          "text": "R = N × L"
        },
        {
          "key": "D",
          "text": "R = L + N"
        }
      ],
      "correctAnswer": "R = 2(N·L)N - L",
      "explanation": "This formula reflects L about N to get the reflection direction.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-18",
      "question": "Which is NOT a property of ambient light in Phong model?",
      "options": [
        {
          "key": "A",
          "text": "Independent of surface normal"
        },
        {
          "key": "B",
          "text": "Independent of viewer position"
        },
        {
          "key": "C",
          "text": "Depends on light direction"
        },
        {
          "key": "D",
          "text": "Constant everywhere"
        }
      ],
      "correctAnswer": "Depends on light direction",
      "explanation": "Ambient light is uniform and does not depend on light direction or surface orientation.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-19",
      "question": "For a rough surface, the shininess exponent should be:",
      "options": [
        {
          "key": "A",
          "text": "Very high"
        },
        {
          "key": "B",
          "text": "Very low or zero"
        },
        {
          "key": "C",
          "text": "Negative"
        },
        {
          "key": "D",
          "text": "Infinite"
        }
      ],
      "correctAnswer": "Very low or zero",
      "explanation": "Low shininess creates broad, diffuse specular highlights typical of rough surfaces.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-20",
      "question": "The Phong model cannot simulate:",
      "options": [
        {
          "key": "A",
          "text": "Shiny highlights"
        },
        {
          "key": "B",
          "text": "Surface color"
        },
        {
          "key": "C",
          "text": "Shadows between objects"
        },
        {
          "key": "D",
          "text": "Light intensity variation"
        }
      ],
      "correctAnswer": "Shadows between objects",
      "explanation": "As a local model, Phong cannot simulate shadows or inter-object reflections.",
      "difficulty": "medium"
    }
  ]
}
