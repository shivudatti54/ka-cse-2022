    {
      "id": "mcq-4",
      "question": "What problem does double buffering solve?",
      "options": [
        {
          "key": "A",
          "text": "Color banding"
        },
        {
          "key": "B",
          "text": "Screen flicker"
        },
        {
          "key": "C",
          "text": "Memory overflow"
        },
        {
          "key": "D",
          "text": "Slow rendering"
        }
      ],
      "correctAnswer": "Screen flicker",
      "explanation": "Double buffering uses two buffers - one displayed while drawing to the other, then swaps to eliminate visible drawing artifacts.",
      "difficulty": "medium"
    },
    {
