    {
      "id": "mcq-1",
      "question": "What is the primary purpose of a frame buffer?",
      "options": [
        {
          "key": "A",
          "text": "To store CPU instructions"
        },
        {
          "key": "B",
          "text": "To store image data for display"
        },
        {
          "key": "C",
          "text": "To process keyboard input"
        },
        {
          "key": "D",
          "text": "To manage memory allocation"
        }
      ],
      "correctAnswer": "To store image data for display",
      "explanation": "Frame buffer is dedicated memory that holds pixel color values to be displayed on screen.",
      "difficulty": "easy"
    },
    {
