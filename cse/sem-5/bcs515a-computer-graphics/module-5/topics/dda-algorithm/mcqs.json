{
  "topicId": "dda-algorithm",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "DDA in computer graphics stands for:",
      "options": [
        {
          "key": "A",
          "text": "Digital Differential Analyzer"
        },
        {
          "key": "B",
          "text": "Digital Data Analyzer"
        },
        {
          "key": "C",
          "text": "Digital Drawing Algorithm"
        },
        {
          "key": "D",
          "text": "Direct Data Access"
        }
      ],
      "correctAnswer": "Digital Differential Analyzer",
      "explanation": "DDA stands for Digital Differential Analyzer, originally used in analog computers for solving differential equations.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "In DDA algorithm, if slope m = 0.5, which direction is incremented?",
      "options": [
        {
          "key": "A",
          "text": "y-direction only"
        },
        {
          "key": "B",
          "text": "x-direction only"
        },
        {
          "key": "C",
          "text": "Both x and y"
        },
        {
          "key": "D",
          "text": "Neither"
        }
      ],
      "correctAnswer": "x-direction only",
      "explanation": "When |m| < 1, we step in x-direction and increment y by m (0.5).",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "What type of arithmetic does DDA algorithm primarily use?",
      "options": [
        {
          "key": "A",
          "text": "Integer arithmetic"
        },
        {
          "key": "B",
          "text": "Floating-point arithmetic"
        },
        {
          "key": "C",
          "text": "Binary arithmetic"
        },
        {
          "key": "D",
          "text": "Hexadecimal arithmetic"
        }
      ],
      "correctAnswer": "Floating-point arithmetic",
      "explanation": "DDA uses floating-point arithmetic for calculating intermediate pixel positions, which is computationally expensive.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-4",
      "question": "For a line from (2,3) to (10,11), what is the slope?",
      "options": [
        {
          "key": "A",
          "text": "0.8"
        },
        {
          "key": "B",
          "text": "1.0"
        },
        {
          "key": "C",
          "text": "1.5"
        },
        {
          "key": "D",
          "text": "2.0"
        }
      ],
      "correctAnswer": "1.0",
      "explanation": "m = (11-3)/(10-2) = 8/8 = 1.0",
      "difficulty": "medium"
    },
    {
      "id": "mcq-5",
      "question": "When is DDA algorithm preferred over Bresenham's algorithm?",
      "options": [
        {
          "key": "A",
          "text": "For hardware with integer-only support"
        },
        {
          "key": "B",
          "text": "When floating-point units are available and simplicity is prioritized"
        },
        {
          "key": "C",
          "text": "For anti-aliased lines"
        },
        {
          "key": "D",
          "text": "Never"
        }
      ],
      "correctAnswer": "When floating-point units are available and simplicity is prioritized",
      "explanation": "DDA is conceptually simpler and easier to understand when floating-point hardware is available.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-6",
      "question": "The main drawback of DDA algorithm is:",
      "options": [
        {
          "key": "A",
          "text": "Complex implementation"
        },
        {
          "key": "B",
          "text": "Accumulation of rounding errors"
        },
        {
          "key": "C",
          "text": "Slow speed"
        },
        {
          "key": "D",
          "text": "Cannot draw diagonal lines"
        }
      ],
      "correctAnswer": "Accumulation of rounding errors",
      "explanation": "Due to floating-point operations and rounding, errors accumulate especially in longer lines.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-7",
      "question": "In DDA, if |m| > 1, we should:",
      "options": [
        {
          "key": "A",
          "text": "Increment x by 1"
        },
        {
          "key": "B",
          "text": "Increment y by 1"
        },
        {
          "key": "C",
          "text": "Increment both x and y by 1"
        },
        {
          "key": "D",
          "text": "Decrement both"
        }
      ],
      "correctAnswer": "Increment y by 1",
      "explanation": "When slope > 1, stepping in y-direction gives better pixel density; x is incremented by 1/m.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-8",
      "question": "What is the space complexity of DDA algorithm?",
      "options": [
        {
          "key": "A",
          "text": "O(1)"
        },
        {
          "key": "B",
          "text": "O(n)"
        },
        {
          "key": "C",
          "text": "O(n²)"
        },
        {
          "key": "D",
          "text": "O(log n)"
        }
      ],
      "correctAnswer": "O(1)",
      "explanation": "DDA uses only a few variables regardless of line length.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-9",
      "question": "Which algorithm is faster for line drawing: DDA or Bresenham?",
      "options": [
        {
          "key": "A",
          "text": "DDA"
        },
        {
          "key": "B",
          "text": "Bresenham"
        },
        {
          "key": "C",
          "text": "Both are equal"
        },
        {
          "key": "D",
          "text": "Depends on line length"
        }
      ],
      "correctAnswer": "Bresenham",
      "explanation": "Bresenham uses only integer arithmetic which is faster than floating-point operations.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-10",
      "question": "DDA algorithm is used in:",
      "options": [
        {
          "key": "A",
          "text": "Vector graphics"
        },
        {
          "key": "B",
          "text": "Raster graphics"
        },
        {
          "key": "C",
          "text": "3D graphics"
        },
        {
          "key": "D",
          "text": "Text rendering"
        }
      ],
      "correctAnswer": "Raster graphics",
      "explanation": "DDA converts vector line definitions to raster (pixel-based) display.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-11",
      "question": "For a horizontal line, the slope is:",
      "options": [
        {
          "key": "A",
          "text": "0"
        },
        {
          "key": "B",
          "text": "1"
        },
        {
          "key": "C",
          "text": "Undefined"
        },
        {
          "key": "D",
          "text": "Infinite"
        }
      ],
      "correctAnswer": "0",
      "explanation": "Horizontal lines have Δy = 0, so m = 0.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-12",
      "question": "The increment value in DDA is calculated as:",
      "options": [
        {
          "key": "A",
          "text": "1/m"
        },
        {
          "key": "B",
          "text": "m"
        },
        {
          "key": "C",
          "text": "1"
        },
        {
          "key": "D",
          "text": "m²"
        }
      ],
      "correctAnswer": "1/m",
      "explanation": "When stepping in the direction with larger change, the other coordinate increments by 1/m to maintain correct slope.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-13",
      "question": "Rounding in DDA is done to:",
      "options": [
        {
          "key": "A",
          "text": "Improve speed"
        },
        {
          "key": "B",
          "text": "Get integer pixel coordinates"
        },
        {
          "key": "C",
          "text": "Reduce memory"
        },
        {
          "key": "D",
          "text": "Increase accuracy"
        }
      ],
      "correctAnswer": "Get integer pixel coordinates",
      "explanation": "Pixel positions must be integers (whole pixels) for display on screen.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-14",
      "question": "What is the incremental approach in DDA?",
      "options": [
        {
          "key": "A",
          "text": "Calculate entire line at once"
        },
        {
          "key": "B",
          "text": "Add fixed values at each step"
        },
        {
          "key": "C",
          "text": "Use recursion"
        },
        {
          "key": "D",
          "text": "Skip pixels"
        }
      ],
      "correctAnswer": "Add fixed values at each step",
      "explanation": "Each pixel position is calculated by adding fixed increments to the previous position.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-15",
      "question": "DDA algorithm was introduced in:",
      "options": [
        {
          "key": "A",
          "text": "1990s"
        },
        {
          "key": "B",
          "text": "1980s"
        },
        {
          "key": "C",
          "text": "1950s"
        },
        {
          "key": "D",
          "text": "1970s"
        }
      ],
      "correctAnswer": "1950s",
      "explanation": "DDA originated from analog computers in the 1950s for solving differential equations.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-16",
      "question": "For a line with slope 2.5, what is the x-increment?",
      "options": [
        {
          "key": "A",
          "text": "0.4"
        },
        {
          "key": "B",
          "text": "0.5"
        },
        {
          "key": "C",
          "text": "2.5"
        },
        {
          "key": "D",
          "text": "1.0"
        }
      ],
      "correctAnswer": "0.4",
      "explanation": "x-increment = 1/m = 1/2.5 = 0.4",
      "difficulty": "medium"
    },
    {
      "id": "mcq-17",
      "question": "DDA is more accurate than Bresenham for:",
      "options": [
        {
          "key": "A",
          "text": "All lines"
        },
        {
          "key": "B",
          "text": "Short lines only"
        },
        {
          "key": "C",
          "text": "Neither"
        },
        {
          "key": "D",
          "text": "Both are equally accurate"
        }
      ],
      "correctAnswer": "Short lines only",
      "explanation": "For short lines, floating-point precision in DDA may give visually smoother results.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-18",
      "question": "The term 'raster' in computer graphics refers to:",
      "options": [
        {
          "key": "A",
          "text": "Vector points"
        },
        {
          "key": "B",
          "text": "Pixel grid"
        },
        {
          "key": "C",
          "text": "Color model"
        },
        {
          "key": "D",
          "text": "Display resolution"
        }
      ],
      "correctAnswer": "Pixel grid",
      "explanation": "Raster graphics represents images as a grid of pixels.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-19",
      "question": "Why is DDA considered computationally expensive?",
      "options": [
        {
          "key": "A",
          "text": "Too many variables"
        },
        {
          "key": "B",
          "text": "Floating-point operations"
        },
        {
          "key": "C",
          "text": "Complex loops"
        },
        {
          "key": "D",
          "text": "Memory access"
        }
      ],
      "correctAnswer": "Floating-point operations",
      "explanation": "Floating-point multiplication and division are slower than integer operations.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-20",
      "question": "Which case requires stepping in y-direction in DDA?",
      "options": [
        {
          "key": "A",
          "text": "|m| < 1"
        },
        {
          "key": "B",
          "text": "|m| > 1"
        },
        {
          "key": "C",
          "text": "m = 1"
        },
        {
          "key": "D",
          "text": "m = 0"
        }
      ],
      "correctAnswer": "|m| > 1",
