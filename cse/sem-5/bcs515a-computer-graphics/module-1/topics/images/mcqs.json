    {
      "id": "mcq-1",
      "question": "What does a pixel represent in a digital image?",
      "options": [
        {
          "key": "A",
          "text": "A color printer"
        },
        {
          "key": "B",
          "text": "Smallest picture element"
        },
        {
          "key": "C",
          "text": "A compression technique"
        },
        {
          "key": "D",
          "text": "An image format"
        }
      ],
      "correctAnswer": "Smallest picture element",
      "explanation": "Pixel (picture element) is the fundamental unit of a digital image with specific location and intensity/color value.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "For a 256-level grayscale image, how many bits are required per pixel?",
      "options": [
        {
          "key": "A",
          "text": "4 bits"
        },
        {
          "key": "B",
          "text": "8 bits"
        },
        {
          "key": "C",
          "text": "16 bits"
        },
        {
          "key": "D",
          "text": "24 bits"
        }
      ],
      "correctAnswer": "8 bits",
      "explanation": "256 = 2⁸, so 8 bits are needed to represent 256 different gray levels (0-255).",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "Which process converts continuous image to discrete pixels?",
      "options": [
        {
          "key": "A",
          "text": "Quantization"
        },
        {
          "key": "B",
          "text": "Sampling"
        },
        {
          "key": "C",
          "text": "Compression"
        },
        {
          "key": "D",
          "text": "Enhancement"
        }
      ],
      "correctAnswer": "Sampling",
      "explanation": "Sampling divides the continuous image into a finite grid of pixels, determining spatial resolution.",
      "difficulty": "easy"
    },
    {
