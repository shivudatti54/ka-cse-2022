{
  "topicId": "affine-transformations",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "In homogeneous coordinates, a 2D point (x, y) is represented as:",
      "options": [
        {
          "key": "A",
          "text": "(x, y, 0)"
        },
        {
          "key": "B",
          "text": "(x, y, 1)"
        },
        {
          "key": "C",
          "text": "(x, y, w)"
        },
        {
          "key": "D",
          "text": "(x, y, z)"
        }
      ],
      "correctAnswer": "(x, y, 1)",
      "explanation": "Homogeneous coordinates add an extra coordinate (usually 1) to represent 2D points, enabling transformation using 3×3 matrices.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "Which transformation preserves parallel lines?",
      "options": [
        {
          "key": "A",
          "text": "Perspective transformation"
        },
        {
          "key": "B",
          "text": "Affine transformation"
        },
        {
          "key": "C",
          "text": "Projective transformation"
        },
        {
          "key": "D",
          "text": "Curved transformation"
        }
      ],
      "correctAnswer": "Affine transformation",
      "explanation": "By definition, affine transformations preserve parallelism - parallel lines in the original remain parallel after transformation.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "The translation matrix for moving a point by (tx, ty) is:",
      "options": [
        {
          "key": "A",
          "text": "[tx ty 0; 0 0 1]"
        },
        {
          "key": "B",
          "text": "[1 0 tx; 0 1 ty; 0 0 1]"
        },
        {
          "key": "C",
          "text": "[1 0 0; tx ty 0; 0 1 1]"
        },
        {
          "key": "D",
          "text": "[tx 0 1; 0 ty 1; 0 0 0]"
        }
      ],
      "correctAnswer": "[1 0 tx; 0 1 ty; 0 0 1]",
      "explanation": "Translation matrix in homogeneous form has identity in top-left 2×2 and translation values in the third column.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-4",
      "question": "Rotation by 90° counterclockwise corresponds to which matrix?",
      "options": [
        {
          "key": "A",
          "text": "[0 -1 0; 1 0 0; 0 0 1]"
        },
        {
          "key": "B",
          "text": "[1 1 0; 0 1 0; 0 0 1]"
        },
        {
          "key": "C",
          "text": "[0 1 0; -1 0 0; 0 0 1]"
        },
        {
          "key": "D",
          "text": "[1 0 0; 0 1 0; 0 0 1]"
        }
      ],
      "correctAnswer": "[0 -1 0; 1 0 0; 0 0 1]",
      "explanation": "For 90° rotation: cos(90°)=0, sin(90°)=1, giving matrix [0 -1; 1 0].",
      "difficulty": "medium"
    },
    {
      "id": "mcq-5",
      "question": "Uniform scaling uses:",
      "options": [
        {
          "key": "A",
          "text": "sx = -sy"
        },
        {
          "key": "B",
          "text": "sx = sy"
        },
        {
          "key": "C",
          "text": "sx = 1/sy"
        },
        {
          "key": "D",
          "text": "sx + sy = 1"
        }
      ],
      "correctAnswer": "sx = sy",
      "explanation": "Uniform scaling maintains aspect ratio by using equal scale factors in both x and y directions.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-6",
      "question": "The transformation matrix for reflection about X-axis is:",
      "options": [
        {
          "key": "A",
          "text": "[-1 0 0; 0 1 0; 0 0 1]"
        },
        {
          "key": "B",
          "text": "[1 0 0; 0 -1 0; 0 0 1]"
        },
        {
          "key": "C",
          "text": "[1 0 0; 0 1 0; 0 0 -1]"
        },
        {
          "key": "D",
          "text": "[0 1 0; 1 0 0; 0 0 1]"
        }
      ],
      "correctAnswer": "[1 0 0; 0 -1 0; 0 0 1]",
      "explanation": "Reflection about X-axis negates the y-coordinate while keeping x unchanged, represented by diagonal [1, -1, 1].",
      "difficulty": "medium"
    },
    {
      "id": "mcq-7",
      "question": "What type of transformation has matrix form [1 shx 0; 0 1 0; 0 0 1]?",
      "options": [
        {
          "key": "A",
          "text": "Rotation"
        },
        {
          "key": "B",
          "text": "Scaling"
        },
        {
          "key": "C",
          "text": "X-shear"
        },
        {
          "key": "D",
          "text": "Translation"
        }
      ],
      "correctAnswer": "X-shear",
      "explanation": "This matrix shears the object along X-axis, where shx is the shear factor. The y-coordinate remains unchanged.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-8",
      "question": "Matrix multiplication for transformations is:",
      "options": [
        {
          "key": "A",
          "text": "Commutative"
        },
        {
          "key": "B",
          "text": "Associative"
        },
        {
          "key": "C",
          "text": "Both A and B"
        },
        {
          "key": "D",
          "text": "Neither"
        }
      ],
      "correctAnswer": "Associative",
      "explanation": "T1 × (T2 × T3) = (T1 × T2) × T3, but T1 × T2 ≠ T2 × T1 - order matters in transformations.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-9",
      "question": "To rotate about a pivot point P(2,3) by 45°, the correct sequence is:",
      "options": [
        {
          "key": "A",
          "text": "Rotate then translate"
        },
        {
          "key": "B",
          "text": "Translate pivot to origin, rotate, translate back"
        },
        {
          "key": "C",
          "text": "Scale then rotate"
        },
        {
          "key": "D",
          "text": "Shear then rotate"
        }
      ],
      "correctAnswer": "Translate pivot to origin, rotate, translate back",
      "explanation": "To rotate about arbitrary point: T(pivot) × R(θ) × T(-pivot).",
      "difficulty": "hard"
    },
    {
      "id": "mcq-10",
      "question": "The inverse of translation matrix T(tx, ty) is:",
      "options": [
        {
          "key": "A",
          "text": "[1 0 -tx; 0 1 -ty; 0 0 1]"
        },
        {
          "key": "B",
          "text": "[1 0 tx; 0 1 ty; 0 0 -1]"
        },
        {
          "key": "C",
          "text": "[-tx -ty 0; 0 0 1]"
        },
        {
          "key": "D",
          "text": "[tx ty 1]"
        }
      ],
      "correctAnswer": "[1 0 -tx; 0 1 -ty; 0 0 1]",
      "explanation": "Inverse translation negates the translation values to move the point back to original position.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-11",
      "question": "A 3D affine transformation uses:",
      "options": [
        {
          "key": "A",
          "text": "2×2 matrix"
        },
        {
          "key": "B",
          "text": "3×3 matrix"
        },
        {
          "key": "C",
          "text": "4×4 matrix"
        },
        {
          "key": "D",
          "text": "5×5 matrix"
        }
      ],
      "correctAnswer": "4×4 matrix",
      "explanation": "3D homogeneous coordinates (x,y,z,w) require a 4×4 transformation matrix.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-12",
      "question": "Which is NOT an affine transformation?",
      "options": [
        {
          "key": "A",
          "text": "Rotation"
        },
        {
          "key": "B",
          "text": "Translation"
        },
        {
          "key": "C",
          "text": "Scaling"
        },
        {
          "key": "D",
          "text": "Perspective projection"
        }
      ],
      "correctAnswer": "Perspective projection",
      "explanation": "Perspective projection is a projective transformation that does not preserve parallelism, unlike affine transformations.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-13",
      "question": "The general 2D affine transformation matrix has how many independent parameters?",
      "options": [
        {
          "key": "A",
          "text": "4"
        },
        {
          "key": "B",
          "text": "6"
        },
        {
          "key": "C",
          "text": "8"
        },
        {
          "key": "D",
          "text": "9"
        }
      ],
      "correctAnswer": "6",
      "explanation": "Matrix [a b tx; c d ty; 0 0 1] has 6 independent parameters: a,b,c,d,tx,ty (bottom row is fixed).",
      "difficulty": "hard"
    },
    {
      "id": "mcq-14",
      "question": "Scaling by factor 2 in both directions followed by translation by (10, 20) is represented as:",
      "options": [
        {
          "key": "A",
          "text": "T × S"
        },
        {
          "key": "B",
          "text": "S × T"
        },
        {
          "key": "C",
          "text": "S + T"
        },
        {
          "key": "D",
          "text": "T + S"
        }
      ],
      "correctAnswer": "T × S",
      "explanation": "In homogeneous coordinates: M = T × S = [1 0 10; 0 1 20; 0 0 1] × [2 0 0; 0 2 0; 0 0 1].",
      "difficulty": "hard"
    },
    {
      "id": "mcq-15",
      "question": "What property do affine transformations NOT preserve?",
      "options": [
        {
          "key": "A",
          "text": "Parallel lines"
        },
        {
          "key": "B",
          "text": "Ratios of distances"
        },
        {
          "key": "C",
          "text": "Angles between lines"
        },
        {
          "key": "D",
          "text": "Straight lines"
        }
      ],
      "correctAnswer": "Angles between lines",
      "explanation": "Affine transformations preserve parallelism and ratios but not necessarily angles or lengths.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-16",
      "question": "Reflection about line y = x is achieved by matrix:",
      "options": [
        {
          "key": "A",
          "text": "[0 1 0; 1 0 0; 0 0 1]"
        },
        {
          "key": "B",
          "text": "[-1 0 0; 0 -1 0; 0 0 1]"
        },
        {
          "key": "C",
          "text": "[0 -1 0; -1 0 0; 0 0 1]"
        },
        {
          "key": "D",
          "text": "[1 0 0; 0 1 0; 0 0 1]"
        }
      ],
      "correctAnswer": "[0 1 0; 1 0 0; 0 0 1]",
      "explanation": "Reflection about y=x swaps x and y coordinates, represented by swapping diagonal elements.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-17",
      "question": "The transformation that changes the shape but not size is:",
      "options": [
        {
          "key": "A",
          "text": "Scaling"
        },
        {
          "key": "B",
          "text": "Rotation"
        },
        {
          "key": "C",
          "text": "Shearing"
        },
        {
          "key": "D",
          "text": "Translation"
        }
      ],
      "correctAnswer": "Shearing",
      "explanation": "Shearing distorts the shape by slanting while maintaining area/size, unlike scaling which changes dimensions.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-18",
      "question": "Order of transformations matters because matrix multiplication is:",
      "options": [
        {
          "key": "A",
          "text": "Commutative"
        },
        {
          "key": "B",
          "text": "Associative but not commutative"
        },
        {
          "key": "C",
          "text": "Idempotent"
        },
        {
          "key": "D",
          "text": "Transitive"
        }
      ],
      "correctAnswer": "Associative but not commutative",
      "explanation": "While (AB)C = A(BC), generally AB ≠ BA, hence the order of applying transformations affects the final result.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-19",
      "question": "A point at (3, 4) after 90° rotation about origin becomes:",
      "options": [
        {
          "key": "A",
          "text": "(3, 4)"
        },
        {
          "key": "B",
          "text": "(-4, 3)"
        },
        {
          "key": "C",
          "text": "(4, -3)"
        },
        {
          "key": "D",
          "text": "(-3, -4)"
        }
      ],
      "correctAnswer": "(-4, 3)",
      "explanation": "90° CCW rotation formula: x' = -y, y' = x. So (3,4) → (-4, 3).",
      "difficulty": "medium"
    },
    {
      "id": "mcq-20",
      "question": "Identity transformation matrix is:",
      "options": [
        {
          "key": "A",
          "text": "[0 0 0; 0 0 0; 0 0 1]"
        },
        {
          "key": "B",
          "text": "[1 0 0; 0 1 0; 0 0 1]"
        },
        {
          "key": "C",
          "text": "[1 1 0; 0 1 1; 0 0 1]"
        },
        {
          "key": "D",
          "text": "[0 1 0; 1 0 0; 0 0 1]"
        }
      ],
      "correctAnswer": "[1 0 0; 0 1 0; 0 0 1]",
      "explanation": "Identity matrix leaves points unchanged - identity elements on diagonal, zeros elsewhere.",
      "difficulty": "easy"
    }
  ]
}
