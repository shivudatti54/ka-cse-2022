    },
    {
      "id": "mcq-20",
      "question": "The transition function RESULT(s,a) returns:",
      "options": [
        {
          "key": "A",
          "text": "True/False"
        },
        {
          "key": "B",
          "text": "Cost of action"
        },
        {
          "key": "C",
          "text": "Next state"
        },
        {
          "key": "D",
