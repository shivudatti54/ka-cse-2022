{
  "topicId": "algorithms-for-planning-as-state-space-search",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "In planning as state space search, what does each node represent?",
      "options": [
        {
          "key": "A",
          "text": "An action"
        },
        {
          "key": "B",
          "text": "A state"
        },
        {
          "key": "C",
          "text": "A goal"
        },
        {
          "key": "D",
          "text": "A heuristic"
        }
      ],
      "correctAnswer": "A state",
      "explanation": "In state space search, nodes represent states (world configurations), and edges represent actions that transition between states.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "What is the initial node in a planning state space?",
      "options": [
        {
          "key": "A",
          "text": "Goal state"
        },
        {
          "key": "B",
          "text": "Starting state of the problem"
        },
        {
          "key": "C",
          "text": "Any random state"
        },
        {
          "key": "D",
          "text": "Final state"
        }
      ],
      "correctAnswer": "Starting state of the problem",
      "explanation": "The initial node represents the starting configuration of the world before any actions are performed.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "In forward state space search, the search proceeds from:",
      "options": [
        {
          "key": "A",
          "text": "Goal to initial state"
        },
        {
          "key": "B",
          "text": "Initial state to goal"
        },
        {
          "key": "C",
          "text": "Middle to both ends"
        },
        {
          "key": "D",
          "text": "None of the above"
        }
      ],
      "correctAnswer": "Initial state to goal",
      "explanation": "Forward search starts at the initial state and applies actions to move forward until the goal is reached.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-4",
      "question": "The STRIPS representation uses how many components?",
      "options": [
        {
          "key": "A",
          "text": "One"
        },
        {
          "key": "B",
          "text": "Two"
        },
        {
          "key": "C",
          "text": "Three"
        },
        {
          "key": "D",
          "text": "Four"
        }
      ],
      "correctAnswer": "Three",
      "explanation": "STRIPS has three components: PRECONDITION, ADD LIST, and DELETE LIST.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-5",
      "question": "Which planning approach starts from the goal state?",
      "options": [
        {
          "key": "A",
          "text": "Forward search"
        },
        {
          "key": "B",
          "text": "Progressive planning"
        },
        {
          "key": "C",
          "text": "Backward search"
        },
        {
          "key": "D",
          "text": "Linear planning"
        }
      ],
      "correctAnswer": "Backward search",
      "explanation": "Backward search or regressive planning starts from the goal and works backward to the initial state.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-6",
      "question": "What is the main advantage of backward planning?",
      "options": [
        {
          "key": "A",
          "text": "More branching factor"
        },
        {
          "key": "B",
          "text": "Less branching factor"
        },
        {
          "key": "C",
          "text": "Slower search"
        },
        {
          "key": "D",
          "text": "No advantage"
        }
      ],
      "correctAnswer": "Less branching factor",
      "explanation": "Backward planning typically has lower branching factor because fewer actions can lead to a given goal than all possible actions from initial state.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-7",
      "question": "A planning graph is a:",
      "options": [
        {
          "key": "A",
          "text": "Tree structure"
        },
        {
          "key": "B",
          "text": "Directed acyclic graph"
        },
        {
          "key": "C",
          "text": "Linear list"
        },
        {
          "key": "D",
          "text": "Stack"
        }
      ],
      "correctAnswer": "Directed acyclic graph",
      "explanation": "A planning graph is a directed graph where nodes represent states and actions, with edges showing prerequisites and effects.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-8",
      "question": "In partial order planning, what is maintained?",
      "options": [
        {
          "key": "A",
          "text": "Complete action sequence"
        },
        {
          "key": "B",
          "text": "Set of constraints"
        },
        {
          "key": "C",
          "text": "Single path"
        },
        {
          "key": "D",
          "text": "All goals simultaneously"
        }
      ],
      "correctAnswer": "Set of constraints",
      "explanation": "Partial order planning maintains constraints specifying ordering requirements between actions, not a total order.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-9",
      "question": "What does the DELETE list contain in STRIPS?",
      "options": [
        {
          "key": "A",
          "text": "Preconditions that become true"
        },
        {
          "key": "B",
          "text": "Preconditions that become false"
        },
        {
          "key": "C",
          "text": "Effects that become true"
        },
        {
          "key": "D",
          "text": "Effects that become false"
        }
      ],
      "correctAnswer": "Effects that become false",
      "explanation": "DELETE list contains fluents (conditions) that become false after the action is performed.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-10",
      "question": "Goal regression is used in:",
      "options": [
        {
          "key": "A",
          "text": "Forward planning only"
        },
        {
          "key": "B",
          "text": "Backward planning only"
        },
        {
          "key": "C",
          "text": "Both planning approaches"
        },
        {
          "key": "D",
          "text": "Neither"
        }
      ],
      "correctAnswer": "Backward planning only",
      "explanation": "Goal regression computes what state must have existed before an action to achieve a goal, used only in backward planning.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-11",
      "question": "Which heuristic ignores delete lists?",
      "options": [
        {
          "key": "A",
          "text": "Admissible heuristic"
        },
        {
          "key": "B",
          "text": "Delete-list relaxation"
        },
        {
          "key": "C",
          "text": "Ignore preconditions"
        },
        {
          "key": "D",
          "text": "State abstraction"
        }
      ],
      "correctAnswer": "Delete-list relaxation",
      "explanation": "Delete-list relaxation ignores negative effects (deletes), making the heuristic both efficient and often admissible.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-12",
      "question": "The frame problem in planning deals with:",
      "options": [
        {
          "key": "A",
          "text": "Finding the shortest path"
        },
        {
          "key": "B",
          "text": "Determining what remains unchanged"
        },
        {
          "key": "C",
          "text": "Goal representation"
        },
        {
          "key": "D",
          "text": "Action sequencing"
        }
      ],
      "correctAnswer": "Determining what remains unchanged",
      "explanation": "The frame problem is about specifying what doesn't change when an action is performed.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-13",
      "question": "What is a solution in state space search for planning?",
      "options": [
        {
          "key": "A",
          "text": "Any state"
        },
        {
          "key": "B",
          "text": "A path from initial to goal"
        },
        {
          "key": "C",
          "text": "A single action"
        },
        {
          "key": "D",
          "text": "A heuristic"
        }
      ],
      "correctAnswer": "A path from initial to goal",
      "explanation": "A solution is a sequence of actions (path) that transforms the initial state into a goal state.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-14",
      "question": "Plan execution monitoring is important because:",
      "options": [
        {
          "key": "A",
          "text": "Plans always succeed"
        },
        {
          "key": "B",
          "text": "Unexpected states may occur"
        },
        {
          "key": "C",
          "text": "Actions are reversible"
        },
        {
          "key": "D",
          "text": "Goals change"
        }
      ],
      "correctAnswer": "Unexpected states may occur",
      "explanation": "Real-world execution may encounter unexpected states, requiring monitoring and potentially replanning.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-15",
      "question": "The ADD list in STRIPS contains:",
      "options": [
        {
          "key": "A",
          "text": "Preconditions of the action"
        },
        {
          "key": "B",
          "text": "Conditions made true by action"
        },
        {
          "key": "C",
          "text": "Conditions made false by action"
        },
        {
          "key": "D",
          "text": "Conditions needed before action"
        }
      ],
      "correctAnswer": "Conditions made true by action",
      "explanation": "ADD list contains fluents that become true (are added) after the action is executed.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-16",
      "question": "Which is NOT a component of state space planning?",
      "options": [
        {
          "key": "A",
          "text": "Initial state"
        },
        {
          "key": "B",
          "text": "Goal state"
        },
        {
          "key": "C",
          "text": "Transition function"
        },
        {
          "key": "D",
          "text": "Neural network"
        }
      ],
      "correctAnswer": "Neural network",
      "explanation": "State space planning uses Initial state, Goal state, Actions, and Transition function - no neural networks involved.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-17",
      "question": "In totally ordered planning:",
      "options": [
        {
          "key": "A",
          "text": "Actions can be in any order"
        },
        {
