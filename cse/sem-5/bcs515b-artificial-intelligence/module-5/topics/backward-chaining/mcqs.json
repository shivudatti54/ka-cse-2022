{
  "topicId": "backward-chaining",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "In backward chaining, the inference engine starts from:",
      "options": [
        {
          "key": "A",
          "text": "Known facts"
        },
        {
          "key": "B",
          "text": "Goal/Hypothesis"
        },
        {
          "key": "C",
          "text": "Random data"
        },
        {
          "key": "D",
          "text": "All possible conclusions"
        }
      ],
      "correctAnswer": "Goal/Hypothesis",
      "explanation": "Backward chaining is goal-driven. It begins with what we want to prove and works backwards to find supporting facts.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "Backward chaining is also known as:",
      "options": [
        {
          "key": "A",
          "text": "Data-driven inference"
        },
        {
          "key": "B",
          "text": "Goal-driven inference"
        },
        {
          "key": "C",
          "text": "Pattern-directed inference"
        },
        {
          "key": "D",
          "text": "Event-driven inference"
        }
      ],
      "correctAnswer": "Goal-driven inference",
      "explanation": "Backward chaining starts from goals and determines what facts are needed—hence goal-driven reasoning.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "Which search strategy is typically used in backward chaining?",
      "options": [
        {
          "key": "A",
          "text": "Breadth-first search"
        },
        {
          "key": "B",
          "text": "Depth-first search"
        },
        {
          "key": "C",
          "text": "A* search"
        },
        {
          "key": "D",
          "text": "Uniform-cost search"
        }
      ],
      "correctAnswer": "Depth-first search",
      "explanation": "Backward chaining commonly uses DFS to explore rule chains, pursuing one branch fully before backtracking.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-4",
      "question": "Horn clauses are essential in:",
      "options": [
        {
          "key": "A",
          "text": "Forward chaining systems"
        },
        {
          "key": "B",
          "text": "Logic programming and Prolog"
        },
        {
          "key": "C",
          "text": "Neural networks"
        },
        {
          "key": "D",
          "text": "Fuzzy logic systems"
        }
      ],
      "correctAnswer": "Logic programming and Prolog",
      "explanation": "Horn clauses (at most one positive literal) are the basis for logic programming languages like Prolog that use backward chaining.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-5",
      "question": "What happens when backward chaining encounters a failed rule path?",
      "options": [
        {
          "key": "A",
          "text": "System stops completely"
        },
        {
          "key": "B",
          "text": "Backtracking occurs"
        },
        {
          "key": "C",
          "text": "Forward chaining begins"
        },
        {
          "key": "D",
          "text": "Random selection"
        }
      ],
      "correctAnswer": "Backtracking occurs",
      "explanation": "When a rule path fails, backtracking returns to previous choice points to explore alternative rule sequences.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-6",
      "question": "Which type of system is backward chaining best suited for?",
      "options": [
        {
          "key": "A",
          "text": "Monitoring systems"
        },
        {
          "key": "B",
          "text": "Diagnostic/consultation systems"
        },
        {
          "key": "C",
          "text": "Data processing systems"
        },
        {
          "key": "D",
          "text": "Pattern recognition systems"
        }
      ],
      "correctAnswer": "Diagnostic/consultation systems",
      "explanation": "Backward chaining excels in diagnostic systems where you start with symptoms (goals) and work backwards to find causes.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-7",
      "question": "The proof tree in backward chaining has which structure?",
      "options": [
        {
          "key": "A",
          "text": "Root = known facts"
        },
        {
          "key": "B",
          "text": "Root = goal to prove"
        },
        {
          "key": "C",
          "text": "Root = rule set"
        },
        {
          "key": "D",
          "text": "Root = database"
        }
      ],
      "correctAnswer": "Root = goal to prove",
      "explanation": "In a proof tree, the root represents the main goal being proved, with sub-goals as branches leading to known facts at leaves.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-8",
      "question": "What is unification in backward chaining?",
      "options": [
        {
          "key": "A",
          "text": "Combining two rules"
        },
        {
          "key": "B",
          "text": "Making formulas identical via substitutions"
        },
        {
          "key": "C",
          "text": "Creating new facts"
        },
        {
          "key": "D",
          "text": "Deleting variables"
        }
      ],
      "correctAnswer": "Making formulas identical via substitutions",
      "explanation": "Unification finds variable substitutions that make two atomic formulas identical, essential for matching goals with rules.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-9",
      "question": "Which algorithm prevents infinite loops in backward chaining?",
      "options": [
        {
          "key": "A",
          "text": "Cycle detection"
        },
        {
          "key": "B",
          "text": "Breadth-first search"
        },
        {
          "key": "C",
          "text": "Random walk"
        },
        {
          "key": "D",
          "text": "Memoization only"
        }
      ],
      "correctAnswer": "Cycle detection",
      "explanation": "Cycle detection prevents revisiting the same goal state, avoiding infinite loops in depth-first backward chaining.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-10",
      "question": "Prolog uses which chaining method by default?",
      "options": [
        {
          "key": "A",
          "text": "Forward chaining only"
        },
        {
          "key": "B",
          "text": "Backward chaining with DFS"
        },
        {
          "key": "C",
          "text": "Bidirectional chaining"
        },
        {
          "key": "D",
          "text": "Parallel chaining"
        }
      ],
      "correctAnswer": "Backward chaining with DFS",
      "explanation": "Prolog implements backward chaining with depth-first search and backtracking as its primary inference mechanism.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-11",
      "question": "In a rule 'A ← B, C, D', proving A requires:",
      "options": [
        {
          "key": "A",
          "text": "Proving only B"
        },
        {
          "key": "B",
          "text": "Proving B and C only"
        },
        {
          "key": "C",
          "text": "Proving all of B, C, and D"
        },
        {
          "key": "D",
          "text": "Proving any one of them"
        }
      ],
      "correctAnswer": "Proving all of B, C, and D",
      "explanation": "The comma represents conjunction—all conditions (B, C, D) must be true for the rule head A to be satisfied.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-12",
      "question": "Backward chaining is inefficient when:",
      "options": [
        {
          "key": "A",
          "text": "Goals are few and specific"
        },
        {
          "key": "B",
          "text": "There are many potential goals"
        },
        {
          "key": "C",
          "text": "Facts are well-structured"
        },
        {
          "key": "D",
          "text": "Rules are simple"
        }
      ],
      "correctAnswer": "There are many potential goals",
      "explanation": "When many goals exist, backward chaining may explore many irrelevant paths, reducing efficiency.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-13",
      "question": "What is iterative deepening used for in backward chaining?",
      "options": [
        {
          "key": "A",
          "text": "Speed up computation"
        },
        {
          "key": "B",
          "text": "Limit search depth progressively"
        },
        {
          "key": "C",
          "text": "Reduce memory usage"
        },
        {
          "key": "D",
          "text": "Improve accuracy"
        }
      ],
      "correctAnswer": "Limit search depth progressively",
      "explanation": "Iterative deepening limits depth (1,2,3...) to avoid infinite loops while ensuring solution findability.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-14",
      "question": "Which of these is NOT a component of backward chaining?",
      "options": [
        {
          "key": "A",
          "text": "Goal stack"
        },
        {
          "key": "B",
          "text": "Rule set"
        },
        {
          "key": "C",
          "text": "Forward chainer"
        },
        {
          "key": "D",
          "text": "Unification algorithm"
        }
      ],
      "correctAnswer": "Forward chainer",
      "explanation": "Backward chaining uses a goal stack, rule set, and unification—it does not involve a forward chainer which is a separate mechanism.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-15",
      "question": "Resolution in backward chaining generates:",
      "options": [
        {
          "key": "A",
          "text": "New facts"
        },
        {
          "key": "B",
          "text": "Resolvents"
        },
        {
          "key": "C",
          "text": "Rules"
        },
        {
          "key": "D",
          "text": "Queries"
        }
      ],
      "correctAnswer": "Resolvents",
      "explanation": "Resolution is an inference rule that combines two clauses to produce a new clause called a resolvent.",
      "difficulty": "hard"
    },
    {
