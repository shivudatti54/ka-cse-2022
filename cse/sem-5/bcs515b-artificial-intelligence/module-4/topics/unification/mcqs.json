{
  "topicId": "unification",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "What is the primary purpose of unification in logic programming?",
      "options": [
        {
          "key": "A",
          "text": "Pattern matching and variable binding"
        },
        {
          "key": "B",
          "text": "Sorting data"
        },
        {
          "key": "C",
          "text": "File handling"
        },
        {
          "key": "D",
          "text": "Network communication"
        }
      ],
      "correctAnswer": "Pattern matching and variable binding",
      "explanation": "Unification is the core mechanism in logic programming for pattern matching and binding variables to values, enabling logical inference.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "Which of the following is NOT a condition for unification failure?",
      "options": [
        {
          "key": "A",
          "text": "Two distinct constants"
        },
        {
          "key": "B",
          "text": "Variable and its own term"
        },
        {
          "key": "C",
          "text": "Function and constant"
        },
        {
          "key": "D",
          "text": "Same variable names"
        }
      ],
      "correctAnswer": "Same variable names",
      "explanation": "Same variable names can be unified (they become identical). Failure occurs when terms have incompatible structures or the occurs check fails.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-3",
      "question": "What does the occurs check prevent?",
      "options": [
        {
          "key": "A",
          "text": "Infinite loops"
        },
        {
          "key": "B",
          "text": "Circular definitions"
        },
        {
          "key": "C",
          "text": "Infinite structures"
        },
        {
          "key": "D",
          "text": "All of the above"
        }
      ],
      "correctAnswer": "Infinite structures",
      "explanation": "The occurs check prevents binding a variable to a term containing that variable, which would create infinite structures like X = f(X).",
      "difficulty": "medium"
    },
    {
      "id": "mcq-4",
      "question": "The MGU is unique up to:",
      "options": [
        {
          "key": "A",
          "text": "Constant renaming"
        },
        {
          "key": "B",
          "text": "Function renaming"
        },
        {
          "key": "C",
          "text": "Variable renaming"
        },
        {
          "key": "D",
          "text": "Term ordering"
        }
      ],
      "correctAnswer": "Variable renaming",
      "explanation": "The Most General Unifier is unique up to variable renaming because any two MGUs differ only by renaming the bound variables.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-5",
      "question": "In Prolog, what happens when unifying X = f(X)?",
      "options": [
        {
          "key": "A",
          "text": "Fails with occurs check"
        },
        {
          "key": "B",
          "text": "Creates infinite structure"
        },
        {
          "key": "C",
          "text": "Returns true"
        },
        {
          "key": "D",
          "text": "Creates circular term"
        }
      ],
      "correctAnswer": "Creates infinite structure",
      "explanation": "Prolog disables occurs check by default, allowing the creation of circular/infinite terms like X = f(X).",
      "difficulty": "medium"
    },
    {
      "id": "mcq-6",
      "question": "Which of these can be unified? f(a, X) and f(Y, b)",
      "options": [
        {
          "key": "A",
          "text": "{X/b, Y/a}"
        },
        {
          "key": "B",
          "text": "{X=a, Y=b}"
        },
        {
          "key": "C",
          "text": "{X/b} only"
        },
        {
          "key": "D",
          "text": "Cannot be unified"
        }
      ],
      "correctAnswer": "{X/b, Y/a}",
      "explanation": "f(a,X) with f(Y,b): Y→a and X→b gives f(a,b) for both. This is the MGU.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-7",
      "question": "What is the time complexity of unification algorithm?",
      "options": [
        {
          "key": "A",
          "text": "O(n)"
        },
        {
          "key": "B",
          "text": "O(n²)"
        },
        {
          "key": "C",
          "text": "O(log n)"
        },
        {
          "key": "D",
          "text": "O(1)"
        }
      ],
      "correctAnswer": "O(n)",
      "explanation": "The unification algorithm runs in linear time O(n) where n is the combined size of the input terms.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-8",
      "question": "A substitution where θ = θ∘θ is called:",
      "options": [
        {
          "key": "A",
          "text": "Idempotent"
        },
        {
          "key": "B",
          "text": "Commutative"
        },
        {
          "key": "C",
          "text": "Associative"
        },
        {
          "key": "D",
          "text": "Transitive"
        }
      ],
      "correctAnswer": "Idempotent",
      "explanation": "A substitution θ is idempotent if applying it twice has the same effect as applying it once: θ = θ∘θ.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-9",
      "question": "Can f(X, g(X)) and f(Y, g(a)) be unified?",
      "options": [
        {
          "key": "A",
          "text": "Yes with {X/a}"
        },
        {
          "key": "B",
          "text": "No - occurs check fails"
        },
        {
          "key": "C",
          "text": "Yes with {X/Y}"
        },
        {
          "key": "D",
          "text": "No - different functors"
        }
      ],
      "correctAnswer": "No - occurs check fails",
      "explanation": "To unify g(X) with g(a), we need X=a, but then X occurs in g(X), violating occurs check.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-10",
      "question": "What is structure sharing in Prolog?",
      "options": [
        {
          "key": "A",
          "text": "Sharing memory for identical subterms"
        },
        {
          "key": "B",
          "text": "Sharing variables between clauses"
        },
        {
          "key": "C",
          "text": "Sharing database facts"
        },
        {
          "key": "D",
          "text": "Sharing predicate definitions"
        }
      ],
      "correctAnswer": "Sharing memory for identical subterms",
      "explanation": "Structure sharing is a memory optimization where identical subterms are represented once and referenced multiple times.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-11",
      "question": "Which is a ground term?",
      "options": [
        {
          "key": "A",
          "text": "X"
        },
        {
          "key": "B",
          "text": "f(X,Y)"
        },
        {
          "key": "C",
          "text": "g(a,b,c)"
        },
        {
          "key": "D",
          "text": "h(X)"
        }
      ],
      "correctAnswer": "g(a,b,c)",
      "explanation": "A ground term contains no variables. g(a,b,c) has only constants a,b,c, so it is ground.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-12",
      "question": "The unification algorithm returns what when terms cannot be unified?",
      "options": [
        {
          "key": "A",
          "text": "Failure/False"
        },
        {
          "key": "B",
          "text": "Empty substitution"
        },
        {
          "key": "C",
          "text": "Exception"
        },
        {
          "key": "D",
          "text": "Random value"
        }
      ],
      "correctAnswer": "Failure/False",
      "explanation": "When terms cannot be unified (incompatible structures or occurs check fails), the algorithm returns failure or false.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-13",
      "question": "Two unifiers θ and σ are equivalent if:",
      "options": [
        {
          "key": "A",
          "text": "θ⊢α = σ⊢α for all terms"
        },
        {
          "key": "B",
          "text": "θ and σ have same domain"
        },
        {
          "key": "C",
          "text": "θ and σ have same range"
        },
        {
          "key": "D",
          "text": "They unify the same terms"
        }
      ],
      "correctAnswer": "θ⊢α = σ⊢α for all terms",
      "explications": "Two unifiers are equivalent if they give the same result when applied to any term α.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-14",
      "question": "What does {X/a, Y/a, Z/b} simplify to?",
      "options": [
        {
          "key": "A",
          "text": "{X/Y, Z/b}"
        },
        {
          "key": "B",
          "text": "{X/a, Z/b}"
        },
        {
          "key": "C",
          "text": "{Y/a, Z/b}"
        },
        {
          "key": "D",
          "text": "Cannot simplify"
        }
      ],
      "correctAnswer": "{X/a, Z/b}",
      "explanation": "Since X and Y both bind to 'a', keeping only one binding (X/a) is sufficient - it's idempotent.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-15",
      "question": "In automatic theorem proving, unification is used for:",
      "options": [
        {
          "key": "A",
          "text": "Resolution"
        },
        {
          "key": "B",
          "text": "Backtracking"
        },
        {
          "key": "C",
          "text": "Cut operations"
        },
        {
          "key": "D",
          "text": "Input parsing"
        }
      ],
      "correctAnswer": "Resolution",
      "explanation": "Unification is essential in resolution-based theorem proving to find complementary literals and apply the resolution rule.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-16",
      "question": "Which property ensures MGU has no redundant bindings?",
      "options": [
        {
          "key": "A",
          "text": "Idempotency"
        },
        {
          "key": "B",
          "text": "Most general"
        },
        {
          "key": "C",
          "text": "Least fixed point"
        },
        {
          "key": "D",
          "text": "Minimality"
        }
      ],
      "correctAnswer": "Idempotency",
      "explanation": "An idempotent substitution has no redundant bindings - each variable is bound exactly once to what's needed.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-17",
      "question": "Unify p(X, f(Y)) with p(a, Z):",
      "options": [
        {
          "key": "A",
          "text": "{X/a, Z/f(Y)}"
        },
        {
          "key": "B",
          "text": "{X/a, Y/Z, Z/f(Y)}"
        },
        {
          "key": "C",
          "text": "{X/a, Y/a, Z/f(a)}"
        },
        {
          "key": "D",
          "text": "{Z/f(a)}"
        }
      ],
      "correctAnswer": "{X/a, Z/f(Y)}",
      "explanation": "Matching p(X,f(Y)) with p(a,Z): X→a, and Z must equal f(Y). Result: {X/a, Z/f(Y)}",
      "difficulty": "medium"
    },
    {
      "id": "mcq-18",
      "question": "A variable can be unified with:",
      "options": [
        {
          "key": "A",
          "text": "Any term"
        },
        {
          "key": "B",
          "text": "Only constants"
        },
        {
          "key": "C",
          "text": "Only complex terms"
        },
        {
          "key": "D",
          "text": "Only variables"
        }
      ],
      "correctAnswer": "Any term",
      "explanation": "A variable can be unified with any term: constants, functions, or other variables.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-19",
      "question": "The unification algorithm is:",
      "options": [
        {
          "key": "A",
          "text": "Sound and complete"
        },
        {
          "key": "B",
          "text": "Only sound"
        },
        {
          "key": "C",
          "text": "Only complete"
        },
        {
          "key": "D",
          "text": "Neither"
        }
      ],
      "correctAnswer": "Sound and complete",
      "explanation": "The standard unification algorithm is both sound (produces only unifiers) and complete (finds all unifiers).",
      "difficulty": "hard"
    },
    {
      "id": "mcq-20",
      "question": "What is a clause in Prolog that represents a fact?",
      "options": [
        {
          "key": "A",
          "text": "Head :- Body"
        },
        {
          "key": "B",
          "text": "Head"
        },
        {
          "key": "C",
          "text": ":- Body"
        },
        {
          "key": "D",
          "text": "Head, Body"
        }
      ],
      "correctAnswer": "Head",
      "explanation": "A fact in Prolog is a clause with only a head and no body, e.g., likes(john, mary). It represents a ground atom.",
      "difficulty": "medium"
    }
  ]
}
