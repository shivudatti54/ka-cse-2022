    {
      "id": "mcq-11",
      "question": "What is the correct sequence of operations to add element x to a queue?",
      "options": [
        {
          "key": "A",
          "text": "rear++, queue[rear]=x"
        },
        {
          "key": "B",
          "text": "front++, queue[front]=x"
        },
        {
          "key": "C",
          "text": "queue[front]=x, front++"
        },
        {
          "key": "D",
          "text": "rear--, queue[rear]=x"
        }
      ],
      "correctAnswer": "rear++, queue[rear]=x",
      "explanation": "Increment rear pointer first, then insert element at the new rear position.",
      "difficulty": "medium"
    },
