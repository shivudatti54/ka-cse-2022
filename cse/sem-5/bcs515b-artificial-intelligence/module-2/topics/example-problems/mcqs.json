    {
      "id": "mcq-4",
      "question": "In a circular queue, if front=5 and MAXSIZE=10, what will be the new front after one dequeue?",
      "options": [
        {
          "key": "A",
          "text": "6"
        },
        {
          "key": "B",
          "text": "5"
        },
        {
          "key": "C",
          "text": "4"
        },
        {
          "key": "D",
          "text": "0"
        }
      ],
      "correctAnswer": "6",
      "explanation": "New front = (front + 1) % MAXSIZE = (5+1)%10 = 6",
      "difficulty": "medium"
    },
    {
