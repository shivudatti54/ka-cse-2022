        {
          "key": "A",
          "text": "front == -1"
        },
        {
          "key": "B",
          "text": "rear == MAXSIZE-1"
        },
        {
          "key": "C",
          "text": "(rear+1)%MAXSIZE == front"
        },
        {
          "key": "D",
          "text": "front == rear"
        }
      ],
      "correctAnswer": "(rear+1)%MAXSIZE == front",
      "explanation": "This condition avoids ambiguity between full and empty states.",
      "difficulty": "hard"
    },
