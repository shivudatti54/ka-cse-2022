    {
      "id": "mcq-3",
      "question": "What is the result of evaluating postfix expression: 10 5 + 3 *?",
      "options": [
        {
          "key": "A",
          "text": "45"
        },
        {
          "key": "B",
          "text": "15"
        },
        {
          "key": "C",
          "text": "50"
        },
        {
          "key": "D",
          "text": "35"
        }
      ],
      "correctAnswer": "45",
