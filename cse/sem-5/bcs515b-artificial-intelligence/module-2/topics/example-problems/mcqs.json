    {
      "id": "mcq-1",
      "question": "In a stack implementation using array, what condition indicates overflow?",
      "options": [
        {
          "key": "A",
          "text": "top == -1"
        },
        {
          "key": "B",
          "text": "top == MAXSIZE-1"
        },
        {
          "key": "C",
          "text": "front == -1"
        },
        {
          "key": "D",
          "text": "rear == MAXSIZE"
        }
      ],
      "correctAnswer": "top == MAXSIZE-1",
      "explanation": "When top reaches the maximum array index, stack is full and cannot accept more elements.",
      "difficulty": "easy"
    },
    {
