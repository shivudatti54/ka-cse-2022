          "key": "C",
          "text": "Completeness"
        },
        {
          "key": "D",
          "text": "Optimality"
        }
      ],
      "correctAnswer": "Consistency",
      "explanation": "Consistent (monotonic) heuristic ensures f-cost never decreases along a path.",
      "difficulty": "hard"
