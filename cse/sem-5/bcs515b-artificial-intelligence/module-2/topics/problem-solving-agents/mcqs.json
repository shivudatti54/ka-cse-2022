{
  "topicId": "problem-solving-agents",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "In problem formulation, which component defines what constitutes a solution?",
      "options": [
        {
          "key": "A",
          "text": "Initial state"
        },
        {
          "key": "B",
          "text": "Goal test"
        },
        {
          "key": "C",
          "text": "Successor function"
        },
        {
          "key": "D",
          "text": "Path cost"
        }
      ],
      "correctAnswer": "Goal test",
      "explanation": "Goal test determines whether a given state is the goal state, defining what constitutes a solution.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "Which search algorithm is complete but not optimal for uniform cost problems?",
      "options": [
        {
          "key": "A",
          "text": "DFS"
        },
        {
          "key": "B",
          "text": "BFS"
        },
        {
          "key": "C",
          "text": "Uniform-cost"
        },
        {
          "key": "D",
          "text": "A*"
        }
      ],
      "correctAnswer": "BFS",
      "explanation": "BFS is complete but only optimal when all step costs are equal. For varying costs, uniform-cost is optimal.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-3",
      "question": "A* search is optimal if the heuristic function is:",
      "options": [
        {
          "key": "A",
          "text": "Admissible"
        },
        {
          "key": "B",
          "text": "Consistent"
        },
        {
          "key": "C",
          "text": "Dominant"
        },
        {
          "key": "D",
          "text": "Monotonic"
        }
      ],
      "correctAnswer": "Admissible",
      "explanation": "A* with an admissible (never overestimating) heuristic guarantees optimal solution.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-4",
      "question": "Which algorithm uses the evaluation function f(n) = g(n) + h(n)?",
      "options": [
        {
          "key": "A",
          "text": "Greedy Best-First"
        },
        {
          "key": "B",
          "text": "Uniform-cost"
        },
        {
          "key": "C",
          "text": "A*"
        },
        {
          "key": "D",
          "text": "Depth-limited"
        }
      ],
      "correctAnswer": "A*",
      "explanation": "A* combines actual cost g(n) from start with heuristic estimate h(n) to goal.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-5",
      "question": "What is the time complexity of BFS with branching factor b and depth d?",
      "options": [
        {
          "key": "A",
          "text": "O(b^d)"
        },
        {
          "key": "B",
          "text": "O(bd)"
        },
        {
          "key": "C",
          "text": "O(d)"
        },
        {
          "key": "D",
          "text": "O(b^d/2)"
        }
      ],
      "correctAnswer": "O(b^d)",
      "explanation": "BFS explores all nodes at depth d and above, generating approximately b^d nodes.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-6",
      "question": "Greedy Best-First Search is:",
      "options": [
        {
          "key": "A",
          "text": "Complete"
        },
        {
          "key": "B",
          "text": "Optimal"
        },
        {
          "key": "C",
          "text": "Not guaranteed to be complete or optimal"
        },
        {
          "key": "D",
          "text": "Memory efficient"
        }
      ],
      "correctAnswer": "Not guaranteed to be complete or optimal",
      "explanation": "Greedy can get stuck in loops and may not find optimal solutions.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-7",
      "question": "Which search technique uses backtracking?",
      "options": [
        {
          "key": "A",
          "text": "BFS"
        },
        {
          "key": "B",
          "text": "DFS"
        },
        {
          "key": "C",
          "text": "Uniform-cost"
        },
        {
          "key": "D",
          "text": "A*"
        }
      ],
      "correctAnswer": "DFS",
      "explanation": "DFS uses backtracking to explore paths, returning to previous nodes when dead-ends are reached.",
      "difficulty": "easy"
    },
