{
  "topicId": "core-principles",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "Which OOP concept binds data and methods together?",
      "options": [
        {
          "key": "A",
          "text": "Abstraction"
        },
        {
          "key": "B",
          "text": "Encapsulation"
        },
        {
          "key": "C",
          "text": "Inheritance"
        },
        {
          "key": "D",
          "text": "Polymorphism"
        }
      ],
      "correctAnswer": "Encapsulation",
      "explanation": "Encapsulation bundles data and methods into a single unit (class), restricting direct access to some components.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "What is the process of hiding internal implementation details called?",
      "options": [
        {
          "key": "A",
          "text": "Encapsulation"
        },
        {
          "key": "B",
          "text": "Abstraction"
        },
        {
          "key": "C",
          "text": "Inheritance"
        },
        {
          "key": "D",
          "text": "Polymorphism"
        }
      ],
      "correctAnswer": "Abstraction",
      "explanation": "Abstraction hides complex implementation details and shows only essential features to the user.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "Which principle allows a class to acquire properties of another class?",
      "options": [
        {
          "key": "A",
          "text": "Encapsulation"
        },
        {
          "key": "B",
          "text": "Abstraction"
        },
        {
          "key": "C",
          "text": "Inheritance"
        },
        {
          "key": "D",
          "text": "Polymorphism"
        }
      ],
      "correctAnswer": "Inheritance",
      "explanation": "Inheritance enables a derived class to inherit attributes and methods from a base class.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-4",
      "question": "The ability to take many forms is called:",
      "options": [
        {
          "key": "A",
          "text": "Encapsulation"
        },
        {
          "key": "B",
          "text": "Abstraction"
        },
        {
          "key": "C",
          "text": "Inheritance"
        },
        {
          "key": "D",
          "text": "Polymorphism"
        }
      ],
      "correctAnswer": "Polymorphism",
      "explanation": "Polymorphism allows objects of different classes to be treated as objects of a common superclass.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-5",
      "question": "Which access specifier makes members accessible only within the class?",
      "options": [
        {
          "key": "A",
          "text": "Public"
        },
        {
          "key": "B",
          "text": "Private"
        },
        {
          "key": "C",
          "text": "Protected"
        },
        {
          "key": "D",
          "text": "Default"
        }
      ],
      "correctAnswer": "Private",
      "explanation": "Private members are accessible only within the class they are declared in.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-6",
      "question": "What is a blueprint for creating objects called?",
      "options": [
        {
          "key": "A",
          "text": "Object"
        },
        {
          "key": "B",
          "text": "Method"
        },
        {
          "key": "C",
          "text": "Class"
        },
        {
          "key": "D",
          "text": "Function"
        }
      ],
      "correctAnswer": "Class",
      "explanation": "A class is a blueprint or template that defines the structure and behavior of objects.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-7",
      "question": "When a derived class defines a method already in base class, it is called:",
      "options": [
        {
          "key": "A",
          "text": "Overloading"
        },
        {
          "key": "B",
          "text": "Overriding"
        },
        {
          "key": "C",
          "text": "Hiding"
        },
        {
          "key": "D",
          "text": "Shadowing"
        }
      ],
      "correctAnswer": "Overriding",
      "explanation": "Method overriding allows a derived class to provide a specific implementation of a base class method.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-8",
      "question": "Which type of inheritance involves one base class and one derived class?",
      "options": [
        {
          "key": "A",
          "text": "Multiple Inheritance"
        },
        {
          "key": "B",
          "text": "Multilevel Inheritance"
        },
        {
          "key": "C",
          "text": "Single Inheritance"
        },
        {
          "key": "D",
          "text": "Hierarchical Inheritance"
        }
      ],
      "correctAnswer": "Single Inheritance",
      "explanation": "Single inheritance involves one base class and one derived class.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-9",
      "question": "A class that cannot be instantiated is called:",
      "options": [
        {
          "key": "A",
          "text": "Abstract Class"
        },
        {
          "key": "B",
          "text": "Concrete Class"
        },
        {
          "key": "C",
          "text": "Base Class"
        },
        {
          "key": "D",
          "text": "Derived Class"
        }
      ],
      "correctAnswer": "Abstract Class",
      "explanation": "An abstract class may contain abstract methods without implementation and cannot be instantiated directly.",
      "difficulty": "medium"
    },
    {
