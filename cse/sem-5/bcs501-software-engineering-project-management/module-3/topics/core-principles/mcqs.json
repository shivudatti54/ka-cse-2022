      "difficulty": "easy"
    },
    {
      "id": "mcq-12",
      "question": "What is the size of an object in OOP determined by?",
      "options": [
        {
          "key": "A",
          "text": "Only methods"
        },
        {
          "key": "B",
          "text": "Only data members"
        },
        {
          "key": "C",
          "text": "Both data members and methods"
        },
        {
          "key": "D",
          "text": "Number of constructors"
        }
      ],
      "correctAnswer": "Only data members",
      "explanation": "Object size is determined by its data members (attributes), not by its methods which are shared.",
      "difficulty": "hard"
    },
    {
