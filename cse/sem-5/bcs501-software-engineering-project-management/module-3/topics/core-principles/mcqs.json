    },
    {
      "id": "mcq-11",
      "question": "Which OOP principle promotes code reusability?",
      "options": [
        {
          "key": "A",
          "text": "Encapsulation"
        },
        {
          "key": "B",
          "text": "Abstraction"
        },
        {
          "key": "C",
          "text": "Inheritance"
        },
        {
          "key": "D",
          "text": "Polymorphism"
        }
      ],
      "correctAnswer": "Inheritance",
