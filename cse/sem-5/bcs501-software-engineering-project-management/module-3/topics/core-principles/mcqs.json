          "text": "static"
        },
        {
          "key": "B",
          "text": "final"
        },
        {
          "key": "C",
          "text": "sealed"
        },
        {
          "key": "D",
          "text": "abstract"
        }
      ],
      "correctAnswer": "sealed",
