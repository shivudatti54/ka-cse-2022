    },
    {
      "id": "mcq-12",
      "question": "Opportunity cost represents:",
      "options": [
        {
          "key": "A",
          "text": "Project revenue"
        },
        {
          "key": "B",
          "text": "Cost of delays"
        },
        {
          "key": "C",
          "text": "Benefits foregone from alternative projects"
        },
        {
          "key": "D",
          "text": "Total project budget"
        }
      ],
      "correctAnswer": "C",
      "explanation": "Opportunity cost is the potential benefit lost when choosing one project over another alternative.",
      "difficulty": "medium"
    },
    {
