{
  "topicId": "business-case",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "A business case is primarily used to:",
      "options": [
        {
          "key": "A",
          "text": "Document technical specifications"
        },
        {
          "key": "B",
          "text": "Justify project investment"
        },
        {
          "key": "C",
          "text": "Schedule project milestones"
        },
        {
          "key": "D",
          "text": "Define software architecture"
        }
      ],
      "correctAnswer": "B",
      "explanation": "The business case provides justification for initiating a project by presenting costs, benefits, and risks for decision-making.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "Which of the following is NOT a component of a business case?",
      "options": [
        {
          "key": "A",
          "text": "Executive summary"
        },
        {
          "key": "B",
          "text": "Project schedule"
        },
        {
          "key": "C",
          "text": "Cost-benefit analysis"
        },
        {
          "key": "D",
          "text": "Risk assessment"
        }
      ],
      "correctAnswer": "B",
      "explanation": "Project schedule is part of project planning, not the business case. Business case includes executive summary, CBA, risk assessment, and recommendations.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "A project with positive NPV should be:",
      "options": [
        {
          "key": "A",
          "text": "Rejected immediately"
        },
        {
          "key": "B",
          "text": "Accepted if IRR is higher than cost of capital"
        },
        {
          "key": "C",
          "text": "Deferred to next year"
        },
        {
          "key": "D",
          "text": "Sent for re-evaluation"
        }
      ],
      "correctAnswer": "B",
      "explanation": "A positive NPV indicates value creation. However, it should also be accepted only if IRR exceeds the required rate of return.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-4",
      "question": "ROI is calculated as:",
      "options": [
        {
          "key": "A",
          "text": "Benefits minus Costs"
        },
        {
          "key": "B",
          "text": "(Benefits/Costs) × 100%"
        },
        {
          "key": "C",
          "text": "(Net Profit/Cost) × 100%"
        },
        {
          "key": "D",
          "text": "Annual Cash Flow/Total Investment"
        }
      ],
      "correctAnswer": "C",
      "explanation": "ROI = (Net Profit / Cost of Investment) × 100%, which shows the percentage return on the invested capital.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-5",
      "question": "Intangible benefits in a business case include:",
      "options": [
        {
          "key": "A",
          "text": "Increased revenue"
        },
        {
          "key": "B",
          "text": "Cost savings"
        },
        {
          "key": "C",
          "text": "Improved customer satisfaction"
        },
        {
          "key": "D",
          "text": "Reduced operational costs"
        }
      ],
      "correctAnswer": "C",
      "explanation": "Intangible benefits are qualitative and difficult to quantify, such as customer satisfaction, employee morale, or brand reputation.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-6",
      "question": "The IRR is the discount rate that makes:",
      "options": [
        {
          "key": "A",
          "text": "NPV positive"
        },
        {
          "key": "B",
          "text": "NPV zero"
        },
        {
          "key": "C",
          "text": "Benefits equal to costs"
        },
        {
          "key": "D",
          "text": "Payback period minimum"
        }
      ],
      "correctAnswer": "B",
      "explanation": "IRR is the rate at which the NPV equals zero. It's the break-even discount rate for the project.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-7",
      "question": "Strategic alignment ensures:",
      "options": [
        {
          "key": "A",
          "text": "Technical compatibility"
        },
        {
          "key": "B",
          "text": "Project supports organizational goals"
        },
        {
          "key": "C",
          "text": "Budget approval"
        },
        {
          "key": "D",
          "text": "Team competency"
        }
      ],
      "correctAnswer": "B",
      "explanation": "Strategic alignment confirms that the project supports the organization's long-term objectives and vision.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-8",
      "question": "Which feasibility assessment evaluates if the organization can afford the project?",
