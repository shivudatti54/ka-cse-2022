    {
      "id": "mcq-11",
      "question": "The payback period measures:",
      "options": [
        {
          "key": "A",
          "text": "Project quality"
        },
        {
          "key": "B",
          "text": "Time to recover investment"
        },
        {
          "key": "C",
          "text": "Total project cost"
        },
        {
          "key": "D",
          "text": "Risk level"
        }
