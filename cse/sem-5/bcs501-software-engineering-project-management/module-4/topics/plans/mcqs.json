      "id": "mcq-1",
      "question": "Which document serves as a blueprint for the entire testing process?",
      "options": [
        {
          "key": "A",
          "text": "Test Case"
        },
        {
          "key": "B",
          "text": "Test Plan"
        },
        {
          "key": "C",
          "text": "Test Strategy"
        },
        {
          "key": "D",
          "text": "Test Report"
        }
      ],
      "correctAnswer": "Test Plan",
      "explanation": "Test Plan is a comprehensive document outlining scope, approach, resources, and schedule of testing activities - it serves as a blueprint.",
