    {
      "id": "mcq-1",
      "question": "Which of the following is NOT a valid criterion for categorizing software projects?",
      "options": [
        {
          "key": "A",
          "text": "Size based on LOC"
        },
        {
          "key": "B",
          "text": "Color scheme used"
        },
        {
          "key": "C",
          "text": "Complexity level"
        },
        {
          "key": "D",
          "text": "Development methodology"
        }
      ],
      "correctAnswer": "Color scheme used",
      "explanation": "Color scheme is unrelated to project characteristics. Size (LOC), complexity, and methodology are standard categorization criteria.",
      "difficulty": "easy"
    },
