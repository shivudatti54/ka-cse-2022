      "correctAnswer": "od -A n file",
      "explanation": "od -A n sets address-base to none, removing the address column from the output.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-18",
      "question": "What is the output of echo \"hello\" | wc -c?",
      "options": [
        {
          "key": "A",
          "text": "5"
        },
        {
          "key": "B",
          "text": "6"
        },
        {
          "key": "C",
          "text": "4"
        },
        {
          "key": "D",
          "text": "hello"
        }
      ],
      "correctAnswer": "6",
