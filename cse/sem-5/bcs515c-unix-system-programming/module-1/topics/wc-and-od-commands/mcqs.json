    },
    {
      "id": "mcq-19",
      "question": "Which command is equivalent to wc -l < file.txt?",
      "options": [
        {
          "key": "A",
          "text": "cat file.txt | wc -l"
        },
        {
          "key": "B",
          "text": "wc -l file.txt"
        },
        {
          "key": "C",
          "text": "wc < file.txt"
        },
        {
          "key": "D",
          "text": "All of the above"
        }
      ],
      "correctAnswer": "All of the above",
      "explanation": "All these commands will display the line count of file.txt. The difference is in output format - with redirection, only the count is shown.",
      "difficulty": "medium"
    },
    {
