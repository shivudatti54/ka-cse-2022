{
  "topicId": "wc-and-od-commands",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "What does the wc command primarily used for?",
      "options": [
        {
          "key": "A",
          "text": "Count words in a file"
        },
        {
          "key": "B",
          "text": "Count lines, words, and characters"
        },
        {
          "key": "C",
          "text": "Delete files"
        },
        {
          "key": "D",
          "text": "Compress files"
        }
      ],
      "correctAnswer": "Count lines, words, and characters",
      "explanation": "WC (Word Count) is a utility command that counts the number of lines, words, bytes, and characters in a file or input stream.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "Which option of wc command is used to count only lines?",
      "options": [
        {
          "key": "A",
          "text": "-w"
        },
        {
          "key": "B",
          "text": "-c"
        },
        {
          "key": "C",
          "text": "-l"
        },
        {
          "key": "D",
          "text": "-m"
        }
      ],
      "correctAnswer": "-l",
      "explanation": "The -l option specifically counts and displays the number of newline characters, which equals the number of lines in a file.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "What will be the output of wc -l file.txt if file.txt has 10 lines?",
      "options": [
        {
          "key": "A",
          "text": "10"
        },
        {
          "key": "B",
          "text": "file.txt 10"
        },
        {
          "key": "C",
          "text": "10 file.txt"
        },
        {
          "key": "D",
          "text": "10 lines"
        }
      ],
      "correctAnswer": "10",
      "explanation": "When used with a single file, wc displays the count followed by the filename by default.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-4",
      "question": "What does wc -c display?",
      "options": [
        {
          "key": "A",
          "text": "Number of characters"
        },
        {
          "key": "B",
          "text": "Number of words"
        },
        {
          "key": "C",
          "text": "Number of bytes"
        },
        {
          "key": "D",
          "text": "Number of lines"
        }
      ],
      "correctAnswer": "Number of bytes",
      "explanation": "The -c option displays the count of bytes in a file, which is typically the same as the file size.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-5",
      "question": "Which od option is used to skip initial bytes of a file?",
      "options": [
        {
          "key": "A",
          "text": "-N"
        },
        {
          "key": "B",
          "text": "-t"
        },
        {
          "key": "C",
          "text": "-j"
        },
        {
          "key": "D",
          "text": "-A"
        }
      ],
      "correctAnswer": "-j",
      "explanation": "The -j option skips the first N bytes of the input file before starting to dump the content.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-6",
      "question": "What does od -t x1 display?",
      "output": "Hexadecimal bytes separated by spaces",
      "explanation": "The -t x1 option displays output in hexadecimal format with 1 byte per value, space-separated.",
      "difficulty": "medium",
      "options": [
        {
          "key": "A",
          "text": "Option A"
        },
        {
          "key": "B",
          "text": "Option B"
        },
        {
          "key": "C",
          "text": "Option C"
        },
        {
          "key": "D",
          "text": "Option D"
        }
      ],
      "correctAnswer": "A"
    },
    {
      "id": "mcq-7",
      "question": "Which od option is used to display ASCII characters?",
      "options": [
        {
          "key": "A",
          "text": "-t c"
        },
        {
          "key": "B",
          "text": "-t a"
        },
        {
          "key": "C",
          "text": "-t ASCII"
        },
        {
          "key": "D",
          "text": "-c"
        }
      ],
      "correctAnswer": "-t c",
      "explanation": "The -t c option displays characters, interpreting bytes as ASCII characters and showing printable characters and backslash escapes for non-printable ones.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-8",
      "question": "What is the default address base in od command?",
      "options": [
        {
          "key": "A",
          "text": "Decimal"
        },
        {
          "key": "B",
          "text": "Hexadecimal"
        },
        {
          "key": "C",
          "text": "Octal"
        },
        {
          "key": "D",
          "text": "None"
        }
      ],
      "correctAnswer": "Octal",
      "explanation": "By default, od uses octal (base-8) for displaying file offsets/addresses in the output.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-9",
      "question": "What does od -A n do?",
      "options": [
        {
          "key": "A",
          "text": "Shows decimal addresses"
        },
        {
          "key": "B",
          "text": "Shows hex addresses"
        },
        {
          "key": "C",
          "text": "Removes address column"
        },
        {
          "key": "D",
          "text": "Shows octal addresses"
        }
      ],
      "correctAnswer": "Removes address column",
      "explanation": "The -A n option sets the address base to 'none', which removes the address/offset column from the output.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-10",
      "question": "Which command displays only word count from a file?",
      "options": [
        {
          "key": "A",
          "text": "wc -w filename"
        },
        {
          "key": "B",
          "text": "wc filename"
        },
        {
          "key": "C",
          "text": "wc -words filename"
        },
        {
          "key": "D",
          "text": "wc --words filename"
        }
      ],
      "correctAnswer": "wc -w filename",
      "explanation": "The -w option specifically displays only the word count from the specified file.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-11",
      "question": "What will wc -l -w file.txt display?",
      "options": [
        {
          "key": "A",
          "text": "Only line count"
        },
        {
          "key": "B",
          "text": "Only word count"
        },
        {
          "key": "C",
          "text": "Line count and word count"
        },
        {
          "key": "D",
          "text": "Error"
        }
      ],
      "correctAnswer": "Line count and word count",
      "explanation": "When multiple options are used, wc displays all corresponding counts in order: lines, words, bytes, characters.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-12",
      "question": "What is the purpose of od -v option?",
      "options": [
        {
          "key": "A",
          "text": "Verbose mode"
        },
        {
          "key": "B",
          "text": "Show version"
        },
        {
          "key": "C",
          "text": "Prevent duplicate line suppression"
        },
        {
          "key": "D",
          "text": "Verify file"
        }
      ],
      "correctAnswer": "Prevent duplicate line suppression",
      "explanation": "The -v option (no duplication) shows all lines even if they are identical to the previous line, unlike the default behavior.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-13",
      "question": "Which command shows first 32 bytes of a binary file in hex?",
      "options": [
        {
          "key": "A",
          "text": "od -N 32 -t x1 file.bin"
        },
        {
          "key": "B",
          "text": "od -N 32 -t x file.bin"
        },
        {
          "key": "C",
          "text": "od -j 32 -t x1 file.bin"
        },
        {
          "key": "D",
          "text": "od -32 -t x1 file.bin"
        }
      ],
      "correctAnswer": "od -N 32 -t x1 file.bin",
      "explanation": "-N 32 limits output to first 32 bytes, -t x1 displays them in hexadecimal format with 1 byte per value.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-14",
      "question": "What does wc -L return?",
      "options": [
        {
          "key": "A",
          "text": "Longest line length"
        },
        {
          "key": "B",
          "text": "Total lines"
        },
        {
          "key": "C",
          "text": "Last line number"
        },
        {
          "key": "D",
          "text": "License info"
        }
      ],
      "correctAnswer": "Longest line length",
      "explanation": "The -L option prints the length of the longest line (in characters) in the file.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-15",
      "question": "Which od type displays signed decimal?",
      "options": [
        {
          "key": "A",
          "text": "-t d"
        },
        {
          "key": "B",
          "text": "-t s"
        },
        {
          "key": "C",
          "text": "-t i"
        },
        {
          "key": "D",
          "text": "-t u"
