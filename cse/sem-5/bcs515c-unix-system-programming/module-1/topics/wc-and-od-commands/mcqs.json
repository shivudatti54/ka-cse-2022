    },
    {
      "id": "mcq-17",
      "question": "How to display file content without addresses using od?",
      "options": [
        {
          "key": "A",
          "text": "od -A n file"
        },
        {
          "key": "B",
          "text": "od -n file"
        },
        {
          "key": "C",
          "text": "od -no-address file"
        },
        {
          "key": "D",
          "text": "od -a file"
        }
