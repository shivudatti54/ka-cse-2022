{
  "topicId": "relative-and-absolute-pathnames-directory-commands",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "Which command displays the current working directory?",
      "options": [
        {
          "key": "A",
          "text": "pwd"
        },
        {
          "key": "B",
          "text": "cd"
        },
        {
          "key": "C",
          "text": "ls"
        },
        {
          "key": "D",
          "text": "dir"
        }
      ],
      "correctAnswer": "pwd",
      "explanation": "pwd (Print Working Directory) displays the absolute path of the current directory you are in.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "What does the path /home/user/documents represent?",
      "options": [
        {
          "key": "A",
          "text": "Relative path"
        },
        {
          "key": "B",
          "text": "Absolute path"
        },
        {
          "key": "C",
          "text": "Shortcut path"
        },
        {
          "key": "D",
          "text": "Temporary path"
        }
      ],
      "correctAnswer": "Absolute path",
      "explanation": "It starts with '/' (root directory), making it an absolute path.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "What does '..' represent in a path?",
      "options": [
        {
          "key": "A",
          "text": "Root directory"
        },
        {
          "key": "B",
          "text": "Current directory"
        },
        {
          "key": "C",
          "text": "Parent directory"
        },
        {
          "key": "D",
          "text": "Home directory"
        }
      ],
      "correctAnswer": "Parent directory",
      "explanation": "'..' is used to refer to the parent directory (one level up).",
      "difficulty": "easy"
    },
    {
      "id": "mcq-4",
      "question": "Which symbol represents the home directory?",
      "options": [
        {
          "key": "A",
          "text": "."
        },
        {
          "key": "B",
          "text": ".."
        },
        {
          "key": "C",
          "text": "~"
        },
        {
          "key": "D",
          "text": "-"
        }
      ],
      "correctAnswer": "~",
      "explanation": "Tilde (~) represents the current user's home directory in Linux/Unix.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-5",
      "question": "If you are in /home/user/docs and run 'cd ..', where will you be?",
      "options": [
        {
          "key": "A",
          "text": "docs"
        },
        {
          "key": "B",
          "text": "user"
        },
        {
          "key": "C",
          "text": "home"
        },
        {
          "key": "D",
          "text": "/home/user/docs"
        }
      ],
      "correctAnswer": "user",
      "explanation": "'..' moves up one level, so from /home/user/docs you go to /home/user.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-6",
      "question": "What does 'cd -' do?",
      "options": [
        {
          "key": "A",
          "text": "Goes to root"
        },
        {
          "key": "B",
          "text": "Goes to home"
        },
        {
          "key": "C",
          "text": "Goes to previous directory"
        },
        {
          "key": "D",
          "text": "Lists directories"
        }
      ],
      "correctAnswer": "Goes to previous directory",
      "explanation": "cd - switches to the previous working directory (the directory before the last cd command).",
      "difficulty": "medium"
    },
    {
      "id": "mcq-7",
      "question": "Which command is used to create a new directory?",
      "options": [
        {
          "key": "A",
          "text": "rm"
        },
        {
          "key": "B",
          "text": "mkdir"
        },
        {
          "key": "C",
          "text": "touch"
        },
        {
          "key": "D",
          "text": "create"
        }
      ],
      "correctAnswer": "mkdir",
      "explanation": "mkdir (Make Directory) creates new directories in Linux/Unix.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-8",
      "question": "What is the correct command to list all files including hidden ones?",
      "options": [
        {
          "key": "A",
          "text": "ls"
        },
        {
          "key": "B",
          "text": "ls -a"
        },
        {
          "key": "C",
          "text": "ls -l"
        },
        {
          "key": "D",
          "text": "dir"
        }
      ],
      "correctAnswer": "ls -a",
      "explanation": "ls -a lists all files including those starting with '.' (hidden files).",
      "difficulty": "medium"
    },
    {
      "id": "mcq-9",
      "question": "What does './program' mean?",
      "options": [
        {
          "key": "A",
          "text": "Run program from home"
        },
        {
          "key": "B",
          "text": "Run program from root"
        },
        {
          "key": "C",
          "text": "Run program from current directory"
        },
        {
          "key": "D",
          "text": "Run program from parent"
        }
      ],
      "correctAnswer": "Run program from current directory",
      "explanation": "'.' represents current directory, so ./program runs program in current directory.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-10",
      "question": "Which command removes an empty directory?",
      "options": [
        {
          "key": "A",
          "text": "rm"
        },
        {
          "key": "B",
          "text": "rmdir"
        },
        {
          "key": "C",
          "text": "del"
        },
        {
          "key": "D",
          "text": "remove"
        }
      ],
      "correctAnswer": "rmdir",
      "explanation": "rmdir removes empty directories. For non-empty directories, rm -r is needed.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-11",
      "question": "What is the absolute path of a file located at /home/student/data/file.txt?",
      "options": [
        {
          "key": "A",
          "text": "data/file.txt"
        },
        {
          "key": "B",
          "text": "../student/data/file.txt"
        },
        {
          "key": "C",
          "text": "/home/student/data/file.txt"
        },
        {
          "key": "D",
          "text": "./data/file.txt"
        }
      ],
      "correctAnswer": "/home/student/data/file.txt",
      "explanation": "Absolute paths always start from root (/) and provide complete path location.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-12",
      "question": "If pwd shows /opt and you run 'cd ../var/log', where will you be?",
      "options": [
        {
          "key": "A",
          "text": "/var/log"
        },
        {
          "key": "B",
          "text": "/opt/var/log"
        },
        {
          "key": "C",
          "text": "/var"
        },
        {
          "key": "D",
          "text": "/opt/../var/log"
        }
      ],
      "correctAnswer": "/var/log",
      "explanation": "'..' from /opt goes to /, then /var/log becomes absolute path /var/log.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-13",
      "question": "Which symbol represents the current directory?",
      "options": [
        {
          "key": "A",
          "text": "."
        },
        {
          "key": "B",
          "text": ".."
        },
        {
          "key": "C",
          "text": "/"
        },
        {
          "key": "D",
          "text": "~"
        }
      ],
      "correctAnswer": ".",
      "explanation": "Single dot (.) represents the current working directory.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-14",
      "question": "What will 'cd ~username' do?",
      "options": [
        {
          "key": "A",
          "text": "Go to current user's home"
        },
        {
          "key": "B",
          "text": "Go to specified user's home"
        },
        {
          "key": "C",
          "text": "Go to root"
        },
        {
          "key": "D",
          "text": "Show error"
        }
      ],
      "correctAnswer": "Go to specified user's home",
      "explanation": "cd ~username navigates to the home directory of the specified user.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-15",
      "question": "What is the root directory represented by?",
      "options": [
        {
          "key": "A",
          "text": "."
        },
        {
          "key": "B",
          "text": ".."
        },
        {
          "key": "C",
          "text": "~"
        },
        {
          "key": "D",
          "text": "/"
        }
      ],
      "correctAnswer": "/",
      "explanation": "Forward slash (/) represents the root directory - the top of the filesystem hierarchy.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-16",
      "question": "Which is NOT a valid directory command?",
      "options": [
        {
          "key": "A",
          "text": "pwd"
        },
        {
          "key": "B",
          "text": "cd"
        },
        {
          "key": "C",
          "text": "ls"
        },
        {
          "key": "D",
          "text": "path"
        }
      ],
      "correctAnswer": "path",
      "explanation": "path is not a standard directory command. pwd, cd, and ls are all directory navigation/listing commands.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-17",
      "question": "What does 'ls ..' do?",
      "options": [
        {
          "key": "A",
          "text": "List current directory"
        },
        {
          "key": "B",
          "text": "List parent directory"
        },
        {
          "key": "C",
          "text": "List root"
        },
        {
          "key": "D",
          "text": "Show error"
        }
      ],
      "correctAnswer": "List parent directory",
      "explanation": "ls .. lists contents of the parent directory using relative path.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-18",
      "question": "If you are in /home/user and run 'mkdir ../backup', where is the directory created?",
      "options": [
        {
          "key": "A",
          "text": "/home/backup"
        },
        {
          "key": "B",
          "text": "/backup"
        },
        {
          "key": "C",
          "text": "/home/user/../backup"
        },
        {
          "key": "D",
          "text": "Both A and C are correct"
        }
      ],
      "correctAnswer": "/home/backup",
      "explanation": ".. from /home goes to /home's parent (which is /), so ../backup = /home/backup.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-19",
      "question": "Which command creates multiple nested directories at once?",
      "options": [
        {
          "key": "A",
          "text": "mkdir"
        },
        {
          "key": "B",
          "text": "mkdir -p"
        },
        {
          "key": "C",
          "text": "mkpath"
        },
        {
          "key": "D",
          "text": "makedirs"
        }
      ],
      "correctAnswer": "mkdir -p",
      "explanation": "mkdir -p creates parent directories as needed. Example: mkdir -p a/b/c creates a, b, and c.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-20",
      "question": "What is the difference between 'cd' and 'cd ~'?",
      "options": [
        {
          "key": "A",
          "text": "Same thing"
        },
        {
          "key": "B",
          "text": "cd goes to root, cd ~ goes to home"
        },
        {
          "key": "C",
          "text": "cd goes to previous, cd ~ goes to home"
        },
        {
          "key": "D",
          "text": "cd is invalid without argument"
        }
      ],
      "correctAnswer": "Same thing",
      "explanation": "cd without arguments and cd ~ both navigate to the user's home directory.",
      "difficulty": "medium"
    }
  ]
}
