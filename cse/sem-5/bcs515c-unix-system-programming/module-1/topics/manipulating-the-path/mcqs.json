{
  "topicId": "manipulating-the-path",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "What will os.path.join('home', 'user', 'docs') return on Windows?",
      "options": [
        {
          "key": "A",
          "text": "home\\user\\docs"
        },
        {
          "key": "B",
          "text": "home/user/docs"
        },
        {
          "key": "C",
          "text": "home\\\\user\\\\docs"
        },
        {
          "key": "D",
          "text": "home user docs"
        }
      ],
      "correctAnswer": "home\\user\\docs",
      "explanation": "os.path.join() uses OS-specific separators - backslash on Windows, forward slash on Unix.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "Which function checks if a path points to a regular file?",
      "options": [
        {
          "key": "A",
          "text": "os.path.exists()"
        },
        {
          "key": "B",
          "text": "os.path.isfile()"
        },
        {
          "key": "C",
          "text": "os.path.isdir()"
        },
        {
          "key": "D",
          "text": "os.path.islink()"
        }
      ],
      "correctAnswer": "os.path.isfile()",
      "explanation": "isfile() specifically checks for regular files. exists() checks any path type.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "What does Path('file.txt').stem return for 'document.tar.gz'?",
      "options": [
        {
          "key": "A",
          "text": ".gz"
        },
        {
          "key": "B",
          "text": "tar.gz"
        },
        {
          "key": "C",
          "text": "document.tar"
        },
        {
          "key": "D",
          "text": "document"
        }
      ],
      "correctAnswer": "document.tar",
      "explanation": "stem returns everything except the final suffix - for 'document.tar.gz', stem is 'document.tar' (last extension removed).",
      "difficulty": "medium"
    },
    {
      "id": "mcq-4",
      "question": "What is the correct way to create a path object for '/home/user/file.txt'?",
      "options": [
        {
          "key": "A",
          "text": "Path('/home/user/file.txt')"
        },
        {
          "key": "B",
          "text": "pathlib('/home/user/file.txt')"
        },
        {
          "key": "C",
          "text": "new Path('/home/user/file.txt')"
        },
        {
          "key": "D",
          "text": "os.path('/home/user/file.txt')"
        }
      ],
      "correctAnswer": "Path('/home/user/file.txt')",
      "explanation": "Path is a class from pathlib module, instantiated directly with the path string.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-5",
      "question": "Which method returns the file extension including the dot?",
      "options": [
        {
          "key": "A",
          "text": ".stem"
        },
        {
          "key": "B",
          "text": ".suffix"
        },
        {
          "key": "C",
          "text": ".extension"
        },
        {
          "key": "D",
          "text": ".type"
        }
      ],
      "correctAnswer": ".suffix",
      "explanation": ".suffix returns the extension including the dot (e.g., '.txt'), while .stem returns just the filename without extension.",
      "difficulty": "easy"
    },
    {
