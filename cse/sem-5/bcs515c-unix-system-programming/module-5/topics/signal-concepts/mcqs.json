    {
      "id": "mcq-16",
      "question": "The exponential signal e^(at) is decaying when:",
      "options": [
        {
          "key": "A",
          "text": "a>0"
        },
        {
          "key": "B",
          "text": "a<0"
        },
        {
          "key": "C",
          "text": "a=0"
        },
        {
          "key": "D",
          "text": "a=1"
        }
      ],
      "correctAnswer": "a<0",
