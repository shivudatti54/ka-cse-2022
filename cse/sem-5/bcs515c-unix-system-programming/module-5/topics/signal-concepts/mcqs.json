    {
      "id": "mcq-17",
      "question": "What is the autocorrelation of a signal with itself?",
      "options": [
        {
          "key": "A",
          "text": "Zero"
        },
        {
          "key": "B",
          "text": "Infinity"
        },
        {
          "key": "C",
          "text": "Energy"
        },
        {
          "key": "D",
          "text": "Minimum at zero"
        }
      ],
      "correctAnswer": "Energy",
      "explanation": "Autocorrelation of a signal with itself at zero lag equals the signal's energy (or power for power signals).",
      "difficulty": "hard"
    },
    {
      "id": "mcq-18",
      "question": "A memoryless system output depends on:",
      "options": [
        {
          "key": "A",
          "text": "Only present input"
        },
        {
          "key": "B",
          "text": "Past inputs"
        },
        {
          "key": "C",
          "text": "Future inputs"
        },
        {
          "key": "D",
          "text": "All of above"
        }
      ],
      "correctAnswer": "Only present input",
      "explanation": "Memoryless system output y(t) depends only on the present input x(t), not on past or future values.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-19",
      "question": "The commutation property of convolution states:",
      "options": [
        {
          "key": "A",
          "text": "x*h = h*x"
        },
        {
          "key": "B",
          "text": "(x*h)*g = x*(h*g)"
        },
        {
          "key": "C",
          "text": "x*(h+g) = x*h + x*g"
        },
        {
          "key": "D",
          "text": "All of the above"
        }
      ],
      "correctAnswer": "All of the above",
      "explanation": "Convolution is commutative, associative, and distributive: x*h = h*x, (x*h)*g = x*(h*g), x*(h+g) = x*h + x*g.",
      "difficulty": "medium"
    },
    {
