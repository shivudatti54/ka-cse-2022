{
  "topicId": "signal-concepts",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "Which of the following is NOT a basic element of signal processing?",
      "options": [
        {
          "key": "A",
          "text": "Amplitude modulation"
        },
        {
          "key": "B",
          "text": "Time shifting"
        },
        {
          "key": "C",
          "text": "Scaling"
        },
        {
          "key": "D",
          "text": "Convolution"
        }
      ],
      "correctAnswer": "Amplitude modulation",
      "explanation": "Time shifting, scaling, and flipping are basic signal operations. Amplitude modulation is an application, not a basic element.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "The signal x(t) = sin(2t) is a:",
      "options": [
        {
          "key": "A",
          "text": "Energy signal"
        },
        {
          "key": "B",
          "text": "Power signal"
        },
        {
          "key": "C",
          "text": "Neither energy nor power"
        },
        {
          "key": "D",
          "text": "Both energy and power"
        }
      ],
      "correctAnswer": "Power signal",
      "explanation": "Sinusoidal signals are periodic and bounded, having finite non-zero average power. Their total energy is infinite.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "For a unit impulse signal δ(t), the value of ∫δ(t)dt from -∞ to ∞ is:",
      "options": [
        {
          "key": "A",
          "text": "0"
        },
        {
          "key": "B",
          "text": "1"
        },
        {
          "key": "C",
          "text": "∞"
        },
        {
          "key": "D",
          "text": "Undefined"
        }
      ],
      "correctAnswer": "1",
      "explanation": "The unit impulse has unit area (sifting property). The integral of δ(t) over all time equals 1.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-4",
      "question": "Which property does NOT hold for discrete-time unit impulse δ[n]?",
      "options": [
        {
          "key": "A",
          "text": "δ[n] = 1 at n=0"
        },
        {
          "key": "B",
          "text": "δ[n] = 0 otherwise"
        },
        {
          "key": "C",
          "text": "∑δ[n] = 1"
        },
        {
          "key": "D",
          "text": "∫δ(t)dt = 1"
        }
      ],
      "correctAnswer": "∫δ(t)dt = 1",
      "explanation": "δ[n] is discrete-time (summation applies, not integration). For discrete signals, we use summation: ∑δ[n] from -∞ to ∞ = 1.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-5",
      "question": "The fundamental period of x(t) = cos(4πt) is:",
      "options": [
        {
          "key": "A",
          "text": "0.5 seconds"
        },
        {
          "key": "B",
          "text": "1 second"
        },
        {
          "key": "C",
          "text": "2 seconds"
        },
        {
          "key": "D",
          "text": "4 seconds"
        }
      ],
      "correctAnswer": "0.5 seconds",
      "explanation": "Given ω = 4π, period T = 2π/ω = 2π/(4π) = 0.5 seconds.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-6",
      "question": "Which of the following is an odd signal?",
      "options": [
        {
          "key": "A",
          "text": "cos(t)"
        },
        {
          "key": "B",
          "text": "sin(t)"
        },
        {
          "key": "C",
          "text": "e^(-t)"
        },
        {
          "key": "D",
          "text": "t²"
        }
      ],
      "correctAnswer": "sin(t)",
      "explanation": "sin(-t) = -sin(t), so sin(t) is odd. cos(t) is even, e^(-t) is neither, t² is even.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-7",
      "question": "A system is linear if it satisfies:",
      "options": [
        {
          "key": "A",
          "text": "Superposition"
        },
        {
          "key": "B",
          "text": "Causality"
        },
        {
          "key": "C",
          "text": "Memorylessness"
        },
        {
          "key": "D",
          "text": "Stability"
        }
      ],
      "correctAnswer": "Superposition",
      "explanation": "Linear systems satisfy superposition (additivity + homogeneity). Causality, memorylessness, and stability are separate system properties.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-8",
      "question": "For an LTI system, output y(t) is equal to:",
      "options": [
        {
          "key": "A",
          "text": "x(t) + h(t)"
        },
        {
          "key": "B",
          "text": "x(t) * h(t)"
        },
        {
          "key": "C",
          "text": "x(t)h(t)"
        },
        {
          "key": "D",
          "text": "d/dt[x(t)]"
        }
      ],
      "correctAnswer": "x(t) * h(t)",
      "explanation": "For LTI systems, output is convolution of input with impulse response: y(t) = x(t) * h(t).",
      "difficulty": "easy"
    },
    {
      "id": "mcq-9",
      "question": "What is the value of u(t) - u(t-1)?",
      "options": [
        {
          "key": "A",
          "text": "Unit impulse"
        },
        {
          "key": "B",
          "text": "Unit step delayed"
        },
        {
          "key": "C",
          "text": "Rectangular pulse"
        },
        {
          "key": "D",
          "text": "Zero"
        }
      ],
      "correctAnswer": "Rectangular pulse",
      "explanation": "u(t) - u(t-1) equals 1 for 0≤t<1 and 0 elsewhere, forming a rectangular pulse of width 1.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-10",
      "question": "The rectangular function rect(t/T) equals:",
      "options": [
        {
          "key": "A",
          "text": "1 for |t|<T/2"
        },
        {
          "key": "B",
          "text": "1 for |t|≤T/2"
        },
        {
          "key": "C",
          "text": "0 for |t|<T/2"
        },
        {
          "key": "D",
          "text": "1 for all t"
        }
      ],
      "correctAnswer": "1 for |t|<T/2",
      "explanation": "Rect(t/T) = 1 for |t| < T/2 (or sometimes ≤ T/2), and 0 otherwise.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-11",
      "question": "Which signal has infinite energy but finite power?",
      "options": [
        {
          "key": "A",
          "text": "x(t) = e^(-at)u(t)"
        },
        {
          "key": "B",
          "text": "x(t) = e^(-|t|)"
        },
        {
          "key": "C",
          "text": "x(t) = sin(t)"
        },
        {
          "key": "D",
          "text": "x(t) = e^(-t)"
        }
      ],
      "correctAnswer": "x(t) = sin(t)",
      "explanation": "Sinusoidal signals are bounded and periodic, having infinite energy (integral diverges) but finite non-zero average power.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-12",
      "question": "The sgn(t) (signum) function equals:",
      "options": [
        {
          "key": "A",
          "text": "1 for t>0, 0 for t=0, -1 for t<0"
        },
        {
          "key": "B",
          "text": "1 for t≥0, -1 for t<0"
        },
        {
          "key": "C",
          "text": "1 for t>0, -1 for t≤0"
        },
        {
          "key": "D",
          "text": "-1 for t>0, 1 for t<0"
        }
      ],
      "correctAnswer": "1 for t>0, 0 for t=0, -1 for t<0",
      "explanation": "The signum function sgn(t) returns the sign of t: +1 for positive, 0 at origin, -1 for negative.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-13",
      "question": "A system is causal if:",
      "options": [
        {
          "key": "A",
          "text": "h(t) = 0 for t>0"
        },
        {
          "key": "B",
          "text": "h(t) = 0 for t<0"
        },
        {
          "key": "C",
          "text": "h(t) = 1 for t>0"
        },
        {
          "key": "D",
          "text": "h(t) = 1 for all t"
        }
      ],
      "correctAnswer": "h(t) = 0 for t<0",
      "explanation": "For causal systems, impulse response h(t) = 0 for t<0. Output depends only on present and past inputs.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-14",
      "question": "What does time inversion x(-t) do to a signal?",
      "options": [
        {
          "key": "A",
          "text": "Shifts right"
        },
        {
          "key": "B",
          "text": "Shifts left"
        },
        {
          "key": "C",
          "text": "Reflects about y-axis"
        },
        {
          "key": "D",
          "text": "Scales amplitude"
        }
      ],
      "correctAnswer": "Reflects about y-axis",
      "explanation": "Time inversion (flipping) x(-t) reflects the signal about the y-axis, reversing its time axis.",
      "difficulty": "easy"
    },
