      "id": "mcq-1",
      "question": "In M-ary signaling, if M=16, how many bits are represented per symbol?",
      "options": [
        {
          "key": "A",
          "text": "2 bits"
        },
        {
          "key": "B",
          "text": "4 bits"
        },
        {
          "key": "C",
          "text": "8 bits"
        },
        {
          "key": "D",
          "text": "16 bits"
        }
      ],
      "correctAnswer": "4 bits",
      "explanation": "log₂16 = 4, so each symbol represents 4 bits",
      "difficulty": "easy"
    },
