          "text": "1200 baud"
        },
        {
          "key": "D",
          "text": "2400 baud"
        }
      ],
      "correctAnswer": "600 baud",
      "explanation": "Symbol rate = bit rate / log₂M = 1200/2 = 600 baud",
      "difficulty": "medium"
