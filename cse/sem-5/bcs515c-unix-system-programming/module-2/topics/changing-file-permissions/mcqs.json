    },
    {
      "id": "mcq-20",
      "question": "To secure a private key file, what permissions should be set?",
      "options": [
        {
          "key": "A",
          "text": "644"
        },
        {
          "key": "B",
          "text": "755"
        },
        {
          "key": "C",
          "text": "600"
        },
        {
          "key": "D",
          "text": "777"
        }
