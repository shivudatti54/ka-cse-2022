{
  "topicId": "changing-file-permissions",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "What is the numeric value for 'Write' permission in Linux?",
      "options": [
        {
          "key": "A",
          "text": "1"
        },
        {
          "key": "B",
          "text": "2"
        },
        {
          "key": "C",
          "text": "3"
        },
        {
          "key": "D",
          "text": "4"
        }
      ],
      "correctAnswer": "2",
      "explanation": "Numeric permissions are: Read=4, Write=2, Execute=1. Write has value 2.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "Which command is used to change file permissions in Linux?",
      "options": [
        {
          "key": "A",
          "text": "chown"
        },
        {
          "key": "B",
          "text": "chmod"
        },
        {
          "key": "C",
          "text": "chmodown"
        },
        {
          "key": "D",
          "text": "permchange"
        }
      ],
      "correctAnswer": "chmod",
      "explanation": "chmod (change mode) is the command used to change file permissions in Linux/Unix.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "What does the permission string 'rw-r--r--' represent as a numeric value?",
      "options": [
        {
          "key": "A",
          "text": "644"
        },
        {
          "key": "B",
          "text": "666"
        },
        {
          "key": "C",
          "text": "755"
        },
        {
          "key": "D",
          "text": "777"
        }
      ],
      "correctAnswer": "644",
      "explanation": "rw- = 6 (4+2), r-- = 4, r-- = 4. So 644. Owner has read+write, others have read only.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-4",
      "question": "Which permission set is commonly used for executable files?",
      "options": [
        {
          "key": "A",
          "text": "644"
        },
        {
          "key": "B",
          "text": "755"
        },
        {
          "key": "C",
          "text": "777"
        },
        {
          "key": "D",
          "text": "600"
        }
      ],
      "correctAnswer": "755",
      "explanation": "755 gives owner full permissions (rwx=7) and others read+execute (r-x=5), common for scripts and programs.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-5",
      "question": "What does 'chmod u+x script.sh' do?",
      "options": [
        {
          "key": "A",
          "text": "Adds execute for all users"
        },
        {
          "key": "B",
          "text": "Adds execute for owner only"
        },
        {
          "key": "C",
          "text": "Removes execute for owner"
        },
        {
          "key": "D",
          "text": "Sets execute for group"
        }
      ],
      "correctAnswer": "Adds execute for owner only",
      "explanation": "u+x adds execute permission to the owner (user). g+x would add for group, o+x for others.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-6",
      "question": "What is the default umask value in most Linux systems?",
      "options": [
        {
          "key": "A",
          "text": "000"
        },
        {
          "key": "B",
          "text": "022"
        },
        {
          "key": "C",
          "text": "033"
        },
        {
          "key": "D",
          "text": "077"
        }
      ],
      "correctAnswer": "022",
      "explanation": "Default umask is typically 022, which subtracts 022 from default file/directory permissions.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-7",
      "question": "What is the permission value for rwxr-xr-x?",
      "options": [
        {
          "key": "A",
          "text": "755"
        },
        {
          "key": "B",
          "text": "775"
        },
        {
          "key": "C",
          "text": "644"
        },
        {
          "key": "D",
          "text": "711"
        }
      ],
      "correctAnswer": "755",
      "explanation": "rwx=7 (4+2+1), r-x=5 (4+0+1), r-x=5. Combined: 755.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-8",
      "question": "Which special permission is represented by the number 4000?",
      "options": [
        {
          "key": "A",
          "text": "Sticky Bit"
        },
        {
          "key": "B",
          "text": "SetGID"
        },
        {
          "key": "C",
          "text": "SetUID"
        },
        {
          "key": "D",
          "text": "Execute"
        }
      ],
      "correctAnswer": "SetUID",
      "explanation": "4000 represents SetUID, 2000 is SetGID, 1000 is Sticky Bit.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-9",
      "question": "What happens when you set the Sticky Bit on a directory?",
      "options": [
        {
          "key": "A",
          "text": "Everyone can delete files"
        },
        {
          "key": "B",
          "text": "Only owner can delete files"
        },
        {
          "key": "C",
          "text": "No one can access"
        },
        {
          "key": "D",
          "text": "Files become hidden"
        }
      ],
      "correctAnswer": "Only owner can delete files",
      "explanation": "Sticky Bit on a directory ensures only the file owner (or root) can delete/rename files. Example: /tmp",
      "difficulty": "medium"
    },
    {
      "id": "mcq-10",
      "question": "What is the permission of a file created with default umask 022?",
      "options": [
        {
          "key": "A",
          "text": "644"
        },
        {
          "key": "B",
          "text": "755"
        },
        {
          "key": "C",
          "text": "666"
        },
        {
          "key": "D",
          "text": "777"
        }
      ],
      "correctAnswer": "644",
      "explanation": "Default file permission is 666 (rw-rw-rw-). Subtract umask 022: 666-022=644.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-11",
      "question": "What does 'chmod -R 755 /mydir' do?",
      "options": [
        {
          "key": "A",
          "text": "Changes only file permissions"
        },
        {
          "key": "B",
          "text": "Changes directory permissions only"
        },
        {
          "key": "C",
          "text": "Changes all files and subdirectories"
        },
        {
          "key": "D",
          "text": "Changes permissions temporarily"
        }
      ],
      "correctAnswer": "Changes all files and subdirectories",
      "explanation": "-R flag makes chmod operate recursively on all files and directories within the specified path.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-12",
      "question": "Which permission allows only the owner to read and write, others have no access?",
      "options": [
        {
          "key": "A",
          "text": "600"
        },
        {
          "key": "B",
          "text": "700"
        },
        {
          "key": "C",
          "text": "400"
        },
        {
          "key": "D",
          "text": "100"
        }
      ],
      "correctAnswer": "600",
      "explanation": "600 = rw------- means owner has read+write (6), group and others have no permissions (0).",
      "difficulty": "medium"
    },
    {
      "id": "mcq-13",
      "question": "In symbolic mode, what does 'chmod a=r filename' do?",
      "options": [
        {
          "key": "A",
          "text": "Sets read for all only"
        },
        {
          "key": "B",
          "text": "Sets read and execute for all"
        },
        {
          "key": "C",
          "text": "Removes all permissions"
        },
        {
          "key": "D",
          "text": "Sets execute for owner"
        }
      ],
      "correctAnswer": "Sets read for all only",
      "explanation": "a=r sets read permission for all (owner, group, others) and removes write and execute.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-14",
      "question": "What does the 's' in 'rwsr-xr-x' indicate?",
      "options": [
        {
          "key": "A",
          "text": "Size is large"
        },
        {
          "key": "B",
          "text": "SetUID is set"
        },
        {
          "key": "C",
          "text": "File is shared"
        },
        {
          "key": "D",
          "text": "Special directory"
        }
      ],
      "correctAnswer": "SetUID is set",
      "explanation": "When SetUID is set on an executable, 'x' becomes 's'. This allows the program to run with owner's privileges.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-15",
      "question": "What is the permission of a directory created with default umask 022?",
      "options": [
        {
          "key": "A",
          "text": "755"
        },
        {
          "key": "B",
          "text": "777"
        },
        {
          "key": "C",
          "text": "644"
        },
        {
          "key": "D",
          "text": "700"
        }
      ],
      "correctAnswer": "755",
      "explanation": "Default directory permission is 777 (rwxrwxrwx). Subtract umask 022: 777-022=755.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-16",
      "question": "Which command removes write permission from group and others?",
      "options": [
        {
          "key": "A",
          "text": "chmod go-w filename"
        },
        {
          "key": "B",
          "text": "chmod a-w filename"
        },
        {
          "key": "C",
          "text": "chmod -w filename"
        },
        {
          "key": "D",
          "text": "chmod go=rw filename"
        }
      ],
      "correctAnswer": "chmod go-w filename",
      "explanation": "go-w removes write permission from group (g) and others (o). This sets permissions to r-xr-xr-x.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-17",
      "question": "What is 4755 permission used for?",
      "options": [
        {
          "key": "A",
          "text": "Standard file"
        },
        {
          "key": "B",
          "text": "Directory with sticky bit"
        },
        {
          "key": "C",
          "text": "Executable with SetUID"
        },
        {
          "key": "D",
          "text": "Read-only file"
        }
      ],
      "correctAnswer": "Executable with SetUID",
      "explanation": "4755 = 4 (SetUID) + 755. This sets the SetUID bit along with rwxr-xr-x permissions.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-18",
      "question": "What is the difference between chmod +x and chmod a+x?",
      "options": [
        {
          "key": "A",
          "text": "They are different"
        },
        {
          "key": "B",
          "text": "They are the same"
        },
        {
          "key": "C",
          "text": "+x only works on files"
        },
        {
          "key": "D",
          "text": "a+x only works on directories"
        }
      ],
      "correctAnswer": "They are the same",
      "explanation": "In chmod, '+' without a specifier defaults to 'a' (all), so chmod +x is equivalent to chmod a+x.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-19",
      "question": "What is the correct order of permission groups in ls -l output?",
      "options": [
        {
          "key": "A",
          "text": "Others, Group, Owner"
        },
        {
          "key": "B",
          "text": "Owner, Group, Others"
        },
        {
          "key": "C",
          "text": "Group, Owner, Others"
        },
        {
          "key": "D",
          "text": "All, Owner, Group"
