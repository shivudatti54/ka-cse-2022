      ],
      "correctAnswer": "Empty lines",
      "explanation": "^ matches start of line and $ matches end of line with nothing in between, so it matches empty lines.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-18",
      "question": "How do you match a literal backslash?",
      "options": [
