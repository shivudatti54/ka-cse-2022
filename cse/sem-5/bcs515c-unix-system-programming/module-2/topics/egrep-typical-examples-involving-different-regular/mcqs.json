{
  "topicId": "egrep-typical-examples-involving-different-regular",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "Which command is equivalent to egrep?",
      "options": [
        {
          "key": "A",
          "text": "grep -E"
        },
        {
          "key": "B",
          "text": "grep -F"
        },
        {
          "key": "C",
          "text": "grep -i"
        },
        {
          "key": "D",
          "text": "grep -v"
        }
      ],
      "correctAnswer": "grep -E",
      "explanation": "egrep is equivalent to grep -E, which enables extended regular expression support.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "What will 'egrep 'a+' file.txt' match?",
      "options": [
        {
          "key": "A",
          "text": "Exactly one 'a'"
        },
        {
          "key": "B",
          "text": "Zero or more 'a'"
        },
        {
          "key": "C",
          "text": "One or more 'a'"
        },
        {
          "key": "D",
          "text": "Only two 'a'"
        }
      ],
      "correctAnswer": "One or more 'a'",
      "explanation": "The + quantifier matches one or more occurrences of the preceding character, so 'a+' matches 'a', 'aa', 'aaa', etc.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "What does the pattern 'colou?r' match?",
      "options": [
        {
          "key": "A",
          "text": "colour only"
        },
        {
          "key": "B",
          "text": "color only"
        },
        {
          "key": "C",
          "text": "colour and color"
        },
        {
          "key": "D",
          "text": "colouur"
        }
      ],
      "correctAnswer": "colour and color",
      "explanation": "The ? makes the 'u' optional, so it matches both 'colour' (with u) and 'color' (without u).",
      "difficulty": "easy"
    },
    {
      "id": "mcq-4",
      "question": "Which pattern matches either 'cat' or 'dog'?",
      "options": [
        {
          "key": "A",
          "text": "[cat|dog]"
        },
        {
          "key": "B",
          "text": "(cat|dog)"
        },
        {
          "key": "C",
          "text": "cat|dog"
        },
        {
          "key": "D",
          "text": "{cat|dog}"
        }
      ],
      "correctAnswer": "cat|dog",
      "explanation": "The pipe | is the alternation operator in egrep, matching either the expression before or after it.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-5",
      "question": "What does '[A-Z][0-9]' match?",
      "options": [
        {
          "key": "A",
          "text": "A letter followed by a digit"
        },
        {
          "key": "B",
          "text": "A to Z and 0-9"
        },
        {
          "key": "C",
          "text": "One character either letter or digit"
        },
        {
          "key": "D",
          "text": "Uppercase only"
        }
      ],
      "correctAnswer": "A letter followed by a digit",
      "explanation": "This pattern matches one uppercase letter followed by one digit (0-9).",
      "difficulty": "medium"
    },
    {
      "id": "mcq-6",
      "question": "What is the meaning of '^The' at the start of a pattern?",
      "options": [
        {
          "key": "A",
          "text": "Ends with 'The'"
        },
        {
          "key": "B",
          "text": "Starts with 'The'"
        },
        {
          "key": "C",
          "text": "Contains 'The'"
        },
        {
          "key": "D",
          "text": "The letter T is capitalized"
        }
      ],
      "correctAnswer": "Starts with 'The'",
      "explanation": "The caret ^ is an anchor that matches the beginning of a line.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-7",
      "question": "How do you match a literal asterisk (*) character?",
      "options": [
        {
          "key": "A",
          "text": "[*]"
        },
        {
          "key": "B",
          "text": "*"
        },
        {
          "key": "C",
          "text": "\\*"
        },
        {
          "key": "D",
          "text": "(*)"
        }
      ],
      "correctAnswer": "\\*",
      "explanation": "Backslash escapes metacharacters in egrep, so \\* matches a literal asterisk.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-8",
      "question": "What does the pattern 'go{2,4}d' match?",
      "options": [
        {
          "key": "A",
          "text": "god only"
        },
        {
          "key": "B",
          "text": "good, goood, goooood"
        },
        {
          "key": "C",
          "text": "g2d, g3d, g4d"
        },
        {
          "key": "D",
          "text": "godd, good, goood"
        }
      ],
      "correctAnswer": "good, goood, goooood",
      "explanation": "{2,4} matches 2 to 4 occurrences of 'o', so it matches 'ood', 'ooood', 'oooood'.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-9",
      "question": "Which option displays line numbers in egrep output?",
      "options": [
        {
          "key": "A",
          "text": "-l"
        },
        {
          "key": "B",
          "text": "-n"
        },
        {
          "key": "C",
          "text": "-c"
        },
        {
          "key": "D",
          "text": "-v"
        }
      ],
      "correctAnswer": "-n",
      "explanation": "The -n option prefixes each matching line with its line number in the file.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-10",
      "question": "What will 'egrep '[^a-z]' file.txt' match?",
      "options": [
        {
          "key": "A",
          "text": "Only lowercase letters"
        },
        {
          "key": "B",
          "text": "Only uppercase letters"
        },
        {
          "key": "C",
          "text": "Any character not lowercase letter"
        },
        {
          "key": "D",
          "text": "All letters"
        }
      ],
      "correctAnswer": "Any character not lowercase letter",
      "explanation": "[^a-z] is a negated character class that matches any character except lowercase a to z.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-11",
      "question": "What does the pattern '(.)\\1' match?",
      "options": [
        {
          "key": "A",
          "text": "Any two characters"
        },
        {
          "key": "B",
          "text": "Two identical consecutive characters"
        },
        {
          "key": "C",
          "text": "Single character"
        },
        {
          "key": "D",
          "text": "Nothing"
        }
      ],
      "correctAnswer": "Two identical consecutive characters",
      "explanation": "\\1 is a backreference that matches the same character captured by the first group.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-12",
      "question": "What is the difference between * and + quantifiers?",
      "options": [
        {
          "key": "A",
          "text": "No difference"
        },
        {
          "key": "B",
          "text": "* matches zero or more, + matches one or more"
        },
        {
          "key": "C",
          "text": "+ matches zero or more"
        },
        {
          "key": "D",
          "text": "* is for words only"
        }
      ],
      "correctAnswer": "* matches zero or more, + matches one or more",
      "explanation": "* allows zero occurrences (optional), while + requires at least one occurrence.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-13",
      "question": "Which character class matches any digit?",
      "options": [
        {
          "key": "A",
          "text": "[[:alpha:]]"
        },
        {
          "key": "B",
          "text": "[[:digit:]]"
        },
        {
          "key": "C",
          "text": "[[:space:]]"
        },
        {
          "key": "D",
          "text": "[[:punct:]]"
        }
      ],
      "correctAnswer": "[[:digit:]]",
      "explanation": "[[:digit:]] is a POSIX character class that matches any digit 0-9.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-14",
      "question": "What does egrep -w 'hello' file.txt do?",
      "options": [
        {
          "key": "A",
          "text": "Matches hello anywhere"
        },
        {
          "key": "B",
          "text": "Matches only whole word 'hello'"
        },
        {
          "key": "C",
          "text": "Counts hello occurrences"
        },
        {
          "key": "D",
          "text": "Shows line numbers"
        }
      ],
      "correctAnswer": "Matches only whole word 'hello'",
