      "difficulty": "easy"
    },
    {
      "id": "mcq-16",
      "question": "Which pattern matches email addresses like user@domain.com?",
      "options": [
        {
          "key": "A",
          "text": "[\\w.@]+"
        },
        {
          "key": "B",
          "text": "\\w+@\\w+\\.\\w+"
        },
        {
          "key": "C",
          "text": "[a-z]+@[a-z]+\\.[a-z]+"
        },
        {
          "key": "D",
          "text": "All of above"
        }
      ],
      "correctAnswer": "\\w+@\\w+\\.[a-z]+",
      "explanation": "\\w+ matches word characters, \\. matches literal dot, [a-z]+ matches domain extension. This is a simple email pattern.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-17",
      "question": "What does the pattern '^$' match?",
      "options": [
        {
          "key": "A",
          "text": "Any line"
        },
        {
          "key": "B",
          "text": "Empty lines"
        },
        {
          "key": "C",
          "text": "Lines with two characters"
        },
        {
          "key": "D",
          "text": "Lines starting with $"
