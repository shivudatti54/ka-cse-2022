      "difficulty": "medium"
    },
    {
      "id": "mcq-15",
      "question": "What does 'egrep -c pattern file.txt' output?",
      "options": [
        {
          "key": "A",
          "text": "Matching lines"
        },
        {
          "key": "B",
          "text": "Count of matches"
        },
        {
          "key": "C",
          "text": "Line numbers"
        },
        {
          "key": "D",
          "text": "Inverted matches"
        }
      ],
      "correctAnswer": "Count of matches",
