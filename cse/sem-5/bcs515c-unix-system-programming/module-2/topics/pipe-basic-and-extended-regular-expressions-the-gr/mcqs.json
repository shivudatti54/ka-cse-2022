    {
      "id": "mcq-19",
      "question": "Which regex matches exactly 3 digits?",
      "options": [
        {
          "key": "A",
          "text": "[0-9]*"
        },
        {
          "key": "B",
          "text": "[0-9]+"
        },
        {
          "key": "C",
          "text": "[0-9]{3}"
        },
        {
          "key": "D",
