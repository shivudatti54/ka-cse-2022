      "question": "In ERE, what does the | operator do?",
      "options": [
        {
          "key": "A",
          "text": "Bitwise OR"
        },
        {
          "key": "B",
          "text": "Alternation (OR)"
        },
        {
          "key": "C",
          "text": "Pipe to file"
        },
        {
          "key": "D",
          "text": "End of pattern"
        }
      ],
      "correctAnswer": "Alternation (OR)",
      "explanation": "The | operator in Extended Regular Expressions matches either the expression before or after it.",
