  "mcqs": [
    {
      "id": "mcq-1",
      "question": "What is the primary purpose of a pipe (|) in Unix?",
      "options": [
        {
          "key": "A",
          "text": "To redirect error messages"
        },
        {
          "key": "B",
          "text": "To connect command output to another command's input"
        },
        {
          "key": "C",
          "text": "To create a new file"
        },
        {
          "key": "D",
          "text": "To terminate a process"
        }
      ],
      "correctAnswer": "To connect command output to another command's input",
      "explanation": "The pipe (|) takes the standard output of the command on the left and feeds it as standard input to the command on the right.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "Which command is used to search for patterns in text files using regular expressions?",
      "options": [
        {
          "key": "A",
          "text": "cat"
        },
        {
          "key": "B",
          "text": "ls"
        },
        {
          "key": "C",
          "text": "grep"
        },
        {
          "key": "D",
          "text": "chmod"
        }
      ],
      "correctAnswer": "grep",
      "explanation": "grep (Global Regular Expression Print) is specifically designed to search for patterns matching regular expressions.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "What does grep -l do?",
      "options": [
        {
          "key": "A",
          "text": "Shows line numbers"
        },
        {
          "key": "B",
          "text": "Lists filenames only"
        },
        {
          "key": "C",
          "text": "Makes search case-insensitive"
        },
        {
          "key": "D",
          "text": "Inverts match"
        }
      ],
      "correctAnswer": "Lists filenames only",
      "explanation": "The -l option outputs only the names of files containing matching lines, not the actual lines.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-4",
      "question": "In BRE, how do you match a literal asterisk?",
      "options": [
        {
          "key": "A",
          "text": "*"
        },
        {
          "key": "B",
          "text": "\\*"
        },
        {
          "key": "C",
          "text": ".*"
        },
        {
          "key": "D",
          "text": "[*]"
        }
      ],
      "correctAnswer": "\\*",
      "explanation": "In Basic Regular Expressions, special characters must be escaped with backslash to match them literally.",
      "difficulty": "medium"
    },
    {
