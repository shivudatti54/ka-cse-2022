    {
      "id": "mcq-10",
      "question": "In ERE, what does the + quantifier mean?",
      "options": [
        {
          "key": "A",
          "text": "Zero or more"
        },
        {
          "key": "B",
          "text": "One or more"
        },
        {
          "key": "C",
          "text": "Exactly one"
        },
        {
          "key": "D",
          "text": "Zero or one"
        }
      ],
      "correctAnswer": "One or more",
      "explanation": "+ matches one or more occurrences of the preceding element, unlike * which matches zero or more.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-11",
      "question": "What does the regex pattern 'go+d' match?",
      "options": [
        {
          "key": "A",
          "text": "gd"
        },
        {
          "key": "B",
          "text": "god"
        },
        {
          "key": "C",
          "text": "good"
        },
        {
          "key": "D",
          "text": "goooood"
        }
      ],
      "correctAnswer": "god",
      "explanation": "In ERE, + means one or more, so go+d matches 'god', 'good', 'goooood' etc., but not 'gd'.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-12",
      "question": "Which command searches for fixed strings (not regex)?",
