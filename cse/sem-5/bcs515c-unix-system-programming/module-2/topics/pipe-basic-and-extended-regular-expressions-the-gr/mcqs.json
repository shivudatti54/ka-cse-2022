    },
    {
      "id": "mcq-14",
      "question": "What does [^aeiou] match?",
      "options": [
        {
          "key": "A",
          "text": "Only vowels"
        },
        {
          "key": "B",
          "text": "Any consonant only"
        },
        {
          "key": "C",
          "text": "Any non-vowel character"
        },
        {
          "key": "D",
          "text": "The literal string [^aeiou]"
        }
      ],
      "correctAnswer": "Any non-vowel character",
      "explanation": "Inside a character class, ^ negates the match, so [^aeiou] matches any character except vowels.",
      "difficulty": "medium"
    },
