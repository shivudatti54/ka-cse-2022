    {
      "id": "mcq-6",
      "question": "What does the regex pattern '^$' match?",
      "options": [
        {
          "key": "A",
          "text": "Any line with $ symbol"
        },
        {
          "key": "B",
          "text": "Empty lines only"
        },
        {
          "key": "C",
          "text": "Lines starting with $"
        },
        {
          "key": "D",
          "text": "The end of file"
        }
      ],
      "correctAnswer": "Empty lines only",
      "explanation": "^ anchors to line start and $ anchors to line end, so together they match lines with nothing between them.",
      "difficulty": "medium"
    },
    {
