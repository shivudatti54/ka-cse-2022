{
  "topicId": "environment-list",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "Which command is used to display all environment variables in Linux?",
      "options": [
        {
          "key": "A",
          "text": "set"
        },
        {
          "key": "B",
          "text": "env"
        },
        {
          "key": "C",
          "text": "printenv"
        },
        {
          "key": "D",
          "text": "Both B and C"
        }
      ],
      "correctAnswer": "Both B and C",
      "explanation": "Both env and printenv display environment variables. set shows all variables including shell variables.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "What is the correct syntax to set an environment variable in bash?",
      "options": [
        {
          "key": "A",
          "text": "set VAR=value"
        },
        {
          "key": "B",
          "text": "export VAR=value"
        },
        {
          "key": "C",
          "text": "VAR=value"
        },
        {
          "key": "D",
          "text": "env VAR=value"
        }
      ],
      "correctAnswer": "export VAR=value",
      "explanation": "The export command marks a variable to be exported to child processes, making it an environment variable.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "Which environment variable contains the list of directories searched for commands?",
      "options": [
        {
          "key": "A",
          "text": "HOME"
        },
        {
          "key": "B",
          "text": "SHELL"
        },
        {
          "key": "C",
          "text": "PATH"
        },
        {
          "key": "D",
          "text": "PWD"
        }
      ],
      "correctAnswer": "PATH",
      "explanation": "PATH is a colon-separated list of directories where the shell looks for executable files.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-4",
      "question": "What separator is used between directories in the PATH variable?",
      "options": [
        {
          "key": "A",
          "text": "Semicolon (;)"
        },
        {
          "key": "B",
          "text": "Comma (,)"
        },
        {
          "key": "C",
          "text": "Colon (:)"
        },
        {
          "key": "D",
          "text": "Space ( )"
        }
      ],
      "correctAnswer": "Colon (:)",
      "explanation": "Directories in PATH are separated by colons, e.g., /usr/bin:/bin:/usr/local/bin.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-5",
      "question": "Which command removes an environment variable from the current shell?",
