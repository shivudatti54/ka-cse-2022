          "key": "A",
          "text": "Global to all systems"
        },
        {
          "key": "B",
          "text": "Available to all users"
        },
        {
          "key": "C",
          "text": "Local to current shell only"
        },
        {
          "key": "D",
          "text": "Permanently stored"
        }
      ],
      "correctAnswer": "Local to current shell only",
      "explanation": "Shell variables are local to the shell session and are not exported to child processes.",
      "difficulty": "medium"
    },
