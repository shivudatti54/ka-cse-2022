        {
          "key": "D",
          "text": "Both A and B"
        }
      ],
      "correctAnswer": "Both A and B",
      "explanation": "Both echo $VAR and printenv VAR can display the value of a specific variable.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-8",
      "question": "Environment variables are inherited by:",
      "options": [
        {
          "key": "A",
          "text": "Parent processes only"
        },
        {
          "key": "B",
          "text": "Child processes only"
        },
        {
          "key": "C",
          "text": "All processes"
        },
        {
          "key": "D",
          "text": "No processes"
        }
      ],
      "correctAnswer": "Child processes only",
      "explanation": "Environment variables are passed from parent to child processes when a new process is spawned.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-9",
      "question": "Which command will show all environment variables starting with 'TERM'?",
      "options": [
        {
          "key": "A",
          "text": "env | grep TERM"
        },
        {
          "key": "B",
          "text": "printenv TERM"
        },
        {
          "key": "C",
          "text": "set TERM"
        },
        {
          "key": "D",
          "text": "echo $TERM*"
        }
      ],
      "correctAnswer": "env | grep TERM",
      "explanation": "Using pipe with grep filters environment variables containing the pattern TERM.",
      "difficulty": "medium"
    },
    {
