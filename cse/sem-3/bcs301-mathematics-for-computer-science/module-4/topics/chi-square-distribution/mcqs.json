{
  "topicId": "chi-square-distribution",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "What is the primary purpose of the Chi-Square Goodness of Fit test?",
      "options": [
        {
          "key": "A",
          "text": "To compare two samples"
        },
        {
          "key": "B",
          "text": "To test independence"
        },
        {
          "key": "C",
          "text": "To assess model fit to observed data"
        },
        {
          "key": "D",
          "text": "To measure correlation"
        }
      ],
      "correctAnswer": "C",
      "explanation": "The test evaluates how well observed data matches a theoretical distribution.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-2",
      "question": "Degrees of freedom for a Chi-Square test are calculated as:",
      "options": [
        {
          "key": "A",
          "text": "n - 1"
        },
        {
          "key": "B",
          "text": "n"
        },
        {
          "key": "C",
          "text": "n + 1"
        },
        {
          "key": "D",
          "text": "2n"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Degrees of freedom = number of categories minus 1 (df = k - 1).",
      "difficulty": "medium"
    },
    {
      "id": "mcq-3",
      "question": "The Chi-Square test statistic formula is:",
      "options": [
        {
          "key": "A",
          "text": "Σ(O - E)"
        },
        {
          "key": "B",
          "text": "Σ(O/E)"
        },
        {
          "key": "C",
          "text": "Σ(O - E)²/E"
        },
        {
          "key": "D",
          "text": "Σ(O + E)²"
        }
      ],
      "correctAnswer": "C",
      "explanation": "The formula sums the squared differences between observed (O) and expected (E) values divided by expected values.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-4",
      "question": "Which is true about the null hypothesis?",
      "options": [
        {
          "key": "A",
          "text": "Data does not fit the distribution"
        },
        {
          "key": "B",
          "text": "Data fits the distribution"
        },
        {
          "key": "C",
          "text": "Samples are independent"
        },
        {
          "key": "D",
          "text": "Variances are equal"
        }
      ],
      "correctAnswer": "B",
      "explanation": "H₀ assumes the data follows the hypothesized distribution.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-5",
      "question": "When is this test NOT appropriate?",
      "options": [
        {
          "key": "A",
          "text": "Categorical data"
        },
        {
          "key": "B",
          "text": "Numerical data"
        },
        {
          "key": "C",
          "text": "Paired observations"
        },
        {
          "key": "D",
          "text": "Expected frequencies < 5"
        }
      ],
      "correctAnswer": "D",
      "explanation": "Expected frequencies should be ≥ 5 in all categories.",
      "difficulty": "medium"
    }
  ]
}
