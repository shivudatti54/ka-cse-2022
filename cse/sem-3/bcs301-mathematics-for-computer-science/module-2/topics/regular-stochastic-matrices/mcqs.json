{
  "topicId": "regular-stochastic-matrices",
  "mcqs": [
    {
      "id": "q1",
      "question": "What defines a regular stochastic matrix?",
      "options": [
        {
          "key": "A",
          "text": "Some power has all positive entries."
        },
        {
          "key": "B",
          "text": "All entries are positive."
        },
        {
          "key": "C",
          "text": "Determinant is 1."
        },
        {
          "key": "D",
          "text": "Square matrix with integers."
        }
      ],
      "correctAnswer": "A",
      "explanation": "A matrix is regular if a power of it has all entries > 0.",
      "difficulty": "medium"
    },
    {
      "id": "q2",
      "question": "What is guaranteed for regular matrices?",
      "options": [
        {
          "key": "A",
          "text": "Converge to steady-state."
        },
        {
          "key": "B",
          "text": "Become identity matrix."
        },
        {
          "key": "C",
          "text": "Oscillate indefinitely."
        },
        {
          "key": "D",
          "text": "No real eigenvalues."
        }
      ],
      "correctAnswer": "A",
      "explanation": "Regular matrices ensure convergence to a unique steady-state.",
      "difficulty": "medium"
    },
    {
      "id": "q3",
      "question": "Which matrix is regular?",
      "options": [
        {
          "key": "A",
          "text": "[[0.5, 0.5], [1, 0]]"
        },
        {
          "key": "B",
          "text": "[[1, 0], [0, 1]]"
        },
        {
          "key": "C",
          "text": "[[0, 1], [1, 0]]"
        },
        {
          "key": "D",
          "text": "[[1, 0], [0.5, 0.5]]"
        }
      ],
      "correctAnswer": "A",
      "explanation": "P² has all positive entries, making it regular.",
      "difficulty": "medium"
    },
    {
      "id": "q4",
      "question": "What condition makes P = [[0, 1], [a, b]] regular?",
      "options": [
        {
          "key": "A",
          "text": "a > 0, b > 0"
        },
        {
          "key": "B",
          "text": "a + b = 1"
        },
        {
          "key": "C",
          "text": "a = 0.5"
        },
        {
          "key": "D",
          "text": "b = 0.5"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Both a and b must be positive for some power to be positive.",
      "difficulty": "medium"
    },
    {
      "id": "q5",
      "question": "What is the steady-state vector?",
      "options": [
        {
          "key": "A",
          "text": "Left eigenvector for eigenvalue 1"
        },
        {
          "key": "B",
          "text": "Right eigenvector for eigenvalue 1"
        },
        {
          "key": "C",
          "text": "Any probability vector"
        },
        {
          "key": "D",
          "text": "Zero vector"
        }
      ],
      "correctAnswer": "A",
      "explanation": "It's the left eigenvector corresponding to eigenvalue 1.",
      "difficulty": "medium"
    }
  ]
}
