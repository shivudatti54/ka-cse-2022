{
  "topicId": "mean-and-variance",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "What is the formula for the mean of a discrete random variable X?",
      "options": [
        {
          "key": "A",
          "text": "E(X) = Σx_i"
        },
        {
          "key": "B",
          "text": "E(X) = ΣP(x_i)"
        },
        {
          "key": "C",
          "text": "E(X) = Σx_iP(x_i)"
        },
        {
          "key": "D",
          "text": "E(X) = Σ(x_i - P(x_i))"
        }
      ],
      "correctAnswer": "C",
      "explanation": "The mean is calculated as the sum of each outcome multiplied by its probability.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-2",
      "question": "Which of the following best describes variance?",
      "options": [
        {
          "key": "A",
          "text": "Measure of central tendency"
        },
        {
          "key": "B",
          "text": "Measure of data spread"
        },
        {
          "key": "C",
          "text": "Probability of occurrence"
        },
        {
          "key": "D",
          "text": "Weighted average"
        }
      ],
      "correctAnswer": "B",
      "explanation": "Variance quantifies how spread out the values are from the mean.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-3",
      "question": "If a random variable X has outcomes {1, 2, 3} with equal probabilities, what is Var(X)?",
      "options": [
        {
          "key": "A",
          "text": "0.67"
        },
        {
          "key": "B",
          "text": "1.0"
        },
        {
          "key": "C",
          "text": "2.0"
        },
        {
          "key": "D",
          "text": "3.0"
        }
      ],
      "correctAnswer": "A",
      "explanation": "E(X) = 2; Var(X) = E[(X-2)²] = (1² + 0 + 1²)/3 = 2/3 ≈ 0.67",
      "difficulty": "medium"
    },
    {
      "id": "mcq-4",
      "question": "What does a higher variance indicate?",
      "options": [
        {
          "key": "A",
          "text": "Data is closer to the mean"
        },
        {
          "key": "B",
          "text": "Data is more predictable"
        },
        {
          "key": "C",
          "text": "Data is more spread out"
        },
        {
          "key": "D",
          "text": "Mean is zero"
        }
      ],
      "correctAnswer": "C",
      "explanation": "Higher variance means data points are more dispersed from the mean.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-5",
      "question": "Which is true about mean and variance?",
      "options": [
        {
          "key": "A",
          "text": "Mean is always positive"
        },
        {
          "key": "B",
          "text": "Variance has units squared"
        },
        {
          "key": "C",
          "text": "Mean requires variance"
        },
        {
          "key": "D",
          "text": "Variance is additive"
        }
      ],
      "correctAnswer": "B",
      "explanation": "Variance units are squared (e.g., meters² if data is in meters).",
      "difficulty": "medium"
    }
  ]
}
