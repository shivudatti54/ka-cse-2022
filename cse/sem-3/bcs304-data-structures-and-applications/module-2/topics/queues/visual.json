    {
      "id": "d3",
      "title": "Queue Types Comparison",
      "type": "comparison",
      "content": {
        "items": [
          {
            "name": "Linear Queue",
            "description": "Basic FIFO queue with front and rear pointers moving in one direction"
          },
          {
            "name": "Circular Queue",
            "description": "Rear wraps around to reuse freed slots at the front, solving memory wastage"
          },
          {
            "name": "Deque (Double-Ended Queue)",
            "description": "Insertion and deletion allowed at both front and rear ends"
          },
          {
            "name": "Priority Queue",
            "description": "Elements are dequeued based on priority rather than arrival order"
          }
        ]
      }
