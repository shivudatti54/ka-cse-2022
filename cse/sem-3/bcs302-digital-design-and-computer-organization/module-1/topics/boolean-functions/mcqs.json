      "question": "Which Boolean operator represents the logical AND operation?",
      "options": [
        {
          "key": "A",
          "text": "+"
        },
        {
          "key": "B",
          "text": "•"
        },
        {
          "key": "C",
          "text": "⊕"
        },
        {
          "key": "D",
          "text": "'"
        }
      ],
      "correctIndex": 1,
      "explanation": "The dot symbol (•) represents AND. The plus (+) is OR, ⊕ is XOR, and ' is NOT.",
      "difficulty": "medium",
      "correctAnswer": "A"
