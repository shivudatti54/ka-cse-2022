  "mcqs": [
    {
      "id": "mcq-1",
      "question": "Which of these is NOT a proposition?",
      "options": [
        {
          "key": "A",
          "text": "2+2=4"
        },
        {
          "key": "B",
          "text": "Paris is in Germany"
        },
        {
          "key": "C",
          "text": "x > 5"
        },
        {
          "key": "D",
          "text": "All of these"
        }
      ],
      "correctAnswer": 2,
      "explanation": "A proposition must have a fixed truth value. 'x > 5' is contingent on x's value.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-2",
      "question": "How many rows are in a truth table for 2 propositions?",
      "options": [
        {
          "key": "A",
          "text": "2"
        },
        {
          "key": "B",
          "text": "4"
        },
        {
          "key": "C",
          "text": "8"
        },
        {
          "key": "D",
          "text": "16"
        }
      ],
      "correctAnswer": 1,
      "explanation": "Each proposition has 2 possible values (T/F), so 2^2 = 4 combinations.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-3",
      "question": "When is p → q FALSE?",
      "options": [
        {
          "key": "A",
          "text": "p=T, q=T"
        },
        {
          "key": "B",
          "text": "p=T, q=F"
        },
        {
          "key": "C",
          "text": "p=F, q=T"
        },
        {
          "key": "D",
          "text": "p=F, q=F"
        }
      ],
      "correctAnswer": 1,
      "explanation": "Implication is only false when the antecedent is true and the consequent is false.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-4",
      "question": "Which connective has the highest precedence?",
      "options": [
        {
          "key": "A",
          "text": "∧ (AND)"
        },
        {
          "key": "B",
          "text": "∨ (OR)"
        },
        {
          "key": "C",
          "text": "¬ (NOT)"
        },
        {
          "key": "D",
          "text": "→ (IMPLIES)"
        }
      ],
      "correctAnswer": 2,
      "explanation": "Negation (¬) is evaluated before other connectives according to precedence rules.",
      "difficulty": "medium"
