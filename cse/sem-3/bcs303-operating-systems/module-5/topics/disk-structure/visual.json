    {
      "id": "d3",
      "title": "CAV vs CLV",
      "type": "comparison",
      "content": {
        "nodes": [
          {
            "id": "n1",
            "label": "CAV: Constant RPM, same sectors/track, used by HDDs"
          },
          {
            "id": "n2",
            "label": "CLV: Variable RPM, more sectors on outer tracks, used by CD/DVD"
          },
          {
            "id": "n3",
            "label": "ZBR (hybrid): Zones with varying sectors/track, constant RPM within zones"
          }
        ],
        "edges": []
      }
    },
    {
      "id": "d4",
      "title": "HDD vs SSD",
      "type": "comparison",
      "content": {
        "nodes": [
          {
            "id": "n1",
            "label": "HDD: Magnetic platters, moving heads, seek time 3-15ms"
          },
          {
            "id": "n2",
            "label": "SSD: NAND flash, no moving parts, ~0.1ms access"
          },
          {
            "id": "n3",
            "label": "HDD needs disk scheduling; SSD does not"
          }
        ],
        "edges": []
      }
