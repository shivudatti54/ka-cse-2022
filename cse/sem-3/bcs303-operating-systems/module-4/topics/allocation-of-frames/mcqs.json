      "id": "mcq-1",
      "question": "Which allocation scheme assigns a fixed number of frames to a process for its entire execution?",
      "options": [
        {
          "key": "A",
          "text": "Fixed Allocation"
        },
        {
          "key": "B",
          "text": "Dynamic Allocation"
        },
        {
          "key": "C",
          "text": "Priority Allocation"
        },
        {
          "key": "D",
          "text": "Round-Robin"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Fixed Allocation assigns frames statically, while Dynamic Allocation adjusts frames during execution.",
      "difficulty": "medium"
    },
    {
