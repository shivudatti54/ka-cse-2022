      "question": "Which constructor is used for dynamic memory allocation in class?",
      "options": [
        {
          "key": "A",
          "text": "Default constructor"
        },
        {
          "key": "B",
          "text": "Copy constructor"
        },
        {
          "key": "C",
          "text": "Dynamic constructor"
        },
        {
          "key": "D",
          "text": "None"
        }
      ],
      "correctAnswer": "Dynamic constructor",
      "explanation": "Dynamic constructor uses new operator to allocate memory for pointer members during object creation.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-16",
      "question": "What is the parameter type of copy constructor?",
      "options": [
        {
          "key": "A",
          "text": "Object by value"
        },
        {
          "key": "B",
          "text": "Pointer to object"
        },
        {
          "key": "C",
          "text": "Reference to object"
        },
        {
          "key": "D",
          "text": "Object itself"
        }
      ],
      "correctAnswer": "Reference to object",
      "explanation": "Copy constructor takes a reference to const object: ClassName(const ClassName& obj). Using reference avoids infinite recursion.",
      "difficulty": "medium"
    },
