    {
      "id": "mcq-20",
      "question": "What is called when object is returned by value from a function?",
      "options": [
        {
          "key": "A",
          "text": "Default constructor"
        },
        {
          "key": "B",
          "text": "Copy constructor"
        },
        {
          "key": "C",
          "text": "Destructor only"
        },
        {
          "key": "D",
          "text": "Move constructor"
        }
      ],
      "correctAnswer": "Copy constructor",
      "explanation": "Returning object by value triggers copy constructor (or move constructor in C++11+) to create the returned object.",
