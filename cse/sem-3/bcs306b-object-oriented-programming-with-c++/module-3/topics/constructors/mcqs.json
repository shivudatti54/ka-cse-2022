      "question": "How many copy constructors can a class have?",
      "options": [
        {
          "key": "A",
          "text": "Only one"
        },
        {
          "key": "B",
          "text": "As many as needed"
        },
        {
          "key": "C",
          "text": "Only two"
        },
        {
          "key": "D",
          "text": "None"
        }
      ],
      "correctAnswer": "Only one",
