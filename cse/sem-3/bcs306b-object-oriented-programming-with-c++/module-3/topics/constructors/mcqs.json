{
  "topicId": "constructors",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "What is the return type of a constructor in C++?",
      "options": [
        {
          "key": "A",
          "text": "void"
        },
        {
          "key": "B",
          "text": "int"
        },
        {
          "key": "C",
          "text": "No return type"
        },
        {
          "key": "D",
          "text": "Depends on class"
        }
      ],
      "correctAnswer": "No return type",
      "explanation": "Constructors do not have any return type, not even void. They are special member functions for initialization.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "Which keyword is used to prevent implicit conversions using single-parameter constructor?",
      "options": [
        {
          "key": "A",
          "text": "static"
        },
        {
          "key": "B",
          "text": "const"
        },
        {
          "key": "C",
          "text": "explicit"
        },
        {
          "key": "D",
          "text": "virtual"
        }
      ],
      "correctAnswer": "explicit",
      "explanation": "The 'explicit' keyword prevents implicit conversions and copying of objects using single-argument constructors.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-3",
      "question": "What is called when an object is passed by value to a function?",
      "options": [
        {
          "key": "A",
          "text": "Default constructor"
        },
        {
          "key": "B",
          "text": "Copy constructor"
        },
        {
          "key": "C",
          "text": "Parameterized constructor"
        },
        {
          "key": "D",
          "text": "Destructor"
        }
      ],
      "correctAnswer": "Copy constructor",
      "explanation": "Copy constructor is invoked when an object is passed by value to a function or returned by value.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-4",
      "question": "Which of the following is NOT a type of constructor?",
      "options": [
        {
          "key": "A",
          "text": "Default constructor"
        },
        {
          "key": "B",
          "text": "Copy constructor"
        },
        {
          "key": "C",
          "text": "Virtual constructor"
        },
        {
          "key": "D",
          "text": "Parameterized constructor"
        }
      ],
      "correctAnswer": "Virtual constructor",
      "explanation": "Constructors cannot be virtual in C++. There is no concept of virtual constructors.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-5",
      "question": "What is the output of default constructor provided by compiler?",
      "options": [
        {
          "key": "A",
          "text": "Garbage values"
        },
        {
          "key": "B",
          "text": "Zero"
        },
        {
          "key": "C",
          "text": "Depends on data type"
        },
        {
          "key": "D",
          "text": "Compile error"
        }
      ],
      "correctAnswer": "Garbage values",
      "explanation": "Default constructor provided by compiler does not initialize data members, leaving them with garbage values.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-6",
      "question": "Which constructor initializes an object using another object of same class?",
      "options": [
        {
          "key": "A",
          "text": "Default constructor"
        },
        {
          "key": "B",
          "text": "Copy constructor"
        },
        {
          "key": "C",
          "text": "Parameterized constructor"
        },
        {
          "key": "D",
          "text": "Move constructor"
        }
      ],
      "correctAnswer": "Copy constructor",
      "explanation": "Copy constructor creates a new object as a copy of an existing object of the same class.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-7",
      "question": "What is the syntax of member initializer list?",
      "options": [
        {
          "key": "A",
          "text": "ClassName() : var1(val1), var2(val2)"
        },
        {
          "key": "B",
          "text": "ClassName(var1,var2) : initialize(var1,var2)"
        },
        {
          "key": "C",
          "text": "ClassName() {var1=val1}"
        },
        {
          "key": "D",
          "text": "None of these"
        }
      ],
      "correctAnswer": "ClassName() : var1(val1), var2(val2)",
      "explanation": "Member initializer list comes after constructor parameter list, preceded by colon, with comma-separated initializations.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-8",
      "question": "In inheritance, which constructor is called first?",
      "options": [
        {
          "key": "A",
          "text": "Derived class constructor"
        },
        {
          "key": "B",
          "text": "Base class constructor"
        },
        {
          "key": "C",
          "text": "Both simultaneously"
        },
        {
          "key": "D",
          "text": "Depends on order"
        }
      ],
      "correctAnswer": "Base class constructor",
      "explanation": "Base class constructor is executed before derived class constructor to ensure proper initialization of inherited members.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-9",
      "question": "Can a constructor return a value?",
      "options": [
        {
          "key": "A",
          "text": "Yes, always"
        },
        {
          "key": "B",
          "text": "Yes, but only void"
        },
        {
          "key": "C",
          "text": "No"
        },
        {
          "key": "D",
          "text": "Only if explicitly specified"
        }
      ],
      "correctAnswer": "No",
      "explanation": "Constructors cannot return a value in C++. They have no return type, not even void.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-10",
      "question": "What is the name of destructor for class 'Student'?",
      "options": [
        {
          "key": "A",
          "text": "~Student()"
        },
        {
          "key": "B",
          "text": "~Student"
        },
        {
          "key": "C",
          "text": "destructor_Student()"
        },
        {
          "key": "D",
          "text": "Student~()"
        }
      ],
      "correctAnswer": "~Student()",
      "explanation": "Destructor has the same name as class prefixed with tilde (~). For class Student, it is ~Student().",
      "difficulty": "easy"
    },
    {
      "id": "mcq-11",
      "question": "Which is more efficient: assignment in constructor body or initializer list?",
      "options": [
        {
          "key": "A",
          "text": "Assignment in body"
        },
        {
          "key": "B",
          "text": "Initializer list"
        },
        {
          "key": "C",
          "text": "Both are same"
        },
        {
          "key": "D",
          "text": "Depends on compiler"
        }
      ],
      "correctAnswer": "Initializer list",
      "explanation": "Initializer list initializes members directly, avoiding extra copy/assignment operations. More efficient for const and reference members.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-12",
      "question": "What happens if we don't define any constructor in a class?",
      "options": [
        {
          "key": "A",
          "text": "Error occurs"
        },
        {
          "key": "B",
          "text": "Compiler provides default constructor"
        },
        {
          "key": "C",
          "text": "Objects cannot be created"
        },
        {
          "key": "D",
          "text": "Runtime error"
        }
      ],
      "correctAnswer": "Compiler provides default constructor",
      "explanation": "If no constructor is defined, compiler automatically generates a default constructor (parameterless).",
      "difficulty": "easy"
    },
    {
      "id": "mcq-13",
      "question": "When are private constructors used?",
      "options": [
        {
          "key": "A",
          "text": "Always by default"
        },
        {
          "key": "B",
          "text": "For singleton pattern"
        },
        {
          "key": "C",
          "text": "For abstract classes"
        },
        {
          "key": "D",
          "text": "Never"
        }
      ],
      "correctAnswer": "For singleton pattern",
      "explanation": "Private constructors are used to implement Singleton pattern and factory methods to control object creation.",
      "difficulty": "medium"
    },
    {
