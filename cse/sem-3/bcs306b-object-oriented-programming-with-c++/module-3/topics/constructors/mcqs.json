      "difficulty": "medium"
    },
    {
      "id": "mcq-19",
      "question": "Which of these is correct syntax for parameterized constructor?",
      "options": [
        {
          "key": "A",
          "text": "void MyClass(int x)"
        },
        {
          "key": "B",
          "text": "MyClass(int x)"
        },
        {
          "key": "C",
          "text": "int MyClass(int x)"
        },
        {
          "key": "D",
