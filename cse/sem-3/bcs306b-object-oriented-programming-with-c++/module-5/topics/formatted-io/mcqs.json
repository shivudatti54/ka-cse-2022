      "id": "mcq-2",
      "question": "What is the output of: cout << setw(5) << 42;",
      "options": [
        {
          "key": "A",
          "text": "42"
        },
        {
          "key": "B",
          "text": " 42"
        },
        {
          "key": "C",
          "text": "42 "
        },
        {
          "key": "D",
          "text": "0042"
        }
      ],
      "correctAnswer": " 42",
      "explanation": "setw(5) sets a minimum width of 5 characters. Since 42 is only 2 digits, it is padded with spaces on the left.",
      "difficulty": "easy"
    },
