          "text": "file.finished()"
        },
        {
          "key": "D",
          "text": "file.endof()"
        }
      ],
      "correctAnswer": "file.eof()",
      "explanation": "eof() returns true when the stream has reached the end-of-file during reading.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-13",
      "question": "What is the purpose of ios::ate mode?",
      "options": [
        {
          "key": "A",
          "text": "Append to end"
        },
        {
          "key": "B",
          "text": "Open at beginning"
        },
        {
          "key": "C",
          "text": "Open and truncate"
        },
        {
          "key": "D",
          "text": "Binary mode only"
        }
      ],
      "correctAnswer": "Append to end",
      "explanation": "ios::ate (at end) positions the file pointer at the end of file initially, but allows seeking.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-14",
      "question": "What happens if you open a file with ofstream that doesn't exist?",
      "options": [
        {
          "key": "A",
          "text": "Error occurs"
        },
        {
          "key": "B",
          "text": "File is created automatically"
        },
        {
          "key": "C",
          "text": "Program crashes"
        },
        {
          "key": "D",
          "text": "Returns NULL"
        }
      ],
      "correctAnswer": "File is created automatically",
      "explanation": "ofstream automatically creates a new file if it doesn't exist when opened for writing.",
      "difficulty": "easy"
    },
    {
