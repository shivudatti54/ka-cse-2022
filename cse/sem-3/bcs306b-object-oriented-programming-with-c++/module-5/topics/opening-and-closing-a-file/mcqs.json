      "difficulty": "medium"
    },
    {
      "id": "mcq-11",
      "question": "What does fstream require for proper operation?",
      "options": [
        {
          "key": "A",
          "text": "Only ios::in"
        },
        {
          "key": "B",
          "text": "Only ios::out"
        },
        {
          "key": "C",
          "text": "Both ios::in and ios::out"
        },
        {
          "key": "D",
          "text": "No mode specification"
        }
      ],
      "correctAnswer": "Both ios::in and ios::out",
      "explanation": "fstream needs explicit mode specification like fstream file(\"data.txt\", ios::in | ios::out);",
      "difficulty": "medium"
    },
    {
      "id": "mcq-12",
      "question": "Which method returns true if end-of-file is reached?",
      "options": [
        {
