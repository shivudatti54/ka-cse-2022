{
  "topicId": "opening-and-closing-a-file",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "Which header file is required for file handling in C++?",
      "options": [
        {
          "key": "A",
          "text": "<iostream>"
        },
        {
          "key": "B",
          "text": "<fstream>"
        },
        {
          "key": "C",
          "text": "<stdio.h>"
        },
        {
          "key": "D",
          "text": "<file.h>"
        }
      ],
      "correctAnswer": "<fstream>",
      "explanation": "<fstream> header provides ifstream, ofstream, and fstream classes for file operations in C++.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "Which class is used to write data to a file?",
      "options": [
        {
          "key": "A",
          "text": "ifstream"
        },
        {
          "key": "B",
          "text": "ofstream"
        },
        {
          "key": "C",
          "text": "fstream"
        },
        {
          "key": "D",
          "text": "iostream"
        }
      ],
      "correctAnswer": "ofstream",
      "explanation": "ofstream (output file stream) is used for writing data to files. 'of' stands for output.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "Which class is used to read data from a file?",
      "options": [
        {
          "key": "A",
          "text": "ifstream"
        },
        {
          "key": "B",
          "text": "ofstream"
        },
        {
          "key": "C",
          "text": "fstream"
        },
        {
          "key": "D",
          "text": "iostream"
        }
      ],
      "correctAnswer": "ifstream",
      "explanation": "ifstream (input file stream) is used for reading data from files. 'if' stands for input.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-4",
      "question": "What is the correct way to open a file for writing?",
      "options": [
        {
          "key": "A",
          "text": "ifstream file(\"data.txt\");"
        },
        {
          "key": "B",
          "text": "ofstream file(\"data.txt\");"
        },
        {
          "key": "C",
          "text": "fstream file(\"data.txt\");"
        },
        {
          "key": "D",
          "text": "stream file(\"data.txt\");"
        }
      ],
      "correctAnswer": "ofstream file(\"data.txt\");",
      "explanation": "ofstream opens a file for writing. The constructor automatically opens the file.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-5",
      "question": "How do you check if a file opened successfully?",
      "options": [
        {
          "key": "A",
          "text": "file.check()"
        },
        {
          "key": "B",
          "text": "file.is_open()"
        },
        {
          "key": "C",
          "text": "file.success()"
        },
        {
          "key": "D",
          "text": "file.opened()"
        }
      ],
      "correctAnswer": "file.is_open()",
      "explanation": "is_open() returns true if file is successfully opened, false otherwise.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-6",
      "question": "Which mode opens a file for appending data?",
      "options": [
        {
          "key": "A",
          "text": "ios::out"
        },
        {
          "key": "B",
          "text": "ios::app"
        },
        {
          "key": "C",
          "text": "ios::ate"
        },
        {
          "key": "D",
          "text": "ios::trunc"
        }
      ],
      "correctAnswer": "ios::app",
      "explanation": "ios::app (append) mode positions the cursor at end of file and appends new data.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-7",
      "question": "What does ios::trunc mode do?",
      "options": [
        {
          "key": "A",
          "text": "Keeps existing data"
        },
        {
          "key": "B",
          "text": "Deletes existing data"
        },
        {
          "key": "C",
          "text": "Creates new file"
        },
        {
          "key": "D",
          "text": "Reads in binary mode"
        }
      ],
      "correctAnswer": "Deletes existing data",
      "explanation": "ios::trunc truncates the file to zero length, discarding all existing content.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-8",
      "question": "What is the default mode for ofstream?",
      "options": [
        {
          "key": "A",
          "text": "ios::in"
        },
        {
          "key": "B",
          "text": "ios::out"
        },
        {
          "key": "C",
          "text": "ios::out | ios::trunc"
        },
        {
          "key": "D",
          "text": "ios::app"
        }
      ],
      "correctAnswer": "ios::out | ios::trunc",
      "explanation": "ofstream defaults to write mode with truncation, meaning it creates new file or overwrites existing.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-9",
      "question": "How do you close a file stream?",
      "options": [
        {
          "key": "A",
          "text": "file.end()"
        },
        {
          "key": "B",
          "text": "file.close()"
        },
        {
          "key": "C",
          "text": "file.exit()"
        },
        {
          "key": "D",
          "text": "file.terminate()"
        }
      ],
      "correctAnswer": "file.close()",
      "explanation": "close() method closes the file and flushes any buffered data to the file.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-10",
      "question": "Which file mode is used for binary file operations?",
      "options": [
        {
          "key": "A",
          "text": "ios::binary"
        },
        {
          "key": "B",
          "text": "ios::bin"
        },
