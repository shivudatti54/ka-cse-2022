      "difficulty": "medium"
    },
    {
      "id": "mcq-11",
      "question": "What is the correct way to rethrow an exception in catch block?",
      "options": [
        {
          "key": "A",
          "text": "throw;"
        },
        {
          "key": "B",
          "text": "throw e;"
        },
        {
          "key": "C",
          "text": "rethrow;"
        },
        {
          "key": "D",
          "text": "throw new exception;"
        }
      ],
      "correctAnswer": "throw;",
      "explanation": "Using throw; without an operand rethrows the currently caught exception.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-12",
      "question": "What type should catch blocks typically catch exceptions by?",
      "options": [
        {
          "key": "A",
          "text": "By value"
        },
        {
          "key": "B",
          "text": "By pointer"
        },
        {
          "key": "C",
          "text": "By reference"
        },
        {
          "key": "D",
          "text": "By const value"
        }
      ],
      "correctAnswer": "By reference",
      "explanation": "Catching by reference avoids object slicing and allows polymorphic behavior.",
      "difficulty": "hard"
    },
    {
