{
  "topicId": "applying-exception-handling",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "Which keyword is used to monitor a block of code for exceptions?",
      "options": [
        {
          "key": "A",
          "text": "throw"
        },
        {
          "key": "B",
          "text": "catch"
        },
        {
          "key": "C",
          "text": "try"
        },
        {
          "key": "D",
          "text": "monitor"
        }
      ],
      "correctAnswer": "try",
      "explanation": "The try keyword defines a block of code that may throw exceptions, which must be followed by catch blocks.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "What is the correct order of exception handling keywords?",
      "options": [
        {
          "key": "A",
          "text": "catch-throw-try"
        },
        {
          "key": "B",
          "text": "try-throw-catch"
        },
        {
          "key": "C",
          "text": "throw-try-catch"
        },
        {
          "key": "D",
          "text": "try-catch-throw"
        }
      ],
      "correctAnswer": "try-throw-catch",
      "explanation": "First try block monitors code, then throw raises exception, finally catch handles it.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "What is printed by: try{ throw 10; } catch(double){ cout<<\"double\"; } catch(int){ cout<<\"int\"; }?",
      "options": [
        {
          "key": "A",
          "text": "double"
        },
        {
          "key": "B",
          "text": "int"
        },
        {
          "key": "C",
          "text": "10"
        },
        {
          "key": "D",
          "text": "Compilation error"
        }
      ],
      "correctAnswer": "int",
      "explanation": "catch(double) doesn't match int, so catch(int) handles it. Catch blocks are checked in order.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-4",
      "question": "Which class is the base for all standard C++ exceptions?",
      "options": [
        {
          "key": "A",
          "text": "std::error"
        },
        {
          "key": "B",
          "text": "std::exception"
        },
        {
          "key": "C",
          "text": "std::runtime_error"
        },
        {
          "key": "D",
          "text": "std::base_exception"
        }
      ],
      "correctAnswer": "std::exception",
      "explanation": "std::exception is the base class for all standard library exceptions in C++.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-5",
      "question": "What does noexcept specifier guarantee?",
      "options": [
        {
          "key": "A",
          "text": "Function may throw"
        },
        {
          "key": "B",
          "text": "Function won't throw"
        },
        {
          "key": "C",
          "text": "Function must catch all exceptions"
        },
        {
          "key": "D",
          "text": "Function is deprecated"
        }
      ],
      "correctAnswer": "Function won't throw",
      "explanation": "noexcept declares that a function will not throw exceptions; violation calls std::terminate.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-6",
      "question": "What is the output: try{ throw \"error\"; } catch(const char* p){ cout<<p; }?",
      "options": [
        {
          "key": "A",
          "text": "error"
        },
        {
          "key": "B",
          "text": "p"
        },
        {
          "key": "C",
          "text": "Compilation error"
        },
        {
          "key": "D",
          "text": "Nothing"
        }
      ],
      "correctAnswer": "error",
      "explanation": "throw \"error\" creates a const char* exception which is caught by the catch block.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-7",
      "question": "Which standard exception is thrown when new fails to allocate memory?",
      "options": [
        {
          "key": "A",
          "text": "std::bad_alloc"
        },
        {
          "key": "B",
          "text": "std::runtime_error"
        },
        {
          "key": "C",
          "text": "std::overflow_error"
        },
        {
          "key": "D",
          "text": "std::memory_error"
        }
      ],
      "correctAnswer": "std::bad_alloc",
      "explanation": "When new fails to allocate memory, it throws std::bad_alloc exception.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-8",
      "question": "What does catch(...) do?",
      "options": [
        {
          "key": "A",
          "text": "Catches only integers"
        },
        {
          "key": "B",
          "text": "Catches all exceptions"
        },
        {
          "key": "C",
          "text": "Skips all exceptions"
        },
        {
          "key": "D",
          "text": "Compiles error"
        }
      ],
      "correctAnswer": "Catches all exceptions",
      "explanation": "The ellipsis (...) in catch catches any type of exception, serving as a catch-all handler.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-9",
      "question": "What is stack unwinding?",
      "options": [
        {
          "key": "A",
          "text": "Memory allocation"
        },
        {
          "key": "B",
          "text": "Exception propagation with cleanup"
        },
        {
          "key": "C",
          "text": "Stack overflow"
        },
        {
          "key": "D",
          "text": "Function return"
        }
      ],
      "correctAnswer": "Exception propagation with cleanup",
      "explanation": "Stack unwinding destroys local objects as exceptions propagate up the call stack.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-10",
      "question": "Which exception is thrown when vector::at() accesses invalid index?",
      "options": [
        {
          "key": "A",
          "text": "std::out_of_range"
        },
        {
          "key": "B",
          "text": "std::range_error"
        },
        {
          "key": "C",
          "text": "std::logic_error"
        },
        {
          "key": "D",
          "text": "std::index_error"
        }
      ],
      "correctAnswer": "std::out_of_range",
