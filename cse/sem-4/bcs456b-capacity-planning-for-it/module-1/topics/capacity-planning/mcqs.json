{
  "topicId": "capacity-planning",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "Capacity planning primarily deals with:",
      "options": [
        {
          "key": "A",
          "text": "Only CPU resources"
        },
        {
          "key": "B",
          "text": "Only storage resources"
        },
        {
          "key": "C",
          "text": "Determining optimal computing resources for workloads"
        },
        {
          "key": "D",
          "text": "Installing new hardware only"
        }
      ],
      "correctAnswer": "Determining optimal computing resources for workloads",
      "explanation": "Capacity planning is a comprehensive process that considers all computing resources including CPU, memory, storage, and network to meet workload demands.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "Which strategy adds capacity after demand exceeds supply?",
      "options": [
        {
          "key": "A",
          "text": "Lead Strategy"
        },
        {
          "key": "B",
          "text": "Lag Strategy"
        },
        {
          "key": "C",
          "text": "Match Strategy"
        },
        {
          "key": "D",
          "text": "Forecast Strategy"
        }
      ],
      "correctAnswer": "Lag Strategy",
      "explanation": "Lag Strategy reacts to existing demand by adding capacity only after the current capacity is exceeded.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-3",
      "question": "A CPU utilization of 95% sustained indicates:",
      "options": [
        {
          "key": "A",
          "text": "Excellent performance"
        },
        {
          "key": "B",
          "text": "Underutilized system"
        },
        {
          "key": "C",
          "text": "Capacity bottleneck"
        },
        {
          "key": "D",
          "text": "Optimal capacity"
        }
      ],
      "correctAnswer": "Capacity bottleneck",
      "explanation": "Sustained CPU utilization above 80-85% indicates the system is approaching capacity limits and may experience performance degradation.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-4",
      "question": "Throughput is measured in:",
      "options": [
        {
          "key": "A",
          "text": "Milliseconds"
        },
        {
          "key": "B",
          "text": "Percentage"
        },
        {
          "key": "C",
          "text": "Tasks per unit time"
        },
        {
          "key": "D",
          "text": "Bytes"
        }
      ],
      "correctAnswer": "Tasks per unit time",
      "explanation": "Throughput represents the number of processes or transactions completed in a given time period (e.g., TPS, processes/sec).",
      "difficulty": "easy"
    },
    {
      "id": "mcq-5",
      "question": "Response time includes:",
      "options": [
        {
          "key": "A",
          "text": "Only service time"
        },
        {
          "key": "B",
          "text": "Only CPU time"
        },
        {
          "key": "C",
          "text": "Wait time + Service time"
        },
        {
          "key": "D",
          "text": "Network latency only"
        }
      ],
      "correctAnswer": "Wait time + Service time",
      "explanation": "Response time is the total time from request submission to first response, encompassing both waiting in queue and actual processing time.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-6",
      "question": "The proactive capacity planning strategy is:",
      "options": [
        {
          "key": "A",
          "text": "Lag Strategy"
        },
        {
          "key": "B",
          "text": "Match Strategy"
        },
        {
          "key": "C",
          "text": "Lead Strategy"
        },
        {
          "key": "D",
          "text": "Reactive Strategy"
        }
      ],
      "correctAnswer": "Lead Strategy",
      "explanation": "Lead Strategy is proactive as it adds capacity in anticipation of future demand, preventing service disruptions.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-7",
      "question": "A system bottleneck is typically the:",
      "options": [
        {
          "key": "A",
          "text": "Fastest component"
        },
        {
          "key": "B",
          "text": "Most underutilized component"
        },
        {
          "key": "C",
          "text": "Component operating at near-full capacity"
        },
        {
          "key": "D",
          "text": "Random component"
        }
      ],
      "correctAnswer": "Component operating at near-full capacity",
      "explanation": "A bottleneck is the constraint that limits overall performance, usually the resource most heavily utilized.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-8",
      "question": "Benchmarking is used to:",
      "options": [
        {
          "key": "A",
          "text": "Monitor daily operations"
        },
        {
          "key": "B",
          "text": "Measure performance under controlled conditions"
        },
        {
          "key": "C",
          "text": "Schedule processes"
        },
        {
          "key": "D",
          "text": "Manage memory"
        }
      ],
      "correctAnswer": "Measure performance under controlled conditions",
      "explanation": "Benchmarking uses standardized tests to measure and compare system performance for capacity planning purposes.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-9",
      "question": "Virtual memory helps in:",
      "options": [
        {
          "key": "A",
          "text": "Reducing CPU usage"
        },
        {
          "key": "B",
          "text": "Extending available memory using disk"
        },
        {
          "key": "C",
          "text": "Increasing network speed"
        },
        {
          "key": "D",
          "text": "Reducing heat generation"
        }
      ],
      "correctAnswer": "Extending available memory using disk",
      "explanation": "Virtual memory uses disk space to simulate additional RAM, allowing memory-intensive applications to run on systems with limited physical memory.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-10",
      "question": "Workload characterization involves:",
      "options": [
        {
          "key": "A",
          "text": "Deleting old workloads"
        },
        {
          "key": "B",
          "text": "Identifying and quantifying workload types"
        },
        {
          "key": "C",
          "text": "Compressing data"
        },
        {
          "key": "D",
          "text": "Encrypting files"
        }
      ],
      "correctAnswer": "Identifying and quantifying workload types",
      "explanation": "Workload characterization analyzes the nature and volume of different workloads to properly plan capacity requirements.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-11",
      "question": "In queueing theory, utilization factor (ρ) must be:",
      "options": [
        {
          "key": "A",
          "text": "Equal to 1"
        },
        {
          "key": "B",
          "text": "Greater than 1"
        },
        {
          "key": "C",
          "text": "Less than 1"
        },
        {
          "key": "D",
          "text": "Equal to 0"
        }
      ],
      "correctAnswer": "Less than 1",
      "explanation": "For stable operation, utilization factor (arrival rate/service rate) must be less than 1. At ρ≥1, the queue grows infinitely.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-12",
      "question": "The Match Strategy for capacity planning:",
      "options": [
        {
          "key": "A",
          "text": "Adds all capacity at once"
        },
        {
          "key": "B",
          "text": "Adds capacity incrementally with demand"
        },
        {
          "key": "C",
          "text": "Never adds capacity"
        },
        {
          "key": "D",
          "text": "Adds capacity before demand"
        }
      ],
      "correctAnswer": "Adds capacity incrementally with demand",
      "explanation": "Match Strategy balances lead and lag by adding capacity in small increments as demand grows, optimizing resource utilization.",
      "difficulty": "medium"
    },
    {
