          "key": "B",
          "text": "Comparing future performance measurements"
        },
        {
          "key": "C",
          "text": "Formatting hard drives"
        },
        {
          "key": "D",
          "text": "Installing updates"
        }
      ],
      "correctAnswer": "Comparing future performance measurements",
      "explanation": "Baselines provide reference points for normal performance to identify deviations and plan capacity upgrades.",
      "difficulty": "easy"
    },
    {
