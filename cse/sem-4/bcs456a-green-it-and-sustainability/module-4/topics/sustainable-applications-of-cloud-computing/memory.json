{
  "topicId": "sustainable-applications-of-cloud-computing",
  "mnemonics": [
    {
      "id": "m-1",
      "title": "PUE\u8bb0\u5fc6\u6cd5",
      "content": "PUE = Power Used by Equipment / Total Power. \u8bb0\u4f4f: PUE\u8d8a\u4f4e\u8d8a\u597d, \u50cf\u4f60\u7684\u8003\u8bd5\u6210\u7ee9(PUE)\u8d8a\u4f4e\u8d8a\u597d! PUE\u7684\u7406\u60f3\u503c\u662f1.1-1.2(90%\u4ee5\u4e0a\u7684\u80fd\u91cf\u7528\u4e8e\u8ba1\u7b97)"
    }
  ],
  "acronyms": [
    {
      "term": "PUE",
      "expansion": "Power Usage Effectiveness",
      "usage": "Measures data center energy efficiency; lower is better (ideal: 1.1-1.2)"
    },
    {
      "term": "DCIM",
      "expansion": "Data Center Infrastructure Management",
      "usage": "Software for monitoring and optimizing data center energy usage"
    },
    {
      "term": "RECs",
      "expansion": "Renewable Energy Certificates",
      "usage": "Tradable certificates proving renewable energy generation for carbon offsetting"
    },
    {
      "term": "VM",
      "expansion": "Virtual Machine",
      "usage": "Software emulation of a physical computer that enables server consolidation"
    },
    {
      "term": "AI/ML",
      "expansion": "Artificial Intelligence/Machine Learning",
      "usage": "Technologies used to optimize cloud resource allocation and predict energy needs"
    }
  ],
  "visualTips": [
    {
      "concept": "PUE\u8ba1\u7b97",
      "visualization": "\u60f3\u8c61\u4e00\u4e2a\u997c\u56fe: \u603b\u80fd\u91cf\u662f\u6574\u4e2a\u997c, IT\u8bbe\u5907\u80fd\u91cf\u662f\u9634\u5f71\u90e8\u5206\u3002PUE = \u6574\u997c/\u9634\u5f71\u90e8\u5206\u3002PUE=1\u610f\u5473\u7740\u6574\u4e2a\u997c\u90fd\u662f\u9634\u5f71(\u5b8c\u7f8e\u6548\u7387)!"
    },
    {
      "concept": "VM Consolidation",
      "visualization": "\u60f3\u8c61\u4e00\u4e2a\u516c\u5bd3\u697c(\u7269\u7406\u670d\u52a1\u5668)\u91cc\u6709\u8bb8\u591a\u7a7a\u623f\u95f4(\u672a\u5145\u5206\u5229\u7528\u7684VM)\u3002\u6574\u5408\u5c31\u662f\u628a\u591a\u4e2a\u7a7a\u623f\u95f4\u7684\u4e1c\u897f\u5408\u5e76\u5230\u51e0\u4e2a\u623f\u95f4, \u5173\u6389\u7a7a\u623f\u95f4\u7701\u7535!"
    },
    {
      "concept": "Dynamic Resource Provisioning",
      "visualization": "\u60f3\u8c61\u81ea\u52a8\u4f38\u7f29\u95e8: \u9ad8\u5cf0\u671f\u591a\u5f00\u901a\u9053(\u6269\u5bb9), \u4f4e\u5cf0\u671f\u5c11\u5f00\u901a\u9053(\u7f29\u5bb9), \u5c31\u50cf\u6839\u636e\u4eba\u6d41\u8c03\u6574\u5165\u53e3\u6570\u91cf\u4e00\u6837!"
    },
    {
      "concept": "Server Utilization",
      "visualization": "\u60f3\u8c61\u4e00\u4e2a\u5de5\u5382\u7684\u673a\u5668: \u5229\u7528\u7387\u4f4e\u5c31\u50cf\u53ea\u5f00\u52a820%\u7684\u673a\u5668\u5374\u6d88\u8017100%\u7684\u80fd\u6e90, \u662f\u5de8\u5927\u7684\u6d6a\u8d39! \u76ee\u6807\u662f\u9ad8\u5229\u7528\u7387"
    }
  ],
  "analogies": [
