        {
          "key": "B",
          "text": "Two children"
        },
        {
          "key": "C",
          "text": "Three children"
        },
        {
          "key": "D",
          "text": "Any number of children"
        }
      ],
      "correctAnswer": "B",
      "explanation": "Huffman tree is a binary tree where each internal node has exactly two children (left=0, right=1).",
      "difficulty": "easy"
    },
    {
