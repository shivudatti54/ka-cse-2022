{
  "topicId": "huffman-trees-codes",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "In Huffman coding, frequently occurring characters receive:",
      "options": [
        {
          "key": "A",
          "text": "Shorter codewords"
        },
        {
          "key": "B",
          "text": "Longer codewords"
        },
        {
          "key": "C",
          "text": "Fixed-length codewords"
        },
        {
          "key": "D",
          "text": "No codewords"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Huffman coding assigns shorter binary codes to characters with higher frequency to achieve compression.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "What type of algorithm is Huffman coding?",
      "options": [
        {
          "key": "A",
          "text": "Dynamic Programming"
        },
        {
          "key": "B",
          "text": "Greedy Algorithm"
        },
        {
          "key": "C",
          "text": "Divide and Conquer"
        },
        {
          "key": "D",
          "text": "Backtracking"
        }
      ],
      "correctAnswer": "B",
      "explanation": "Huffman coding uses a greedy approach by always merging the two nodes with minimum frequency.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "The time complexity of building a Huffman tree with n characters is:",
      "options": [
        {
          "key": "A",
          "text": "O(n)"
        },
        {
          "key": "B",
          "text": "O(n log n)"
        },
        {
          "key": "C",
          "text": "O(n\u00b2)"
        },
        {
          "key": "D",
          "text": "O(log n)"
        }
      ],
      "correctAnswer": "B",
      "explanation": "Using a min-heap, we perform n-1 merges, each taking O(log n) time, giving O(n log n).",
      "difficulty": "medium"
    },
    {
      "id": "mcq-4",
      "question": "A Huffman code is an example of:",
      "options": [
