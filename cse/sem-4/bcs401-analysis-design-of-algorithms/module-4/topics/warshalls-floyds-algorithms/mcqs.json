    },
    {
      "id": "mcq-15",
      "question": "The recurrence in Floyd's algorithm is:",
      "options": [
        {
          "key": "A",
          "text": "D[i][j] = D[i][k] + D[k][j]"
        },
        {
          "key": "B",
          "text": "D[i][j] = min(D[i][j], D[i][k] + D[k][j])"
        },
        {
          "key": "C",
          "text": "D[i][j] = max(D[i][j], D[i][k] + D[k][j])"
        },
        {
          "key": "D",
          "text": "D[i][j] = D[i][j] + D[k][j]"
        }
      ],
      "correctAnswer": "D[i][j] = min(D[i][j], D[i][k] + D[k][j])",
      "explanation": "This finds the minimum between the current path and the path through vertex k.",
      "difficulty": "medium"
    },
