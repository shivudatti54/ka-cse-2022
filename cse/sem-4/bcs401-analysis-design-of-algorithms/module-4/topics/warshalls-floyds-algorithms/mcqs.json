{
  "topicId": "warshalls-floyds-algorithms",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "Warshall's algorithm is used to find:",
      "options": [
        {
          "key": "A",
          "text": "Shortest path between all pairs"
        },
        {
          "key": "B",
          "text": "Transitive closure of a graph"
        },
        {
          "key": "C",
          "text": "Minimum spanning tree"
        },
        {
          "key": "D",
          "text": "Topological sort"
        }
      ],
      "correctAnswer": "Transitive closure of a graph",
      "explanation": "Warshall's algorithm computes the transitive closure, which determines reachability between every pair of vertices using boolean values.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "The time complexity of both Warshall's and Floyd's algorithms is:",
      "options": [
        {
          "key": "A",
          "text": "O(n)"
        },
        {
          "key": "B",
          "text": "O(n\u00b2)"
        },
        {
          "key": "C",
          "text": "O(n\u00b3)"
        },
        {
          "key": "D",
          "text": "O(n log n)"
        }
      ],
      "correctAnswer": "O(n\u00b3)",
      "explanation": "Both algorithms use three nested loops over n vertices, resulting in cubic time complexity.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "Floyd's algorithm is also known as:",
      "options": [
        {
          "key": "A",
          "text": "Dijkstra's algorithm"
        },
        {
          "key": "B",
          "text": "Kruskal's algorithm"
        },
        {
          "key": "C",
          "text": "Warshal's algorithm"
        },
        {
          "key": "D",
          "text": "All-pairs shortest path algorithm"
        }
      ],
      "correctAnswer": "All-pairs shortest path algorithm",
      "explanation": "Floyd's algorithm finds shortest paths between all pairs of vertices, making it an all-pairs shortest path algorithm.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-4",
      "question": "In Floyd's algorithm, the distance matrix is initialized with:",
      "options": [
        {
          "key": "A",
          "text": "All zeros"
        },
        {
          "key": "B",
          "text": "All ones"
        },
        {
          "key": "C",
          "text": "Edge weights (or \u221e if no edge)"
        },
        {
          "key": "D",
          "text": "Adjacency list"
        }
      ],
      "correctAnswer": "Edge weights (or \u221e if no edge)",
      "explanation": "D[i][j] is initialized to the weight of edge i\u2192j, 0 for i=j, and \u221e for non-existent edges.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-5",
      "question": "Warshall's algorithm uses which type of matrix representation?",
      "options": [
        {
          "key": "A",
          "text": "Adjacency list"
        },
        {
          "key": "B",
          "text": "Incidence matrix"
        },
