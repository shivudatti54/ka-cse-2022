    },
    {
      "id": "mcq-13",
      "question": "Partial derivative of sin(xy) with respect to x treating y constant is",
      "options": [
        {
          "key": "A",
          "text": "y cos(xy)"
        },
        {
          "key": "B",
          "text": "x cos(xy)"
