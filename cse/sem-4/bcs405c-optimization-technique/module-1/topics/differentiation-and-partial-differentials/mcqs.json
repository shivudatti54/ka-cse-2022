    {
      "id": "mcq-15",
      "question": "The second order partial derivative fₓᵧ equals fᵧₓ when",
      "options": [
        {
          "key": "A",
          "text": "Both are continuous"
        },
        {
          "key": "B",
          "text": "f is linear"
        },
        {
          "key": "C",
          "text": "x = y"
        },
        {
          "key": "D",
          "text": "f is constant"
        }
      ],
      "correctAnswer": "Both are continuous",
      "explanation": "Clairaut's theorem states mixed partials are equal if they are continuous in a neighborhood ( Schwarz's theorem).",
      "difficulty": "medium"
    },
    {
      "id": "mcq-16",
      "question": "For maxima and minima, the second derivative test uses",
      "options": [
