    {
      "id": "mcq-1",
      "question": "Which best describes a mental model?",
      "options": [
        {
          "key": "A",
          "text": "A. Developer's system documentation"
        },
        {
          "key": "B",
          "text": "B. User's understanding of system operation"
        },
        {
          "key": "C",
          "text": "C. UI color scheme"
        },
        {
          "key": "D",
          "text": "D. Database schema"
        }
      ],
      "correctAnswer": "B",
      "explanation": "Mental models represent user's perspective, not technical implementation.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
