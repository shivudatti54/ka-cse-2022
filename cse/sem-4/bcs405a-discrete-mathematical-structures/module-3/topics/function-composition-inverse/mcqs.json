{
  "topicId": "function-composition-inverse",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "Let f: {1,2,3} \u2192 {a,b,c,d} be defined by f(1)=a, f(2)=b, f(3)=c. What type of function is this?",
      "options": [
        {
          "key": "A",
          "text": "Injective only"
        },
        {
          "key": "B",
          "text": "Surjective only"
        },
        {
          "key": "C",
          "text": "Bijective"
        },
        {
          "key": "D",
          "text": "Neither injective nor surjective"
        }
      ],
      "correctAnswer": "Injective only",
      "explanation": "Each element in domain maps to unique element in codomain (injective), but codomain element d has no pre-image (not surjective).",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "If f: \u211d \u2192 \u211d is defined by f(x) = 2x + 1, which of the following is true?",
      "options": [
        {
          "key": "A",
          "text": "f is not a function"
        },
        {
          "key": "B",
          "text": "f is only injective"
        },
        {
          "key": "C",
          "text": "f is only surjective"
        },
        {
          "key": "D",
          "text": "f is bijective"
        }
      ],
      "correctAnswer": "f is bijective",
      "explanation": "f(x) = 2x + 1 is one-to-one (linear with non-zero slope) and onto (any y \u2208 \u211d can be written as y = 2x+1 for x = (y-1)/2).",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "Given f: \u2124 \u2192 \u2124 where f(x) = x\u00b2, what is the range?",
      "options": [
        {
          "key": "A",
          "text": "\u2124"
        },
        {
          "key": "B",
          "text": "All integers"
        },
        {
          "key": "C",
          "text": "Non-negative integers"
        },
        {
          "key": "D",
          "text": "All positive integers"
        }
      ],
      "correctAnswer": "Non-negative integers",
      "explanation": "For any integer x, x\u00b2 \u2265 0. Also, not every non-negative integer is a perfect square, so range is {0,1,4,9,16,...}.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-4",
      "question": "Let f(x) = x + 2 and g(x) = 2x. Find (f \u2218 g)(3).",
      "options": [
        {
          "key": "A",
          "text": "5"
        },
        {
          "key": "B",
          "text": "8"
        },
        {
          "key": "C",
          "text": "10"
        },
        {
          "key": "D",
          "text": "14"
        }
      ],
      "correctAnswer": "8",
      "explanation": "(f \u2218 g)(3) = f(g(3)) = f(6) = 6 + 2 = 8.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-5",
      "question": "Which of the following functions has an inverse?",
      "options": [
        {
          "key": "A",
          "text": "f: \u211d \u2192 \u211d, f(x) = x\u00b2"
        },
        {
          "key": "B",
          "text": "f: \u211d \u2192 \u211d\u207a, f(x) = x\u00b2"
        },
        {
          "key": "C",
          "text": "f: \u2124 \u2192 \u2124, f(x) = 2x"
        },
        {
          "key": "D",
          "text": "f: \u211d \u2192 \u211d, f(x) = x\u00b3"
        }
      ],
      "correctAnswer": "f: \u211d \u2192 \u211d, f(x) = x\u00b3",
      "explanation": "x\u00b3 is bijective (strictly monotonic). x\u00b2 is not injective over \u211d. 2x is bijective over \u2124, but the question asks about \u211d \u2192 \u211d options.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-6",
      "question": "The inverse of f(x) = (x-1)/3 is:",
      "options": [
        {
          "key": "A",
          "text": "f\u207b\u00b9(x) = 3x + 1"
        },
        {
          "key": "B",
          "text": "f\u207b\u00b9(x) = 3x - 1"
        },
        {
          "key": "C",
          "text": "f\u207b\u00b9(x) = x/3 + 1"
        },
        {
          "key": "D",
          "text": "f\u207b\u00b9(x) = x + 3"
        }
      ],
      "correctAnswer": "f\u207b\u00b9(x) = 3x + 1",
      "explanation": "Let y = (x-1)/3, then 3y = x-1, so x = 3y + 1. Replace y with x: f\u207b\u00b9(x) = 3x + 1.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-7",
      "question": "If f and g are both bijective functions, then f \u2218 g is:",
      "options": [
        {
          "key": "A",
          "text": "Always bijective"
        },
        {
          "key": "B",
          "text": "Never bijective"
        },
        {
          "key": "C",
          "text": "Sometimes bijective"
        },
        {
          "key": "D",
          "text": "Insufficient information"
        }
      ],
      "correctAnswer": "Always bijective",
      "explanation": "Composition of two bijective functions is always bijective. (f \u2218 g)\u207b\u00b9 = g\u207b\u00b9 \u2218 f\u207b\u00b9.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-8",
      "question": "Which property does function composition NOT satisfy?",
      "options": [
        {
          "key": "A",
          "text": "Associativity"
        },
        {
          "key": "B",
          "text": "Commutativity"
        },
        {
          "key": "C",
          "text": "Identity"
        },
        {
          "key": "D",
          "text": "Inverse"
        }
      ],
      "correctAnswer": "Commutativity",
      "explanation": "In general, f \u2218 g \u2260 g \u2218 f. Composition is associative but not commutative.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-9",
      "question": "A function f: A \u2192 B is surjective if and only if:",
      "options": [
        {
          "key": "A",
          "text": "|A| = |B|"
        },
        {
          "key": "B",
          "text": "|A| \u2264 |B|"
        },
        {
          "key": "C",
          "text": "|A| \u2265 |B|"
        },
        {
          "key": "D",
          "text": "f\u207b\u00b9 exists"
        }
      ],
      "correctAnswer": "|A| \u2265 |B|",
      "explanation": "For surjectivity, each element in B must have at least one pre-image, requiring at least as many domain elements as codomain elements.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-10",
      "question": "Let f: {1,2} \u2192 {a,b} and g: {a,b} \u2192 {x,y}. Number of possible functions f and g such that (f \u2218 g) is constant is:",
      "options": [
        {
          "key": "A",
          "text": "2"
        },
        {
          "key": "B",
          "text": "4"
        },
        {
          "key": "C",
          "text": "8"
        },
        {
          "key": "D",
          "text": "16"
        }
      ],
      "correctAnswer": "8",
      "explanation": "For (f \u2218 g) to be constant, all inputs map to same output. There are 2 choices for constant value (x or y). For each, g maps both a,b to that value (1 way), and f must map x,y to that same value (1 way). Actually 2\u00d72\u00d72=8.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-11",
      "question": "What is \u230a-3.7\u230b?",
      "options": [
        {
          "key": "A",
          "text": "-3"
        },
        {
          "key": "B",
          "text": "-4"
        },
        {
          "key": "C",
          "text": "3"
        },
        {
          "key": "D",
          "text": "4"
        }
      ],
      "correctAnswer": "-4",
      "explanation": "Floor gives greatest integer \u2264 -3.7, which is -4 (since -4 < -3.7 < -3).",
      "difficulty": "easy"
    },
    {
      "id": "mcq-12",
      "question": "The number of bijective functions from a set of n elements to itself is:",
      "options": [
        {
          "key": "A",
          "text": "n"
        },
        {
          "key": "B",
          "text": "n!"
        },
        {
          "key": "C",
          "text": "2\u207f"
        },
        {
          "key": "D",
          "text": "n\u00b2"
        }
      ],
      "correctAnswer": "n!",
      "explanation": "This is the number of permutations of n elements, which equals n! = n \u00d7 (n-1) \u00d7 ... \u00d7 1.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-13",
      "question": "If f \u2218 f = f, f is called:",
      "options": [
        {
          "key": "A",
          "text": "Idempotent"
        },
        {
          "key": "B",
          "text": "Involutory"
        },
        {
          "key": "C",
          "text": "Periodic"
        },
        {
          "key": "D",
          "text": "None"
        }
      ],
      "correctAnswer": "Idempotent",
      "explanation": "A function where f(f(x)) = f(x) for all x is called idempotent. Examples: projection functions.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-14",
      "question": "For f: \u211d \u2192 \u211d\u207a defined by f(x) = e\u02e3, the inverse function is:",
      "options": [
        {
          "key": "A",
          "text": "ln(x)"
        },
        {
          "key": "B",
          "text": "log\u2081\u2080(x)"
        },
        {
          "key": "C",
          "text": "e\u02e3"
        },
        {
          "key": "D",
          "text": "1/e\u02e3"
        }
      ],
      "correctAnswer": "ln(x)",
      "explanation": "If y = e\u02e3, then x = ln(y). The natural logarithm is the inverse of the exponential function.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-15",
      "question": "Which is true about the composition of an injective function with any function?",
      "options": [
        {
          "key": "A",
          "text": "Always injective"
        },
        {
          "key": "B",
          "text": "Never injective"
        },
        {
          "key": "C",
          "text": "Injective if other function is surjective"
        },
        {
          "key": "D",
          "text": "Cannot determine"
        }
      ],
      "correctAnswer": "Always injective",
      "explanation": "If f is injective and g is any function with compatible domains, then f \u2218 g is injective. If g is injective, f \u2218 g may not be injective if f is not.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-16",
      "question": "The function f: \u2115 \u2192 \u2115 defined by f(n) = n + 1 is:",
      "options": [
        {
          "key": "A",
          "text": "Injective only"
        },
        {
          "key": "B",
          "text": "Surjective only"
        },
        {
          "key": "C",
          "text": "Bijective"
        },
        {
          "key": "D",
          "text": "Neither"
        }
      ],
      "correctAnswer": "Injective only",
      "explanation": "f(n\u2081) = f(n\u2082) \u21d2 n\u2081+1 = n\u2082+1 \u21d2 n\u2081 = n\u2082, so injective. But 1 has no pre-image (0 not in \u2115), so not surjective.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-17",
      "question": "What is the domain of f\u207b\u00b9 if f: A \u2192 B is bijective?",
      "options": [
        {
          "key": "A",
          "text": "A"
        },
        {
          "key": "B",
          "text": "B"
        },
        {
          "key": "C",
          "text": "A \u00d7 B"
        },
        {
          "key": "D",
          "text": "P(A)"
        }
      ],
      "correctAnswer": "B",
      "explanation": "If f: A \u2192 B is bijective, the inverse function f\u207b\u00b9: B \u2192 A has domain B and codomain A.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-18",
      "question": "If f(x) = x\u00b3 - 1, then f\u207b\u00b9(7) equals:",
      "options": [
        {
          "key": "A",
          "text": "1"
        },
        {
          "key": "B",
          "text": "2"
        },
        {
          "key": "C",
          "text": "3"
        },
        {
          "key": "D",
          "text": "4"
        }
      ],
      "correctAnswer": "2",
      "explanation": "Solve x\u00b3 - 1 = 7 \u21d2 x\u00b3 = 8 \u21d2 x = 2. So f\u207b\u00b9(7) = 2.",
      "difficulty": "medium"
    }
  ]
}
