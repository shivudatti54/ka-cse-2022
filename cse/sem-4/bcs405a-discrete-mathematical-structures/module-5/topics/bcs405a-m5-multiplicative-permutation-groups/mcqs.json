    {
      "id": "mcq-6",
      "question": "Which of the following is an odd permutation?",
      "options": [
        {
          "key": "A",
          "text": "(1 2)"
        },
        {
          "key": "B",
          "text": "(1 2 3)"
        },
        {
          "key": "C",
          "text": "(1 2)(3 4)"
        },
        {
          "key": "D",
          "text": "identity"
        }
      ],
      "correctAnswer": "(1 2)",
      "explanation": "A transposition (2-cycle) is odd. (1 2 3) is even (3-cycle = 2 transpositions).",
      "difficulty": "easy"
    },
    {
      "id": "mcq-7",
      "question": "What is the order of the alternating group A4?",
      "options": [
        {
          "key": "A",
          "text": "12"
        },
        {
          "key": "B",
          "text": "24"
        },
        {
          "key": "C",
          "text": "6"
        },
        {
          "key": "D",
          "text": "4"
        }
      ],
      "correctAnswer": "12",
      "explanation": "|An| = n!/2, so |A4| = 4!/2 = 24/2 = 12.",
      "difficulty": "medium"
    },
