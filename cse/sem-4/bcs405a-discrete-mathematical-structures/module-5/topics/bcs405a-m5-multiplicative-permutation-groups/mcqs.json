    {
      "id": "mcq-3",
      "question": "Using Fermat's Little Theorem, find 3^6 mod 7",
      "options": [
        {
          "key": "A",
          "text": "1"
        },
        {
          "key": "B",
          "text": "2"
        },
        {
          "key": "C",
          "text": "6"
        },
        {
          "key": "D",
          "text": "3"
        }
      ],
      "correctAnswer": "1",
      "explanation": "By FLT: 3^(7-1) = 3^6 \u2261 1 (mod 7) since 7 is prime and 7 \u2224 3.",
      "difficulty": "easy"
    },
    {
