      "id": "mcq-1",
      "question": "What is the order of the multiplicative group Z7*?",
      "options": [
        {
          "key": "A",
          "text": "6"
        },
        {
          "key": "B",
          "text": "7"
        },
        {
          "key": "C",
          "text": "8"
        },
        {
          "key": "D",
          "text": "5"
        }
      ],
      "correctAnswer": "6",
      "explanation": "Z7* = {1,2,3,4,5,6} has 7-1 = 6 elements since 7 is prime.",
      "difficulty": "easy"
    },
    {
