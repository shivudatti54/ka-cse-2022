{
  "topicId": "definitions-and-examples-of-particular-groups",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "What is the order of the symmetric group S3?",
      "options": [
        {
          "key": "A",
          "text": "3"
        },
        {
          "key": "B",
          "text": "6"
        },
        {
          "key": "C",
          "text": "9"
        },
        {
          "key": "D",
          "text": "12"
        }
      ],
      "correctAnswer": "6",
      "explanation": "S3 contains all permutations of 3 elements, so |S3| = 3! = 6.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "Which of the following groups is cyclic?",
      "options": [
        {
          "key": "A",
          "text": "S3"
        },
        {
          "key": "B",
          "text": "Q8"
        },
        {
          "key": "C",
          "text": "Z6"
        },
        {
          "key": "D",
          "text": "V4"
        }
      ],
      "correctAnswer": "Z6",
      "explanation": "Z6 under addition modulo 6 is cyclic, generated by 1. S3 and Q8 are non-abelian, V4 is abelian but not cyclic.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "The Klein four-group V4 is isomorphic to which group?",
      "options": [
        {
          "key": "A",
          "text": "Z4"
        },
        {
          "key": "B",
          "text": "Z2 × Z2"
        },
        {
          "key": "C",
          "text": "Z3"
        },
        {
          "key": "D",
          "text": "Z6"
        }
      ],
      "correctAnswer": "Z2 × Z2",
      "explanation": "V4 is isomorphic to Z2 × Z2, the direct product of two copies of Z2.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-4",
      "question": "What is the order of element 3 in Z8?",
      "options": [
        {
          "key": "A",
          "text": "2"
        },
        {
          "key": "B",
          "text": "4"
        },
        {
          "key": "C",
          "text": "6"
        },
        {
          "key": "D",
          "text": "8"
        }
      ],
      "correctAnswer": "8",
      "explanation": "In Z8, 3 has order 8 because 3×8 = 24 ≡ 0 (mod 8), and no smaller positive integer works.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-5",
      "question": "How many elements of order 2 does S3 have?",
      "options": [
        {
          "key": "A",
          "text": "1"
        },
        {
          "key": "B",
          "text": "2"
        },
        {
          "key": "C",
          "text": "3"
        },
        {
          "key": "D",
          "text": "4"
        }
      ],
      "correctAnswer": "3",
      "explanation": "S3 has 3 transpositions: (12), (13), (23), each of which has order 2.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-6",
      "question": "Which group represents symmetries of a square?",
      "options": [
        {
          "key": "A",
          "text": "D3"
        },
        {
          "key": "B",
          "text": "D4"
        },
        {
          "key": "C",
          "text": "D5"
        },
        {
          "key": "D",
          "text": "D6"
        }
      ],
      "correctAnswer": "D4",
      "explanation": "D4 is the dihedral group of order 8 representing symmetries of a square (regular 4-gon).",
      "difficulty": "easy"
    },
    {
      "id": "mcq-7",
      "question": "What is the order of the alternating group A4?",
      "options": [
        {
          "key": "A",
          "text": "4"
        },
        {
          "key": "B",
          "text": "6"
        },
        {
          "key": "C",
          "text": "12"
        },
        {
          "key": "D",
          "text": "24"
        }
      ],
      "correctAnswer": "12",
      "explanation": "|A4| = 4!/2 = 12, as it contains all even permutations of 4 elements.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-8",
      "question": "In U(10), what is the order of element 3?",
      "options": [
        {
          "key": "A",
          "text": "2"
        },
        {
          "key": "B",
          "text": "3"
        },
        {
          "key": "C",
          "text": "4"
        },
        {
          "key": "D",
          "text": "5"
        }
      ],
      "correctAnswer": "4",
      "explanation": "In U(10) = {1,3,7,9}, 3^2 = 9, 3^3 = 27 ≡ 7, 3^4 = 81 ≡ 1 (mod 10), so order is 4.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-9",
      "question": "Which of the following is NOT a cyclic group?",
      "options": [
        {
          "key": "A",
          "text": "Z5"
        },
        {
          "key": "B",
          "text": "Z8"
        },
        {
          "key": "C",
          "text": "U(7)"
        },
        {
          "key": "D",
          "text": "U(8)"
        }
      ],
      "correctAnswer": "U(8)",
      "explanation": "U(8) = {1,3,5,7} is not cyclic because it has no generator - no element has order φ(8)=4.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-10",
      "question": "The dihedral group D5 has how many elements?",
      "options": [
        {
          "key": "A",
          "text": "5"
        },
        {
          "key": "B",
          "text": "8"
        },
        {
          "key": "C",
          "text": "10"
        },
        {
          "key": "D",
          "text": "20"
        }
      ],
      "correctAnswer": "10",
      "explanation": "D_n has 2n elements. For n=5, D5 has 10 elements (5 rotations + 5 reflections).",
      "difficulty": "easy"
    },
    {
      "id": "mcq-11",
      "question": "In Q8, what is the order of element i?",
      "options": [
        {
          "key": "A",
          "text": "2"
        },
        {
          "key": "B",
          "text": "4"
        },
        {
          "key": "C",
          "text": "6"
        },
        {
          "key": "D",
          "text": "8"
        }
      ],
      "correctAnswer": "4",
      "explanation": "In Q8, i^2 = -1, i^4 = 1, so order is 4. Same for j and k.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-12",
      "question": "What is the generator(s) of Z7?",
      "options": [
        {
          "key": "A",
          "text": "Only 1"
        },
        {
          "key": "B",
          "text": "Only 3"
        },
        {
          "key": "C",
          "text": "1, 2, 3, 4, 5, 6"
        },
        {
          "key": "D",
          "text": "1 and 6"
        }
      ],
      "correctAnswer": "1, 2, 3, 4, 5, 6",
      "explanation": "Since 7 is prime, all 6 non-zero elements in Z7 are generators (φ(7) = 6).",
      "difficulty": "medium"
    },
    {
      "id": "mcq-13",
      "question": "Which statement is true about all cyclic groups?",
      "options": [
        {
          "key": "A",
          "text": "They are infinite"
        },
        {
          "key": "B",
          "text": "They are non-abelian"
        },
        {
          "key": "C",
          "text": "They are abelian"
        },
        {
          "key": "D",
          "text": "They have prime order"
        }
      ],
      "correctAnswer": "They are abelian",
      "explanation": "All cyclic groups are abelian because g^a · g^b = g^(a+b) = g^b · g^a for any elements.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-14",
      "question": "The group Z12 ⊕ Z4 has order:",
      "options": [
        {
          "key": "A",
          "text": "16"
        },
        {
          "key": "B",
          "text": "24"
        },
        {
          "key": "C",
          "text": "48"
        },
        {
          "key": "D",
          "text": "12"
        }
      ],
      "correctAnswer": "48",
      "explanation": "Order of direct product is product of orders: |Z12 × Z4| = 12 × 4 = 48.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-15",
      "question": "How many subgroups does a cyclic group of prime order p have?",
      "options": [
        {
          "key": "A",
          "text": "0"
        },
        {
          "key": "B",
          "text": "1"
        },
        {
          "key": "C",
          "text": "2"
        },
        {
          "key": "D",
          "text": "p"
        }
      ],
      "correctAnswer": "2",
      "explanation": "A cyclic group of prime order p has exactly 2 subgroups: the trivial subgroup {e} and the group itself.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-16",
      "question": "U(9) is isomorphic to which group?",
      "options": [
        {
          "key": "A",
          "text": "Z6"
        },
        {
          "key": "B",
          "text": "Z8"
        },
        {
          "key": "C",
          "text": "Z2 × Z2"
        },
        {
          "key": "D",
          "text": "Z3"
        }
      ],
      "correctAnswer": "Z6",
      "explanation": "U(9) = {1,2,4,5,7,8} has 6 elements and is cyclic, hence isomorphic to Z6.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-17",
      "question": "What is the identity element in the Quaternion group Q8?",
      "options": [
        {
          "key": "A",
          "text": "i"
        },
        {
          "key": "B",
          "text": "j"
        },
        {
          "key": "C",
          "text": "1"
        },
        {
          "key": "D",
          "text": "-1"
        }
      ],
      "correctAnswer": "1",
      "explanation": "In Q8, 1 is the identity element. The element -1 is of order 2.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-18",
      "question": "The group (Z, +) is:",
      "options": [
        {
          "key": "A",
          "text": "Finite"
        },
        {
          "key": "B",
          "text": "Cyclic of order infinite"
        },
        {
          "key": "C",
          "text": "Non-cyclic"
        },
        {
          "key": "D",
          "text": "Finite of order 0"
        }
      ],
      "correctAnswer": "Cyclic of order infinite",
      "explanation": "Z under addition is an infinite cyclic group generated by 1 (or -1).",
      "difficulty": "easy"
    },
    {
      "id": "mcq-19",
      "question": "If G is a group of order 12, which could be a subgroup?",
      "options": [
        {
          "key": "A",
          "text": "Z13"
        },
        {
          "key": "B",
          "text": "Z7"
        },
        {
          "key": "C",
          "text": "Z6"
        },
        {
          "key": "D",
          "text": "Z15"
        }
      ],
      "correctAnswer": "Z6",
      "explanation": "By Lagrange's Theorem, a subgroup's order must divide the group's order. 6 divides 12.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-20",
      "question": "The center of Q8 (Z(Q8)) contains:",
      "options": [
        {
          "key": "A",
          "text": "All 8 elements"
        },
        {
          "key": "B",
          "text": "Only 1"
        },
        {
          "key": "C",
          "text": "1 and -1"
        },
        {
          "key": "D",
          "text": "i, j, k"
        }
      ],
      "correctAnswer": "1 and -1",
      "explanation": "Z(Q8) = {1, -1} because only 1 and -1 commute with all elements of Q8.",
      "difficulty": "hard"
    }
  ]
}
