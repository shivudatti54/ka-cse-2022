{
  "topicId": "bcs405a-m1-logical-implication",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "The contrapositive of 'If it rains, then the ground is wet' is:",
      "options": [
        {
          "key": "A",
          "text": "If the ground is wet, then it rains"
        },
        {
          "key": "B",
          "text": "If the ground is not wet, then it does not rain"
        },
        {
          "key": "C",
          "text": "It does not rain or the ground is wet"
        },
        {
          "key": "D",
          "text": "If it does not rain, then the ground is not wet"
        }
      ],
      "correctAnswer": "If the ground is not wet, then it does not rain",
      "explanation": "The contrapositive negates both parts and swaps them: (p \u2192 q) becomes (\u00acq \u2192 \u00acp).",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "Which rule of inference is used in: 'If x > 0, then x\u00b2 > 0. x > 0. Therefore, x\u00b2 > 0'?",
      "options": [
        {
          "key": "A",
          "text": "Modus Tollens"
        },
        {
          "key": "B",
          "text": "Modus Ponens"
        },
        {
          "key": "C",
          "text": "Hypothetical Syllogism"
        },
        {
          "key": "D",
          "text": "Disjunctive Syllogism"
        }
      ],
      "correctAnswer": "Modus Ponens",
      "explanation": "Modus Ponens: From (p \u2192 q) and p, conclude q.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "What is the converse of p \u2192 q?",
      "options": [
        {
          "key": "A",
          "text": "q \u2192 p"
        },
        {
          "key": "B",
          "text": "\u00acp \u2192 \u00acq"
        },
        {
          "key": "C",
          "text": "\u00acq \u2192 \u00acp"
        },
        {
          "key": "D",
          "text": "p \u2227 q"
        }
      ],
      "correctAnswer": "q \u2192 p",
      "explanation": "The converse swaps the hypothesis and conclusion.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-4",
      "question": "Which of the following is logically equivalent to p \u2192 q?",
      "options": [
        {
          "key": "A",
          "text": "\u00acp \u2228 q"
        },
        {
          "key": "B",
          "text": "p \u2227 q"
        },
        {
          "key": "C",
          "text": "\u00acq \u2192 \u00acp"
        },
        {
          "key": "D",
          "text": "Both A and C"
        }
      ],
      "correctAnswer": "Both A and C",
      "explanation": "p \u2192 q is equivalent to \u00acp \u2228 q (material implication) and also to its contrapositive \u00acq \u2192 \u00acp.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-5",
      "question": "An argument is valid when:",
      "options": [
        {
          "key": "A",
          "text": "All premises are true"
        },
        {
          "key": "B",
          "text": "The conclusion is true"
        },
        {
          "key": "C",
          "text": "Whenever premises are true, conclusion is true"
        },
        {
          "key": "D",
          "text": "The argument has true premises and true conclusion"
        }
      ],
      "correctAnswer": "Whenever premises are true, conclusion is true",
      "explanation": "Validity concerns the logical structure, not the actual truth of premises.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-6",
      "question": "Modus Tollens can be expressed as:",
      "options": [
        {
          "key": "A",
          "text": "[(p \u2192 q) \u2227 p] \u21d2 q"
        },
        {
          "key": "B",
          "text": "[(p \u2192 q) \u2227 \u00acq] \u21d2 \u00acp"
        },
        {
          "key": "C",
          "text": "[(p \u2228 q) \u2227 \u00acp] \u21d2 q"
        },
        {
          "key": "D",
          "text": "[(p \u2192 q) \u2227 (q \u2192 r)] \u21d2 (p \u2192 r)"
        }
      ],
      "correctAnswer": "[(p \u2192 q) \u2227 \u00acq] \u21d2 \u00acp",
      "explanation": "Modus Tollens: If p implies q, and q is false, then p must be false.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-7",
      "question": "The inverse of p \u2192 q is:",
      "options": [
        {
          "key": "A",
          "text": "q \u2192 p"
        },
        {
          "key": "B",
          "text": "\u00acp \u2192 \u00acq"
        },
        {
          "key": "C",
          "text": "\u00acq \u2192 \u00acp"
        },
        {
          "key": "D",
          "text": "\u00acp \u2228 q"
        }
      ],
      "correctAnswer": "\u00acp \u2192 \u00acq",
      "explanation": "The inverse negates both the hypothesis and conclusion.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-8",
      "question": "What rule of inference is used in: 'Either it is sunny or it is cold. It is not cold. Therefore, it is sunny.'?",
      "options": [
        {
          "key": "A",
          "text": "Modus Ponens"
        },
        {
          "key": "B",
          "text": "Modus Tollens"
        },
        {
          "key": "C",
          "text": "Disjunctive Syllogism"
        },
        {
          "key": "D",
          "text": "Hypothetical Syllogism"
        }
      ],
      "correctAnswer": "Disjunctive Syllogism",
      "explanation": "Disjunctive Syllogism: From (p \u2228 q) and \u00acp, conclude q.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-9",
      "question": "Which rule of inference is: [(p \u2192 q) \u2227 (q \u2192 r)] \u21d2 (p \u2192 r)?",
      "options": [
        {
          "key": "A",
          "text": "Modus Ponens"
        },
        {
          "key": "B",
          "text": "Modus Tollens"
        },
        {
          "key": "C",
          "text": "Hypothetical Syllogism"
        },
        {
          "key": "D",
          "text": "Resolution"
        }
      ],
      "correctAnswer": "Hypothetical Syllogism",
      "explanation": "Hypothetical Syllogism chains implications together.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-10",
      "question": "The statement 'If today is Sunday, then tomorrow is Monday' and 'Tomorrow is not Monday' together imply:",
      "options": [
        {
          "key": "A",
          "text": "Today is Sunday"
        },
        {
          "key": "B",
          "text": "Today is not Sunday"
        },
        {
          "key": "C",
          "text": "Today is Monday"
        },
        {
          "key": "D",
          "text": "Tomorrow is Sunday"
        }
      ],
      "correctAnswer": "Today is not Sunday",
      "explanation": "Using Modus Tollens: If p \u2192 q and \u00acq, then \u00acp.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-11",
      "question": "Which is a tautology?",
      "options": [
        {
          "key": "A",
          "text": "p \u2192 p"
        },
        {
          "key": "B",
          "text": "p \u2192 \u00acp"
        },
        {
          "key": "C",
          "text": "p \u2227 \u00acp"
        },
        {
          "key": "D",
          "text": "p \u2228 \u00acp"
        }
      ],
      "correctAnswer": "p \u2228 p",
      "explanation": "Law of Excluded Middle: p \u2228 \u00acp is always true.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-12",
      "question": "What is the resolution rule?",
      "options": [
        {
          "key": "A",
          "text": "[(p \u2192 q) \u2227 p] \u21d2 q"
        },
        {
          "key": "B",
          "text": "[(p \u2228 q) \u2227 \u00acq] \u21d2 p"
        },
        {
          "key": "C",
          "text": "[(p \u2228 q) \u2227 (\u00acq \u2228 r)] \u21d2 (p \u2228 r)"
        },
        {
          "key": "D",
          "text": "[(p \u2227 q)] \u21d2 p"
        }
      ],
      "correctAnswer": "[(p \u2228 q) \u2227 (\u00acq \u2228 r)] \u21d2 (p \u2228 r)",
      "explanation": "Resolution is fundamental in automated theorem proving.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-13",
      "question": "A sound argument must be:",
      "options": [
        {
          "key": "A",
          "text": "Valid only"
        },
        {
          "key": "B",
          "text": "True conclusion only"
        },
        {
          "key": "C",
          "text": "Valid with true premises"
        },
        {
          "key": "D",
          "text": "Popular"
        }
      ],
      "correctAnswer": "Valid with true premises",
      "explanation": "Soundness requires both validity and true premises.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-14",
      "question": "Simplification rule states:",
      "options": [
        {
          "key": "A",
          "text": "p \u21d2 (p \u2228 q)"
        },
        {
          "key": "B",
          "text": "(p \u2227 q) \u21d2 p"
        },
        {
          "key": "C",
          "text": "p and q \u21d2 (p \u2227 q)"
        },
        {
          "key": "D",
          "text": "p \u21d2 q \u21d2 (p \u2227 q)"
        }
      ],
      "correctAnswer": "(p \u2227 q) \u21d2 p",
      "explanation": "From a conjunction, we can infer any of its conjuncts.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-15",
      "question": "The fallacy of denying the antecedent is:",
      "options": [
        {
          "key": "A",
          "text": "[(p \u2192 q) \u2227 p] \u21d2 q"
        },
        {
          "key": "B",
          "text": "[(p \u2192 q) \u2227 \u00acp] \u21d2 \u00acq"
        },
        {
          "key": "C",
          "text": "[(p \u2192 q) \u2227 \u00acq] \u21d2 \u00acp"
        },
        {
          "key": "D",
          "text": "[(p \u2192 q) \u2227 q] \u21d2 p"
        }
      ],
      "correctAnswer": "[(p \u2192 q) \u2227 \u00acp] \u21d2 \u00acq",
      "explanation": "This is INVALID. Just because p is false doesn't mean q is false.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-16",
      "question": "The fallacy of affirming the consequent is:",
      "options": [
        {
          "key": "A",
          "text": "[(p \u2192 q) \u2227 p] \u21d2 q"
        },
        {
          "key": "B",
          "text": "[(p \u2192 q) \u2227 \u00acp] \u21d2 \u00acq"
        },
        {
          "key": "C",
          "text": "[(p \u2192 q) \u2227 \u00acq] \u21d2 \u00acp"
        },
        {
          "key": "D",
          "text": "[(p \u2192 q) \u2227 q] \u21d2 p"
        }
      ],
      "correctAnswer": "[(p \u2192 q) \u2227 q] \u21d2 p",
      "explanation": "This is INVALID. q being true doesn't imply p is true.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-17",
      "question": "Addition rule: From p, we can conclude:",
      "options": [
        {
          "key": "A",
          "text": "p \u2227 q"
        },
        {
          "key": "B",
          "text": "p \u2192 q"
        },
        {
          "key": "C",
          "text": "p \u2228 q"
        },
        {
          "key": "D",
          "text": "q \u2192 p"
        }
      ],
      "correctAnswer": "p \u2228 q",
      "explanation": "Addition introduces a disjunction: p \u21d2 (p \u2228 q).",
      "difficulty": "easy"
    },
    {
      "id": "mcq-18",
      "question": "The conjunction rule states:",
      "options": [
        {
          "key": "A",
          "text": "(p \u2227 q) \u21d2 p"
        },
        {
          "key": "B",
          "text": "p and q \u21d2 (p \u2227 q)"
        },
        {
          "key": "C",
          "text": "p \u21d2 (p \u2228 q)"
        },
        {
          "key": "D",
          "text": "(p \u2228 q) \u21d2 p"
        }
      ],
      "correctAnswer": "p and q \u21d2 (p \u2227 q)",
      "explanation": "From two separate premises, we can form their conjunction.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-19",
      "question": "For an argument to be valid, the conclusion must be true:",
      "options": [
        {
          "key": "A",
          "text": "Always"
        },
        {
          "key": "B",
          "text": "When premises are true"
        },
        {
          "key": "C",
          "text": "When premises are false"
        },
        {
          "key": "D",
          "text": "Never"
        }
      ],
      "correctAnswer": "When premises are true",
      "explanation": "In a valid argument, truth of premises guarantees truth of conclusion.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-20",
      "question": "Which is logically equivalent to \u00ac(p \u2227 q)?",
      "options": [
        {
          "key": "A",
          "text": "\u00acp \u2227 \u00acq"
        },
        {
          "key": "B",
          "text": "\u00acp \u2228 \u00acq"
        },
        {
          "key": "C",
          "text": "p \u2227 q"
        },
        {
          "key": "D",
          "text": "\u00acp \u2192 \u00acq"
        }
      ],
      "correctAnswer": "\u00acp \u2228 \u00acq",
      "explanation": "De Morgan's Law: Negation of conjunction is disjunction of negations.",
      "difficulty": "medium"
    }
  ]
}
