      "id": "mcq-1",
      "question": "What is the number of derangements of 4 objects?",
      "options": [
        {
          "key": "A",
          "text": "9"
        },
        {
          "key": "B",
          "text": "8"
        },
        {
          "key": "C",
          "text": "10"
        },
        {
          "key": "D",
          "text": "12"
        }
      ],
      "correctAnswer": "A",
      "explanation": "D(4) = 4! × (1 - 1/1! + 1/2! - 1/3! + 1/4!) = 24 × (1 - 1 + 0.5 - 0.1667 + 0.0417) = 24 × 0.375 = 9",
      "difficulty": "medium"
    },
