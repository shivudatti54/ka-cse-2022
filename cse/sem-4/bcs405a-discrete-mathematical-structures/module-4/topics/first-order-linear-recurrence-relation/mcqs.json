{
  "topicId": "first-order-linear-recurrence-relation",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "The general form of a first-order linear recurrence relation is:",
      "options": [
        {
          "key": "A",
          "text": "aₙ = c × aₙ₋₁ + d"
        },
        {
          "key": "B",
          "text": "aₙ = aₙ₋₁ + aₙ₋₂"
        },
        {
          "key": "C",
          "text": "aₙ = c × aₙ₋₁ × d"
        },
        {
          "key": "D",
          "text": "aₙ = aₙ₋₁²"
        }
      ],
      "correctAnswer": "aₙ = c × aₙ₋₁ + d",
      "explanation": "First-order means depends on aₙ₋₁ only, linear means variables to power 1, and d is a constant term.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "For the recurrence aₙ = 3aₙ₋₁ with a₀ = 2, find a₃",
      "options": [
        {
          "key": "A",
          "text": "18"
        },
        {
          "key": "B",
          "text": "54"
        },
        {
          "key": "C",
          "text": "162"
        },
        {
          "key": "D",
          "text": "6"
        }
      ],
      "correctAnswer": "54",
      "explanation": "a₁=3×2=6, a₂=3×6=18, a₃=3×18=54. Each term multiplies by 3.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "The solution of aₙ = aₙ₋₁ + 5 with a₀ = 3 is:",
      "options": [
        {
          "key": "A",
          "text": "aₙ = 3 + 5n"
        },
        {
          "key": "B",
          "text": "aₙ = 3 × 5ⁿ"
        },
        {
          "key": "C",
          "text": "aₙ = 3 + 5ⁿ"
        },
        {
          "key": "D",
          "text": "aₙ = 5 + 3n"
        }
      ],
      "correctAnswer": "aₙ = 3 + 5n",
      "explanation": "When c=1, we get arithmetic progression: aₙ = a₀ + nd = 3 + 5n.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-4",
      "question": "Which of the following is a homogeneous first-order recurrence?",
      "options": [
        {
          "key": "A",
          "text": "aₙ = 2aₙ₋₁ + 3"
        },
        {
          "key": "B",
          "text": "aₙ = 2aₙ₋₁"
        },
        {
          "key": "C",
          "text": "aₙ = aₙ₋₁ + n"
        },
        {
          "key": "D",
          "text": "aₙ = aₙ₋₁²"
        }
      ],
      "correctAnswer": "aₙ = 2aₙ₋₁",
      "explanation": "Homogeneous means the constant term d=0, so only aₙ = 2aₙ₋₁ qualifies.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-5",
      "question": "For aₙ = 0.5aₙ₋₁ + 10 with a₀ = 20, the steady-state value is:",
      "options": [
        {
          "key": "A",
          "text": "10"
        },
        {
          "key": "B",
          "text": "20"
        },
        {
          "key": "C",
          "text": "30"
        },
        {
          "key": "D",
          "text": "40"
        }
      ],
      "correctAnswer": "20",
      "explanation": "Steady-state L = d/(1-c) = 10/(1-0.5) = 10/0.5 = 20.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-6",
      "question": "The recurrence aₙ = aₙ₋₁ + aₙ₋₂ (Fibonacci) is:",
      "options": [
        {
          "key": "A",
          "text": "First-order homogeneous"
        },
        {
          "key": "B",
          "text": "Second-order homogeneous"
        },
        {
          "key": "C",
          "text": "First-order non-homogeneous"
        },
        {
          "key": "D",
          "text": "Second-order non-homogeneous"
        }
      ],
      "correctAnswer": "Second-order homogeneous",
      "explanation": "It depends on two previous terms (second-order) and has no constant term (homogeneous).",
      "difficulty": "medium"
    },
    {
      "id": "mcq-7",
      "question": "Find a₄ for aₙ = 2aₙ₋₁ + 1 with a₀ = 1",
      "options": [
        {
          "key": "A",
          "text": "15"
        },
        {
          "key": "B",
          "text": "31"
        },
        {
          "key": "C",
          "text": "17"
        },
        {
          "key": "D",
          "text": "30"
        }
      ],
      "correctAnswer": "31",
      "explanation": "a₁=2×1+1=3, a₂=2×3+1=7, a₃=2×7+1=15, a₄=2×15+1=31.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-8",
      "question": "The Tower of Hanoi requires 2ⁿ - 1 moves. This comes from recurrence:",
      "options": [
        {
          "key": "A",
          "text": "Tₙ = 2Tₙ₋₁ + 1"
        },
        {
          "key": "B",
          "text": "Tₙ = Tₙ₋₁ + 2"
        },
        {
          "key": "C",
          "text": "Tₙ = 2Tₙ₋₁ - 1"
        },
        {
          "key": "D",
          "text": "Tₙ = Tₙ₋₁ + 1"
        }
      ],
      "correctAnswer": "Tₙ = 2Tₙ₋₁ + 1",
      "explanation": "Moving n disks: move n-1 to aux, move largest, then move n-1 to target - two recursive calls plus 1 move.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-9",
      "question": "The recurrence aₙ = (1.05)aₙ₋₁ represents:",
      "options": [
        {
          "key": "A",
          "text": "Simple interest"
        },
        {
          "key": "B",
          "text": "Compound interest at 5%"
        },
        {
          "key": "C",
          "text": "Depreciation"
        },
        {
          "key": "D",
          "text": "Linear growth"
        }
      ],
      "correctAnswer": "Compound interest at 5%",
      "explanation": "Each period multiplies by 1.05, representing 5% interest compounded each period.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-10",
      "question": "For aₙ = c×aₙ₋₁ (homogeneous), the solution is:",
      "options": [
        {
          "key": "A",
          "text": "aₙ = a₀ × cⁿ"
        },
        {
          "key": "B",
          "text": "aₙ = a₀ + c×n"
        },
        {
          "key": "C",
          "text": "aₙ = a₀ × nᶜ"
        },
        {
          "key": "D",
          "text": "aₙ = c + a₀×n"
        }
      ],
      "correctAnswer": "aₙ = a₀ × cⁿ",
      "explanation": "The homogeneous solution forms a geometric progression with ratio c.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-11",
      "question": "If |c| < 1 in aₙ = c×aₙ₋₁ + d, the sequence:",
      "options": [
        {
          "key": "A",
          "text": "Converges to steady-state"
        },
        {
          "key": "B",
          "text": "Diverges"
        },
        {
          "key": "C",
          "text": "Oscillates"
        },
        {
          "key": "D",
          "text": "Remains constant"
        }
      ],
      "correctAnswer": "Converges to steady-state",
      "explanation": "When |c|<1, the homogeneous part decays to zero and the sequence approaches d/(1-c).",
      "difficulty": "medium"
    },
    {
      "id": "mcq-12",
      "question": "The particular solution of aₙ = 3aₙ₋₁ + 5 is:",
      "options": [
        {
          "key": "A",
          "text": "-2.5"
        },
        {
          "key": "B",
          "text": "5"
        },
        {
          "key": "C",
          "text": "-5/2"
        },
        {
          "key": "D",
          "text": "2.5"
        }
      ],
      "correctAnswer": "-2.5",
      "explanation": "Set aₙ = A, then A = 3A + 5 gives A - 3A = 5, so -2A = 5, A = -2.5 or -5/2.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-13",
      "question": "A bacteria culture doubles every hour. Recurrence:",
      "options": [
        {
          "key": "A",
          "text": "aₙ = 2aₙ₋₁"
        },
        {
          "key": "B",
          "text": "aₙ = aₙ₋₁ + 2"
        },
        {
          "key": "C",
          "text": "aₙ = 2aₙ₋₁ + 1"
        },
        {
          "key": "D",
          "text": "aₙ = aₙ₋₁²"
        }
      ],
      "correctAnswer": "aₙ = 2aₙ₋₁",
      "explanation": "Doubling means each hour the count is multiplied by 2, which is a homogeneous first-order recurrence.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-14",
      "question": "The general solution of aₙ = c×aₙ₋₁ + d (c≠1) is:",
      "options": [
        {
          "key": "A",
          "text": "aₙ = A×cⁿ + d/(1-c)"
        },
        {
          "key": "B",
          "text": "aₙ = A×cⁿ + d"
        },
        {
          "key": "C",
          "text": "aₙ = A×cⁿ - d/(1-c)"
        },
        {
          "key": "D",
          "text": "aₙ = A×n + d"
        }
      ],
      "correctAnswer": "aₙ = A×cⁿ + d/(1-c)",
      "explanation": "This combines homogeneous solution (A×cⁿ) with particular solution (d/(1-c)).",
      "difficulty": "hard"
    },
    {
      "id": "mcq-15",
      "question": "For aₙ = aₙ₋₁ + n (non-constant term), this is:",
      "back": "Not a first-order linear recurrence with constant coefficients",
      "options": [
        {
          "key": "A",
          "text": "First-order linear with constant coefficients"
        },
        {
          "key": "B",
          "text": "First-order linear with variable coefficients"
        },
        {
          "key": "C",
          "text": "Second-order recurrence"
        },
        {
          "key": "D",
          "text": "Homogeneous recurrence"
        }
      ],
      "correctAnswer": "First-order linear with variable coefficients",
      "explanation": "The coefficient of aₙ₋₁ is 1 (constant) but the added term is n (variable), so it's not constant coefficient.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-16",
      "question": "Number of regions formed by n lines in a plane (no two parallel, no three concurrent) follows:",
      "options": [
        {
          "key": "A",
          "text": "Rₙ = Rₙ₋₁ + n"
        },
        {
          "key": "B",
          "text": "Rₙ = 2Rₙ₋₁"
        },
        {
          "key": "C",
          "text": "Rₙ = Rₙ₋₁ + 1"
        },
        {
          "key": "D",
          "text": "Rₙ = nRₙ₋₁"
        }
      ],
      "correctAnswer": "Rₙ = Rₙ₋₁ + n",
      "explanation": "Each new line crosses all previous lines, adding n new regions. R₀ = 1 gives Rₙ = n(n+1)/2 + 1.",
      "difficulty": "medium"
    },
    {
