{
  "topicId": "bcs405a-module-2-wop-induction",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "According to the Well-Ordering Principle, every non-empty set of __________ has a least element.",
      "options": [
        {
          "key": "A",
          "text": "real numbers"
        },
        {
          "key": "B",
          "text": "natural numbers"
        },
        {
          "key": "C",
          "text": "positive integers"
        },
        {
          "key": "D",
          "text": "integers"
        }
      ],
      "correctAnswer": "positive integers",
      "explanation": "The Well-Ordering Principle specifically states that every non-empty set of positive integers has a least or smallest element.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "In mathematical induction, what must be proven first?",
      "options": [
        {
          "key": "A",
          "text": "The inductive step"
        },
        {
          "key": "B",
          "text": "The base case"
        },
        {
          "key": "C",
          "text": "The hypothesis"
        },
        {
          "key": "D",
          "text": "The conclusion"
        }
      ],
      "correctAnswer": "The base case",
      "explanation": "The base case (usually n=1) must be proven first before attempting the inductive step.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "What is assumed in the inductive step of a proof by induction?",
      "options": [
        {
          "key": "A",
          "text": "P(k+1) is true"
        },
        {
          "key": "B",
          "text": "P(k) is true"
        },
        {
          "key": "C",
          "text": "P(1) is true"
        },
        {
          "key": "D",
          "text": "Nothing is assumed"
        }
      ],
      "correctAnswer": "P(k) is true",
      "explanation": "In the inductive step, we assume P(k) is true for an arbitrary k and prove P(k+1) follows from it.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-4",
      "question": "Which of the following is NOT equivalent to mathematical induction?",
      "options": [
        {
          "key": "A",
          "text": "Well-Ordering Principle"
        },
        {
          "key": "B",
          "text": "Pigeonhole Principle"
        },
        {
          "key": "C",
          "text": "Second Principle of Induction"
        },
        {
          "key": "D",
          "text": "Recursive Definition"
        }
      ],
      "correctAnswer": "Pigeonhole Principle",
      "explanation": "The Pigeonhole Principle is a different combinatorial principle, while WOP, second induction, and induction itself are all equivalent.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-5",
      "question": "In strong induction, what is assumed in the inductive hypothesis?",
      "options": [
        {
          "key": "A",
          "text": "Only P(k) is true"
        },
        {
          "key": "B",
          "text": "P(1) through P(k) are true"
        },
        {
          "key": "C",
          "text": "P(k) and P(k+1) are true"
        },
        {
          "key": "D",
          "text": "Nothing specific"
        }
      ],
      "correctAnswer": "P(1) through P(k) are true",
      "explanation": "Strong induction assumes all statements from P(1) to P(k) are true to prove P(k+1).",
      "difficulty": "medium"
    },
    {
      "id": "mcq-6",
      "question": "What is the sum of the series 1 + 2 + 3 + ... + n?",
      "options": [
        {
          "key": "A",
          "text": "n(n-1)/2"
        },
        {
          "key": "B",
          "text": "n(n+1)/2"
        },
        {
          "key": "C",
          "text": "n\u00b2"
        },
        {
          "key": "D",
          "text": "n(n+1)(2n+1)/6"
        }
      ],
      "correctAnswer": "n(n+1)/2",
      "explanation": "This is a well-known formula that can be proven by induction: 1+2+...+n = n(n+1)/2",
      "difficulty": "easy"
    },
    {
