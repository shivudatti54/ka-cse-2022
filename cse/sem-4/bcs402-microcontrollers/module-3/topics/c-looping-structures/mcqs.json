    {
      "id": "mcq-8",
      "question": "What is the result of nested loops: for(i=0; i<2; i++) for(j=0; j<2; j++);",
      "options": [
        {
          "key": "A",
          "text": "2 iterations"
        },
        {
          "key": "B",
          "text": "3 iterations"
        },
        {
          "key": "C",
          "text": "4 iterations"
        },
        {
          "key": "D",
          "text": "infinite"
        }
      ],
      "correctAnswer": "4 iterations",
      "explanation": "Outer loop runs 2 times (i=0,1), inner loop runs 2 times for each outer iteration (j=0,1). Total = 2×2 = 4.",
      "difficulty": "medium"
    },
    {
