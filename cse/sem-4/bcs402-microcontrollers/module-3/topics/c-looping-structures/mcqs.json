    {
      "id": "mcq-1",
      "question": "Which loop executes at least once regardless of condition?",
      "options": [
        {
          "key": "A",
          "text": "for loop"
        },
        {
          "key": "B",
          "text": "while loop"
        },
        {
          "key": "C",
          "text": "do-while loop"
        },
        {
          "key": "D",
          "text": "nested loop"
        }
      ],
      "correctAnswer": "do-while loop",
      "explanation": "do-while checks the condition after executing the loop body, guaranteeing at least one execution.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "What is the output of: for(i=0; i<3; i++) printf(\"%d\", i);",
      "options": [
        {
          "key": "A",
          "text": "012"
        },
        {
          "key": "B",
          "text": "123"
        },
        {
          "key": "C",
          "text": "0112"
        },
        {
          "key": "D",
          "text": "0123"
        }
      ],
      "correctAnswer": "012",
      "explanation": "i starts at 0, prints 0,1,2. Loop exits when i=3 (condition i<3 is false).",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "Which statement immediately exits a loop?",
      "options": [
        {
          "key": "A",
          "text": "return"
        },
        {
          "key": "B",
          "text": "break"
        },
        {
          "key": "C",
          "text": "continue"
        },
        {
          "key": "D",
          "text": "exit"
        }
      ],
      "correctAnswer": "break",
      "explanation": "break terminates the innermost loop and transfers control to the next statement after the loop.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-4",
      "question": "In 8051, which loop type is commonly used for infinite main program loop?",
      "options": [
        {
          "key": "A",
          "text": "for(;;)"
        },
        {
          "key": "B",
          "text": "while(0)"
        },
        {
          "key": "C",
          "text": "do-while(0)"
        },
        {
          "key": "D",
          "text": "while(-1)"
        }
      ],
      "correctAnswer": "for(;;)",
      "explanation": "for(;;) creates an infinite loop as it has no condition to terminate. while(1) also works but for(;;) is traditional in embedded C.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-5",
      "question": "How many times will this execute? int i=5; while(i<5) { i++; }",
      "options": [
        {
          "key": "A",
          "text": "0"
        },
        {
          "key": "B",
          "text": "5"
        },
        {
          "key": "C",
          "text": "1"
        },
        {
          "key": "D",
          "text": "infinite"
        }
      ],
      "correctAnswer": "0",
      "explanation": "while checks condition before execution. Since i=5 is not less than 5, the loop body never executes.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-6",
      "question": "What does continue do in a loop?",
