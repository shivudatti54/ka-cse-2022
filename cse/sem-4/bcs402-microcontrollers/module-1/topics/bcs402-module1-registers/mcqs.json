{
  "topicId": "bcs402-module1-registers",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "What is the size of the Program Counter (PC) in 8051 microcontroller?",
      "options": [
        {
          "key": "A",
          "text": "8 bits"
        },
        {
          "key": "B",
          "text": "16 bits"
        },
        {
          "key": "C",
          "text": "32 bits"
        },
        {
          "key": "D",
          "text": "4 bits"
        }
      ],
      "correctAnswer": "16 bits",
      "explanation": "PC is a 16-bit register that can address up to 64KB of code memory (0000H-FFFFH).",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "What is the initial value of Stack Pointer after reset in 8051?",
      "options": [
        {
          "key": "A",
          "text": "00H"
        },
        {
          "key": "B",
          "text": "07H"
        },
        {
          "key": "C",
          "text": "08H"
        },
        {
          "key": "D",
          "text": "FFH"
        }
      ],
      "correctAnswer": "07H",
      "explanation": "SP is initialized to 07H after reset, which means the stack starts at address 08H (after the register bank 0).",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "Which register is used for multiplication and division operations in 8051?",
      "options": [
        {
          "key": "A",
          "text": "Accumulator (A)"
        },
        {
          "key": "B",
          "text": "B register"
        },
        {
          "key": "C",
          "text": "DPTR"
        },
        {
          "key": "D",
          "text": "PSW"
        }
      ],
      "correctAnswer": "B register",
      "explanation": "The B register works with the Accumulator for MUL AB and DIV AB instructions.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-4",
      "question": "How many register banks are available in 8051?",
      "options": [
        {
          "key": "A",
          "text": "1"
        },
        {
          "key": "B",
          "text": "2"
        },
        {
          "key": "C",
          "text": "4"
        },
        {
          "key": "D",
          "text": "8"
        }
      ],
      "correctAnswer": "4",
      "explanation": "8051 has 4 register banks (Bank 0-3), each with 8 registers (R0-R7), selected by RS0 and RS1 bits in PSW.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-5",
      "question": "Which bit in PSW selects Register Bank 2?",
      "options": [
        {
          "key": "A",
          "text": "RS0=0, RS1=0"
        },
        {
          "key": "B",
          "text": "RS0=1, RS1=0"
        },
        {
          "key": "C",
          "text": "RS0=0, RS1=1"
        },
        {
          "key": "D",
          "text": "RS0=1, RS1=1"
        }
      ],
      "correctAnswer": "RS0=0, RS1=1",
      "explanation": "RS1=1 and RS0=0 selects Bank 2 (addresses 10H-17H).",
      "difficulty": "medium"
    },
    {
      "id": "mcq-6",
      "question": "What is the address range of Register Bank 0?",
      "options": [
        {
          "key": "A",
          "text": "00H-07H"
        },
        {
          "key": "B",
          "text": "08H-0FH"
        },
        {
          "key": "C",
          "text": "10H-17H"
        },
        {
          "key": "D",
          "text": "18H-1FH"
        }
      ],
      "correctAnswer": "00H-07H",
      "explanation": "Bank 0 occupies internal RAM addresses 00H to 07H (R0=00H, R1=01H, ..., R7=07H).",
      "difficulty": "medium"
    },
    {
      "id": "mcq-7",
      "question": "Which register holds the address of external data memory?",
      "options": [
        {
          "key": "A",
          "text": "PC"
        },
        {
          "key": "B",
          "text": "SP"
        },
        {
          "key": "C",
          "text": "DPTR"
        },
        {
          "key": "D",
          "text": "PSW"
        }
      ],
      "correctAnswer": "DPTR",
      "explanation": "DPTR (Data Pointer) is used to point to external data memory addresses for MOVX instructions.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-8",
      "question": "What is the function of the Parity (P) flag in PSW?",
      "explanation": "P flag reflects odd parity of the Accumulator - it is set if Accumulator has odd number of 1s.",
      "options": [
        {
          "key": "A",
          "text": "Indicates overflow"
        },
        {
          "key": "B",
          "text": "Shows carry"
        },
        {
          "key": "C",
          "text": "Indicates parity"
        },
        {
          "key": "D",
          "text": "Shows zero"
        }
      ],
      "correctAnswer": "Indicates parity",
      "difficulty": "easy"
    },
    {
      "id": "mcq-9",
      "question": "Which SFR is used to enable serial interrupts?",
      "options": [
        {
          "key": "A",
          "text": "IE"
        },
        {
          "key": "B",
          "text": "IP"
        },
        {
          "key": "C",
          "text": "SCON"
        },
        {
          "key": "D",
          "text": "TCON"
        }
      ],
      "correctAnswer": "IE",
      "explanation": "IE (Interrupt Enable) register bit ES enables Serial interrupt. EA enables all interrupts.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-10",
      "question": "What is SBUF register used for?",
      "options": [
        {
          "key": "A",
          "text": "Timer control"
        },
        {
          "key": "B",
          "text": "Serial data buffer"
        },
        {
          "key": "C",
          "text": "Interrupt control"
        },
        {
          "key": "D",
          "text": "Port latching"
        }
      ],
      "correctAnswer": "Serial data buffer",
      "explanation": "SBUF holds data to be transmitted or received serially - it's actually two registers sharing the same address.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-11",
      "question": "Which register bits indicate arithmetic overflow in 8051?",
      "options": [
        {
          "key": "A",
          "text": "CY and AC"
        },
        {
          "key": "B",
          "text": "P and OV"
        },
        {
          "key": "C",
          "text": "OV only"
        },
        {
          "key": "D",
          "text": "CY only"
        }
      ],
      "correctAnswer": "OV only",
      "explanation": "OV (Overflow) flag in PSW indicates signed arithmetic overflow; CY is for unsigned carry.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-12",
      "question": "How many Special Function Registers (SFRs) does 8051 have?",
      "options": [
        {
          "key": "A",
          "text": "16"
        },
        {
          "key": "B",
          "text": "21"
        },
        {
          "key": "C",
          "text": "32"
        },
        {
          "key": "D",
          "text": "64"
        }
      ],
      "correctAnswer": "21",
      "explanation": "8051 has 21 SFRs including ports P0-P3, accumulator, B, PSW, SP, DPTR, timer registers, serial port registers, and interrupt registers.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-13",
      "question": "Which register bank is selected when RS1=1 and RS0=1?",
      "options": [
        {
          "key": "A",
          "text": "Bank 0"
        },
        {
          "key": "B",
          "text": "Bank 1"
        },
        {
          "key": "C",
          "text": "Bank 2"
        },
        {
          "key": "D",
          "text": "Bank 3"
        }
      ],
      "correctAnswer": "Bank 3",
      "explanation": "RS1=1 and RS0=1 selects Bank 3 (addresses 18H-1FH).",
      "difficulty": "medium"
    },
    {
      "id": "mcq-14",
      "question": "What is the size of DPTR register?",
      "options": [
        {
          "key": "A",
          "text": "8 bits"
        },
        {
          "key": "B",
          "text": "16 bits"
        },
        {
          "key": "C",
          "text": "24 bits"
        },
        {
          "key": "D",
          "text": "32 bits"
        }
      ],
      "correctAnswer": "16 bits",
      "explanation": "DPTR is a 16-bit register consisting of DPH (high byte) and DPL (low byte).",
      "difficulty": "easy"
    },
    {
      "id": "mcq-15",
      "question": "Which flag is affected by ADD instruction but not by logical operations?",
      "options": [
        {
          "key": "A",
          "text": "Parity flag"
        },
        {
          "key": "B",
          "text": "Carry flag"
        },
        {
          "key": "C",
          "text": "Overflow flag"
        },
        {
          "key": "D",
          "text": "All of the above"
        }
      ],
      "correctAnswer": "Carry flag",
      "explanation": "Carry (CY) and other arithmetic flags are affected by arithmetic operations but not by logical operations like ANL, ORL.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-16",
      "question": "What is the default value of all ports after reset?",
      "options": [
        {
          "key": "A",
          "text": "00H"
        },
        {
          "key": "B",
          "text": "FFH"
        },
        {
          "key": "C",
          "text": "AAH"
        },
        {
          "key": "D",
          "text": "55H"
        }
      ],
      "correctAnswer": "FFH",
      "explanation": "All ports are configured as input ports (FFH) after reset since they are internally pulled high.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-17",
      "question": "Which register is incremented automatically after fetching an instruction?",
      "options": [
        {
          "key": "A",
          "text": "SP"
        },
        {
          "key": "B",
          "text": "PC"
        },
        {
          "key": "C",
          "text": "DPTR"
        },
        {
          "key": "D",
          "text": "PSW"
        }
      ],
      "correctAnswer": "PC",
      "explanation": "Program Counter (PC) is automatically incremented after each instruction fetch to point to the next instruction.",
      "difficulty": "easy"
    },
    {
