  "topicId": "a-simple-swing-application",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "Which class is the main container for a Swing application?",
      "options": [
        {
          "key": "A",
          "text": "JFrame"
        },
        {
          "key": "B",
          "text": "JPanel"
        },
        {
          "key": "C",
          "text": "JButton"
        },
        {
          "key": "D",
          "text": "JLabel"
        }
      ],
      "correctAnswer": "A",
      "explanation": "JFrame is the main window container in Swing applications that holds other components.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-2",
      "question": "What is the purpose of a LayoutManager in Swing?",
      "options": [
        {
          "key": "A",
          "text": "To handle button clicks"
        },
        {
          "key": "B",
          "text": "To arrange components in containers"
        },
        {
          "key": "C",
          "text": "To create new components"
        },
        {
          "key": "D",
          "text": "To paint graphics on screen"
        }
      ],
      "correctAnswer": "B",
      "explanation": "LayoutManagers like FlowLayout and BorderLayout control how components are positioned within containers.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-3",
      "question": "Which interface must be implemented to handle button click events?",
      "options": [
        {
          "key": "A",
          "text": "MouseListener"
        },
        {
          "key": "B",
          "text": "ActionListener"
        },
        {
          "key": "C",
          "text": "KeyListener"
        },
        {
          "key": "D",
          "text": "WindowListener"
        }
      ],
      "correctAnswer": "B",
      "explanation": "ActionListener is the interface used to handle action events like button clicks in Swing.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-4",
      "question": "What method must be implemented when using ActionListener?",
      "options": [
        {
          "key": "A",
          "text": "mouseClicked()"
        },
        {
          "key": "B",
          "text": "actionPerformed()"
        },
        {
          "key": "C",
          "text": "keyPressed()"
        },
        {
          "key": "D",
          "text": "windowClosed()"
        }
      ],
      "correctAnswer": "B",
      "explanation": "The actionPerformed() method is called when an action event (like a button click) occurs.",
      "difficulty": "medium"
    },
    {
