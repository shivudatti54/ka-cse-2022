      "id": "d1",
      "title": "FIRSET Set Computation Flow",
      "type": "flow",
      "content": {
        "nodes": [
          {
            "id": "n1",
            "label": "Start with terminals: FIRST(terminal) = {terminal}"
          },
          {
            "id": "n2",
            "label": "For non-terminals: Initialize FIRST = ∅"
          },
          {
            "id": "n3",
            "label": "For each production X → Y₁Y₂...Yₖ"
          },
          {
            "id": "n4",
            "label": "Add FIRST(Y₁) to FIRST(X)"
          },
          {
            "id": "n5",
            "label": "If Y₁ → ε, add FIRST(Y₂) to FIRST(X)"
          },
          {
            "id": "n6",
            "label": "Continue until no ε or end"
          },
          {
            "id": "n7",
            "label": "If all derive ε, add ε to FIRST(X)"
          },
          {
            "id": "n8",
            "label": "Repeat until no changes"
          }
        ],
        "edges": [
