  "diagrams": [
    {
      "id": "d1",
      "title": "Effect of Erosion and Dilation on a Binary Object",
      "type": "flow",
      "content": {
        "nodes": [
          {
            "id": "n1",
            "label": "Original Object"
          },
          {
            "id": "n2",
            "label": "Erosion (A ⊖ B)\n- Removes outer layer\n- Shrinks object\n- Breaks thin connections"
          },
          {
            "id": "n3",
            "label": "Dilation (A ⊕ B)\n- Adds outer layer\n- Expands object\n- Fills small holes"
          }
        ],
        "edges": [
          {
            "from": "n1",
            "to": "n2",
            "label": "Apply Erosion"
          },
          {
            "from": "n1",
            "to": "n3",
            "label": "Apply Dilation"
          }
        ]
      }
    },
    {
      "id": "d2",
      "title": "Structuring Element Placement for Erosion",
      "type": "matrix",
      "content": {
        "label": "Erosion Check: SE must FIT inside the object",
        "matrix": [
          ["SE", "SE", "SE", "Img", "Img"],
          ["SE", "(Origin)", "SE", "Img", "Img"],
          ["SE", "SE", "SE", "Img", "Img"],
          ["Img", "Img", "Img", "Img", "Img"],
          ["Img", "Img", "Img", "Img", "Img"]
        ],
        "highlight": {
          "cells": [
            [0, 0],
            [0, 1],
            [0, 2],
            [1, 0],
            [1, 1],
            [1, 2],
            [2, 0],
            [2, 1],
            [2, 2]
          ],
          "meaning": "The entire 3x3 SE is placed over the image. For output to be 1, all highlighted 'SE' cells must correspond to '1' in the image."
        }
      }
    },
    {
      "id": "d3",
      "title": "Structuring Element Placement for Dilation",
      "type": "matrix",
      "content": {
        "label": "Dilation Check: SE must HIT the object",
        "matrix": [
          ["Img", "Img", "Img", "Img", "Img"],
          ["Img", "SE", "SE", "SE", "Img"],
          ["Img", "SE", "(Origin)", "SE", "Img"],
          ["Img", "SE", "SE", "SE", "Img"],
          ["Img", "Img", "Img", "Img", "Img"]
        ],
        "highlight": {
          "cells": [
            [1, 1],
            [1, 2],
            [1, 3],
            [2, 1],
            [2, 2],
            [2, 3],
            [3, 1],
            [3, 2],
            [3, 3]
          ],
          "meaning": "The 3x3 SE is centered on a pixel. For output to be 1, at least one highlighted 'SE' cell must correspond to a '1' in the image."
        }
      }
    }
