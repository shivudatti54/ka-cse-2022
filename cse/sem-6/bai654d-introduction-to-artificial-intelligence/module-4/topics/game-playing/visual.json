            "id": "n3",
            "label": "Traverse tree depth-first"
          },
          {
            "id": "n4",
            "label": "At MAX node: update α = max(α, child_value)"
          },
          {
            "id": "n5",
            "label": "At MIN node: update β = min(β, child_value)"
          },
          {
            "id": "n6",
            "label": "Check if α ≥ β"
          },
          {
            "id": "n7",
            "label": "If yes: prune remaining siblings"
          },
          {
            "id": "n8",
            "label": "If no: continue to next child"
          },
          {
            "id": "n9",
            "label": "Reach terminal node: return value"
          },
