    {
      "id": "mcq1",
      "question": "Which of the following is the correct representation of the set of all even integers greater than 2 but less than 10?",
      "options": [
        {
          "key": "A",
          "text": "{4, 6, 8}"
        },
        {
          "key": "B",
          "text": "{2, 4, 6, 8, 10}"
        },
        {
          "key": "C",
          "text": "{4, 6, 8, 10}"
        },
        {
          "key": "D",
          "text": "{2, 4, 6, 8}"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Even integers greater than 2 but less than 10 are 4, 6, and 8. The set should not include 2 or 10 as they don't satisfy the conditions.",
      "difficulty": "easy"
    },
    {
      "id": "mcq2",
      "question": "If A = {1, 2, 3} and B = {2, 3, 4}, what is A \u0394 B (symmetric difference)?",
      "options": [
        {
          "key": "A",
          "text": "{1, 4}"
        },
        {
          "key": "B",
          "text": "{2, 3}"
        },
        {
          "key": "C",
          "text": "{1, 2, 3, 4}"
        },
        {
          "key": "D",
          "text": "\u2205"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Symmetric difference includes elements in A or B but not both. A - B = {1}, B - A = {4}, so A \u0394 B = {1, 4}.",
      "difficulty": "medium"
    },
    {
      "id": "mcq3",
      "question": "What is the cardinality of the power set of {a, b, c, d}?",
      "options": [
        {
          "key": "A",
          "text": "4"
        },
        {
          "key": "B",
          "text": "8"
        },
        {
          "key": "C",
          "text": "16"
        },
        {
          "key": "D",
          "text": "32"
        }
      ],
      "correctAnswer": "C",
      "explanation": "The power set of a set with n elements has 2\u207f elements. Since |{a, b, c, d}| = 4, the power set has 2\u2074 = 16 elements.",
      "difficulty": "medium"
    },
    {
      "id": "mcq4",
      "question": "Which law states that (A \u222a B)\u1d9c = A\u1d9c \u2229 B\u1d9c?",
      "options": [
        {
          "key": "A",
          "text": "Distributive Law"
        },
        {
          "key": "B",
          "text": "Associative Law"
        },
        {
          "key": "C",
          "text": "De Morgan's Law"
        },
        {
          "key": "D",
          "text": "Absorption Law"
        }
      ],
      "correctAnswer": "C",
      "explanation": "This is one of De Morgan's Laws, which describe the complement of unions and intersections.",
      "difficulty": "easy"
    },
    {
      "id": "mcq5",
      "question": "If |A| = 5, |B| = 7, and |A \u2229 B| = 3, what is |A \u222a B|?",
      "options": [
        {
          "key": "A",
          "text": "9"
        },
        {
          "key": "B",
          "text": "12"
        },
        {
          "key": "C",
          "text": "15"
        },
        {
          "key": "D",
          "text": "Cannot be determined"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Using the inclusion-exclusion principle: |A \u222a B| = |A| + |B| - |A \u2229 B| = 5 + 7 - 3 = 9.",
      "difficulty": "medium"
    },
