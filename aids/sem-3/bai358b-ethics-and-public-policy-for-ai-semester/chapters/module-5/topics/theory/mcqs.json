      "question": "If A \u2286 B and B \u2286 C, which of the following must be true?",
      "options": [
        {
          "key": "A",
          "text": "A = C"
        },
        {
          "key": "B",
          "text": "A \u2286 C"
        },
        {
          "key": "C",
          "text": "C \u2286 A"
        },
        {
          "key": "D",
          "text": "A \u2229 C = \u2205"
        }
      ],
      "correctAnswer": "B",
      "explanation": "The subset relation is transitive: if A \u2286 B and B \u2286 C, then A \u2286 C.",
      "difficulty": "easy"
