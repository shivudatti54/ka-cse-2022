      "title": "OS Architecture Models Comparison",
      "type": "comparison",
      "content": {
        "items": [
          {
            "label": "Monolithic",
            "properties": {
              "performance": "High",
              "stability": "Lower (one service can crash OS)",
              "maintenance": "Difficult",
              "examples": "Linux, Windows"
            }
          },
          {
            "label": "Microkernel",
            "properties": {
              "performance": "Lower due to message passing",
              "stability": "Higher (services isolated)",
              "maintenance": "Easier",
              "examples": "Minix, QNX"
            }
          },
          {
            "label": "Layered",
            "properties": {
              "performance": "Moderate",
              "stability": "Moderate",
              "maintenance": "Moderate",
