  "topicId": "deadlock-prevention",
  "visuals": [
    {
      "id": "deadlock-prevention-svg",
      "title": "Deadlock Prevention and Avoidance",
      "description": "Visual diagram showing the four necessary conditions, prevention techniques for each, safe/unsafe state concepts, and the Banker's Algorithm flow",
      "type": "animated-svg",
      "file": "assets/deadlock-prevention.svg",
      "animated": true
    }
  ],
  "diagrams": [
    {
      "id": "d1",
      "title": "Prevention: Breaking the Four Conditions",
      "type": "table",
      "content": {
        "headers": ["Condition", "Prevention Technique"],
        "rows": [
          ["Mutual Exclusion", "Use spooling / sharable resources"],
          ["Hold and Wait", "Request all resources at once (pre-allocation)"],
          ["No Preemption", "Allow OS to preempt resources from waiting processes"],
          ["Circular Wait", "Impose total ordering on resource types (R[i] < R[j])"]
        ]
      }
    },
    {
      "id": "d2",
      "title": "Safe vs Unsafe States",
      "type": "concept",
      "content": {
        "nodes": [
          {
            "id": "n1",
            "label": "Safe State: A sequence exists where all processes can complete"
          },
          {
            "id": "n2",
            "label": "Unsafe State: No guarantee all processes can finish"
          },
          {
            "id": "n3",
            "label": "Deadlock: A subset of unsafe states where processes are permanently blocked"
          }
        ],
        "relationships": [
          {
            "from": "n2",
            "contains": "n3",
            "label": "Deadlock is a subset of unsafe states"
          },
          {
            "from": "n1",
            "excludes": "n3",
            "label": "Safe state prevents deadlock"
          }
        ]
      }
    },
    {
      "id": "d3",
      "title": "Banker's Algorithm Safety Check",
      "type": "flow",
      "content": {
        "nodes": [
          {
            "id": "s1",
            "label": "Start: Work = Available, Finish[i] = false for all i"
          },
          {
            "id": "s2",
            "label": "Find i where Finish[i] = false and Need[i] <= Work"
          },
          {
            "id": "s3",
            "label": "Work = Work + Allocation[i], Finish[i] = true"
          },
          {
            "id": "s4",
            "label": "All Finish[i] = true? SAFE. Otherwise UNSAFE."
          }
        ],
        "edges": [
          {
            "from": "s1",
            "to": "s2"
          },
          {
            "from": "s2",
            "to": "s3",
            "label": "found"
          },
          {
            "from": "s3",
            "to": "s2",
            "label": "loop back"
          },
          {
            "from": "s2",
            "to": "s4",
            "label": "no such i found"
          }
        ]
      }
    },
    {
      "id": "d4",
      "title": "Resource Allocation Graph with Claim Edges",
