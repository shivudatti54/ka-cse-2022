  "mcqs": [
    {
      "id": "mcq-1",
      "question": "What is the primary goal of Copy-on-Write (COW)?",
      "options": [
        {
          "key": "A",
          "text": "To speed up disk I/O"
        },
        {
          "key": "B",
          "text": "To defer copying until write occurs"
        },
        {
          "key": "C",
          "text": "To encrypt memory pages"
        },
        {
          "key": "D",
          "text": "To prioritize CPU scheduling"
        }
      ],
      "correctAnswer": 1,
      "explanation": "COW delays physical copying of memory until a write operation is attempted, optimizing memory usage.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-2",
      "question": "Which scenario benefits most from COW?",
      "options": [
        {
          "key": "A",
          "text": "Frequent read operations"
        },
        {
          "key": "B",
          "text": "Immediate exec() after fork()"
        },
        {
          "key": "C",
          "text": "CPU-bound tasks"
        },
        {
          "key": "D",
          "text": "Network I/O"
        }
      ],
      "correctAnswer": 1,
      "explanation": "When a child process immediately replaces its image with exec(), COW avoids unnecessary copying.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-3",
      "question": "When does actual copying occur in COW?",
      "options": [
        {
          "key": "A",
          "text": "During fork()"
        },
        {
          "key": "B",
          "text": "When a page is modified"
        },
        {
