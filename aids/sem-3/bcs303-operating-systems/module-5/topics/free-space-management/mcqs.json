      "id": "mcq-1",
      "question": "Which method uses a bit for each block to track free space?",
      "options": [
        {
          "key": "A",
          "text": "Bitmap"
        },
        {
          "key": "B",
          "text": "Linked List"
        },
        {
          "key": "C",
          "text": "Grouping"
        },
        {
          "key": "D",
          "text": "Counting"
        }
      ],
      "correctAnswer": "A",
      "explanation": "The Bitmap method represents each block with a single bit (0=free, 1=allocated).",
      "difficulty": "medium"
    },
    {
