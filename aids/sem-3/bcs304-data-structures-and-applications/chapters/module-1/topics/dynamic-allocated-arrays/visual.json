    {
      "id": "amortized-analysis",
      "title": "Amortized Cost Analysis",
      "type": "diagram",
      "description": "Why append is O(1) amortized despite occasional O(n) resizes",
      "content": {
        "operations": [
          "Insert 1: cost = 1 (no resize)",
          "Insert 2: cost = 1 + 1 = 2 (resize, copy 1 element)",
          "Insert 3: cost = 1 (no resize)",
          "Insert 4: cost = 1 + 2 = 3 (resize, copy 2 elements)",
          "Insert 5: cost = 1 (no resize)",
          "Insert 6: cost = 1 (no resize)",
          "Insert 7: cost = 1 (no resize)",
          "Insert 8: cost = 1 + 4 = 5 (resize, copy 4 elements)"
        ],
        "total": "8 inserts: 1+2+1+3+1+1+1+5 = 15",
        "amortized": "15/8 \u2248 1.87 per operation \u2192 O(1)"
      }
    },
