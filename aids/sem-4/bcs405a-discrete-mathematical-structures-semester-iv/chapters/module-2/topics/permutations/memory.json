{
  "topicId": "permutations",
  "mnemonics": [
    {
      "id": "m1",
      "name": "P vs C",
      "content": "Permutation=Position matters, Combination=Collection",
      "mnemonic": "P for Position, C for Collection"
    }
  ],
  "formulas": [
    {
      "id": "f1",
      "name": "Permutation",
      "formula": "P(n,r) = n!/(n-r)!",
      "example": "P(5,3) = 5!/2! = 60"
    },
    {
      "id": "f2",
      "name": "Combination",
      "formula": "C(n,r) = n!/(r!(n-r)!)",
      "example": "C(5,3) = 5!/(3!2!) = 10"
    },
    {
      "id": "f3",
      "name": "Stars and Bars",
      "formula": "C(n+r-1, r-1) for n items in r bins",
      "example": "10 candies, 3 kids = C(12,2) = 66"
    }
  ]
}