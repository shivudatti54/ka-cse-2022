{
  "topicId": "deadlock-avoidance",
  "diagrams": [
    {
      "id": "matrices",
      "type": "table",
      "title": "Banker's Data Structures",
      "data": {
        "headers": ["Matrix", "Size", "Description"],
        "rows": [
          ["Available", "[m]", "Free resources"],
          ["Max", "[n×m]", "Max demand"],
          ["Allocation", "[n×m]", "Currently held"],
          ["Need", "[n×m]", "Max - Allocation"]
        ]
      }
    },
    {
      "id": "safety",
      "type": "flowchart",
      "title": "Safety Algorithm",
      "data": {
        "steps": [
          "1. Work = Available, Finish[all]=false",
          "2. Find i: Finish[i]=false AND Need[i]≤Work",
          "3. Work = Work + Allocation[i], Finish[i]=true",
          "4. Repeat until all finished (safe) or stuck (unsafe)"
        ]
      }
    }
  ]
}
