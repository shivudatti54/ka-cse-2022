100 C160,80 190,80 230,100\" stroke=\"#1565C0\" stroke-width=\"2\" fill=\"none\" marker-end=\"url(#arrowhead)\"></path><text x=\"175\" y=\"80\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"10\" fill=\"#1565C0\">\n    a, \u03b5 \u2192 A\n    \n  </text><path d=\"M250,120 C250,160 250,180 250,195\" stroke=\"#1565C0\" stroke-width=\"2\" fill=\"none\" marker-end=\"url(#arrowhead)\"></path><text x=\"265\" y=\"160\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"10\" fill=\"#1565C0\">\n    b, A \u2192 \u03b5\n    \n  </text><path d=\"M230,220 C190,240 160,240 120,220\" stroke=\"#1565C0\" stroke-width=\"2\" fill=\"none\" marker-end=\"url(#arrowhead)\"></path><text x=\"175\" y=\"240\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"10\" fill=\"#1565C0\">\n    \u03b5, Z \u2192 Z\n    \n  </text><!-- Self-loop --><path d=\"M275,100 C300,80 325,100 300,120 C275,140 250,120 275,100\" stroke=\"#1565C0\" stroke-width=\"2\" fill=\"none\" marker-end=\"url(#arrowhead)\"></path><text x=\"300\" y=\"90\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"10\" fill=\"#1565C0\">\n    a, A \u2192 AA\n    \n  </text><!-- Stack representation --><rect x=\"320\" y=\"150\" width=\"60\" height=\"120\" fill=\"#E3F2FD\" stroke=\"#1565C0\" stroke-width=\"2\" rx=\"3\"></rect><text x=\"350\" y=\"140\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"10\" fill=\"#1565C0\">\n    Stack\n    \n  </text><!-- Stack elements --><rect x=\"325\" y=\"240\" width=\"50\" height=\"20\" fill=\"#64B5F6\" stroke=\"#0D47A1\" stroke-width=\"1\" rx=\"2\"></rect><text x=\"350\" y=\"253\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"10\" fill=\"white\">\n    A\n    \n  </text><rect x=\"325\" y=\"215\" width=\"50\" height=\"20\" fill=\"#2196F3\" stroke=\"#0D47A1\" stroke-width=\"1\" rx=\"2\"></rect><text x=\"350\" y=\"228\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"10\" fill=\"white\">\n    A\n    \n  </text><rect x=\"325\" y=\"190\" width=\"50\" he