      "svgContent": "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"420\" height=\"350\"><defs><linearGradient id=\"bg\" x1=\"0%\" y1=\"0%\" x2=\"0%\" y2=\"100%\"><stop offset=\"0%\" style=\"stop-color:#E3F2FD\"/><stop offset=\"100%\" style=\"stop-color:#BBDEFB\"/></linearGradient><marker id=\"arrowhead\" markerWidth=\"10\" markerHeight=\"7\" refX=\"9\" refY=\"3.5\" orient=\"auto\"><polygon points=\"0 0, 10 3.5, 0 7\" fill=\"#1565C0\"/></marker></defs><rect width=\"420\" height=\"350\" fill=\"url(#bg)\" rx=\"12\"/><text x=\"210\" y=\"25\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"13\" font-weight=\"bold\" fill=\"#1565C0\">Languages of a PDA</text><!-- PDA Machine --><rect x=\"50\" y=\"60\" width=\"100\" height=\"60\" fill=\"#2196F3\" rx=\"5\"></rect><text x=\"100\" y=\"95\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"11\" fill=\"white\">\n    PDA\n    \n  </text><!-- Accept by Final State --><rect x=\"200\" y=\"50\" width=\"120\" height=\"40\" fill=\"#64B5F6\" rx=\"5\"></rect><text x=\"260\" y=\"75\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"11\" fill=\"white\">\n    Final State Language\n    \n  </text><!-- Accept by Empty Stack --><rect x=\"200\" y=\"120\" width=\"120\" height=\"40\" fill=\"#64B5F6\" rx=\"5\"></rect><text x=\"260\" y=\"145\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"11\" fill=\"white\">\n    Empty Stack Language\n    \n  </text><!-- Arrow to Final State --><path d=\"M150 80 L190 70\" stroke=\"#1565C0\" stroke-width=\"2\" marker-end=\"url(#arrowhead)\"></path><!-- Arrow to Empty Stack --><path d=\"M150 100 L190 130\" stroke=\"#1565C0\" stroke-width=\"2\" marker-end=\"url(#arrowhead)\"></path><!-- Equivalence Label --><text x=\"260\" y=\"180\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"10\" font-style=\"italic\" fill=\"#1565C0\">\n    These languages are equivalent\n    \n  </text><!-- Input String --><rect x=\"20\" y=\"150\" width=\"80\" height=\"30\" fill=\"#1565C0\" rx=\"5\"></rect><text x=\"60\" y=\"170\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"11\" fill=\"white\">\n    Input String\n    \n  </text><!-- Arrow from Input to PDA --><path d=\"M100 165 L50 90\" stroke=\"#1565C0\" stroke-width=\"2\" marker-end=\"url(#arrowhead)\"></path><!-- Stack Symbol --><rect x=\"20\" y=\"200\" width=\"80\" height=\"30\" fill=\"#1565C0\" rx=\"5\"></rect><text x=\"60\" y=\"220\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"11\" fill=\"white\">\n    Stack (Z\u2080)\n    \n  </text><!-- Arrow from Stack to PDA --><path d=\"M100 215 L50 120\" stroke=\"#1565C0\" stroke-width=\"2\" marker-end=\"url(#arrowhead)\"></path></svg>",
