3\" stroke=\"#1565C0\" stroke-width=\"2\"></rect><text x=\"215\" y=\"175\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"11\" fill=\"white\" font-weight=\"bold\">\n    1\n    \n  </text><!-- Read/Write Head --><polygon points=\"215,125 205,145 225,145\" fill=\"#1565C0\"></polygon><text x=\"215\" y=\"115\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"10\" fill=\"#1565C0\">\n    Read/Write Head\n    \n  </text><!-- Connection from Control Unit to Head --><line x1=\"210\" y1=\"120\" x2=\"210\" y2=\"60\" stroke=\"#1565C0\" stroke-width=\"2\" stroke-dasharray=\"4,2\"></line><!-- State Transition --><text x=\"210\" y=\"220\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"11\" fill=\"#1565C0\">\n    Current State: q0\n    \n  </text><!-- Arrow showing tape movement --><polyline points=\"350,170 370,170 365,165 370,170 365,175\" stroke=\"#1565C0\" stroke-width=\"2\" fill=\"none\"></polyline><text x=\"360\" y=\"190\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"10\" fill=\"#1565C0\">\n    Tape Movement\n    \n  </text></svg>",
