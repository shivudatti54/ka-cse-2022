      "animated": true
    },
    {
      "id": "fork-flow",
      "title": "fork() System Call",
      "type": "animated-svg",
      "description": "How fork creates child process",
      "content": {
        "diagram": [
          "Before fork(): After fork():",
          "",
          " Parent Parent (returns child PID)",
          " │ │",
          " fork() │ Child (returns 0)",
          " │ │",
          " [continues] [continues]",
          " │ │",
          " wait() exec() or exit()",
          "",
          "fork() returns:",
          "- Negative: Error",
          "- Zero: In child process",
          "- Positive: In parent (child's PID)"
        ]
      },
      "file": "assets/process-concept.svg",
      "animated": true
    }
  ]
