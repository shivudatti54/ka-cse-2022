          "├─────────────────┤",
          "│ │",
          "│ ↑ │",
          "│ HEAP │ ← malloc/new, grows upward",
          "├─────────────────┤",
          "│ BSS │ ← Uninitialized globals",
          "├─────────────────┤",
          "│ DATA │ ← Initialized globals",
          "├─────────────────┤",
          "│ TEXT │ ← Program code (read-only)",
          "└─────────────────┘",
          "LOW MEMORY"
        ]
      },
