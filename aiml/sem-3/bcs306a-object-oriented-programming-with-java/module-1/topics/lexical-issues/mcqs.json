    {
      "id": "mcq-1",
      "question": "Which of the following is NOT a valid Java identifier?",
      "options": [
        {
          "key": "A",
          "text": "myVariable"
        },
        {
          "key": "B",
          "text": " _private"
        },
        {
          "key": "C",
          "text": "class"
        },
        {
          "key": "D",
          "text": "$money"
        }
      ],
      "correctAnswer": "class",
      "explanation": "'class' is a reserved keyword in Java and cannot be used as an identifier.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "What is the output of System.out.println('a' + 'b'); in Java?",
      "options": [
        {
          "key": "A",
          "text": "ab"
        },
        {
          "key": "B",
          "text": "195"
        },
        {
          "key": "C",
          "text": "Error"
        },
        {
          "key": "D",
          "text": "a+b"
        }
      ],
      "correctAnswer": "195",
      "explanation": "Character literals are treated as integral Unicode values in arithmetic, so 'a'=97 + 'b'=98 = 195.",
      "difficulty": "medium"
    },
    {
