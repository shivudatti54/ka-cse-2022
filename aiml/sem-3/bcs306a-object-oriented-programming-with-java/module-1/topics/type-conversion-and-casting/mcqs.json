{
  "topicId": "type-conversion-and-casting",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "What will be the output of: double d = 10/3; System.out.println(d);",
      "options": [
        {
          "key": "A",
          "text": "3.3333333333333335"
        },
        {
          "key": "B",
          "text": "3.0"
        },
        {
          "key": "C",
          "text": "3"
        },
        {
          "key": "D",
          "text": "Error"
        }
      ],
      "correctAnswer": "3.0",
      "explanation": "Integer division 10/3 gives 3, then assigned to double. Integer 3 is automatically widened to double 3.0",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "What is the result of narrowing conversion: int x = (int) 5.9;",
      "options": [
        {
          "key": "A",
          "text": "5"
        },
        {
          "key": "B",
          "text": "6"
        },
        {
          "key": "C",
          "text": "5.9"
        },
        {
          "key": "D",
          "text": "Error"
        }
      ],
      "correctAnswer": "5",
      "explanation": "Explicit casting truncates the decimal part. 5.9 becomes 5 due to narrowing conversion.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "Which conversion is done automatically by Java compiler?",
      "options": [
        {
          "key": "A",
          "text": "Narrowing conversion"
        },
        {
          "key": "B",
          "text": "Widening conversion"
        },
        {
          "key": "C",
          "text": "Both"
        },
        {
          "key": "D",
          "text": "None"
        }
      ],
      "correctAnswer": "Widening conversion",
      "explanation": "Widening conversions (smaller to larger types) are automatic. Narrowing requires explicit cast operator.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-4",
      "question": "What is upcasting?",
      "options": [
        {
          "key": "A",
          "text": "Converting superclass to subclass"
        },
        {
          "key": "B",
          "text": "Converting subclass to superclass"
        },
        {
          "key": "C",
          "text": "Converting primitive to wrapper"
        },
        {
          "key": "D",
          "text": "Converting wrapper to primitive"
        }
      ],
      "correctAnswer": "Converting subclass to superclass",
      "explanation": "Upcasting moves up the inheritance hierarchy from subclass to superclass. It is implicit and safe.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-5",
      "question": "Which keyword checks object type before casting?",
      "options": [
        {
          "key": "A",
          "text": "check"
        },
        {
          "key": "B",
          "text": "instanceof"
        },
        {
          "key": "C",
          "text": "type"
        },
        {
          "key": "D",
          "text": "is"
        }
      ],
      "correctAnswer": "instanceof",
      "explanation": "instanceof operator checks if an object is an instance of a class or interface before downcasting.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-6",
      "question": "What will: System.out.println((int)(char)(byte) -1); print?",
      "options": [
        {
          "key": "A",
          "text": "65535"
        },
        {
          "key": "B",
          "text": "-1"
        },
        {
          "key": "C",
          "text": "0"
        },
        {
          "key": "D",
          "text": "255"
        }
      ],
      "correctAnswer": "65535",
      "explanation": "-1 is byte (-1 to 255), char converts to unsigned 65535, int converts to 65535.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-7",
      "question": "What is autoboxing?",
      "options": [
        {
          "key": "A",
          "text": "int to Integer"
        },
        {
          "key": "B",
          "text": "Integer to int"
        },
        {
          "key": "C",
          "text": "double to Double"
        },
        {
          "key": "D",
          "text": "long to Long"
        }
      ],
      "correctAnswer": "int to Integer",
      "explanation": "Autoboxing automatically converts primitive types to their wrapper class objects.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-8",
      "question": "What happens when char is promoted in expression?",
      "options": [
        {
          "key": "A",
          "text": "Stays char"
        },
        {
          "key": "B",
          "text": "Promoted to int"
        },
        {
          "key": "C",
          "text": "Promoted to long"
        },
        {
          "key": "D",
          "text": "Promoted to double"
        }
      ],
      "correctAnswer": "Promoted to int",
