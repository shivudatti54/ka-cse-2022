      "difficulty": "medium"
    },
    {
      "id": "mcq-11",
      "question": "Can all narrowing conversions cause data loss?",
      "options": [
        {
          "key": "A",
          "text": "Yes, always"
        },
        {
          "key": "B",
          "text": "No, only specific ones"
        },
        {
          "key": "C",
          "text": "No, never"
        },
        {
          "key": "D",
          "text": "Only with floating point"
        }
      ],
      "correctAnswer": "No, only specific ones",
      "explanation": "Not all narrowing causes loss (e.g., int to long always safe). Data loss occurs when value exceeds target type range or precision is lost.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-12",
      "question": "What is downcasting?",
      "options": [
        {
          "key": "A",
          "text": "Converting superclass to subclass"
        },
        {
          "key": "B",
          "text": "Converting subclass to superclass"
        },
        {
          "key": "C",
          "text": "Converting primitive to wrapper"
        },
        {
          "key": "D",
          "text": "Converting wrapper to primitive"
        }
      ],
      "correctAnswer": "Converting superclass to subclass",
      "explanation": "Downcasting moves down the hierarchy from superclass to subclass. Requires explicit cast.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-13",
      "question": "What exception occurs during invalid downcasting?",
      "options": [
        {
          "key": "A",
          "text": "NullPointerException"
        },
        {
          "key": "B",
          "text": "ClassCastException"
        },
        {
          "key": "C",
          "text": "NumberFormatException"
        },
        {
          "key": "D",
          "text": "IllegalArgumentException"
        }
      ],
      "correctAnswer": "ClassCastException",
      "explanation": "ClassCastException is thrown when an object is cast to a class it doesn't belong to.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-14",
      "question": "What is the result: byte b = 127; b = (byte)(b + 1);",
      "options": [
        {
          "key": "A",
          "text": "127"
        },
        {
          "key": "B",
          "text": "128"
        },
        {
          "key": "C",
          "text": "-128"
        },
        {
          "key": "D",
          "text": "0"
        }
      ],
      "correctAnswer": "-128",
      "explanation": "127+1=128 exceeds byte range. When cast to byte, it wraps around to -128 (overflow).",
      "difficulty": "hard"
    },
    {
      "id": "mcq-15",
      "question": "Which is NOT a widening conversion order?",
      "options": [
        {
          "key": "A",
          "text": "byte to int"
        },
        {
          "key": "B",
          "text": "int to double"
        },
        {
          "key": "C",
          "text": "double to long"
        },
        {
          "key": "D",
          "text": "short to float"
        }
      ],
      "correctAnswer": "double to long",
      "explanation": "double to long is not widening in the standard order. Proper widening: byte→short→int→long→float→double",
      "difficulty": "medium"
    },
