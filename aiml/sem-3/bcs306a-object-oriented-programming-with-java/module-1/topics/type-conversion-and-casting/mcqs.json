    },
    {
      "id": "mcq-9",
      "question": "Which casting requires explicit cast operator?",
      "options": [
        {
          "key": "A",
          "text": "int to long"
        },
        {
          "key": "B",
          "text": "double to int"
        },
        {
          "key": "C",
          "text": "double to float"
        },
        {
          "key": "D",
          "text": "long to double"
        }
      ],
      "correctAnswer": "double to int",
      "explanation": "double to int is a narrowing conversion requiring explicit (int) cast operator.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-10",
      "question": "What is the output: System.out.println('a' + 1);",
      "options": [
        {
          "key": "A",
          "text": "97"
        },
        {
          "key": "B",
          "text": "98"
        },
        {
          "key": "C",
          "text": "a1"
        },
        {
          "key": "D",
          "text": "Error"
        }
      ],
      "correctAnswer": "98",
