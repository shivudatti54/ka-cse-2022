    {
      "id": "d2",
      "title": "Linear Queue vs Circular Queue Comparison",
      "type": "comparison",
      "content": {
        "headers": ["Feature", "Linear Queue", "Circular Queue"],
        "rows": [
          {
            "feature": "Memory Efficiency",
            "linear": "Poor - Wasted space after dequeue",
            "circular": "Excellent - Reuses dequeued spaces"
          },
          {
            "feature": "Enqueue Time",
            "linear": "O(1)",
            "circular": "O(1)"
          },
          {
            "feature": "Dequeue Time",
            "linear": "O(n) - Requires shifting",
            "circular": "O(1) - No shifting needed"
          },
          {
            "feature": "Pointer Movement",
            "linear": "Only forward, no wrap",
            "circular": "Wraps around using modulo"
          },
          {
            "feature": "Implementation",
            "linear": "Simple",
            "circular": "Uses modular arithmetic"
          },
          {
            "feature": "Space Utilization",
            "linear": "n-1 elements for size n",
            "circular": "n-1 elements for size n (sacrificed slot)"
          }
        ]
      }
    },
    {
      "id": "d3",
      "title": "Circular Queue Key Formulas",
      "type": "hierarchy",
      "content": {
        "nodes": [
          {
            "id": "root",
            "label": "Circular Queue Formulas"
          },
          {
            "id": "empty",
            "label": "isEmpty(): front==-1 && rear==-1"
          },
          {
            "id": "full",
            "label": "isFull(): (rear+1)%capacity==front"
          },
          {
            "id": "circincf",
            "label": "Circular Increment Front: front=(front+1)%MAXSIZE"
          },
          {
            "id": "circinr",
            "label": "Circular Increment Rear: rear=(rear+1)%MAXSIZE"
          },
          {
            "id": "size",
            "label": "Queue Size: (rear-front+1) or (MAXSIZE-front+rear+1)"
          },
          {
            "id": "next",
            "label": "Next Index: (i+1)%MAXSIZE"
          }
        ],
        "edges": [
