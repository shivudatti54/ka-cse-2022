      "id": "d3",
      "title": "Effective Access Time (EAT)",
      "type": "formula",
      "content": {
        "nodes": [
          {
            "id": "n1",
            "label": "EAT = (1 - p) x ma + p x (Page Fault Overhead)"
          },
          {
            "id": "n2",
            "label": "ma = 100 ns (RAM access time)"
          },
          {
            "id": "n3",
            "label": "Page Fault Overhead = ~10 ms (disk I/O dominated)"
          },
          {
            "id": "n4",
            "label": "For <10% degradation: p < 1/1,000,000"
          }
        ],
