      "svgContent": "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"420\" height=\"350\"><defs><linearGradient id=\"bg\" x1=\"0%\" y1=\"0%\" x2=\"0%\" y2=\"100%\"><stop offset=\"0%\" style=\"stop-color:#E3F2FD\"/><stop offset=\"100%\" style=\"stop-color:#BBDEFB\"/></linearGradient><marker id=\"arrowhead\" markerWidth=\"10\" markerHeight=\"7\" refX=\"9\" refY=\"3.5\" orient=\"auto\"><polygon points=\"0 0, 10 3.5, 0 7\" fill=\"#1565C0\"/></marker></defs><rect width=\"420\" height=\"350\" fill=\"url(#bg)\" rx=\"12\"/><text x=\"210\" y=\"25\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"13\" font-weight=\"bold\" fill=\"#1565C0\">Equivalence of PDAs and CFGs</text><!-- PDA Box --><rect x=\"50\" y=\"70\" width=\"120\" height=\"60\" fill=\"#2196F3\" rx=\"5\"></rect><text x=\"110\" y=\"105\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"11\" fill=\"white\">\n    Pushdown Automaton (PDA)\n    \n  </text><!-- CFG Box --><rect x=\"250\" y=\"70\" width=\"120\" height=\"60\" fill=\"#2196F3\" rx=\"5\"></rect><text x=\"310\" y=\"105\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"11\" fill=\"white\">\n    Context-Free Grammar (CFG)\n    \n  </text><!-- Conversion Arrow PDA to CFG --><path d=\"M170 100 L250 100\" stroke=\"#1565C0\" stroke-width=\"2\" marker-end=\"url(#arrowhead)\"></path><text x=\"210\" y=\"95\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"10\" fill=\"#1565C0\">\n    Conversion Algorithm\n    \n  </text><!-- Conversion Arrow CFG to PDA --><path d=\"M250 130 L170 130\" stroke=\"#1565C0\" stroke-width=\"2\" marker-end=\"url(#arrowhead)\"></path><text x=\"210\" y=\"125\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"10\" fill=\"#1565C0\">\n    Conversion Algorithm\n    \n  </text><!-- Equivalence Label --><text x=\"210\" y=\"180\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"12\" font-weight=\"bold\" fill=\"#1565C0\">\n    They Recognize the Same Class of Languages\n    \n  </text><!-- Language Examples --><rect x=\"110\" y=\"210\" width=\"200\" height=\"100\" fill=\"#64B5F6\" rx=\"5\"></rect><text x=\"210\" y=\"230\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"11\" font-weight=\"bold\" fill=\"white\">\n    Context-Free Languages\n    \n  </text><text x=\"210\" y=\"250\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"10\" fill=\"white\">\n    { aⁿbⁿ | n ≥ 0 }\n    \n  </text><text x=\"210\" y=\"270\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"10\" fill=\"white\">\n    { wwᴿ | w ∈ {0,1}* }\n    \n  </text><text x=\"210\" y=\"290\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"10\" fill=\"white\">\n    Arithmetic Expressions\n    \n  </text></svg>",
