5 C150,140 180,120 200,100\" stroke=\"#1565C0\" stroke-width=\"2\" marker-end=\"url(#arrowhead)\" fill=\"none\"></path><!-- Kleene Star Operation --><rect x=\"290\" y=\"180\" width=\"80\" height=\"30\" fill=\"#64B5F6\" rx=\"5\"></rect><text x=\"330\" y=\"200\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"11\" fill=\"white\">\n    Kleene Star (*)\n    \n  </text><path d=\"M290,185 C270,140 240,120 220,100\" stroke=\"#1565C0\" stroke-width=\"2\" marker-end=\"url(#arrowhead)\" fill=\"none\"></path><!-- Complement Operation --><rect x=\"50\" y=\"240\" width=\"80\" height=\"30\" fill=\"#64B5F6\" rx=\"5\"></rect><text x=\"90\" y=\"260\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"11\" fill=\"white\">\n    Complement\n    \n  </text><path d=\"M130,255 C150,220 180,200 200,100\" stroke=\"#1565C0\" stroke-width=\"2\" marker-end=\"url(#arrowhead)\" fill=\"none\"></path><!-- Reversal Operation --><rect x=\"290\" y=\"240\" width=\"80\" height=\"30\" fill=\"#64B5F6\" rx=\"5\"></rect><text x=\"330\" y=\"260\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"11\" fill=\"white\">\n    Reversal\n    \n  </text><path d=\"M290,255 C270,220 240,200 220,100\" stroke=\"#1565C0\" stroke-width=\"2\" marker-end=\"url(#arrowhead)\" fill=\"none\"></path></svg>",
