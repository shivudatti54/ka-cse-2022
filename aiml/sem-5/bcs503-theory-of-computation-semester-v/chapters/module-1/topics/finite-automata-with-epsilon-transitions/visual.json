5C0\">\n    a\n    \n  </text><!-- Epsilon transition --><path d=\"M100 125 L100 175 L250 175\" stroke=\"#FF5722\" stroke-width=\"1.5\" stroke-dasharray=\"4,2\" marker-end=\"url(#epsilonArrowhead)\" fill=\"none\"></path><text x=\"150\" y=\"165\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"11\" fill=\"#FF5722\">\n    ε\n    \n  </text><!-- Self-loop epsilon transition --><path d=\"M250 125 C270 140 270 160 250 175\" stroke=\"#FF5722\" stroke-width=\"1.5\" stroke-dasharray=\"4,2\" marker-end=\"url(#epsilonArrowhead)\" fill=\"none\"></path><text x=\"270\" y=\"150\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"11\" fill=\"#FF5722\">\n    ε\n    \n  </text><!-- Legend --><rect x=\"50\" y=\"250\" width=\"320\" height=\"80\" fill=\"#E3F2FD\" stroke=\"#1565C0\" stroke-width=\"1\" rx=\"5\"></rect><text x=\"210\" y=\"270\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"12\" font-weight=\"bold\" fill=\"#1565C0\">\n    Legend\n    \n  </text><path d=\"M80 285 L100 285\" stroke=\"#1565C0\" stroke-width=\"1.5\" marker-end=\"url(#arrowhead)\" fill=\"none\"></path><text x=\"120\" y=\"288\" text-anchor=\"start\" font-family=\"Arial\" font-size=\"11\" fill=\"#1565C0\">\n    Regular transition\n    \n  </text><path d=\"M80 305 L100 305\" stroke=\"#FF5722\" stroke-width=\"1.5\" stroke-dasharray=\"4,2\" marker-end=\"url(#epsilonArrowhead)\" fill=\"none\"></path><text x=\"120\" y=\"308\" text-anchor=\"start\" font-family=\"Arial\" font-size=\"11\" fill=\"#FF5722\">\n    Epsilon transition (ε)\n    \n  </text><circle cx=\"90\" cy=\"325\" r=\"5\" stroke=\"#1565C0\" stroke-width=\"1\" fill=\"none\"></circle><text x=\"120\" y=\"328\" text-anchor=\"start\" font-family=\"Arial\" font-size=\"11\" fill=\"#1565C0\">\n    Final state\n    \n  </text></svg>",
