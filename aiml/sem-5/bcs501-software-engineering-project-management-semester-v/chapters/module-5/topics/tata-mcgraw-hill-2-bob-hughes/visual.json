{
  "type": "flowchart",
  "title": "Software Project Management Process Flow",
  "description": "A flowchart illustrating the key phases and decision points in software project management based on Bob Hughes' framework from Tata McGraw Hill.",
  "elements": [
    "Project Initiation",
    "Feasibility Study",
    "Planning",
    "Requirement Analysis",
    "Design",
    "Implementation",
    "Testing",
    "Deployment",
    "Maintenance"
  ],
  "relationships": [
    "Feasibility leads to Planning",
    "Planning precedes Requirement Analysis",
    "Design follows Requirements",
    "Implementation follows Design",
    "Testing validates Implementation",
    "Deployment follows successful Testing",
    "Maintenance follows Deployment"
  ]
}