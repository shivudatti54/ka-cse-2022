{
  "topicId": "network-flow-max-flow-min-cut",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "In a flow network, which property states that flow on any edge cannot exceed its capacity?",
      "options": [
        {
          "key": "A",
          "text": "Flow conservation"
        },
        {
          "key": "B",
          "text": "Capacity constraint"
        },
        {
          "key": "C",
          "text": "Skew symmetry"
        },
        {
          "key": "D",
          "text": "Mass balance"
        }
      ],
      "correctAnswer": "B",
      "explanation": "Capacity constraint states 0 \u2264 f(e) \u2264 c(e) for every edge e in the network.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "What does the Max-Flow Min-Cut Theorem relate?",
      "options": [
        {
          "key": "A",
          "text": "Maximum flow and minimum vertices"
        },
        {
          "key": "B",
          "text": "Maximum flow and minimum cut capacity"
        },
        {
          "key": "C",
          "text": "Maximum edges and minimum path"
        },
        {
          "key": "D",
          "text": "Maximum capacity and minimum flow"
        }
      ],
      "correctAnswer": "B",
      "explanation": "The theorem states maximum flow value equals minimum cut capacity in any flow network.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "In the residual graph, a backward edge represents:",
      "options": [
        {
          "key": "A",
          "text": "Additional capacity available"
        },
        {
          "key": "B",
          "text": "Ability to cancel flow"
        },
        {
          "key": "C",
          "text": "Permanent flow direction"
        },
        {
          "key": "D",
          "text": "Source to sink connection"
        }
      ],
      "correctAnswer": "B",
      "explanation": "Backward edges allow cancellation of existing flow, representing the ability to reduce flow on that edge.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-4",
      "question": "What is the time complexity of Edmonds-Karp algorithm?",
      "options": [
        {
          "key": "A",
          "text": "O(E * max_flow)"
        },
        {
          "key": "B",
          "text": "O(V * E\u00b2)"
        },
        {
          "key": "C",
          "text": "O(V * E)"
        },
        {
          "key": "D",
          "text": "O(V\u00b2 * E)"
        }
      ],
      "correctAnswer": "D",
      "explanation": "Edmonds-Karp uses BFS, guaranteeing O(V\u00b2E) time complexity, an improvement over basic Ford-Fulkerson.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-5",
      "question": "Which algorithm uses BFS to find shortest augmenting paths?",
      "options": [
        {
          "key": "A",
          "text": "Dijkstra's algorithm"
        },
        {
          "key": "B",
          "text": "Ford-Fulkerson"
        },
        {
          "key": "C",
          "text": "Edmonds-Karp"
        },
        {
          "key": "D",
          "text": "Kruskal's algorithm"
        }
      ],
      "correctAnswer": "C",
      "explanation": "Edmonds-Karp is Ford-Fulkerson with BFS, finding augmenting paths in O(E) time.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-6",
      "question": "A cut is defined as a partition of vertices into sets S and T where:",
      "options": [
        {
          "key": "A",
          "text": "Source is in T and sink in S"
        },
        {
          "key": "B",
          "text": "Both source and sink in S"
        },
        {
          "key": "C",
          "text": "Source in S and sink in T"
        },
        {
          "key": "D",
          "text": "Neither source nor sink in either set"
        }
      ],
      "correctAnswer": "C",
      "explanation": "By definition, source must be in S (containing source) and sink in T (containing sink).",
      "difficulty": "easy"
    },
    {
      "id": "mcq-7",
      "question": "The bottleneck of an augmenting path is:",
      "options": [
        {
          "key": "A",
          "text": "Sum of all edge capacities"
        },
        {
          "key": "B",
          "text": "Maximum residual capacity on path"
        },
        {
          "key": "C",
          "text": "Minimum residual capacity on path"
        },
        {
          "key": "D",
          "text": "Total flow from source"
        }
      ],
      "correctAnswer": "C",
      "explanation": "Bottleneck is the minimum residual capacity among edges, determining how much flow can be pushed.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-8",
      "question": "Flow conservation applies to:",
      "options": [
        {
          "key": "A",
          "text": "Only source vertex"
        },
        {
          "key": "B",
          "text": "Only sink vertex"
        },
        {
          "key": "C",
          "text": "All intermediate vertices"
        },
        {
          "key": "D",
          "text": "All vertices including source and sink"
        }
      ],
      "correctAnswer": "C",
      "explanation": "Flow conservation applies only to intermediate vertices; source produces flow, sink consumes it.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-9",
      "question": "What happens when no augmenting path exists in the residual graph?",
      "options": [
        {
          "key": "A",
          "text": "Algorithm continues forever"
        },
        {
          "key": "B",
          "text": "Current flow is maximum"
        },
        {
          "key": "C",
          "text": "Network is empty"
        },
        {
          "key": "D",
          "text": "Minimum cut is infinite"
        }
      ],
      "correctAnswer": "B",
      "explanation": "By Max-Flow Min-Cut theorem, absence of augmenting path implies current flow is maximum.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-10",
      "question": "In bipartite matching reduction to max-flow, vertices are connected to:",
      "options": [
        {
          "key": "A",
          "text": "Each other directly"
        },
        {
          "key": "B",
          "text": "Source and sink with infinite capacity edges"
        },
        {
          "key": "C",
          "text": "Only to source"
        },
        {
          "key": "D",
          "text": "Only to sink"
        }
      ],
      "correctAnswer": "B",
      "explanation": "Left partition connects to source, right partition connects to sink, all with capacity 1 edges.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-11",
      "question": "Which is NOT a property of a valid flow?",
      "options": [
        {
          "key": "A",
          "text": "Capacity constraint"
        },
        {
          "key": "B",
          "text": "Flow conservation"
        },
        {
          "key": "C",
          "text": "Skew symmetry"
        },
        {
          "key": "D",
          "text": "All edges must be saturated"
        }
      ],
      "correctAnswer": "D",
      "explanation": "Flow does not require all edges to be saturated; only that flow \u2264 capacity on each edge.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-12",
      "question": "The Ford-Fulkerson method terminates when:",
      "options": [
        {
          "key": "A",
          "text": "All vertices are visited"
        },
        {
          "key": "B",
          "text": "No augmenting path exists"
        },
        {
          "key": "C",
          "text": "All edges are used"
        },
        {
          "key": "D",
          "text": "Source capacity is exhausted"
        }
      ],
      "correctAnswer": "B",
      "explanation": "Algorithm terminates when no augmenting path exists in residual graph, reaching maximum flow.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-13",
      "question": "A saturated edge in flow network has:",
      "options": [
        {
          "key": "A",
          "text": "Zero flow"
        },
        {
          "key": "B",
          "text": "Flow equals capacity"
        },
        {
          "key": "C",
          "text": "Flow less than capacity"
        },
        {
          "key": "D",
          "text": "Infinite capacity"
        }
      ],
      "correctAnswer": "B",
      "explanation": "Saturated edge: f(e) = c(e), meaning no more flow can be pushed through that edge.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-14",
      "question": "Minimum cut in a network is the cut with:",
      "options": [
        {
          "key": "A",
          "text": "Maximum capacity"
        },
        {
          "key": "B",
          "text": "Minimum capacity"
        },
        {
          "key": "C",
          "text": "Maximum vertices"
        },
        {
          "key": "D",
          "text": "Minimum vertices"
        }
      ],
      "correctAnswer": "B",
      "explanation": "Minimum cut is the cut (S,T) with smallest total capacity from S to T.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-15",
      "question": "If max flow = 10, then min cut capacity is:",
      "options": [
        {
          "key": "A",
          "text": "Less than 10"
        },
        {
          "key": "B",
          "text": "Equal to 10"
        },
        {
          "key": "C",
          "text": "Greater than 10"
        },
        {
          "key": "D",
          "text": "Cannot be determined"
