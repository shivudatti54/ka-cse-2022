      "id": "mcq-1",
      "question": "Which algorithm combines BFS and Dijkstra for negative weights?",
      "options": [
        {
          "key": "A",
          "text": "SPFA (Shortest Path Faster Algorithm)"
        },
        {
          "key": "B",
          "text": "Floyd-Warshall"
        },
        {
          "key": "C",
          "text": "A* Search"
        },
        {
          "key": "D",
          "text": "Contraction Hierarchies"
        }
      ],
      "correctAnswer": "A",
      "explanation": "SPFA optimizes Bellman-Ford using queue-based relaxation similar to BFS.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-2",
      "question": "What's the asymptotic complexity of Johnson's algorithm?",
      "options": [
        {
          "key": "A",
          "text": "O(mn + n\u00b2 log n)"
        },
        {
          "key": "B",
          "text": "O(n\u00b3)"
        },
        {
          "key": "C",
          "text": "O(m log n)"
        },
        {
          "key": "D",
          "text": "O(kn)"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Bellman-Ford (O(mn)) + n Dijkstra runs (each O(m + n log n))",
      "difficulty": "hard"
    },
