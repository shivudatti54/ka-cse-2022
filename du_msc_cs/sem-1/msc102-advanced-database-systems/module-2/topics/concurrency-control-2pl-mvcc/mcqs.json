    {
      "id": "mcq-1",
      "question": "Which phase in 2PL allows acquiring locks but not releasing?",
      "options": [
        {
          "key": "A",
          "text": "Growing Phase"
        },
        {
          "key": "B",
          "text": "Shrinking Phase"
        },
        {
          "key": "C",
          "text": "Commit Phase"
        },
        {
          "key": "D",
          "text": "Validation Phase"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Growing Phase is when all lock acquisitions must occur before any releases.",
      "difficulty": "easy"
    },
    {
