  "mcqs": [
    {
      "id": "mcq-1",
      "question": "What is the correct order of ARIES recovery phases?",
      "options": [
        {
          "key": "A",
          "text": "Analysis \u2192 Redo \u2192 Undo"
        },
        {
          "key": "B",
          "text": "Redo \u2192 Analysis \u2192 Undo"
        },
        {
          "key": "C",
          "text": "Undo \u2192 Analysis \u2192 Redo"
        },
        {
          "key": "D",
          "text": "Analysis \u2192 Undo \u2192 Redo"
        }
      ],
      "correctAnswer": "A",
      "explanation": "ARIES first analyzes logs, then reapplies changes (redo), finally undoes uncommitted transactions.",
      "difficulty": "easy"
    },
    {
