  "mcqs": [
    {
      "id": "mcq-1",
      "question": "In CAP Theorem, which two properties does a CP system prioritize?",
      "options": [
        {
          "key": "A",
          "text": "Consistency & Partition Tolerance"
        },
        {
          "key": "B",
          "text": "Availability & Consistency"
        },
        {
          "key": "C",
          "text": "Availability & Partition Tolerance"
        },
        {
          "key": "D",
          "text": "All three simultaneously"
        }
      ],
      "correctAnswer": "A",
      "explanation": "CP systems maintain Consistency and Partition Tolerance at expense of Availability during network partitions.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "Which consistency model is used by financial systems requiring ACID properties?",
      "options": [
        {
          "key": "A",
          "text": "Eventual"
        },
        {
          "key": "B",
          "text": "Strong"
        },
        {
          "key": "C",
          "text": "Causal"
        },
        {
          "key": "D",
          "text": "Monotonic"
        }
      ],
      "correctAnswer": "B",
      "explanation": "Financial systems require Strong consistency to prevent overdrafts and maintain transaction atomicity.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-3",
      "question": "What does the 'E' in PACELC stand for?",
      "options": [
        {
          "key": "A",
          "text": "Else"
        },
        {
          "key": "B",
          "text": "Eventual"
        },
        {
          "key": "C",
          "text": "Error"
        },
        {
          "key": "D",
          "text": "Efficiency"
        }
      ],
      "correctAnswer": "A",
      "explanation": "PACELC: If Partitioned (P), choose between Availability and Consistency; Else (E), choose between Latency and Consistency.",
      "difficulty": "hard"
    },
