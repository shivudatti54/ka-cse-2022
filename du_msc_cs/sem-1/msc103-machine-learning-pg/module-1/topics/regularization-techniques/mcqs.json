      "id": "mcq-1",
      "question": "Which regularization technique tends to create sparse weight vectors?",
      "options": [
        {
          "key": "A",
          "text": "L1 Regularization"
        },
        {
          "key": "B",
          "text": "L2 Regularization"
        },
        {
          "key": "C",
          "text": "Dropout"
        },
        {
          "key": "D",
          "text": "Early Stopping"
        }
