      "id": "mcq-3",
      "question": "What is \u03c6(21) where \u03c6 is Euler's totient function?",
      "options": [
        {
          "key": "A",
          "text": "12"
        },
        {
          "key": "B",
          "text": "18"
        },
        {
          "key": "C",
          "text": "8"
        },
        {
          "key": "D",
          "text": "14"
        }
      ],
      "correctAnswer": "A",
      "explanation": "\u03c6(21)=\u03c6(3*7)=(3-1)(7-1)=2*6=12",
      "difficulty": "medium"
    },
