      "id": "mcq-1",
      "question": "Which two characteristics does the CAP theorem guarantee together?",
      "options": [
        {
          "key": "A",
          "text": "Consistency & Partition Tolerance"
        },
        {
          "key": "B",
          "text": "Availability & Consistency"
        },
        {
          "key": "C",
          "text": "Availability & Partition Tolerance"
        },
        {
          "key": "D",
          "text": "All three simultaneously"
        }
      ],
      "correctAnswer": "A",
      "explanation": "CAP theorem states only two can be guaranteed at once. CA systems can't exist in reality due to network partitions.",
      "difficulty": "medium"
    },
