      "question": "Which operation helps maintain spatial dimensions through padding?",
      "options": [
        {
          "key": "A",
          "text": "Same convolution"
        },
        {
          "key": "B",
          "text": "Valid convolution"
        },
        {
          "key": "C",
          "text": "Max pooling"
        },
        {
          "key": "D",
          "text": "Strided convolution"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Same padding adds zeros around input to maintain output size equal to input.",
      "difficulty": "easy"
    },
