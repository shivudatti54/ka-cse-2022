    {
      "id": "mcq-1",
      "question": "Which Word2Vec architecture is more effective for small datasets?",
      "options": [
        {
          "key": "A",
          "text": "CBOW"
        },
        {
          "key": "B",
          "text": "Skip-Gram"
        },
        {
          "key": "C",
          "text": "GloVe"
        },
        {
          "key": "D",
          "text": "LSA"
        }
      ],
      "correctAnswer": "A",
      "explanation": "CBOW learns faster and performs better with smaller datasets due to multiple context inputs.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-2",
      "question": "What is the primary purpose of hierarchical softmax?",
      "options": [
        {
          "key": "A",
          "text": "Reduce computational complexity"
        },
        {
          "key": "B",
          "text": "Increase vector dimensions"
        },
        {
          "key": "C",
          "text": "Handle out-of-vocabulary words"
        },
        {
          "key": "D",
          "text": "Visualize embeddings"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Hierarchical softmax uses Huffman trees to enable O(log V) complexity instead of O(V).",
      "difficulty": "hard"
    },
    {
      "id": "mcq-3",
      "question": "Which model explicitly uses word co-occurrence probabilities?",
      "options": [
        {
          "key": "A",
          "text": "Word2Vec CBOW"
        },
        {
          "key": "B",
          "text": "GloVe"
        },
        {
          "key": "C",
          "text": "Skip-Gram"
        },
        {
          "key": "D",
          "text": "ELMo"
        }
      ],
      "correctAnswer": "B",
      "explanation": "GloVe's objective function incorporates log co-occurrence probabilities explicitly.",
      "difficulty": "easy"
