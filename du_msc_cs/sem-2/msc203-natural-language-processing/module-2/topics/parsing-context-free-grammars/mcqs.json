      "id": "mcq-5",
      "question": "Which is NOT a requirement for Chomsky Normal Form?",
      "options": [
        {
          "key": "A",
          "text": "No \u03b5-productions"
        },
        {
          "key": "B",
          "text": "No unit productions"
        },
        {
          "key": "C",
          "text": "All productions have exactly two non-terminals"
        },
        {
          "key": "D",
          "text": "Start symbol cannot appear on RHS"
        }
      ],
      "correctAnswer": "C",
      "explanation": "CNF allows A\u2192a (single terminal) and A\u2192BC (two non-terminals).",
