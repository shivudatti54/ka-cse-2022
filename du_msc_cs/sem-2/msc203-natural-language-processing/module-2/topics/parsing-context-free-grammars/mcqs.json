  "topicId": "parsing-context-free-grammars",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "Which component of CFG represents actual words in a language?",
      "options": [
        {
          "key": "A",
          "text": "Terminals (\u03a3)"
        },
        {
          "key": "B",
          "text": "Non-terminals (V)"
        },
        {
          "key": "C",
          "text": "Production rules (R)"
        },
        {
          "key": "D",
          "text": "Start symbol (S)"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Terminals are the actual vocabulary tokens of the language.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "Which parsing strategy uses the production rule S \u2192 \u03b1 immediately?",
      "options": [
        {
          "key": "A",
          "text": "Top-down parsing"
        },
        {
          "key": "B",
          "text": "Bottom-up parsing"
        },
        {
          "key": "C",
          "text": "Earley parser"
        },
        {
          "key": "D",
          "text": "CYK algorithm"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Top-down parsers expand start symbol first (root to leaves).",
      "difficulty": "medium"
    },
    {
      "id": "mcq-3",
      "question": "What is the time complexity of CYK algorithm for string length n?",
      "options": [
        {
          "key": "A",
          "text": "O(n\u00b3)"
        },
        {
          "key": "B",
          "text": "O(n\u00b2)"
        },
        {
          "key": "C",
          "text": "O(2\u207f)"
        },
        {
          "key": "D",
          "text": "O(n log n)"
        }
      ],
      "correctAnswer": "A",
      "explanation": "CYK uses 3 nested loops over string length \u2192 cubic complexity.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-4",
      "question": "Which transformation eliminates left recursion?",
      "options": [
        {
          "key": "A",
          "text": "A \u2192 A\u03b1 | \u03b2 becomes A \u2192 \u03b2A' and A' \u2192 \u03b1A' | \u03b5"
        },
        {
          "key": "B",
          "text": "A \u2192 \u03b1 | \u03b2 becomes A \u2192 \u03b1\u03b2"
        },
        {
          "key": "C",
          "text": "A \u2192 B\u03b1 becomes B \u2192 A\u03b1"
        },
        {
          "key": "D",
          "text": "Remove all \u03b5-productions"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Standard left recursion elimination uses right-recursive helper non-terminal.",
      "difficulty": "medium"
    },
