    {
      "id": "mcq-5",
      "question": "What is the probability of unseen bigrams with Laplace smoothing (\u03b4=1)?",
      "options": [
        {
          "key": "A",
          "text": "1/(V + count)"
        },
        {
          "key": "B",
          "text": "1/(count + \u03b4V)"
        },
        {
          "key": "C",
          "text": "\u03b4/(count + V)"
        },
        {
          "key": "D",
          "text": "1/(count + V)"
        }
      ],
      "correctAnswer": "A",
      "explanation": "P = (count + \u03b4)/(total + \u03b4V) \u2192 \u03b4=1 gives 1/(V + count) for unseen",
      "difficulty": "hard"
    }
