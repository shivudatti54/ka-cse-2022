  "mcqs": [
    {
      "id": "mcq-1",
      "question": "Which component acts as the master in HDFS?",
      "options": [
        {
          "key": "A",
          "text": "NameNode"
        },
        {
          "key": "B",
          "text": "DataNode"
        },
        {
          "key": "C",
          "text": "JobTracker"
        },
        {
          "key": "D",
          "text": "ResourceManager"
        }
      ],
      "correctAnswer": "A",
      "explanation": "NameNode manages metadata and coordinates storage",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "What is the correct order of MapReduce phases?",
      "options": [
        {
          "key": "A",
          "text": "Map -> Shuffle -> Reduce"
        },
        {
          "key": "B",
          "text": "Shuffle -> Map -> Reduce"
        },
        {
          "key": "C",
          "text": "Reduce -> Map -> Combine"
        },
        {
          "key": "D",
          "text": "Input -> Output -> Sort"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Map processes input, shuffle transfers data, reduce aggregates",
      "difficulty": "medium"
    },
    {
      "id": "mcq-3",
      "question": "Which mechanism ensures data reliability in HDFS?",
      "options": [
        {
          "key": "A",
          "text": "Block replication"
        },
        {
          "key": "B",
          "text": "In-memory caching"
        },
        {
          "key": "C",
          "text": "RAID configuration"
        },
        {
          "key": "D",
          "text": "Data compression"
        }
      ],
      "correctAnswer": "A",
