      "id": "mcq-1",
      "question": "Which scheduling algorithm is most suitable for time-sharing systems?",
      "options": [
        {
          "key": "A",
          "text": "Round Robin"
        },
        {
          "key": "B",
          "text": "First-Come-First-Served"
        },
        {
          "key": "C",
          "text": "Shortest Job Next"
        },
        {
          "key": "D",
          "text": "Priority Scheduling"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Round Robin's time quantum system ensures fair CPU allocation for interactive systems.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "What is the primary disadvantage of Shortest Job First scheduling?",
      "options": [
        {
          "key": "A",
          "text": "Starvation of long processes"
        },
        {
          "key": "B",
          "text": "High context switch overhead"
        },
        {
          "key": "C",
          "text": "Difficulty estimating CPU burst time"
        },
        {
          "key": "D",
          "text": "Poor I/O device utilization"
        }
      ],
      "correctAnswer": "C",
      "explanation": "Requires accurate prediction of next CPU burst which is often impractical.",
      "difficulty": "medium"
    },
