      "id": "mcq-1",
      "question": "Which allocation method suffers most from external fragmentation?",
      "options": [
        {
          "key": "A",
          "text": "Contiguous"
        },
        {
          "key": "B",
          "text": "Linked"
        },
        {
          "key": "C",
          "text": "Indexed"
        },
        {
          "key": "D",
          "text": "Hashed"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Contiguous allocation requires continuous blocks, leading to fragmented free space over time.",
      "difficulty": "easy"
    },
