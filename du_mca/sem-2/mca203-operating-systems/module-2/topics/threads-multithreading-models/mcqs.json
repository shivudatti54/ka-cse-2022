      "id": "mcq-1",
      "question": "Which threading model requires no kernel support?",
      "options": [
        {
          "key": "A",
          "text": "Many-to-One"
        },
        {
          "key": "B",
          "text": "One-to-One"
        },
        {
          "key": "C",
          "text": "Many-to-Many"
        },
        {
          "key": "D",
          "text": "Two-Level"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Many-to-One model implements threads entirely in user space",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "Which model allows concurrent execution of multiple threads on multi-core CPUs?",
      "options": [
        {
          "key": "A",
          "text": "Many-to-One"
        },
        {
          "key": "B",
          "text": "One-to-One"
        },
        {
          "key": "C",
          "text": "Many-to-Many"
        },
        {
          "key": "D",
          "text": "Both B and C"
        }
      ],
      "correctAnswer": "D",
      "explanation": "Both One-to-One and Many-to-Many models support true parallelism",
      "difficulty": "medium"
    },
    {
      "id": "mcq-3",
      "question": "What is the main drawback of One-to-One model?",
      "options": [
        {
          "key": "A",
          "text": "Overhead of kernel thread creation"
        },
        {
          "key": "B",
          "text": "No true parallelism"
        },
        {
          "key": "C",
          "text": "Complex scheduling"
        },
        {
          "key": "D",
          "text": "Single point of failure"
