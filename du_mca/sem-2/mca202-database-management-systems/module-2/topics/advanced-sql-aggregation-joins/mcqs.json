          "key": "A",
          "text": "COUNT(column)"
        },
        {
          "key": "B",
          "text": "SUM(column)"
        },
        {
          "key": "C",
          "text": "AVG(column)"
        },
        {
          "key": "D",
          "text": "MAX(column)"
