      "question": "Which join type preserves unmatched rows from both tables?",
      "options": [
        {
          "key": "A",
          "text": "FULL OUTER JOIN"
        },
        {
          "key": "B",
          "text": "LEFT JOIN"
        },
        {
          "key": "C",
          "text": "INNER JOIN"
        },
        {
          "key": "D",
          "text": "CROSS JOIN"
        }
      ],
      "correctAnswer": "A",
