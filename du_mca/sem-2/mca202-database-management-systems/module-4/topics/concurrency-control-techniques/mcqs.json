{
  "topicId": "concurrency-control-techniques",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "Which concurrency control technique uses timestamps to order transactions?",
      "options": [
        {
          "key": "A",
          "text": "Timestamp Ordering"
        },
        {
          "key": "B",
          "text": "Two-Phase Locking"
        },
        {
          "key": "C",
          "text": "Validation (Optimistic)"
        },
        {
          "key": "D",
          "text": "Multiversion Scheme"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Timestamp ordering protocol uses timestamps to determine serialization order.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "In Two-Phase Locking, when can a transaction release its first lock?",
      "options": [
        {
          "key": "A",
          "text": "During Growing Phase"
        },
        {
          "key": "B",
          "text": "During Shrinking Phase"
        },
        {
          "key": "C",
          "text": "After Commit"
        },
        {
          "key": "D",
          "text": "Before Acquiring All Locks"
        }
      ],
      "correctAnswer": "B",
      "explanation": "Locks can only be released during the shrinking phase.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-3",
      "question": "Which problem occurs when a transaction reads uncommitted data?",
      "options": [
        {
          "key": "A",
          "text": "Dirty Read"
        },
        {
          "key": "B",
          "text": "Lost Update"
        },
        {
          "key": "C",
          "text": "Unrepeatable Read"
        },
        {
          "key": "D",
          "text": "Phantom Read"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Dirty read occurs when a transaction reads data modified by an uncommitted transaction.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-4",
      "question": "Which deadlock prevention technique uses transaction timestamps?",
      "options": [
        {
          "key": "A",
          "text": "Wait-Die"
        },
        {
          "key": "B",
          "text": "Timeouts"
        },
        {
          "key": "C",
          "text": "Deadlock Detection"
        },
        {
          "key": "D",
          "text": "Resource Ordering"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Wait-Die uses transaction timestamps to decide whether to wait or abort.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-5",
      "question": "What is the main drawback of strict two-phase locking?",
      "options": [
        {
          "key": "A",
          "text": "Increased Locking Overhead"
        },
        {
          "key": "B",
          "text": "Poor Transaction Throughput"
        },
        {
          "key": "C",
          "text": "Cannot Recover from Deadlocks"
        },
        {
          "key": "D",
          "text": "Doesn't Prevent Cascading Rollbacks"
        }
      ],
      "correctAnswer": "B",
      "explanation": "Holding locks until commit reduces concurrency and throughput.",
      "difficulty": "medium"
    }
  ]
}