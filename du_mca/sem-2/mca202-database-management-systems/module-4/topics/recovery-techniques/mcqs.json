      "id": "mcq-1",
      "question": "Which logging technique requires that all log records be written before transaction commit?",
      "options": [
        {
          "key": "A",
          "text": "Write-ahead logging"
        },
        {
          "key": "B",
          "text": "Immediate logging"
        },
