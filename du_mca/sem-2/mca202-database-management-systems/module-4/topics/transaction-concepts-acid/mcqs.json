    {
      "id": "mcq-1",
      "question": "Which ACID property ensures 'all-or-nothing' execution?",
      "options": [
        {
          "key": "A",
          "text": "Atomicity"
        },
        {
          "key": "B",
          "text": "Consistency"
        },
        {
          "key": "C",
          "text": "Isolation"
        },
        {
          "key": "D",
          "text": "Durability"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Atomicity guarantees complete success or total failure of transactions.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "A transaction reads uncommitted data from another transaction. Which ACID property is violated?",
      "options": [
        {
          "key": "A",
          "text": "Atomicity"
        },
        {
          "key": "B",
          "text": "Isolation"
        },
        {
          "key": "C",
          "text": "Consistency"
        },
        {
          "key": "D",
          "text": "Durability"
        }
      ],
      "correctAnswer": "B",
      "explanation": "Isolation prevents transactions from accessing uncommitted changes.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-3",
      "question": "Which recovery mechanism uses UNDO and REDO operations?",
      "options": [
        {
          "key": "A",
          "text": "Checkpoints"
        },
        {
          "key": "B",
          "text": "Write-ahead logging"
        },
        {
          "key": "C",
          "text": "Shadow paging"
        },
        {
          "key": "D",
          "text": "ARIES algorithm"
