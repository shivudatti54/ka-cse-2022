    {
      "id": "mcq-1",
      "question": "Which schema level is closest to end-users?",
      "options": [
        {
          "key": "A",
          "text": "External"
        },
        {
          "key": "B",
          "text": "Conceptual"
        },
        {
          "key": "C",
          "text": "Internal"
        },
        {
          "key": "D",
          "text": "Physical"
        }
      ],
      "correctAnswer": "A",
      "explanation": "External schema provides user-specific views.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "What enables logical data independence?",
      "options": [
        {
          "key": "A",
          "text": "Conceptual-internal mapping"
        },
        {
          "key": "B",
          "text": "External-conceptual mapping"
        },
        {
          "key": "C",
          "text": "Internal schema design"
        },
        {
          "key": "D",
          "text": "Storage optimization"
