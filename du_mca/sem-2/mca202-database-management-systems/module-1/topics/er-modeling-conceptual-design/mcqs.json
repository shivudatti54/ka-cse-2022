{
  "topicId": "er-modeling-conceptual-design",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "Which symbol represents weak entity in ER diagram?",
      "options": [
        {
          "key": "A",
          "text": "Double rectangle"
        },
        {
          "key": "B",
          "text": "Dashed rectangle"
        },
        {
          "key": "C",
          "text": "Rectangle with double border"
        },
        {
          "key": "D",
          "text": "Rectangle with underline"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Weak entities are represented with double rectangles in Chen's notation",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "Which is true about weak entities?",
      "options": [
        {
          "key": "A",
          "text": "Have complete key of their own"
        },
        {
          "key": "B",
          "text": "Participate in total relationship"
        },
        {
          "key": "C",
          "text": "Independent existence"
        },
        {
          "key": "D",
          "text": "No identifying relationship"
        }
      ],
      "correctAnswer": "B",
      "explanation": "Weak entities require total participation in identifying relationship",
      "difficulty": "medium"
    },
    {
      "id": "mcq-3",
      "question": "In cardinality constraints, (1,3) on relationship R from E1 to E2 means:",
      "options": [
        {
          "key": "A",
          "text": "Each E1 relates to 1-3 E2"
        },
        {
          "key": "B",
          "text": "Each E2 relates to 1-3 E1"
        },
        {
          "key": "C",
          "text": "Minimum 1 E1 per E2"
        },
        {
          "key": "D",
          "text": "Maximum 3 relationships"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Cardinality (min,max) shows constraints from source to target entity",
      "difficulty": "hard"
    },
    {
      "id": "mcq-4",
      "question": "Which is NOT a valid relationship type?",
      "options": [
        {
          "key": "A",
          "text": "Unary"
        },
        {
          "key": "B",
          "text": "Binary"
        },
        {
          "key": "C",
          "text": "Ternary"
        },
        {
          "key": "D",
          "text": "Quadrary"
        }
      ],
      "correctAnswer": "D",
      "explanation": "ER model supports unary, binary, ternary but not quadrary relationships",
      "difficulty": "easy"
    },
    {
      "id": "mcq-5",
