        {
          "key": "A",
          "text": "Key constraint"
        },
        {
          "key": "B",
          "text": "Referential integrity"
        },
        {
          "key": "C",
          "text": "Domain constraint"
        },
        {
          "key": "D",
          "text": "Cardinality constraint"
        }
