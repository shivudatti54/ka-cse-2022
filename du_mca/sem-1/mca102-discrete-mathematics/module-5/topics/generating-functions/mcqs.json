    {
      "id": "mcq-2",
      "question": "What is the generating function for the sequence 2, 4, 8, 16,...?",
      "options": [
        {
          "key": "A",
          "text": "2/(1 - 2x)"
        },
        {
          "key": "B",
          "text": "1/(1 - 2x)"
        },
        {
          "key": "C",
          "text": "2x/(1 - x)"
        },
        {
          "key": "D",
          "text": "2/(1 - x)"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Sequence is 2*2\u207f = 2,4,8,... which matches 2/(1-2x) expansion.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-3",
      "question": "Which operation corresponds to shifting a sequence right by k positions?",
      "options": [
        {
          "key": "A",
          "text": "Multiply by x\u1d4f"
        },
        {
          "key": "B",
          "text": "Divide by x\u1d4f"
        },
        {
          "key": "C",
          "text": "Differentiate k times"
        },
        {
          "key": "D",
          "text": "Integrate k times"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Multiplying GF by x\u1d4f shifts coefficients: x\u1d4fG(x) = \u03a3a\u2099x\u207f\u207a\u1d4f.",
      "difficulty": "hard"
    },
    {
