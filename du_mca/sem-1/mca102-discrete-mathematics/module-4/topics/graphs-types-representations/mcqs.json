      "id": "mcq-1",
      "question": "Which representation is most efficient for checking edge existence?",
      "options": [
        {
          "key": "A",
          "text": "Adjacency matrix"
        },
        {
          "key": "B",
          "text": "Adjacency list"
        },
        {
          "key": "C",
          "text": "Incidence matrix"
        },
        {
          "key": "D",
          "text": "Edge list"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Adjacency matrix allows O(1) edge existence checks via direct indexing.",
      "difficulty": "easy"
    },
