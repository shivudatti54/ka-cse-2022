      "question": "What's contrapositive of 'If algorithm halts, then result correct'?",
      "options": [
        {
          "key": "A",
          "text": "If result incorrect, algorithm doesn't halt"
        },
        {
          "key": "B",
          "text": "If algorithm doesn't halt, result incorrect"
        },
        {
          "key": "C",
          "text": "Result correct only if algorithm halts"
        },
        {
          "key": "D",
          "text": "Algorithm halts iff result correct"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Contrapositive: \u00acQ \u2192 \u00acP (P\u2192Q becomes \u00acQ\u2192\u00acP).",
      "difficulty": "hard"
