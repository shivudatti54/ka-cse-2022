  "acronyms": [
    {
      "term": "BREAK",
      "expansion": "Break Repeated Execution And Leave",
      "usage": "Remember break's loop-exit function"
    },
    {
      "term": "CONT",
      "expansion": "Continue Only Next Try",
      "usage": "Emphasizes continuation to next iteration"
    }
  ],
