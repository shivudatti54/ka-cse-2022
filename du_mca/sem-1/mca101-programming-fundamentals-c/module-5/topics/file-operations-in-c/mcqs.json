  "mcqs": [
    {
      "id": "mcq-1",
      "question": "Which mode creates new file if it doesn't exist?",
      "options": [
        {
          "key": "A",
          "text": "r"
        },
        {
          "key": "B",
          "text": "w"
        },
        {
          "key": "C",
          "text": "a"
        },
        {
          "key": "D",
          "text": "r+"
        }
      ],
      "correctAnswer": "B",
      "explanation": "\"w\" mode creates/truncates file. \"r\" requires existing file.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "What does fputc() return on success?",
      "options": [
        {
          "key": "A",
          "text": "Character written"
        },
        {
          "key": "B",
          "text": "1"
        },
        {
          "key": "C",
          "text": "0"
        },
        {
          "key": "D",
          "text": "FILE pointer"
        }
      ],
      "correctAnswer": "A",
      "explanation": "fputc() returns written character. Returns EOF on error.",
      "difficulty": "easy"
    },
    {
