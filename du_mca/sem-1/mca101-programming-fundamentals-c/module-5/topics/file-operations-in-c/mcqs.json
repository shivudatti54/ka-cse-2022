    {
      "id": "mcq-4",
      "question": "What is the correct way to read entire line from file?",
      "options": [
        {
          "key": "A",
          "text": "fgets(buffer, size, fp)"
        },
        {
          "key": "B",
          "text": "fread(buffer, 1, size, fp)"
        },
        {
          "key": "C",
          "text": "fscanf(fp, \"%s\", buffer)"
        },
        {
          "key": "D",
          "text": "getline(&buffer, &size, fp)"
        }
      ],
      "correctAnswer": "A",
      "explanation": "fgets() reads until newline or buffer full. Option D is POSIX-specific.",
      "difficulty": "medium"
    },
    {
