    {
      "id": "mcq-1",
      "question": "What is the output of sizeof() for: struct {char a; int b;} vs union {char a; int b;}?",
      "options": [
        {
          "key": "A",
          "text": "Struct: 5+, Union: 4"
        },
        {
          "key": "B",
          "text": "Struct: 8, Union: 4"
        },
        {
          "key": "C",
          "text": "Both 4 bytes"
        },
        {
          "key": "D",
          "text": "Depends on compiler"
        }
      ],
      "correctAnswer": "D",
      "explanation": "Size depends on padding/alignment rules which vary by compiler.",
      "difficulty": "medium"
    },
    {
