    {
      "id": "mcq-4",
      "question": "Which is most memory-efficient for storing either int or char[4]?",
      "options": [
        {
          "key": "A",
          "text": "Structure"
        },
        {
          "key": "B",
          "text": "Union"
        },
        {
          "key": "C",
          "text": "Enum"
        },
        {
          "key": "D",
          "text": "Array"
        }
      ],
      "correctAnswer": "B",
      "explanation": "Union shares memory between members, using max(4,4)=4 bytes.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-5",
      "question": "What is the correct syntax for nested structures?",
      "options": [
        {
          "key": "A",
          "text": "struct A { struct B {int x;}; };"
        },
        {
          "key": "B",
          "text": "struct A { struct B b; }; (with B defined elsewhere)"
        },
        {
          "key": "C",
          "text": "struct A { union { int x; float y; };"
        },
        {
          "key": "D",
          "text": "All of the above"
        }
      ],
      "correctAnswer": "B",
      "explanation": "Nested struct definitions require prior declaration of inner struct.",
      "difficulty": "hard"
