    {
      "id": "mcq-1",
      "question": "Which memory allocation technique suffers from external fragmentation?",
      "options": [
        {
          "key": "A",
          "text": "Paging"
        },
        {
          "key": "B",
          "text": "Segmentation"
        },
        {
          "key": "C",
          "text": "Demand Paging"
        },
        {
          "key": "D",
          "text": "Virtual Memory"
        }
      ],
      "correctAnswer": "B",
      "explanation": "Segmentation uses variable-sized blocks leading to external fragmentation between segments.",
      "difficulty": "medium"
    },
    {
