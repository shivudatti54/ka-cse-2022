      "id": "mcq-1",
      "question": "Which component manages metadata in HDFS?",
      "options": [
        {
          "key": "A",
          "text": "NameNode"
        },
        {
          "key": "B",
          "text": "DataNode"
        },
        {
          "key": "C",
          "text": "JobTracker"
        },
        {
          "key": "D",
          "text": "ResourceManager"
        }
      ],
      "correctAnswer": "A",
      "explanation": "NameNode is the master server managing metadata and namespace.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "What is the default replication factor in HDFS?",
      "options": [
        {
          "key": "A",
          "text": "3"
        },
        {
          "key": "B",
          "text": "2"
        },
        {
          "key": "C",
          "text": "1"
        },
        {
          "key": "D",
          "text": "4"
