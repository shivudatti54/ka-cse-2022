      "question": "Which phase comes after Map in MapReduce?",
      "options": [
        {
          "key": "A",
          "text": "Shuffle & Sort"
        },
        {
          "key": "B",
          "text": "Reduce"
        },
        {
          "key": "C",
          "text": "Partitioning"
        },
        {
          "key": "D",
          "text": "Combiner"
