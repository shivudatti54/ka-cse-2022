      "id": "mcq-1",
      "question": "Which protocol provides real-time certificate status verification?",
      "options": [
        {
          "key": "A",
          "text": "OCSP"
        },
        {
          "key": "B",
          "text": "CRL"
        },
        {
          "key": "C",
          "text": "SCEP"
        },
        {
          "key": "D",
          "text": "PKCS#12"
        }
      ],
      "correctAnswer": "A",
      "explanation": "OCSP (Online Certificate Status Protocol) enables real-time checks without downloading full revocation lists.",
      "difficulty": "easy"
    },
