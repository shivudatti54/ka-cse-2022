    {
      "id": "mcq-7",
      "question": "What is the trace of covariance matrix in PCA?",
      "options": [
        {
          "key": "A",
          "text": "Total variance in data"
        },
        {
          "key": "B",
          "text": "Number of features"
        },
        {
          "key": "C",
          "text": "Sum of eigenvalues"
        },
        {
          "key": "D",
          "text": "Both A & C"
        }
      ],
      "correctAnswer": "D",
      "explanation": "Trace = sum(diagonal) = total variance = sum(eigenvalues).",
      "difficulty": "hard"
    },
