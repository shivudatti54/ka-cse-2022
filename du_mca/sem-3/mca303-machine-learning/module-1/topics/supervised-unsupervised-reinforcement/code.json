      "title": "Q-Learning Update",
      "description": "Q-value update rule",
      "code": "Q(s,a) = Q(s,a) + \u03b1[r + \u03b3*max(Q(s',a')) - Q(s,a)]",
      "explanation": "Updates Q-value using learning rate (\u03b1), discount factor (\u03b3), and observed reward",
      "timeComplexity": "O(1) per update",
      "spaceComplexity": "O(n) for Q-table"
    }
