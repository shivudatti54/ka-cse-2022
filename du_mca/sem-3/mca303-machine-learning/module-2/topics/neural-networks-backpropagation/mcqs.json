  "topicId": "neural-networks-backpropagation",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "Which step comes first in backpropagation?",
      "options": [
        {
          "key": "A",
          "text": "Forward pass to compute outputs"
        },
        {
          "key": "B",
          "text": "Calculate loss"
        },
        {
          "key": "C",
          "text": "Update weights"
        },
        {
          "key": "D",
          "text": "Compute gradients"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Forward pass must complete before loss calculation and gradient computation can begin.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "Which activation function is most likely to cause vanishing gradients?",
      "options": [
        {
          "key": "A",
          "text": "ReLU"
        },
        {
          "key": "B",
          "text": "Sigmoid"
        },
        {
          "key": "C",
          "text": "Leaky ReLU"
        },
        {
          "key": "D",
          "text": "Softmax"
        }
      ],
      "correctAnswer": "B",
      "explanation": "Sigmoid's derivatives approach zero for large inputs, leading to vanishing gradients.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-3",
      "question": "What does the chain rule enable in backpropagation?",
      "options": [
        {
          "key": "A",
          "text": "Parallel computation of gradients"
        },
        {
          "key": "B",
          "text": "Decomposition of complex derivatives into simpler terms"
        },
        {
          "key": "C",
          "text": "Automatic weight initialization"
        },
        {
          "key": "D",
          "text": "Data normalization"
        }
      ],
      "correctAnswer": "B",
      "explanation": "Chain rule breaks down gradient computation into manageable local derivatives.",
      "difficulty": "medium"
    },
    {
