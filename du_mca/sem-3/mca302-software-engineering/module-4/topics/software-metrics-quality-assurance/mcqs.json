      "id": "mcq-1",
      "question": "Which metric measures independent path execution?",
      "options": [
        {
          "key": "A",
          "text": "Cyclomatic Complexity"
        },
        {
          "key": "B",
          "text": "Halstead Volume"
        },
        {
          "key": "C",
          "text": "Function Point"
        },
        {
          "key": "D",
          "text": "LOC"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Cyclomatic complexity quantifies linearly independent paths through program source code.",
      "difficulty": "easy"
    },
