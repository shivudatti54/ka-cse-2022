    {
      "id": "mcq-4",
      "question": "What is the formula for Halstead Program Volume?",
      "options": [
        {
          "key": "A",
          "text": "(N1 + N2) * log2(n1 + n2)"
        },
        {
          "key": "B",
          "text": "n1 * N2 * log2(n2)"
        },
        {
          "key": "C",
          "text": "(n1/2) * N2"
        },
        {
          "key": "D",
          "text": "n2 * log2(n1)"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Volume = (N1 + N2) * log2(n1 + n2) where N=total operators/operands, n=unique operators/operands.",
      "difficulty": "hard"
    },
