{
  "topicId": "recurrence-master-theorem",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "Which of the following recurrence relations fits the Master Theorem format T(n) = aT(n/b) + f(n)?",
      "options": [
        {
          "key": "A",
          "text": "T(n) = 2T(n/2) + n²"
        },
        {
          "key": "B",
          "text": "T(n) = T(n-1) + n"
        },
        {
          "key": "C",
          "text": "T(n) = T(n/2) + T(n/3) + n"
        },
        {
          "key": "D",
          "text": "T(n) = 4T(n/2) + n³"
        }
      ],
      "correctAnswer": "D",
      "explanation": "Master Theorem requires exactly one recursive term with parameter b > 1.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "For T(n) = 4T(n/2) + n, what is the time complexity?",
      "options": [
        {
          "key": "A",
          "text": "Θ(n²)"
        },
        {
          "key": "B",
          "text": "Θ(n³)"
        },
        {
          "key": "C",
          "text": "Θ(n² log n)"
        },
        {
          "key": "D",
          "text": "Θ(n)"
        }
      ],
      "correctAnswer": "A",
      "explanation": "n^log₂(4) = n² dominates n, so Case 1 applies giving Θ(n²).",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "In the Master Theorem, if f(n) = Θ(n^log_b(a) * log^k(n)) with k ≥ 0, what is T(n)?",
      "options": [
        {
          "key": "A",
          "text": "Θ(n^log_b(a))"
        },
        {
          "key": "B",
          "text": "Θ(n^log_b(a) * log^(k+1)(n))"
        },
        {
          "key": "C",
          "text": "Θ(f(n))"
        },
        {
          "key": "D",
          "text": "Θ(n^log_b(a-1))"
        }
      ],
      "correctAnswer": "B",
      "explanation": "This is Case 2 of Master Theorem, adding one more log factor.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-4",
      "question": "For T(n) = 2T(n/3) + n², the Master Theorem gives which complexity?",
      "options": [
        {
          "key": "A",
          "text": "Θ(n)"
        },
        {
          "key": "B",
          "text": "Θ(n^log₃(2))"
        },
        {
          "key": "C",
          "text": "Θ(n²)"
        },
        {
          "key": "D",
          "text": "Θ(n² log n)"
        }
      ],
      "correctAnswer": "C",
      "explanation": "n^log₃(2) ≈ n^0.63, and n² is polynomially larger, so Case 3 applies.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-5",
      "question": "T(n) = 8T(n/2) + n³ corresponds to which Master Theorem case?",
      "options": [
        {
          "key": "A",
          "text": "Case 1"
        },
        {
          "key": "B",
          "text": "Case 2 with k=0"
        },
        {
          "key": "C",
          "text": "Case 2 with k=3"
        },
        {
          "key": "D",
          "text": "Case 3"
        }
      ],
      "correctAnswer": "B",
      "explanation": "n^log₂(8) = n³ equals f(n) = n³, so Case 2 with k=0 applies.",
      "difficulty": "medium"
    },
