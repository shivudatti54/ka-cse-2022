{
  "topicId": "tree-definitions-traversals",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "In a tree with n nodes, how many edges does it have?",
      "options": [
        {
          "key": "A",
          "text": "n"
        },
        {
          "key": "B",
          "text": "n-1"
        },
        {
          "key": "C",
          "text": "n+1"
        },
        {
          "key": "D",
          "text": "2n"
        }
      ],
      "correctAnswer": "B",
      "explanation": "A tree with n nodes always has exactly n-1 edges. This is a fundamental property of trees.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "Which node is known as the root of the tree?",
      "options": [
        {
          "key": "A",
          "text": "Node with maximum children"
        },
        {
          "key": "B",
          "text": "Topmost node with no parent"
        },
        {
          "key": "C",
          "text": "Leftmost node"
        },
        {
          "key": "D",
          "text": "Node with minimum depth"
        }
      ],
      "correctAnswer": "B",
      "explanation": "The root is the topmost node that has no parent. All other nodes are descendants of the root.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-3",
      "question": "What is the maximum number of nodes at level k in a binary tree?",
      "options": [
        {
          "key": "A",
          "text": "2k"
