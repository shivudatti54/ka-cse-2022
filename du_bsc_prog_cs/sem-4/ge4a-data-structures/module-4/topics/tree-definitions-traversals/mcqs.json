    },
    {
      "id": "mcq-7",
      "question": "What is the time complexity of level order traversal?",
      "options": [
        {
          "key": "A",
          "text": "O(1)"
        },
        {
          "key": "B",
          "text": "O(log n)"
        },
        {
          "key": "C",
          "text": "O(n)"
        },
        {
          "key": "D",
          "text": "O(n log n)"
        }
      ],
      "correctAnswer": "C",
      "explanation": "Level order traversal visits each node exactly once, so time complexity is O(n).",
      "difficulty": "medium"
    },
    {
