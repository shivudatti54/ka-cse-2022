    },
    {
      "id": "mcq-10",
      "question": "Which of the following is NOT a valid boolean law?",
      "options": [
        {
          "key": "A",
          "text": "A + A = A"
        },
        {
          "key": "B",
          "text": "A + A' = 1"
        },
        {
          "key": "C",
          "text": "A \u00b7 A' = 0"
        },
        {
          "key": "D",
          "text": "A + 1 = A"
        }
      ],
      "correctAnswer": "D",
      "explanation": "A + 1 = 1 (not A). This is the Annulment law, not A + 1 = A. The correct law is A + 1 = 1.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-11",
      "question": "A NOR gate is equivalent to:",
      "options": [
        {
          "key": "A",
          "text": "NOT-AND gate"
        },
        {
          "key": "B",
          "text": "NOT-OR gate"
        },
        {
          "key": "C",
          "text": "OR gate with inverted inputs"
        },
        {
          "key": "D",
          "text": "AND gate with inverted inputs"
        }
      ],
      "correctAnswer": "B",
      "explanation": "NOR stands for NOT-OR, meaning it is an OR gate followed by an inverter. Output is 1 only when all inputs are 0.",
