    },
    {
      "id": "mcq-13",
      "question": "Simplify the expression: A + AB",
      "options": [
        {
          "key": "A",
          "text": "A"
        },
        {
          "key": "B",
          "text": "AB"
        },
        {
          "key": "C",
          "text": "B"
        },
        {
          "key": "D",
          "text": "A + B"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Using Absorption Law: A + AB = A(1 + B) = A\u00b71 = A. The term AB is absorbed by A.",
      "difficulty": "medium"
    },
    {
