    },
    {
      "id": "mcq-13",
      "question": "How many bits are needed to represent 256 different values?",
      "options": [
        {
          "key": "A",
          "text": "7 bits"
        },
        {
          "key": "B",
          "text": "8 bits"
        },
        {
          "key": "C",
          "text": "9 bits"
        },
        {
          "key": "D",
          "text": "16 bits"
        }
      ],
      "correctAnswer": "B",
      "explanation": "2^n = 256, so n = 8. 8 bits can represent 0 to 255 (256 values).",
      "difficulty": "easy"
    },
    {
      "id": "mcq-14",
      "question": "What is the decimal value of 8-bit signed number 10000001?",
      "options": [
        {
          "key": "A",
          "text": "-127"
        },
        {
          "key": "B",
          "text": "-1"
        },
        {
          "key": "C",
          "text": "129"
        },
        {
          "key": "D",
          "text": "-129"
        }
      ],
      "correctAnswer": "A",
      "explanation": "In 2's complement, msb 1 means negative. Compute magnitude: invert 10000001 = 01111110, add 1 = 01111111 = 127. So it's -127.",
      "difficulty": "hard"
    },
    {
      "id": "mcq-15",
      "question": "Which arithmetic operation is affected by overflow in 2's complement?",
      "options": [
        {
          "key": "A",
          "text": "Only addition"
        },
        {
          "key": "B",
          "text": "Only subtraction"
        },
        {
          "key": "C",
          "text": "Both addition and subtraction"
        },
        {
          "key": "D",
          "text": "None"
        }
      ],
      "correctAnswer": "C",
      "explanation": "Both addition and subtraction can cause overflow. Subtraction A-B is performed as A + (-B), so overflow can occur in either case.",
      "difficulty": "medium"
    },
    {
