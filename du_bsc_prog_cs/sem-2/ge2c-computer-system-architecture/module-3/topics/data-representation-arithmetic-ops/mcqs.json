    },
    {
      "id": "mcq-18",
      "question": "How do you subtract 5 from 7 using 2's complement?",
      "options": [
        {
          "key": "A",
          "text": "Add 7 + (-5)"
        },
        {
          "key": "B",
          "text": "Add 7 - 5 directly"
        },
        {
          "key": "C",
          "text": "Subtract 7 - 5 in decimal then convert"
        },
        {
          "key": "D",
          "text": "Use 1's complement"
        }
      ],
      "correctAnswer": "A",
      "explanation": "In 2's complement, subtraction is performed as A + (2's complement of B). So 7 - 5 = 7 + (-5).",
      "difficulty": "medium"
    },
    {
