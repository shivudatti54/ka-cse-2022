    {
      "id": "mcq-20",
      "question": "Which is NOT a property of 2's complement?",
      "options": [
        {
          "key": "A",
          "text": "Single zero representation"
        },
        {
          "key": "B",
          "text": "Asymmetric range"
        },
        {
          "key": "C",
          "text": "Signed arithmetic without special cases"
        },
        {
          "key": "D",
          "text": "Two representations of zero"
        }
      ],
      "correctAnswer": "D",
      "explanation": "2's complement has single zero (unlike 1's complement). It has asymmetric range: -2^(n-1) to +(2^(n-1)-1).",
