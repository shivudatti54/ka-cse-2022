    {
      "id": "mcq-17",
      "question": "What is the range of normalized single precision exponent?",
      "options": [
        {
          "key": "A",
          "text": "-126 to +127"
        },
        {
          "key": "B",
          "text": "-127 to +128"
        },
        {
          "key": "C",
          "text": "0 to 255"
        },
        {
          "key": "D",
          "text": "-128 to +127"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Exponent stored as 0-255, biased by 127. Actual exponent: 1-254 give -126 to +127. Exponents 0 and 255 are special (denormals/infinity).",
