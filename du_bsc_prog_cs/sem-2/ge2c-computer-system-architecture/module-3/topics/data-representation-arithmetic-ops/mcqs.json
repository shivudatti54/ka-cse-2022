{
  "topicId": "data-representation-arithmetic-ops",
  "mcqs": [
    {
      "id": "mcq-1",
      "question": "What is the decimal equivalent of binary 11001\u2082?",
      "options": [
        {
          "key": "A",
          "text": "25"
        },
        {
          "key": "B",
          "text": "26"
        },
        {
          "key": "C",
          "text": "24"
        },
        {
          "key": "D",
          "text": "27"
        }
      ],
      "correctAnswer": "A",
      "explanation": "11001\u2082 = 1\u00d72\u2074 + 1\u00d72\u00b3 + 0\u00d72\u00b2 + 0\u00d72\u00b9 + 1\u00d72\u2070 = 16 + 8 + 0 + 0 + 1 = 25",
      "difficulty": "easy"
    },
    {
      "id": "mcq-2",
      "question": "What is the 8-bit 2's complement representation of -28?",
      "options": [
        {
          "key": "A",
          "text": "11100100"
        },
        {
          "key": "B",
          "text": "10011100"
        },
        {
          "key": "C",
          "text": "11100101"
        },
        {
          "key": "D",
          "text": "11000100"
        }
      ],
      "correctAnswer": "A",
      "explanation": "28 in binary = 00011100. Invert bits = 11100011, add 1 = 11100100",
      "difficulty": "medium"
    },
    {
      "id": "mcq-3",
      "question": "In IEEE 754 single precision, what is the bias value?",
      "options": [
        {
          "key": "A",
          "text": "128"
        },
        {
          "key": "B",
          "text": "127"
        },
        {
          "key": "C",
          "text": "255"
        },
        {
          "key": "D",
          "text": "126"
        }
      ],
      "correctAnswer": "B",
      "explanation": "IEEE 754 single precision uses a bias of 127. Double precision uses bias of 1023.",
      "difficulty": "easy"
    },
    {
      "id": "mcq-4",
      "question": "Which representation has both +0 and -0?",
      "options": [
        {
          "key": "A",
          "text": "2's complement"
        },
        {
          "key": "B",
          "text": "1's complement"
        },
        {
          "key": "C",
          "text": "Sign-magnitude"
        },
        {
          "key": "D",
          "text": "Excess-128"
        }
      ],
      "correctAnswer": "B",
      "explanation": "1's complement has two representations of zero: 00000000 (+0) and 11111111 (-0).",
      "difficulty": "medium"
    },
    {
      "id": "mcq-5",
      "question": "What is the Gray code for binary 1100?",
      "options": [
        {
          "key": "A",
          "text": "1101"
        },
        {
          "key": "B",
          "text": "1010"
        },
        {
          "key": "C",
          "text": "1110"
        },
        {
          "key": "D",
          "text": "1001"
        }
      ],
      "correctAnswer": "B",
      "explanation": "Gray code = binary XOR with right-shifted binary. 1100 XOR 0110 = 1010",
      "difficulty": "medium"
    },
    {
      "id": "mcq-6",
      "question": "What is the BCD code for decimal 59?",
      "options": [
        {
          "key": "A",
          "text": "01011001"
        },
        {
          "key": "B",
          "text": "10100101"
        },
        {
          "key": "C",
          "text": "01011011"
        },
        {
          "key": "D",
          "text": "01101001"
        }
      ],
      "correctAnswer": "A",
      "explanation": "5 = 0101, 9 = 1001. So 59 in BCD = 0101 1001",
      "difficulty": "easy"
    },
    {
      "id": "mcq-7",
      "question": "What happens during overflow in signed arithmetic?",
      "options": [
        {
          "key": "A",
          "text": "The sign bit wraps around incorrectly"
        },
        {
          "key": "B",
          "text": "Carry out of MSB is discarded"
        },
        {
          "key": "Result becomes too large for register"
        },
        {
          "key": "D",
          "text": "The computer halts"
        }
      ],
      "correctAnswer": "A",
      "explanation": "In signed arithmetic, overflow causes incorrect sign. Two positives giving negative or two negatives giving positive indicates overflow.",
      "difficulty": "medium"
    },
    {
      "id": "mcq-8",
      "question": "What is the result of adding 01111110 and 00000010 in 8-bit 2's complement?",
      "options": [
        {
          "key": "A",
          "text": "10000000 (overflow)"
        },
        {
          "key": "B",
          "text": "01111111"
        },
        {
          "key": "C",
          "text": "10000001"
        },
        {
          "key": "D",
          "text": "00000000"
        }
      ],
      "correctAnswer": "A",
      "explanation": "126 + 2 = 128. In 8-bit signed, 128 cannot be represented. 10000000 = -128, indicating overflow (two positives gave negative).",
      "difficulty": "hard"
    },
    {
      "id": "mcq-9",
      "question": "Which floating point component determines the precision?",
      "options": [
        {
          "key": "A",
          "text": "Sign bit"
        },
        {
          "key": "B",
          "text": "Exponent"
        },
        {
          "key": "C",
          "text": "Mantissa/Fraction"
        },
        {
          "key": "D",
          "text": "Bias"
        }
      ],
      "correctAnswer": "C",
      "explanation": "The mantissa (or fraction) determines precision. More mantissa bits = more significant digits of precision.",
      "difficulty": "easy"
    },
    {
