    {
      "id": "mcq-12",
      "question": "In normalized floating point, the mantissa must be:",
      "options": [
        {
          "key": "A",
          "text": "Greater than or equal to 1 and less than 2"
        },
        {
          "key": "B",
          "text": "Greater than 0 and less than 1"
        },
        {
          "key": "C",
          "text": "Exactly 1"
        },
        {
          "key": "D",
          "text": "Any value"
        }
      ],
      "correctAnswer": "A",
      "explanation": "Normalized mantissa is 1.xxx...\u2082, so it's in range [1, 2). The leading 1 is implicit in IEEE 754.",
